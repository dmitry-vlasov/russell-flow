{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(./build_java.sh)",
      "Bash(bin/russellj *)",
      "Bash(./bin/russellj *)",
      "Bash(*/bin/russellj *)",
      "Bash(flowc1 *)",
      "Read",
      "Bash(python3 *)",
      "Bash(sed *)",
      "Bash(cd *)",
      "Bash(russellj *)",
      "Bash(docker cp *)",
      "Bash(npm audit *)",
      "Bash(npx vsce *)",
      "Bash(awk '{print $6\" \"$7}')",
      "Bash(awk -F: '{print $1}')",
      "Bash(russellj test-frag-multi2 *)",
      "Bash(echo \"started PID=$!\")",
      "Bash(awk '{print $1, $2, $3, $4, $11}')",
      "Bash(awk '{print \"CPU:\", $3, \"MEM:\", $4, \"TIME:\", $11}')",
      "Bash(awk '{print $2, $3, $4, NF\" fields\"}')",
      "Bash(awk '{print \"Running. CPU:\", $3\"% MEM:\", $4\"% RSS:\", int\\($6/1024\\)\"MB\"}')",
      "Bash(awk '{print \"CPU:\", $3\"% RSS:\", int\\($6/1024\\)\"MB\"}')",
      "Bash(/usr/bin/time -f \"mem: %M user: %U  real: %e\" java -jar -Xss128m -Xmx7g src/russell.jar server=http server-port=20001 import-roots=/home/dmitry/dev/math)",
      "Bash(echo \"Server PID: $!\")",
      "Bash(ps -o etime= -p 1004593)",
      "Bash(awk '/=== baseline/,/=== combined/' /tmp/sanity-3000-v2.out)",
      "Bash(kill 1004593)",
      "Bash(ps -o etime= -p 1017883)",
      "Bash(kill 1017884)",
      "Bash(kill 1017893)",
      "Bash(~/dev/russell-flow/bin/russellj mem=32g no-server=1 \"run-script script=/tmp/sanity-3000.rus\")",
      "Bash(echo \"wrapper_pid=$!\")",
      "Bash(awk '{print \"java_pid=\" $2 \" cpu=\" $3 \"%\"}')",
      "Bash(echo \"wrapper=$!\")",
      "Bash(kill -9 1037670)",
      "Bash(ps -o etime= -p 1086807)",
      "Bash(awk '/=== attempts=3/,EOF' /tmp/sanity-attempts.out)",
      "Bash(kill -9 1086808)",
      "Bash(awk 'NR>=43 && /^}/{print NR; if \\(count++ >= 3\\) exit}' /home/dmitry/dev/russell-flow/src/ru/reprove/reprove_oracle.flow)",
      "Bash(kill -9 1221054)",
      "Bash(ps -o etime= -p 1228660)",
      "Bash(kill -9 1228660)",
      "Bash(kill -9 1228661)",
      "Bash(ps -o etime= -p 1261601)",
      "Bash(kill -9 1261602)",
      "Bash(ps -o etime= -p 1296643)",
      "Bash(xargs -r kill -9)",
      "Bash(ps -o etime= -p 1345966)",
      "Bash(ps -o etime= -p 1405538)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(pkill *)",
      "Bash(killall *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git tag *)",
      "Bash(git reset *)",
      "Bash(git checkout *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-danger.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-command.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "github.com"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "./src",
        "./scripts",
        "./docs",
        "./bin",
        "./set",
        "./db",
        "./.claude",
        "./platforms",
        "/tmp"
      ],
      "denyWrite": [
        "/etc",
        "/usr/local/bin",
        "~/.ssh",
        "/home/dmitry/dev/math"
      ],
      "denyRead": [
        "~/.ssh/id_rsa",
        "~/.aws/credentials",
        "~/.kube/config"
      ],
      "allowRead": [
        ".",
        "/home/dmitry/dev/math"
      ]
    }
  },
  "effortLevel": "medium"
}
