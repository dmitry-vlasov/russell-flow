#!/bin/bash

set -e

SCRIPT_DIR=$( cd "$( dirname "$0" )" && pwd -P )

BASE_DIR=$( cd "$( dirname "$SCRIPT_DIR" )" && pwd -P )

# Default memory for JVM
MEM="10g"
ARGS=()

for i in "$@"
do
case $i in
    mem=*)
		MEM="${i#*=}"
		shift
    ;;
	*)
		ARGS+=($i)
    ;;
esac
done

#echo "mem: $MEM"

if [ -n "$RUSSELL_MATH" ]; then
    ARGS+=("import-roots=$RUSSELL_MATH")
fi

# The test battery (and other `test/*` commands) resolve the .mm datasets relative to
# the process working directory, so they must run from the math dir. Rather than force
# the user to cd there, chdir to $RUSSELL_MATH whenever a `test/*` command is invoked —
# this makes `russellj test/all` work from any directory, identically to launching it
# from the math dir. Non-test commands keep the caller's CWD (so e.g. translating a
# dataset that lives in the current directory still works). The command can appear at
# any argument position (after flags like no-server=1), so scan all of them.
for a in "${ARGS[@]}"; do
    case "$a" in
        test/*)
            if [ -n "$RUSSELL_MATH" ] && [ -d "$RUSSELL_MATH" ]; then
                cd "$RUSSELL_MATH"
            fi
            break
            ;;
    esac
done

/usr/bin/time -f "mem: %M user: %U  real: %e"  java -jar -Xss128m -Xmx$MEM $BASE_DIR/src/russell.jar ${ARGS[*]}
