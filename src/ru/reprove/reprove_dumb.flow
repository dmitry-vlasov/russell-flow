import ru/reprove/reprove_core;
import ru/prover/core/tactics/breadth_first;

export {
	ruCommReproveDumb : RuComm;
}

ruCommReproveDumb = RuComm(
	RuCommInfo(
		"reprove-dumb", "prover",
		"reprove theorems by a breadth-first search (thin wrapper over `reprove`)",
		"target", true, false,
		ruReproveCoreArgs, []
	),
	ruRunReproveDumb
);

ruRunReproveDumb(unit : RuUnit) -> Maybe<RuState> {
	opts = RuReproveOptions(
		"reprove-dumb",
		false,   // step_index not needed for pure BFS
		false,
		false,
		\task, ctx -> {
			max_depth = ruTaskIntArg(task, "max-depth", 5);
			max_size  = ruTaskIntArg(task, "max-size",  4096);
			ruBoundedBFSTactic(max_depth, max_size)
		}
	);
	ruRunReproveCore(unit, opts)
}
