import ru/reprove/reprove_core;
import ru/prover/core/strategies/fragment_replay;
import ru/prover/core/tactics/breadth_first;

export {
	ruCommReproveFragments : RuComm;
}

ruCommReproveFragments = RuComm(
	RuCommInfo(
		"reprove-fragments", "prover",
		"reprove theorems by replaying proof fragments from other theorems (thin wrapper over `reprove`)",
		"target", true, false,
		ruReproveCoreArgs, []
	),
	ruRunReproveFragments
);

ruRunReproveFragments(unit : RuUnit) -> Maybe<RuState> {
	// fragment-depth defaults to 2 for this variant.
	frag_depth_arg = ruTaskStringArg(unit.task, "fragment-depth", "");
	task2 = if (frag_depth_arg == "")
		RuTask(unit.task with args = setTree(unit.task.args, "fragment-depth", flow("2")))
	else unit.task;
	unit2 = RuUnit(unit with task = task2);
	opts = RuReproveOptions(
		"reprove-fragments",
		false,   // step_index not needed
		true,    // need_frags
		false,
		\task, ctx -> {
			max_depth = ruTaskIntArg(task, "max-depth", 3);
			max_size  = ruTaskIntArg(task, "max-size",  4096);
			attempts  = ruTaskIntArg(task, "attempts",  3);
			switch (ctx.frag_pair) {
				Some(fp): ruFragmentReplayStrategy(fp, max_depth, max_size, attempts, ctx.math, ctx.env);
				None():   ruBoundedBFSTactic(max_depth, max_size);
			}
		}
	);
	ruRunReproveCore(unit2, opts)
}
