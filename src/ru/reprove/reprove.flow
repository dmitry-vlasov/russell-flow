import ru/prover/core/prove;
import ru/prover/core/tactics/breadth_first;
import ru/prover/core/tactic_dsl;
import ru/prover/core/strategies/subproof_replay;
import ru/prover/core/strategies/default;
import ru/prover/core/stats;
import ru/prover/core/fragment;
import ru/prover/ml/premise_selector;
import ru/map_decls;
import comm;

export {
	ruCommReprove : RuComm;
}

ruCommReprove = RuComm(
	RuCommInfo(
		"reprove", "prover",
		"reprove theorems with a tactic supplied via the DSL (default: bounded-bfs)",
		"target", true, false,
		[
			RuCommArg("target",         true, "the target: a theorem, file or all",                                            "all"),
			RuCommArg("max-depth",      true, "max proof tree depth (used by the default tactic)",                             "5"),
			RuCommArg("max-size",       true, "max proof tree size (used by the default tactic)",                              "4096"),
			RuCommArg("time-limit",     true, "per-theorem wall-clock limit (e.g. 60s, 5m)",                                   "60s"),
			RuCommArg("job-time-limit", true, "total wall-clock cap for the whole job (empty = n*time-limit/p)",               ""),
			RuCommArg("fragment-depth", true, "fragment-index depth (>0 builds the fragment index and enables fragment-replay)", "0"),
			RuCommArg("load-ml",        true, "set to 1 to load the ML selector (required by the `ml` atom)",                  "0"),
			RuCommArg("tactic",         true, "tactic DSL expression; if empty, bounded-bfs(max-depth, max-size) is used",     ""),
		], []
	),
	ruRunReprove
);

ruRunReprove(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	target = ruDetermineTarget(task, math, env);
	if (target == RuTargetNone()) {
		env.out.println("reprove: no target");
		Some(state);
	} else {
		index          = ruMakeIndexForTarget(target, math, env);
		max_frag_depth = ruTaskIntArg(task, "fragment-depth", 0);
		frag_pair      = if (max_frag_depth > 0)
			Some(ruBuildFragments(math, max_frag_depth, env))
		else None();
		// step_index is always built so the `spr` atom is available.
		step_index = Some(ruBuildStepIndex(math, 3));
		load_ml    = ruTaskIntArg(task, "load-ml", 0) > 0;
		selector   = if (load_ml) {
			s = ruLoadMlSelector(conf);
			if (sizeTree(s.features) == 0) {
				env.out.println("reprove: no ML models found, run learn-assertions first");
				None()
			} else Some(s)
		} else None();

		if (load_ml && selector == None()) Some(state)
		else {
			ctx = RuTacticContext(math, env, step_index, frag_pair, selector);
			tactic_str = ruTaskStringArg(task, "tactic", "");
			tactic = if (tactic_str != "") {
				switch (ruParseAndBuildTactic(tactic_str, ctx)) {
					Some(t): t;
					None():  ruDefaultReproveTactic(task);
				}
			} else ruDefaultReproveTactic(task);

			processed_count = ref 0;
			reproved_count  = ref 0;
			failed_theorems : ref [int] = ref [];
			inc_reproved    = ruAtomicIntInc(reproved_count);
			inc_processed   = ruAtomicIntInc(processed_count);
			th_fail         = ruAtomicRefArrayPush(failed_theorems);

			reprove_fn = \decl, time_limit, env1 -> {
				th = cast(decl : RuDecl -> RuTheorem);
				if (ruTheoremIsProved(th)) {
					inc_processed(1);
					if (ruVerbose(env1.conf) > 1) {
						env1.out.println(i2s(^processed_count) + ": reprove '" + id2s(th.info.id) + "' ...");
					}
					th_timer = ruMakeTimer();
					prover_task = RuProverTask(th.info, tactic, id2s(th.info.id), task.args, th.infer.hyps, ruProofQedStep(th.proof));
					penv0 = switch (frag_pair) {
						Some(fp): ruInitProverEnvWithFrags(prover_task, math, env1, index, time_limit, fp);
						None():   ruInitProverEnv(prover_task, math, env1, index, time_limit);
					};
					penv1 = ruExpandHyp(penv0.tree.root, penv0);
					penv2 = ruProve(penv1);
					if (length(^(penv2.tree.proofs)) > 0) {
						inc_reproved(1);
						if (ruVerbose(env1.conf) > 0) {
							env1.out.println(i2s(^processed_count) + " '" + id2s(th.info.id) +
								"' REPROVED in " + ruTimePassed2s(th_timer) +
								", tree size: " + i2s(ruProverTreeSize(penv2.tree)));
						}
					} else {
						th_fail(th.info.id);
						if (ruVerbose(env1.conf) > 0) {
							env1.out.println(i2s(^processed_count) + " '" + id2s(th.info.id) +
								"' NOT reproved in " + ruTimePassed2s(th_timer));
						}
					}
				}
				RuMappedDecl(true, false, decl);
			};

			new_state = ruMapFnComm(
				RuUnit(task, state, env.out),
				RuMapFn(
					RuMapFnInfo(
						"reprove",
						\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
						\__ -> 1.0,
						\ -> "reproved: " + i2s(^reproved_count) + " theorems"
					),
					reprove_fn
				)
			);

			if (ruVerbose(env.conf) > 0) {
				env.out.println("reprove: reproved " + i2s(^reproved_count) + " theorems");
			}
			if (length(^failed_theorems) > 0 && ruVerbose(env.conf) > 0) {
				ids = if (length(^failed_theorems) <= 10)
					strGlue(map(^failed_theorems, id2s), ", ")
				else
					strGlue(map(take(^failed_theorems, 10), id2s), ", ") + ", ...";
				env.out.println("reprove: not reproved: " + ids);
			}

			Some(RuState(new_state with
				vars = setTree(new_state.vars, "reprove", pairs2tree([
					Pair("reproved-count",  flow(^reproved_count)),
					Pair("failed-count",    flow(length(^failed_theorems))),
					Pair("failed-theorems", flow(map(^failed_theorems, id2s)))
				]))
			))
		}
	}
}

ruDefaultReproveTactic(task : RuTask) -> RuProverTactic {
	max_depth = ruTaskIntArg(task, "max-depth", 5);
	max_size  = ruTaskIntArg(task, "max-size",  4096);
	ruBoundedBFSTactic(max_depth, max_size)
}
