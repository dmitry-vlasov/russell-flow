import ru/reprove/reprove_core;
import ru/prover/core/tactics/breadth_first;

export {
	ruCommReprove : RuComm;
}

ruCommReprove = RuComm(
	RuCommInfo(
		"reprove", "prover",
		"reprove theorems with a tactic supplied via the DSL (or a bounded-bfs default)",
		"target", true, false,
		concat(ruReproveCoreArgs, [
			RuCommArg("load-ml",       true, "set to 1 to load the ML selector into context (needed for the ml atom)", "0"),
		]), []
	),
	ruRunReprove
);

ruRunReprove(unit : RuUnit) -> Maybe<RuState> {
	load_ml = ruTaskIntArg(unit.task, "load-ml", 0) > 0;
	// The fragment-depth arg is read by the core; if > 0, frags are built.
	// The universal reprove always builds step_index so SPR atoms work.
	opts = RuReproveOptions(
		"reprove",
		true,    // need_step_index
		false,   // need_frags (auto-enabled when fragment-depth > 0)
		load_ml,
		\task, ctx -> {
			max_depth = ruTaskIntArg(task, "max-depth", 5);
			max_size  = ruTaskIntArg(task, "max-size",  4096);
			ruBoundedBFSTactic(max_depth, max_size)
		}
	);
	ruRunReproveCore(unit, opts)
}
