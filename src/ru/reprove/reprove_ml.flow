import ru/reprove/reprove_core;
import ru/prover/ml/premise_selector;
import ru/prover/core/tactics/breadth_first;

export {
	ruCommReproveMl : RuComm;
}

ruCommReproveMl = RuComm(
	RuCommInfo(
		"reprove-ml", "prover",
		"reprove theorems guided by learned per-assertion ML models (thin wrapper over `reprove`)",
		"target", true, false,
		concat(ruReproveCoreArgs, [
			RuCommArg("top-k", true, "candidates expanded per step (0 = all, ranked)", "5"),
		]), []
	),
	ruRunReproveMl
);

ruRunReproveMl(unit : RuUnit) -> Maybe<RuState> {
	opts = RuReproveOptions(
		"reprove-ml",
		false,
		false,
		true,    // need_ml
		\task, ctx -> {
			top_k     = ruTaskIntArg(task, "top-k",     5);
			max_depth = ruTaskIntArg(task, "max-depth", 7);
			max_size  = ruTaskIntArg(task, "max-size",  10000);
			switch (ctx.selector) {
				Some(sel): ruMlTactic(sel, top_k, max_depth, max_size);
				None():    ruBoundedBFSTactic(max_depth, max_size);
			}
		}
	);
	ruRunReproveCore(unit, opts)
}
