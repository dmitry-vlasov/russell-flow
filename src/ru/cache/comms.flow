import base/conf;
import ru/cache/cache;
//import ru/util/update;
import ru/parse/comms;
import comm;

export {
	ruSyncCommands : [RuComm];
	ruCacheCommands : [RuComm];
}

ruCacheCommands = [
	RuComm(
		RuCommInfo(
			"cache-load", "sync", "read cached sources", "file", false, false,
			[
				RuCommArg("file", true, "input file", ""),
				RuCommArg("full", true, "load complete files, not just declarations", "0"),
				RuCommArg("imports", true, "load all imported modules transitively", "0"), ruInfoSourceArg, ruInfoTotalArg
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			conf = env.conf;
			file = lookupTreeDef(unit.task.args, "file", "");
			mode = if (lookupTreeDef(unit.task.args, "full", "0") == "1") "exact" else "proofless";
			imports = (lookupTreeDef(unit.task.args, "imports", "0") == "1");
			info_source = ruTaskInfoFn2(env, unit.task.args, "info-source");
			info_total  = ruTaskInfoFn2(env, unit.task.args, "info-total");
			timer = ruMakeTimer();
			if (file != "") {
				ruCacheLoad(ruFileId(file, env.conf), mode, imports, env);
			} else {
				ruCacheLoadAllInfo(mode, env, info_source, info_total);
			}
			// Self-heal a missing/empty disk cache: if after the disk pass the global
			// language cache is still empty (e.g. the user deleted `.cache`, or every
			// entry was stale), a later parse (sync-file-source on the LSP didOpen) would
			// fail with "unknown type: 'wff'" because the prelude declaring the types was
			// never loaded. Read the project roots ONCE to populate the global lang cache
			// and rebuild the disk cache (via ruCreateSource). Gated on the lang cache being
			// empty, so a populated cache (the normal case) skips it; runs at most once per
			// server session.
			if (file == "" && sizeTree(ruLangCacheGet().rules) == 0) {
				ruEnsureProjectLoaded(env);
			}
			Some(RuState(unit.state with vars = setTree(unit.state.vars, "cache-load", pairs2tree([Pair("time", flow(ruTimePassed(timer)))]))));
		}
	),
	RuComm(
		RuCommInfo(
			"cache-clear", "sync", "clear up a cache: mem, disk or all", "what", false, false,
			[RuCommArg("what", false, "which cache: mem, disk or all to clear", "mem")], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			cache = lookupTreeDef(unit.task.args, "what", "mem");
			if (cache == "mem") {
				ruMemCacheClear();
			} else if (cache == "disk") {
				ruDiskCacheClear(env);
			} else if (cache == "all") {
				ruCacheClear(env);
			}
			Some(unit.state); 
		}
	),
	RuComm(
		RuCommInfo(
			"cache-save", "sync", "save cached sources", "file", false, false,
			[RuCommArg("file", true, "input file", "")], []
		),
		\unit -> { 
			env = ruUnitEnv(unit);
			file = lookupTreeDef(unit.task.args, "file", "");
			if (file == "") {
				ruCacheSaveAll(env); 
			} else {
				ruCacheSave(ruFileId(file, env.conf), env); 
			}
			Some(unit.state); 
		}
	),
	RuComm(
		RuCommInfo(
			"cache-info", "sync", "show cache info", "what", false, false,
			[
				RuCommArg("what", true, "what info to show: all, lang, disk,...", "all"),
				RuCommArg("full", true, "extended info or concise", "0")
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			what = lookupTreeDef(unit.task.args, "what", "all");
			full = ruTaskBoolArg(unit.task, "full", false);
			// Structured output: a nested tree keyed by cache name (read by
			// scripts/info/cache.rus as cache-info.<cache>.size / .<cache>.vals).
			data = if (what == "all") ruCacheStats(full, env)
				else if (what == "lang") pairs2tree([Pair("lang", flow(ruLangCacheStats(full)))])
				else if (what == "disk") pairs2tree([Pair("disk", flow(ruDiskCacheStats(full, env)))])
				else {
					unit.out.error("'cache-info what=" + what + "' is not implemented", []);
					makeTree();
				};
			Some(RuState(unit.state with vars = setTree(unit.state.vars, "cache-info", flow(data))));
		}
	),
];

ruSyncCommands = [
	RuComm(
		RuCommInfo(
			"sync-file-source", "sync", "load an updated file source", "file", false, false,
			[RuCommArg("file", false, "input file", ""),  RuCommArg("text", false, "updated source", "")], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			file = lookupTreeDef(unit.task.args, "file", "");
			id = ruFileId(file, env.conf);
			code = lookupTreeDef(unit.task.args, "text", "");
			ruCacheRemove(id, env);
			// Delete the disk cache too: ruParseFast -> ruCacheGet falls back to the disk
			// cache when the mem cache is empty, so without this it reloads a STALE exact
			// entry (old positions) instead of reparsing — the cursor then resolves the
			// symbol one to the right inside def terms. Mirror sync-file-saved.
			ruDiskCacheDelete(id, env);
			ruCodeCacheSet(id, code, env);
			maybeApply(ruParseFast(id, env), \src -> {
				ruCacheAdd(src, true, env);
				ruDiskCacheSave(src, env);
			});
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"sync-file-changed", "sync", "apply changes to a file source", "file", false, false,
			[
				RuCommArg("file", false, "input file", ""),  
				RuCommArg("change-json", false, "change in JSON format", "")
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			conf = env.conf;
			json = ruTaskStringArg(unit.task, "change-json", "");
			switch (json2LspDidChangeTextDocumentParams(parseJson(json))) {
				Some(params): {
					file = ruCorrectUriPath(params.textDocument.uri.path);
					id = ruFileId(file, conf);
					contents = ruCodeCacheGet(id, env).code;
					ruCacheRemove(id, env);
					changed = fold(params.contentChanges, contents, \acc, changes -> lspApplyContentChangeEvent(changes, acc));
					ruCodeCacheSet(id, changed, env);
					maybeApply(ruParseFast(id, env), \src -> 
						ruCacheAdd(src, true, env)
					);
				}
				None(): {
					unit.out.error("file-change: An option 'change-json' must be a vaid Json-encoded LSP DidChangeTextDocimentParams, got: " + json, []);
				}
			}
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"sync-file-saved", "sync", "file was saved", "file", false, false,
			[RuCommArg("file", false, "input file", "")], []
		),
		\unit -> { 
			env = ruUnitEnv(unit);
			conf = env.conf;
			file = ruTaskStringArg(unit.task, "file", "");
			id = ruFileId(file, conf);
			path = ruFindPath(file, conf, ".ru");
			if (fileExists(path)) {
				code = getFileContent(path);
				ruCacheRemove(id, env);
				ruDiskCacheDelete(id, env);
				ruCodeCacheSet(id, code, env); 
				maybeApply(ruParseFast(id, env), \src -> {
					ruCacheAdd(src, true, env);
					ruDiskCacheSave(src, env);
				});
				Some(unit.state);
			} else {
				env.out.error("file: " + file + " is not found at sync-file-saved", []);
				Some(unit.state);
			}
		}
	)
];
