import text/binary;
import ru/util/src;
import ru/cache/remap;
import base/util/fileinfo;
import base/ids;

export {
	ruDiskCacheFiles(env : RuEnv, mode : string) -> [string];
	ruDiskCacheMakeDir(env : RuEnv) -> void;
	ruDiskCacheClear(env : RuEnv) -> void;
	ruDiskCacheSave(src : RuSource, env : RuEnv) -> void;
	ruDiskCacheDelete(id : int, env : RuEnv) -> void;
	ruDiskCacheLoad(id : int, mode : string, env : RuEnv) -> Pair<Maybe<RuSource>, string>;

	ruDiskCacheStats(full : bool, env : RuEnv) -> Tree<string, flow>;
}

ruCacheVersion = 13; // 13: definiendum/definiens carry source positions (cursor/hover in def terms)

// Self-describing cache entry: `names` maps every id used in `source` to its name
// (one table; the id VALUE band tells a type id from any other). On load the ids
// are re-interned against the current session by name (tp2id for type-band ids,
// s2id otherwise), so an entry is portable across projects and id generations.
RuCachedFileSource(
	source : RuSource,
	version : int,
	names : [Pair<int, string>]
);

ruDiskCacheMakeDir(env : RuEnv) -> void {
	ruEnsureDirectoryExists(ruCacheDir(env.conf, "exact"), env.out);
	ruEnsureDirectoryExists(ruCacheDir(env.conf, "proofless"), env.out);
}

ruDiskCacheFiles(env : RuEnv, mode : string) -> [string] {
	ruDoDiskCacheFiles(ruCacheDir(env.conf, mode), env);
}

ruDoDiskCacheFiles(dir : string, env : RuEnv) -> [string] {
	dir_content = readDirectory(dir);
	fold(readDirectory(dir), [], \acc, name -> {
		path = rtrim2(dir, "/") + "/" + name;
		if (isDirectory(path)) {
			concat(acc, ruDoDiskCacheFiles(path, env));
		} else if (endsWith(path, ".cache")) {
			concat(acc, [path]);
		} else {
			acc
		}
	});
}

ruDiskCacheClear(env : RuEnv) -> void {
	errs = ruDeleteDir(ruCacheDir(env.conf, ""));
	iter(errs, \err -> env.out.error(err, []));
}

ruDiskCacheSave(s : RuSource, env : RuEnv) -> void {
	src = RuSource(s with info = ruUpdateFileInfo(s.info, env.conf.workingDir));
	ruDiskCacheDoSave(ruSerializeCached(src), src.info.module, "exact", env);
	ruDiskCacheDoSave(ruSerializeCached(ruClearSourceProofs(src)), src.info.module, "proofless", env);
}

// Serialize a source with its id -> name table, so its ids can be re-interned
// against any future session on load. id2s_ over the source's own (registered)
// ids is exact — no separate mutable layer to fall out of sync.
ruSerializeCached(src : RuSource) -> string {
	names = map(set2array(ruSourceCollectIds(src)), \i -> Pair(i, id2s_(i)));
	toBinary(RuCachedFileSource(src, ruCacheVersion, names));
}

ruDiskCacheDoSave(binary : string, module: string, mode : string, env : RuEnv) -> void {
	path = ruCachedPath(module, mode, env.conf);
	ruEnsureFileDirectoryExists(path, env.out);
	if (!setFileContent(path, binary)) {
		env.out.error("cannot save cached source '" + module + "'", []);
	}
}

ruDiskCacheLoad(id : int, mode : string, env : RuEnv) -> Pair<Maybe<RuSource>, string> {
	conf = env.conf;
	if (ruOptsString(conf.opts, "disk-caching", "") == "0") {
		Pair(None(), "");
	} else {
		file = id2s(id);
		cached_path = ruCachedPath(file, mode, conf);
		if (!fileExists(cached_path)) {
			message = "Cache file: '" + cached_path + "' doesn't exist";
			env.out.trace("disk-cache", \-> message);
			Pair(None(), message);
		} else {
			serialized = getFileContent(cached_path);
			deserialized = deserializeBinary(serialized, IllegalStruct());
			ret = if (deserialized == IllegalStruct()) {
				message = "WARNING: Illegal structure of cache file for '" + file + "'. Cache file is deleted.";
				Pair(None(), message);
			} else {
				cached = cast(deserialized : flow -> RuCachedFileSource);
				file_path = ruFindPath(file, conf, ".ru");
				if (cached.version == ruCacheVersion) {
					// Re-intern every id against the CURRENT session by name: type-band
					// ids via tp2id, others via s2id. After the remap all ids are valid in
					// this session regardless of which generation/project produced the
					// cache — so no ids_ver / own-id / import-id staleness guards needed.
					remap = fold(cached.names, makeTree(), \acc, p ->
						if (p.second == "") acc
						else setTree(acc, p.first, if (ruIsTypeId(p.first)) tp2id(p.second) else s2id(p.second))
					);
					src = ruRemapSourceIds(cached.source, \i -> if (i < 0) i else lookupTreeDef(remap, i, i));
					changed = ruFileChangedMessage(src.info, file_path);
					if (changed != "") {
						ruDiskCacheDelete(id, env);
						env.out.trace("disk-cache", \-> changed);
						Pair(None(), changed);
					} else if (file_path != src.info.path) {
						message = "Cached file " + file + " has different full path:\n" +
							"\t" + src.info.path + "\n\t!=\n\t" + file_path + "\n";
						ruDiskCacheDelete(id, env);
						env.out.trace("disk-cache", \-> message);
						Pair(None(), message);
					} else {
						// Imports are re-interned (registered) above, so id2s is safe here.
						missing_imports = filter(src.imports, \imp ->
							!fileExists(ruFindPath(id2s(imp.id), conf, ".ru"))
						);
						if (length(missing_imports) > 0) {
							message = "Cached file " + file + " imports module(s) whose source no longer exists (" +
								strGlue(map(take(missing_imports, 5), \imp -> id2s(imp.id)), ", ") +
								(if (length(missing_imports) > 5) ", ..." else "") + "); cache deleted.";
							ruDiskCacheDelete(id, env);
							env.out.trace("disk-cache", \-> message);
							Pair(None(), message);
						} else {
							Pair(Some(src), "");
						}
					}
				} else {
					message = "Cached file " + file + " has obsolete cache version:\n" + 
						"cached.version != ruCacheVersion: " + i2s(cached.version) + " != " + i2s(ruCacheVersion);
					ruDiskCacheDelete(id, env);
					env.out.trace("disk-cache", \-> message);
					Pair(None(), message);
				}
			}
			if (isNone(ret.first)) {
				ruDiskCacheDelete(id, env);
			}
			ret;
		}
	}
}

ruDiskCacheDelete(id : int, env : RuEnv) -> void {
	if (ruOptsString(env.conf.opts, "disk-caching", "") != "0") {
		file = id2s(id);
		del_path = \path -> {
			if (!fileExists(path)) {
				env.out.trace("disk-caching", \-> "source '" + file + "' is not cached on filesystem");
			} else {
				err = deleteFile(path);
				// Only a genuine failure if the file is STILL there. A concurrent
				// operation (another editor window sharing this server, or parallel
				// requests) may have deleted it between the fileExists check and here —
				// that race is harmless (the goal is "gone"), so don't log it as an error.
				if (err != "" && fileExists(path)) {
					env.out.error("error while deleting source '" + file + "': " + err, []);
				}
			}
		}
		del_path(ruCachedPath(file, "exact", env.conf));
		del_path(ruCachedPath(file, "proofless", env.conf));
	}
}


ruDiskCacheStats(full : bool, env : RuEnv) -> Tree<string, flow> {
	cached = ruDiskCacheFiles(env, "exact");
	pairs2tree(concat(
		[Pair("size", flow(length(cached)))],
		if (full) [Pair("vals", flow(cached))] else []
	));
}
