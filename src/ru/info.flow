import text/blueprint;
import comm;
import base/comms;
import base/util/lsp;
import lsp/util;
import ru/util/vol;
import ru/util/cursor;
import ru/util/ontology;
import ru/cache/cache;

export {
	ruInfoCommands : [RuComm];

	// Shared outline data (imports + declarations with their name ranges), computed
	// once and consumed by BOTH the human path (info-outline -> scripts/info/outline.rus)
	// and the LSP path (lsp-document-symbol). Keeps the source `code` so each consumer
	// resolves positions itself (human: 1-based line/col; LSP: 0-based ranges).
	RuOutlineItem(kind : string, name : string, range : RuRange);
	RuOutlineData(path : string, code : string, items : [RuOutlineItem]);
	ruOutlineData(file : string, env : RuEnv) -> RuOutlineData;

	// Hover at the task's file/line/col position (shared by info-hover and lsp-hover).
	ruHoverAt(task : RuTask, env : RuEnv) -> RuHover;

	// A located range with its source code (enough for both human line/col and LSP
	// ranges). Shared by info-decl and lsp-definition.
	RuLocData(path : string, code : string, range : RuRange);
	ruDeclLocationAt(task : RuTask, env : RuEnv) -> Maybe<RuLocData>;

	// All uses (proof-step references) of the entity at the cursor: located ranges
	// paired with their source resolver. Shared by info-uses and lsp-references.
	ruUsesAt(task : RuTask, env : RuEnv) -> [Pair<RuLocation, LineResolver>];

	// Source with helper info: code and line resolver.
	RuInfoSource(src : RuSource, code : string, path : string, resolver : LineResolver);
	// Math entities of a given kind ("" or "all" = every kind except theorems; a
	// specific kind name otherwise) paired with their source info. Shared by info-math
	// and lsp-math.
	ruMathEntities(kind : string, env : RuEnv) -> [Pair<RuDecl, RuInfoSource>];
}

ruMathEntities(kind0 : string, env : RuEnv) -> [Pair<RuDecl, RuInfoSource>] {
	kind = if (kind0 == "all") "" else kind0;
	decls = filter(ruDeclCacheAll(), \decl ->
		switch (decl) {
			RuConst(__,__,__):      kind == "const" || kind == "";
			RuType(__,__):          kind == "type"  || kind == "";
			RuRule(__,__,__):       kind == "rule"  || kind == "";
			RuAxiom(__,__):         kind == "axiom" || kind == "";
			RuDef(__,__,__,__):     kind == "def"   || kind == "";
			RuTheorem(__,__,__,__): kind == "theorem";
		}
	);
	srcs = set2array(fold(decls, makeSet(), \acc, decl -> insertSet(acc, decl.info.src)));
	infos = fold(
		filtermap(
			ruConcurrent(map(srcs, \s -> \env1 ->
				maybeBind(ruSourceCacheGet(s, false, env1), \src -> {
					code = ruCodeCacheGet(s, env1);
					if (!ruCodeIsDefined(code)) None()
					else Some(RuInfoSource(src, code.code, code.path, makeLineResolver(code.code)));
				})
			), env),
			idfn
		),
		makeTree(), \acc, info -> setTree(acc, info.src.info.id, info)
	);
	filtermap(decls, \decl -> maybeMap(lookupTree(infos, decl.info.src), \info -> Pair(decl, info)));
}

ruUsesAt(task : RuTask, env : RuEnv) -> [Pair<RuLocation, LineResolver>] {
	eitherMap(ruTask2LineCol(task), \lc -> {
		cursor = ruUnderACursor(lc, env);
		name = ruTaskStringArg(task, "name", cursor.strs.name);
		if (name == "") [] else {
			id = s2id_(name);
			eitherMap(ruDeclCacheGet(id), \decl ->
				list2array(fold(ruSourceCacheAll(true, env), makeList(), \acc, s ->
					fold(s.decls, acc, \ac, d ->
						switch (d) {
							RuTheorem(__,__,__,proof):
								fold(proof.steps, ac, \a, step ->
									if (step.assertion != id) a else {
										code = ruCodeCacheGet(s.info.id, env).code;
										resolver = makeLineResolver(code);
										eitherMap(ruNameRangeByPos(step.pos, code),
											\range -> Cons(Pair(RuLocation(s.info.id, s.info.path, range), resolver), a), a
										);
									}
								);
							default: ac;
						}
					)
				)),
				[]
			);
		}
	}, []);
}

ruHoverAt(task : RuTask, env : RuEnv) -> RuHover {
	eitherMap(ruTask2LineCol(task), \lc -> ruCursorHover(ruUnderACursor(lc, env), env), RuHover("", ""));
}

ruDeclLocationAt(task : RuTask, env : RuEnv) -> Maybe<RuLocData> {
	maybeBind(ruTask2LineCol(task), \lc -> {
		cursor = ruUnderACursor(lc, env);
		id = ruCursorMostSpecificId(cursor, env);
		if (id == -1) None() else
		switch (ruDeclCacheGet(id)) {
			Some(decl): maybeMap(ruCacheGet(decl.info.src, false, env), \src ->
				RuLocData(src.info.path, ruCodeCacheGet(decl.info.src, env).code, ruCodeCacheDeclRange(decl, src, env))
			);
			// A file id only makes sense on an import line (jump to the imported file).
			None(): if (!startsWith(cursor.strs.line, "import")) None() else {
				code = ruCodeCacheGet(id, env);
				if (code == ruNoCode) None() else Some(RuLocData(code.path, code.code, RuRange(0, ruFirstNLinesPos(code.code, 32))));
			}
		}
	});
}

ruOutlineData(file : string, env : RuEnv) -> RuOutlineData {
	module = ruTrimPath(file, env.conf, ".ru");
	eitherMap(ruCacheGet(s2id_(module), false, env), \src -> {
		code = ruCodeCacheGet(src.info.id, env).code;
		items = concat(
			filtermap(src.imports, \imp ->
				maybeMap(ruNameRangeByPos(imp.pos, code), \range -> RuOutlineItem("import", id2s(imp.id), range))
			),
			filtermap(src.decls, \decl ->
				maybeMap(ruNameRangeByPos(decl.info.pos, code), \range -> RuOutlineItem(ruDeclKind(decl), id2s(decl.info.id), range))
			)
		);
		RuOutlineData(src.info.path, code, items);
	}, RuOutlineData("", "", []));
}

ruInfoCommands = [
	ruCommInfoOutline,
	ruCommInfoMath,
	ruCommInfoHover,
	ruCommInfoDecl,
	ruCommInfoUses,
	ruCommInfoFind,
	ruCommInfoSymbol,
	ruCommInfoSource,
	ruCommInfoShow,
	ruCommInfoAxiomatics,
	ruCommInfoVolume,
	ruCommInfoVars,
	ruCommInfoLatex,
];

ruCommInfoDecl = RuComm(
	RuCommInfo(
		"info-decl", "info", "declaration of entity at the given position", "", false, false, 
		[
			RuCommArg("file", false, "input file", ""), 
			RuCommArg("line", false, "line of expr", ""), 
			RuCommArg("col",  false, "column of expr", "")
		], []
	), 
	ruRunInfoDecl
);

ruRunInfoDecl(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	// Pure data {found, path, line, col}; the LSP path is lsp-definition.
	tree = eitherMap(ruDeclLocationAt(unit.task, env),
		\loc -> {
			ln = findLine(makeLineResolver(loc.code), loc.range.start);
			pairs2tree([
				Pair("found", flow(true)), Pair("path", flow(loc.path)),
				Pair("line", flow(ln.lineno)), Pair("col", flow(ln.lineIndex + 1)),
			]);
		},
		pairs2tree([Pair("found", flow(false)), Pair("path", flow("")), Pair("line", flow(0)), Pair("col", flow(0))])
	);
	Some(RuState(unit.state with vars = setTree(unit.state.vars, "info-decl", tree)))
}

ruCommInfoHover = RuComm(
	RuCommInfo(
		"info-hover", "info", "hover info", "", false, false, 
		[
			RuCommArg("file", false, "input file", ""), 
			RuCommArg("line", false, "line of expr", ""), 
			RuCommArg("col", false, "column of expr", "")
		], []
	), 
	ruRunInfoHover
);

ruRunInfoHover(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	// Pure data {message, lang}; the LSP path is the separate lsp-hover command.
	hover = ruHoverAt(unit.task, env);
	Some(RuState(unit.state with vars = setTree(unit.state.vars, "info-hover",
		pairs2tree([Pair("message", flow(hover.message)), Pair("lang", flow(hover.lang))])
	)))
}

ruCommInfoFind = RuComm(
	RuCommInfo(
		"info-find", "info", "find entity with a given name", "name", false, false, 
		[RuCommArg("name", false, "entity name", "")], []
	),
	ruRunInfoFind
);

ruRunInfoFind(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	task = unit.task;
	state = unit.state;
	conf = state.conf;
	name = ruTaskStringArg(task, "name", "");
	// Raw data {kind, path, line, col, msg, snippet}; scripts/info/find.rus formats.
	result = ref pairs2tree([
		Pair("kind", flow("none")), Pair("path", flow("")),
		Pair("line", flow(0)), Pair("col", flow(0)),
		Pair("msg", flow("")), Pair("snippet", flow("")),
	]);
	locate = \decl -> maybeApply(ruCacheGet(decl.info.src, false, env), \cached -> {
		code = ruCodeCacheGet(cached.info.id, env).code;
		ln = findLine(makeLineResolver(code), ruCodeCacheDeclRange(decl, cached, env).start);
		result := pairs2tree([
			Pair("kind", flow("location")), Pair("path", flow(cached.info.path)),
			Pair("line", flow(ln.lineno)), Pair("col", flow(ln.lineIndex + 1)),
			Pair("msg", flow("declaration of " + name)), Pair("snippet", flow("")),
		]);
	});
	id = s2id_(name);
	switch (ruDeclCacheGet(id)) {
		Some(decl): locate(decl);
		None(): {
			code = ruCodeCacheGet(id, env);
			if (code.path != "") {
				result := pairs2tree([
					Pair("kind", flow("source")), Pair("path", flow(code.path)),
					Pair("line", flow(0)), Pair("col", flow(0)), Pair("msg", flow("")),
					Pair("snippet", flow(ruTakeFirstNLines(code.code, 32))),
				]);
			} else {
				lang = ruLangCacheGet();
				normalize = \s -> strReplaces(s, [" ", "", "\t", ""]);
				nm = normalize(name);
				mconst = findInOrder(lang.consts, \__, const ->
					if (normalize(const.latex) == nm || id2s(const.ascii) == nm) Some(const) else None()
				);
				switch (mconst) {
					Some(const): locate(const);
					None(): env.out.error("Declaration '" + name + "' is not found", []);
				}
			}
		}
	}
	Some(RuState(state with vars = setTree(state.vars, "info-find", ^result)));
}

ruCommInfoSymbol = RuComm(
	RuCommInfo(
		"info-symbol", "info", "find entity with a given name, output result in JSON format", "name", false, false, 
		[RuCommArg("name", false, "entity name", "")], []
	),
	ruRunInfoSymbol
);

ruRunInfoSymbol(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	task = unit.task;
	state = unit.state;
	conf = state.conf;
	name = ruTaskStringArg(task, "name", "");
	id = s2id_(name);
	// Raw data {kind, decl, path, code} (same shape as info-show); scripts/info/symbol.rus
	// formats. The LSP workspace/symbol path is the separate lsp-workspace-symbol command.
	store = \kind, decl, path, code -> Some(RuState(state with vars = setTree(state.vars, "info-symbol",
		pairs2tree([Pair("kind", flow(kind)), Pair("decl", flow(decl)), Pair("path", flow(path)), Pair("code", flow(code))])
	)));
	info = ruCachedDecl2s(id, env);
	if (info != "") {
		store("decl", info, "", "");
	} else {
		code = ruCodeCacheGet(id, env);
		if (code.path != "") {
			store("source", "", code.path, ruTakeFirstNLines(code.code, 32));
		} else {
			store("none", "", "", "");
		}
	}
}

ruCommInfoSource = RuComm(
	RuCommInfo(
		"info-source", "info", "find source and output it's characteristics", "name", false, false, 
		[RuCommArg("name", false, "entity name", "")], []
	),
	ruRunInfoSource
);

ruRunInfoSource(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	task = unit.task;
	state = unit.state;
	conf = state.conf;
	name = ruTaskStringArg(task, "name", "");
	store = \decls -> Some(RuState(state with vars = setTree(state.vars, "info-source",
		pairs2tree([
			Pair("name",  flow(name)),
			Pair("count", flow(length(decls))),
			Pair("decls", flow(map(decls, \d -> pairs2tree([
				Pair("kind", flow(ruDeclKind(d))),
				Pair("name", flow(id2s(d.info.id))),
			])))),
		])
	)));
	switch (ruCacheGet(s2id_(name), false, env)) {
		Some(src): store(src.decls);
		None(): {
			env.out.error("Source '" + name + "' is not found", []);
			store([]);
		}
	}
}

ruCommInfoShow = RuComm(
	RuCommInfo(
		"info-show", "info", "find entity with a given name, and print it", "name", false, false, 
		[RuCommArg("name", false, "entity name", "")], []
	),
	ruRunInfoShow
);

ruRunInfoShow(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	task = unit.task;
	state = unit.state;
	conf = state.conf;
	math = ruMathFromSources(state.ru, env);
	name = ruTaskStringArg(task, "name", "");
	id = s2id_(name);
	// Raw data {kind, decl, path, code}; scripts/info/show.rus does the formatting.
	// kind "decl" -> rendered declaration in `decl`; "source" -> `path` + `code` head.
	store = \kind, decl, path, code -> Some(RuState(state with vars = setTree(state.vars, "info-show",
		pairs2tree([Pair("kind", flow(kind)), Pair("decl", flow(decl)), Pair("path", flow(path)), Pair("code", flow(code))])
	)));
	switch (ruFindDecl(id, math.decls, env)) {
		Some(decl): store("decl", ru2s(decl, math), "", "");
		None(): {
			code = ruCodeCacheGet(id, env);
			if (code.path != "") {
				store("source", "", code.path, ruTakeFirstNLines(code.code, 32));
			} else {
				env.out.error("Declaration '" + name + "' is not found", []);
				store("none", "", "", "");
			}
		}
	}
}

ruCommInfoOutline = RuComm(
	RuCommInfo(
		"info-outline", "info", "prints a file outline", "file", false, false, 
		[RuCommArg("file", false, "input file", "")], []
	),
	ruRunInfoOutline
);

ruRunInfoOutline(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	data = ruOutlineData(ruTaskStringArg(unit.task, "file", ""), env);
	resolver = makeLineResolver(data.code);
	// Pure data {path, entries:[{kind,name,line,col}]}; scripts/info/outline.rus
	// formats. The LSP documentSymbol path is the separate lsp-document-symbol command.
	entries = map(data.items, \it -> {
		ln = findLine(resolver, it.range.start);
		pairs2tree([
			Pair("kind", flow(it.kind)),
			Pair("name", flow(it.name)),
			Pair("line", flow(ln.lineno)),
			Pair("col",  flow(ln.lineIndex + 1)),
		]);
	});
	Some(RuState(unit.state with vars = setTree(unit.state.vars, "info-outline",
		pairs2tree([Pair("path", flow(data.path)), Pair("entries", flow(entries))])
	)))
}

ruCommInfoUses = RuComm(
	RuCommInfo(
		"info-uses", "info", "prints all uses of a name", "name", false, false, 
		[
			RuCommArg("name", true, "entity name", ""),
			RuCommArg("file", false, "input file", ""), 
			RuCommArg("line", false, "line of expr", ""), 
			RuCommArg("col", false, "column of expr", "")
		], []
	),
	ruRunInfoUses
);

ruRunInfoUses(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	// Pure data {uses:[{path, line, col}]}; the LSP path is lsp-references.
	uses = map(ruUsesAt(unit.task, env), \p -> {
		ln = findLine(p.second, p.first.range.start);
		pairs2tree([
			Pair("path", flow(p.first.path)),
			Pair("line", flow(ln.lineno)),
			Pair("col",  flow(ln.lineIndex + 1)),
		]);
	});
	Some(RuState(unit.state with vars = setTree(unit.state.vars, "info-uses",
		pairs2tree([Pair("uses", flow(uses))])
	)))
}

ruCommInfoMath = RuComm(
	RuCommInfo(
		"info-math", "info", "prints info about math entities of different kinds", "kind", false, false, 
		[RuCommArg("kind", true, "kind of math, one of: consts, types, axioms, rules, defs. No kind means all of them", "")], []
	),
	ruRunInfoMath
);


ruRunInfoMath(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	// Pure data {entries:[{kind,name,path,line,col}]}; scripts/info/math.rus formats.
	// The LSP path is the separate lsp-math command.
	entries = filtermap(ruMathEntities(ruTaskStringArg(unit.task, "kind", ""), env),
		\p -> maybeMap(ruNameRangeByPos(p.first.info.pos, p.second.code), \range -> {
			ln = findLine(p.second.resolver, range.start);
			pairs2tree([
				Pair("kind", flow(ruDeclKind(p.first))),
				Pair("name", flow(id2s(p.first.info.id))),
				Pair("path", flow(p.second.path)),
				Pair("line", flow(ln.lineno)),
				Pair("col",  flow(ln.lineIndex + 1)),
			]);
		})
	);
	Some(RuState(unit.state with vars = setTree(unit.state.vars, "info-math",
		pairs2tree([Pair("entries", flow(entries))])
	)))
}


ruCommInfoAxiomatics = RuComm(
	RuCommInfo("info-axiomatics", "info", "prints axiomatics info: base axioms for theorems", "", false, false, [], []),
	ruRunInfoAxiomatics
);

ruRunInfoAxiomatics(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	task = unit.task;
	state = unit.state;
	conf = state.conf;
	th_axioms = foldTree(ruDeclCacheTheoremAxioms(), makeTree(), \k, set, acc ->
		setTree(acc, id2s(k), mapSet(set, id2s))
	);
	ax_sets = foldTree(th_axioms, makeTree(), \th, axs, acc -> 
		switch (findInOrder(acc, \as, ths -> if (equalSet(as, axs)) Some(Pair(as, ths)) else None())) {
			Some(pair): setTree(acc, pair.first, insertSet(pair.second, th));
			None(): setTree(acc, axs, makeSet1(th));
		}
	);
	buf = ref [];
	traverseInOrder(ax_sets,
		\axs, names -> {
			if (sizeSet(axs) > 1) {
				out = "axioms: {" + strGlue(set2array(axs), ", ") + "}\n" + "theorems: {" + strGlue(set2array(names), ", ") + "}\n";
				//ruDebugLog(out, conf);
				ruAddStats("theorem-axioms", RuStatsRow(out, pairs2tree([
					Pair("axioms", i2d(sizeSet(axs))),
					Pair("theorems", i2d(sizeSet(names))),
				])));
				refArrayPush(buf, out);
			}
		}
	);
	// Store the raw data (group listing, distribution table, and each statistic)
	// as structured fields; scripts/info/axiomatics.rus supplies the labels/layout.
	Some(RuState(state with
		vars = setTree(state.vars, "info-axiomatics", pairs2tree([
			Pair("groups",        flow(strGlue(^buf, "\n"))),
			Pair("distrib",       flow(strIndent(ruShowStats("theorem-axioms", ruDistribLinSumStats("axioms", "theorems", 10))))),
			Pair("max_axioms",    flow(ruShowStats("theorem-axioms", ruMaxStats("axioms")))),
			Pair("avg_axioms",    flow(ruShowStats("theorem-axioms", ruAvgStats("axioms")))),
			Pair("sigma_axioms",  flow(ruShowStats("theorem-axioms", ruSigmaStats("axioms")))),
			Pair("max_theorems",   flow(ruShowStats("theorem-axioms", ruMaxStats("theorems")))),
			Pair("avg_theorems",   flow(ruShowStats("theorem-axioms", ruAvgStats("theorems")))),
			Pair("sigma_theorems", flow(ruShowStats("theorem-axioms", ruSigmaStats("theorems")))),
		]))
	));
}

ruCommInfoVolume = RuComm(
	RuCommInfo("info-volume", "info", "prints how much of a heap space each kind of AST nodes occupy", "", false, false, [], []), 
	ruRunInfoVolume
);

ruRunInfoVolume(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	task = unit.task;
	state = unit.state;
	conf = state.conf;
	ru_math = ruMathFromSources(state.ru, env);
	ru_sources_vol    = ruJavaTreeVol(ru_math.sources, \_ -> ruJavaIntVol(), ruJavaRuVol);
	ru_consts_vol     = ruJavaTreeVol(ru_math.decls.lang.consts, \_ -> ruJavaIntVol(), ruJavaRuVol);
	ru_types_vol      = ruJavaTreeVol(ru_math.decls.lang.types, \_ -> ruJavaIntVol(), ruJavaRuVol);
	ru_rules_vol      = ruJavaTreeVol(ru_math.decls.lang.rules, \_ -> ruJavaIntVol(), ruJavaRuVol);
	ru_assertions_vol = ruJavaTreeVol(ru_math.decls.assertions, \_ -> ruJavaIntVol(), ruJavaRuVol);
	ru_proofs_vol     = ruJavaTreeVol(ruDeclsProofs(ru_math.decls), \_ -> ruJavaIntVol(), ruJavaRuVol);
	ru_headers_vol    = ru_assertions_vol - ru_proofs_vol;

	mm_sources = state.mm;
	mm_sources_vol = ruJavaTreeVol(mm_sources, \_ -> ruJavaIntVol(), mmJavaMmVol);

	ids_vol           = ruJavaArrayVol(ruIds(), ruJavaStringVol);

	total_vol = ru_sources_vol + mm_sources_vol + ids_vol;
	pct = \x -> round(x * 100.0 / total_vol);
	// Store the raw byte counts (and precomputed percentages) as structured data.
	// scripts/info/volume.rus assembles the human-readable table; the script
	// language can't do arithmetic, so percentages are computed here.
	Some(RuState(state with
		vars = setTree(state.vars, "info-volume", pairs2tree([
			Pair("ru_sources",        flow(ru_sources_vol)),
			Pair("ru_constants",      flow(ru_consts_vol)),
			Pair("ru_types",          flow(ru_types_vol)),
			Pair("ru_rules",          flow(ru_rules_vol)),
			Pair("ru_assertions",     flow(ru_assertions_vol)),
			Pair("ru_proofs",         flow(ru_proofs_vol)),
			Pair("ru_headers",        flow(ru_headers_vol)),
			Pair("mm_sources",        flow(mm_sources_vol)),
			Pair("ids",               flow(ids_vol)),
			Pair("total",             flow(total_vol)),
			Pair("ru_sources_pct",    flow(pct(ru_sources_vol))),
			Pair("ru_constants_pct",  flow(pct(ru_consts_vol))),
			Pair("ru_types_pct",      flow(pct(ru_types_vol))),
			Pair("ru_rules_pct",      flow(pct(ru_rules_vol))),
			Pair("ru_assertions_pct", flow(pct(ru_assertions_vol))),
			Pair("ru_proofs_pct",     flow(pct(ru_proofs_vol))),
			Pair("ru_headers_pct",    flow(pct(ru_headers_vol))),
			Pair("mm_sources_pct",    flow(pct(mm_sources_vol))),
			Pair("ids_pct",           flow(pct(ids_vol))),
		]))
	));
}

ruCommInfoVars = RuComm(
	RuCommInfo("info-vars", "info", "prints all variable declarations", "", false, false, [], []), 
	\unit -> {
		env = ruUnitEnv(unit);
		state = unit.state;
		math = ruMathFromSources(state.ru, env);
		// Store the declared variables as raw data; scripts/info/vars.rus formats.
		Some(RuState(state with vars = setTree(state.vars, "info-vars",
			pairs2tree([Pair("vars", flow(map(
				sortCustom(set2array(ruDeclsDeclaredVars(math.decls)), \v -> id2s(v.id), true),
				\v -> pairs2tree([Pair("name", flow(id2s(v.id))), Pair("type", flow(id2s(v.type)))])
			)))])
		)));
	}
);

ruDeclsDeclaredVars(decls : RuDecls) -> Set<RuVar> {
	foldTree(decls.assertions, 
		foldTree(decls.lang.rules, makeSet(), 
			\__, rule, acc -> foldTree(rule.vars, acc, \__, v, ac -> insertSet(ac, v))
		), 
		\__, ass, acc -> ruAssertionDeclaredVars(ass, acc)
	);
}

ruAssertionDeclaredVars(ass : RuAssertion, acc : Set<RuVar>) -> Set<RuVar> {
	ass_vars = foldTree(ass.infer.vars.vars, acc, \__, v, ac -> insertSet(ac, v));
	switch (ass) {
		RuTheorem(__,__,__,proof): ruProofDeclaredVars(proof, ass_vars);
		default: ass_vars;
	}
}

ruProofDeclaredVars(proof : RuProof, acc : Set<RuVar>) -> Set<RuVar> {
	proof_vars = foldTree(proof.vars.vars, acc, \__, v, ac -> insertSet(ac, v));
	fold(proof.steps, proof_vars, \ac, step -> ruProofDeclaredVars(step.proof, ac));
}

ruCommInfoLatex = RuComm(
	RuCommInfo("info-latex", "info", "find a proper symbol for latex definition", "", false, false, 
		[RuCommArg("def", false, "latex definition of a symbol", "")], []
	), 
	\unit -> {
		env = ruUnitEnv(unit);
		state = unit.state;
		task = unit.task;
		lang = ruLangCacheGet();
		normalize = \s -> strReplaces(s, [" ", "", "\t", ""]);
		latex = normalize(ruTaskStringArg(task, "def", ""));
		buf = ref [];
		traverseInOrder(lang.consts, \id, const ->
			if (normalize(const.latex) == latex) {
				refArrayPush(buf,
					"import " + id2s(const.info.src) + ";;\n\n" + id2s(id)
				);
			}
		);
		Some(ruStoreText(state, "info-latex", strGlue(^buf, "\n")));
	}
);
