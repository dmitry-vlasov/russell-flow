import ds/vector;
import base/util/progress;
import ru/prover/prove;
import ru/prover/stats;
import ru/map_decls;
import comm;

export {
	ruCommReproveOracle : RuComm;
}

ruCommReproveOracle = RuComm(
	RuCommInfo(
		"reprove-oracle", "prover", "reprove theorems with the 'oracle', which leads the proof", "target", true, false, 
		[
			RuCommArg("target", true, "the target: a theorem, file or all", "all"),
			RuCommArg("max-true-props", true, "limit number of proposition choice variants. -1 means no limit", "1"),
			RuCommArg("max-false-props", true, "limit number of proposition choice variants. -1 means no limit", "0"),
			RuCommArg("max-proofs", true, "limit number of proofs in variant tree. -1 means no limit", "-1"),
			RuCommArg("max-variants", true, "limit number of assertion choice variants. -1 means no limit", "-1")
		], []
	),
	ruRunReproveOracle
);

ruReproveOracleTactic(
	theorem : RuTheorem, math : RuMath, mapping : ref Tree<RuProverProp, RuProofStep>,
	max_true_nodes : int, max_false_nodes : int, env : RuEnv
) -> RuProverTactic {
	proof = ruTheoremProofTree(theorem, math);
	leafs : ref [Pair<RuProverProp, RuProofStep>] = ref [];
	queue : ref [Pair<RuProverProp, RuProofStep>] = ref [];
	expand = \tree -> {
		if (length(^queue) == 0) {
			if (sizeTree(^mapping) == 0) {
				traverseInOrder(tree.leafs, \__, n -> 
					if (length(^queue) == 0) {
						switch (n.parent) {
							RuProverRoot(__,__,__):
								if (n.assertion.info.id == proof.assertion) {
									refArrayPush(queue, Pair(n, proof));
								} 
							default: {	}
						}
					}
				);
			} else if (length(^leafs) > 0) {
				first_leaf = ^leafs[0];
				n = first_leaf.first;
				s = first_leaf.second;
				leafs := removeIndex(^leafs, 0);
				iteriVector(n.children, \i, child -> {
					if (length(s.children) <= i) {
						ruCrash("length(s.children) <= i: " + i2s(length(s.children)) + " <= " + i2s(i) + "\n" +
							"s.assertion.info.id: " + id2s(s.assertion) + "\n" +
							"ruArity(n.assertion)=" + i2s(ruArity(n.assertion)) + " n.ass.id=" + id2s(n.assertion.info.id) + "\n" +
							"child.ind=" + i2s(child.ind) + "\n" +
							"n.children inds: " + strGlue(map(vector2array(n.children), \c -> i2s(c.ind)), ",") + "\n" +
							"n:\n" + strIndent(ruProverNode2s(n, math)));
					} else {
						step_child = s.children[i];
						switch (step_child) {
							RuProofStep(assertion,__,__) : {
								iterVector(child.children, \grand ->
									if (grand.assertion.info.id == assertion) {
										refArrayPush(queue, Pair(grand, step_child));
									}
								);
							}
							default: { }
						}
					}
				});
			}
		}
		if (length(^queue) > 0) {
			take_true = if (max_true_nodes < 0) length(^queue) else max_true_nodes;
			out = take(^queue, take_true);
			queue := removeRange(^queue, 0, take_true);
			true_nodes = map(out, \x -> {
				n = x.first;
				s = x.second;
				if (exists(s.children, \ch -> switch (ch) { RuProofStep(__,__,__): true; default: false; })) {
					refArrayPush(leafs, Pair(n, s));
				}
				mapping := setTree(^mapping, n, s);
				n
			});
			// Exclude from false nodes any prop whose parent-prop is already oracle-mapped.
			// Those will be processed as true nodes in a later cycle; expanding them early
			// (without mapping) creates orphan hyps that break ruAddProof's arity check.
			curr_leafs = filter(getTreeValues(tree.leafs), \prop ->
				forall(out, \x -> prop != x.first) &&
				switch (prop.parent) {
					RuProverExp(__, __, __, __, parent_prop): !containsKeyTree(^mapping, parent_prop)
					RuProverRoot(__, __, __): true
				}
			);
			take_false = if (max_false_nodes < 0) length(curr_leafs) else max_false_nodes;
			false_nodes = take(curr_leafs, take_false);
			iter(out, \x -> {
				i = findiDef(^queue, \s -> s.first == x.first, -1);
				if (i != -1) {
					queue := removeIndex(^queue, i);
				}
			});
			concat(true_nodes, false_nodes);
		} else {
			[];
		}
	}
	RuProverTactic("oracle", expand, \__->false);
}

ruReproveOracleUnifyPremise(
	th : RuTheorem,
	unify : (RuProverHyp) -> [RuUnified<RuPremise>],
	mapping : ref Tree<RuProverProp, RuProofStep>,
	math : RuMath,
	env : RuEnv,
	max_proofs : int,
	max_true_nodes : int,
	max_false_nodes : int,
) -> (RuProverHyp) -> [RuUnified<RuPremise>] {
	\hyp : RuProverHyp ->  {
		unif = unify(hyp);
		switch (hyp) {
			RuProverExp(i, __,__,__, parent): {
				switch (lookupTree(^mapping, parent)) {
					Some(step): {
						switch (step.children[i]) {
							RuProofStep(__,__,__): [];
							RuProofHyp(ind,__): {
								p1 = filter(unif, \un -> un.data.ind == ind);
								// If the standard unifier missed the premise (e.g. due to coercion
								// wrappers in the prover hyp expr that aren't in the premise index),
								// fall back to using the theorem's hypothesis at ind directly.
								fallback = if (length(p1) > 0 || ind < 0 || ind >= length(th.infer.hyps)) [] else
									[RuUnified(ruEmptySubst, th.infer.hyps[ind], ruExp(hyp.stmt.exps[0]))];
								result = if (length(p1) > 0) p1 else fallback;
								if (max_proofs <= 1) result else {
									concat(result, take(unif, max_proofs - 1));
								}
							}
						}
					}
					None(): {
						if (max_true_nodes <= 1 && max_false_nodes == 0) {
							ruCrash("must not happen");
						}
						[];
					}
				}
			}
			RuProverRoot(__,__,__): unif;
		}
	}
}

ruReproveOracleUnifyAssertion(
	th : RuTheorem,
	unify : (RuProverHyp) -> [RuUnified<RuAssertion>],
	mapping : ref Tree<RuProverProp, RuProofStep>,
	root : RuAssertion,
	math : RuMath,
	env : RuEnv,
	max_variants : int,
	max_true_nodes : int,
	max_false_nodes : int,
) -> (RuProverHyp) -> [RuUnified<RuAssertion>] {
	// Build doconst for oracle expressions: replace theorem/proof vars (ph0, ph1, ...) with consts (_ph0, _ph1, ...)
	// so that assertion vars sharing the same IDs don't cause occurs-check failures in Phase 2.
	th_all_vars = set2array(mergeSets(ruAssertion2Vars(th), ruProof2Vars(th.proof)));
	th_vars = filter(th_all_vars, \v -> !containsSet(th.meta, v.id));
	cv_map = keys2tree(th_vars, \cv -> ruMakeRuleNode(s2id("_" + id2s(cv.id)), cv.type, 0, 0));
	doconst_oracle = \e : RuExp -> RuExp(map(e.nodes, \n -> lookupTreeDef(cv_map, n, n)), e.pos);
	dbg = ruOptsString(env.conf.opts, "proving-trace", "0") != "0";
	\hyp : RuProverHyp ->  {
		switch (hyp) {
			RuProverExp(i, __,__,__, parent): {
				switch (lookupTree(^mapping, parent)) {
					Some(step): {
						switch (step.children[i]) {
							RuProofStep(ass, children, expr): {
								assertion = lookupTreeDef(math.decls.assertions, ass, ruNoAxiom);
								// Phase 1: bind prover vars in hyp.stmt to oracle const expressions.
								// Oracle steps store expressions in their native (un-coerced) type, while
								// the prover tree holds them in the type declared by the assertion's prop.
								// Apply coercions to e2j to match e1j's type so that ruUnifyExps succeeds
								// even when the only difference is implicit coercion wrappers.
								msub_12 = foldi(hyp.stmt.exps, Some(ruEmptySubst), \j, macc, e1j_term -> {
									maybeBind(macc, \s -> {
										e1j = ruApplySubst(ruExp(e1j_term), s);
										e2j_raw = ruApplySubst(doconst_oracle(ruExp(expr.exps[j])), s);
										e1j_type = ruExpType(e1j);
										e2j_type = ruExpType(e2j_raw);
										e2j = if (e1j_type == e2j_type) e2j_raw else {
											// Oracle steps store exprs in native type; prover tree may differ.
											// Try coercing e2j UP (sub-type to super-type) first, then DOWN.
											either(
												ruApplyCoercions(e2j_raw, e2j_type, e1j_type, math.decls.lang, env),
												either(
													ruPeelToType(e2j_raw, e1j_type, math.decls.lang, env),
													e2j_raw
												)
											)
										};
										ruUnifyExps([e1j, e2j], s, math, env)
									})
								});
								// Phase 2: bind assertion vars by matching oracle expressions against the
								// assertion's prop template. Each slot is matched independently via
								// ruMatchExp so that repeated assertion vars (e.g. ph0 appearing twice in
								// notation-reflexivity) receive consistent coercion-wrapped bindings without
								// the accumulation conflict that ruUnifyExps would produce.
								// Strip the outer coercion node when the oracle type is wider than the
								// assertion's expected type (e.g. Pattern oracle vs Symbol assertion var).
								a_var_ids = foldSet(ruAssertion2Vars(assertion), makeSet(), \acc, v -> insertSet(acc, v.id));
								sub_12_no_assn = eitherMap(msub_12, \sub_12 -> ruFilterSub(sub_12, \v, __ -> !containsSet(a_var_ids, v.id)), ruEmptySubst);
								msub_all = maybeBind(msub_12, \sub_12 ->
									maybeBind(
										foldi(assertion.infer.prop.exps, Some(ruEmptySubst), \j, macc, e3j_term -> {
											maybeBind(macc, \s -> {
												e3j = ruExp(e3j_term);
												e3j_type = ruExpType(e3j);
												e2j_raw = ruApplySubst(doconst_oracle(ruExp(expr.exps[j])), sub_12);
												e2j_type = ruExpType(e2j_raw);
												e2j = if (e2j_type == e3j_type) e2j_raw else {
													switch (ruSuperRule(e3j_type, e2j_type, math.decls.lang, env)) {
														Some(__): RuExp(subrange(e2j_raw.nodes, 1, length(e2j_raw.nodes) - 1), e2j_raw.pos)
														None(): e2j_raw
													}
												};
												// Use ruMatchExp (pattern matching) for each slot independently.
												// ruMatchExp handles multi-step coercions (EV→Variable→Pattern)
												// and each call produces a fresh sub that is then merged, so
												// repeated assertion vars get identical coerced bindings.
												maybeBind(ruMatchExp(e2j, e3j, math, env), \fresh_sub ->
													ruMergeSubst(s, fresh_sub)
												)
											})
										}),
										\sub_23 -> Some(ruMergeSubsUnsafe(sub_12_no_assn, sub_23))
									)
								);
								if (dbg && msub_12 == None()) {
									env.out.println("ORACLE-UNIFY-DBG: Phase1 FAIL: ass=" + id2s(ass) + " th=" + id2s(th.info.id));
									iteri(hyp.stmt.exps, \j, e1j_term -> {
										e1j = ruExp(e1j_term);
										e2j = doconst_oracle(ruExp(expr.exps[j]));
										env.out.println("  Phase1 j=" + i2s(j) +
											" e1j=" + ruExpRPN2s(e1j) +
											" e2j_const=" + ruExpRPN2s(e2j));
									});
								}
								if (dbg && isSome(msub_12) && msub_all == None()) {
									env.out.println("ORACLE-UNIFY-DBG: Phase2 FAIL: ass=" + id2s(ass) + " th=" + id2s(th.info.id));
									dbg_sub_12 = either(msub_12, ruEmptySubst);
									iteri(assertion.infer.prop.exps, \j, e3j_term -> {
										e3j = ruExp(e3j_term);
										e2j_raw = ruApplySubst(doconst_oracle(ruExp(expr.exps[j])), dbg_sub_12);
										e2j_type = ruExpType(e2j_raw);
										e3j_type = ruExpType(e3j);
										e2j = if (e2j_type == e3j_type) e2j_raw else {
											switch (ruSuperRule(e3j_type, e2j_type, math.decls.lang, env)) {
												Some(__): RuExp(subrange(e2j_raw.nodes, 1, length(e2j_raw.nodes) - 1), e2j_raw.pos)
												None(): e2j_raw
											}
										};
										match_result = ruMatchExp(e2j, e3j, math, env);
										env.out.println("  j=" + i2s(j) +
											" e2j=" + ruExpRPN2s(e2j) +
											" e3j=" + ruExpRPN2s(e3j) +
											" match=" + (if (isSome(match_result)) "Some" else "None"));
									});
								}
								v1 = eitherMap(msub_all, \sub -> [RuUnified(sub, assertion, ruApplySubst(ruExp(hyp.stmt.exps[0]), sub))], []);
								if (dbg && length(v1) > 0) {
									env.out.println("ORACLE-UNIFY-DBG: OK hyp-ind=" + i2s(i) + " ass=" + id2s(ass) + " th=" + id2s(th.info.id));
								}
								if (max_variants <= 1) v1 else {
									v2 = unify(hyp);
									concat(v1, take(v2, max_variants - 1));
								}
							}
							RuProofHyp(h,__): {
								if (dbg) {
									env.out.println("ORACLE-UNIFY-DBG: hyp-ind=" + i2s(i) + " -> RuProofHyp(ind=" + i2s(h) + ") th=" + id2s(th.info.id) + " hyp=" + ruExpRPN2s(ruExp(hyp.stmt.exps[0])));
								}
								[];
							}
						}
					}
					None(): {
						if (dbg) {
							env.out.println("ORACLE-UNIFY-DBG: mapping-None for hyp-ind=" + i2s(i) + " th=" + id2s(th.info.id) + " hyp=" + ruExpRPN2s(ruExp(hyp.stmt.exps[0])));
						}
						if (max_true_nodes <= 1 && max_false_nodes == 0) {
							ruCrash("must not happen");
						}
						[];
					}
				}
			}
			RuProverRoot(__,s1,__): {
				// Bind all assertion vars by matching each const-goal expr against each
				// prop template expr. This ensures all vars (not just the first) are bound.
				msub = foldi(root.infer.prop.exps, Some(ruEmptySubst), \j, macc, e3j_term -> {
					maybeBind(macc, \s -> {
						e3j = ruExp(e3j_term);
						e3j_type = ruExpType(e3j);
						e2j_raw = ruExp(s1.exps[j]);
						e2j_type = ruExpType(e2j_raw);
						e2j = if (e2j_type == e3j_type) e2j_raw else {
							switch (ruSuperRule(e3j_type, e2j_type, math.decls.lang, env)) {
								Some(__): RuExp(subrange(e2j_raw.nodes, 1, length(e2j_raw.nodes) - 1), e2j_raw.pos)
								None(): e2j_raw
							}
						};
						maybeBind(ruMatchExp(e2j, e3j, math, env), \fresh_sub ->
							ruMergeSubst(s, fresh_sub)
						)
					})
				});
				eitherMap(msub, \sub -> [RuUnified(sub, root, ruApplySubst(ruExp(s1.exps[0]), sub))], []);
			}
		}
	}
}

RuReproveOracleConf(
	args : Tree<string, flow>,
	index : RuIndex<RuAssertion>,  
	max_proofs : int,
	max_variants : int, 
	max_true_nodes : int,
	max_false_nodes : int,
	debug : bool
);

ruReproveOracleTheorem(
	th : RuTheorem, 
	time_limit : double, 
	conf : RuReproveOracleConf,
	math : RuMath, 
	env : RuEnv
) -> Pair<bool, RuProverEnv> {
	timer = ruMakeTimer();
	mapping = ref makeTree();
	root = lookupTreeDef(math.decls.assertions, ruProofQedStep(th.proof).assertion, ruNoAxiom);
	tactic = ruReproveOracleTactic(th, math, mapping, conf.max_true_nodes, conf.max_false_nodes, env);
	prover_task = RuProverTask(th.info, ruSingleTacticStrategy(tactic), id2s(th.info.id), conf.args, th.infer.hyps, ruProofQedStep(th.proof));
	penv0 = ruInitProverEnv(prover_task, math, env, conf.index, time_limit);
	penv1 = RuProverEnv(penv0 with
		fns = RuProverFuncs(penv0.fns with
			unifyAssertion = ruReproveOracleUnifyAssertion(
				th, penv0.fns.unifyAssertion, mapping, root, math, env, conf.max_variants, conf.max_true_nodes, conf.max_false_nodes
			),
			unifyPremise = ruReproveOracleUnifyPremise(
				th, penv0.fns.unifyPremise, mapping, math, env, conf.max_proofs, conf.max_true_nodes, conf.max_false_nodes
			),
			onProof = \proof_tree -> {
				if (conf.debug && (env.conf.verbose > 1)) {
					env.out.println("<<<! FOUND A PROOF !>>>:\n" + ruProverTree2s(penv0.tree.root, penv0.math, true));
				}
				penv0.fns.onProof(proof_tree);
			}
		)
	);
	penv2 = ruExpandHyp(penv1.tree.root, penv1);
	if (ruOptsString(env.conf.opts, "reprove-stats", "") == "1") {
		init_stats = RuStatsRow("reprove init " + id2s(th.info.id), 
			pairs2tree([
				Pair("size", i2d(length(th.proof.steps))), 
				Pair("time", ruTimePassed(timer))
			])
		);
		ruAddStats("reprove_init", init_stats);
	}
	t = ruMakeTimer();
	if (conf.debug) {
		env.out.println("<<<! PROVING STARTED !>>>");
	}
	penv3 = ruProve(penv2);
	if (conf.debug) {
		env.out.println("<<<! PROVING FINISHED !>>>");
	}
	prove_time = ruTimePassed(t);
	tm = ruTimePassed(timer);
	time = tm / 1000.0;
	if (ruOptsString(env.conf.opts, "reprove-stats", "") == "1") {
		reprove_stats = RuStatsRow("reprove do " + id2s(th.info.id), 
			pairs2tree([
				//Pair("depth", i2d(lookupTreeDef(depths, th.info.id, -1))),
				Pair("size", i2d(ruSizeProverTree(penv2.tree.root))),
				Pair("proof-size", i2d(length(th.proof.steps))), 
				Pair("proof-vol",
					i2d(fold(th.proof.steps, 0, \acc, step ->
						fold(step.stmt.exps, acc, \ac, ex -> ac + length(ruExp(ex).nodes))
					))
				), 
				Pair("time", prove_time),
				Pair("time-per-step", prove_time / i2d(length(th.proof.steps)))
			])
		);
		ruAddStats("reprove_time", reprove_stats);
		stats = RuStatsRow("reproved all " + id2s(th.info.id), 
			pairs2tree([
				Pair("size", i2d(ruSizeProverTree(penv2.tree.root))), 
				Pair("time", tm)
			])
		);
		ruAddStats("reprove_all", stats);
	}
	success = length(^(penv3.tree.proofs)) > 0;
	if (conf.debug) {
		if (success) {
			env.out.println("<<<! PROVING WAS SUCCESSFLL !>>>");
		} else {
			env.out.println("<<<! PROVING WAS NOT SUCCESSFLL !>>>" + 
				(if (env.conf.verbose > 1) "\n" + ruProverTree2s(penv3.tree.root, penv3.math, true) else "")
			);
		}
	}
	Pair(success, penv3);
}

ruRunReproveOracle(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	task = unit.task;
	state = unit.state;
	conf = state.conf;
	math = ruMathFromSources(state.ru, env);
	timer = ruMakeTimer();
	target = ruDetermineTarget(unit.task, math, env);
	if (target != RuTargetNone()) {
		processed_count = ref 0;
		reproved_count = ref 0;
		failed_theorems = ref [];
		inc_reproved = ruAtomicIntInc(reproved_count);
		inc_processed = ruAtomicIntInc(processed_count);
		th_fail = ruAtomicRefArrayPush(failed_theorems);
		all_imported = ruSourcesAllImported(math.sources, env);
		oracle_conf = RuReproveOracleConf(
			task.args,
			ruMakeIndexForTarget(target, math, env),
			ruTaskIntArg(task, "max-proofs", -1),
			ruTaskIntArg(task, "max-variants", -1), 
			ruTaskIntArg(task, "max-true-props", 1),
			ruTaskIntArg(task, "max-false-props", 0),
			false // debug
		);
		reprove_fn = \decl, time_limit, env1 -> {
			th = cast(decl : RuDecl -> RuTheorem);
			if (ruTheoremIsProved(th)) {
				if (ruVerbose(env1.conf) > 2) {
					env1.out.println("\t\t" + i2s(^processed_count) + ": going to reprove theorem '" + id2s(th.info.id) + "'  with lime limit: " + ruTime2s(time_limit) + " ... ");
				}
				th_timer = ruMakeLimitedTimer(time_limit);
				p0 = ruReproveOracleTheorem(th, time_limit, oracle_conf, math, env1);
				if (p0.first) {
					inc_reproved(1);
					if (ruVerbose(env1.conf) > 1) {
						env1.out.println("\t\t" + i2s(^processed_count) + " theorem '" + id2s(th.info.id) + "' was REPROVED in " + ruTimePassed2s(th_timer));
					}
					inc_processed(1);
					RuMappedDecl(true, false, decl);
				} else {
					if (ruTimeIsOver(th_timer)) {
						if (ruVerbose(env1.conf) > 1) {
							env1.out.println("\t\t" + i2s(^processed_count) + " theorem '" + id2s(th.info.id) + "' proof was not finished' in " + ruTimePassed2s(th_timer) + ", time limit: " + ruTime2s(time_limit));
						}
						inc_processed(1);
						RuMappedDecl(false, false, decl);
					} else {
						th_fail(th.info.id);
						env1.out.println("proof env (1):\n" + 
							"\tproofs: " + i2s(length(^(p0.second.tree.proofs))) + "\n"
							"tree:\n" + ruProverTree2s(p0.second.tree.root, p0.second.math, true)

						);
						env1.out.error(
						"theorem '" + id2s(th.info.id) + "' was NOT reproved in " + ruTimePassed2s(th_timer) + ", time limit: " + ruTime2s(time_limit) + 
							(if (ruVerbose(conf) > 1) "\n" + ru2s(th, math) else ""), [
								RuPlace(ruDeclPlace(th, env1) with pos = -1)
							]
						);
						ruReproveOracleTheorem(th, time_limit, 
							RuReproveOracleConf(oracle_conf with debug = true), math, 
							RuEnv(env1 with conf = ruSetConfOpt(env1.conf, "proving-trace", "2"))
						);
						ruCrash("theorem '" + id2s(th.info.id) + "' was NOT reproved in " + ruTimePassed2s(th_timer) + 
							(if (ruVerbose(conf) > 1) "\n" + ru2s(th, math) else ""));
						inc_processed(1);
						RuMappedDecl(true, false, decl);
					}
				}
			} else {
				if (ruVerbose(env1.conf) > 0) {
					env1.out.println("theorem '" + id2s(th.info.id) + "' proof is not complete");
				}
				RuMappedDecl(true, false, decl);
			}
		}
		new_state = ruMapFnComm(
			RuUnit(unit.task, state, env.out),
			RuMapFn(
				RuMapFnInfo(
					"reprove-oracle",
					\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
					// Uniform measure: the oracle follows a known path so the per-theorem
					// overhead (JVM, index lookup) dominates over proof length. Equal time
					// budget avoids starving short-proof theorems on cold JVMs (e.g. Docker).
					\__ -> 1.0,
					//\ -> "reproved: " + i2s(^reproved_count) + " theorems, failed: " + strGlue(map(^failed_theorems, id2s), ", ")
					\ -> "reproved: " + i2s(^reproved_count) + " theorems"
				),
				reprove_fn
			)
		);

		/*if (lookupTreeDef(env.conf.opts, "add-proof-stats", "") == "1") {
			env.out.println("STATS(2):");
			env.out.println(
				"size-time_direct:\n" + 
				ruShowStats("add-proof-stats", ruDistribLogAvgStats("size", "time_direct", 2)) + "\n\n" + 
				"size-time_large:\n" + 
				ruShowStats("add-proof-stats", ruDistribLogAvgStats("size", "time_large", 2)) + "\n\n"
				//+ "unify-inds-stats:\n" + 
				//ruShowStats("unify-inds-stats", ruDistribLogAvgStats("size", "time_unify_inds", 2)) + "\n\n" +
				//"intersect-cols-stats:\n" + 
				//ruShowStats("intersect-cols-stats", ruDistribLogAvgStats("size", "time_intersect_cols", 2))
			);
		} else {
			env.out.println("NO STATS:");
		}*/

		if (ruVerbose(env.conf) > 0) {
			env.out.println("reproved: " + i2s(^reproved_count) + " theorems");
		}
		if (length(^failed_theorems) > 0) {
			if (length(^failed_theorems) < 10) {
				env.out.println("Failed to reprove theorems: " + strGlue(map(^failed_theorems, id2s), ", "));
			} else {
				env.out.println("Failed to reprove theorems:\n" + strIndent(strGlue(map(^failed_theorems, id2s), "\n")));
			}
		}
		Some(RuState(new_state with 
			vars = setTree(new_state.vars, "reprove-oracle", pairs2tree([
				Pair("failed-count", flow(length(^failed_theorems))),
				Pair("failed-theorems", flow(map(^failed_theorems, id2s))),
				Pair("reproved-count", flow(^reproved_count))
			]));
		));
	} else {
		env.out.println("no target for proof reproving with oracle");
		Some(state);
	}
}
