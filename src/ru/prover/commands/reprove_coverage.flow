import ru/prover/commands/coverage;
import ru/prover/core/runner;
import ru/prover/tactics/subproof_replay;
import ru/prover/tactics/dsl;
import ru/map_decls;
import ru/util/target;
import ru/util/exp2s;
import base/concurrent;
import formats/json/json;
import comm;

export {
	ruCommReproveCoverage : RuComm;

	ruStmtFeatures(stmt : RuStmt, lang : RuLang) -> [Pair<string, Json>];
	ruCollectColoredExamples(colored : [RuColoredCoverage], theorem : string, parent : string, depth : int, lang : RuLang) -> [Json];

	// One node of the original proof tree after a single DSL-tactic reproval.
	// `color` is the tag of the DSL atom that covered this step ("" = covered
	// by no tactic, i.e. red).
	RuColoredCoverage(
		assertion : int,
		stmt      : RuStmt,
		color     : string,
		children  : [RuColoredCoverage]
	);

	// Flatten a RuProofCoverage tree into nested RuColoredCoverage, dropping
	// hypothesis leaves (they are always reachable and not proof steps).
	ruColorCoverage(cov : RuProofCoverage) -> [RuColoredCoverage];
}

ruCommReproveCoverage = RuComm(
	RuCommInfo(
		"reprove-coverage", "prover",
		"reprove each theorem with a DSL tactic and colour every original proof step by the atom that covered it; optionally emit ML training data",
		"target", true, false,
		[
			RuCommArg("target",         true, "the target: a theorem, file or all",                              "all"),
			RuCommArg("max-size",       true, "max proof tree size (default tactic)",                             "4096"),
			RuCommArg("attempts",       true, "SPR replay attempts per leaf (default tactic)",                    "3"),
			RuCommArg("time-limit",     true, "per-theorem wall-clock limit",                                     "60s"),
			RuCommArg("job-time-limit", true, "total wall-clock cap for the whole job (empty = n*time-limit/p)",  ""),
			RuCommArg("max-iterations", true, "frontier loop iterations (default tactic)",                        "3"),
			RuCommArg("tactic",         true, "tactic DSL expression that overrides the default frontier loop",   ""),
			RuCommArg("output",               true, "save training examples to db/<name>.json (empty = skip)",          ""),
			RuCommArg("min-index-rule-nodes", true, "min rule-node count for step index entries (1 = index all steps)", "1"),
		], []
	),
	ruRunReproveCoverage
);

ruStmtFeatures(stmt : RuStmt, lang : RuLang) -> [Pair<string, Json>] {
	if (length(stmt.exps) == 0) [] else {
		switch (stmt.exps[0]) {
			RuTerm(__, __, __): [];
			RuExp(nodes, __): {
				exp = cast(stmt.exps[0] : RuTermExp -> RuExp);
				rule_count = fold(nodes, 0, \acc, n -> switch (n) {
					RuRuleNode(__, __): acc + 1;
					default: acc;
				});
				top_rule = if (length(nodes) > 0) {
					switch (nodes[0]) {
						RuRuleNode(ruleType, __): id2s(ruIdType2Id(ruleType));
						RuVar(__, __): "";
					}
				} else "";
				[
					Pair("stmt_size", JsonDouble(i2d(rule_count))),
					Pair("stmt_top",  JsonString(top_rule)),
					Pair("stmt_str",  JsonString(ruSafeExp2s(exp, lang)))
				]
			}
		}
	}
}

ruCollectColoredExamples(
	colored  : [RuColoredCoverage],
	theorem  : string,
	parent   : string,
	depth    : int,
	lang     : RuLang
) -> [Json] {
	concatA(map(colored, \node -> {
		// "" tag → "red" (covered by no tactic).
		color_s = if (node.color == "") "red" else node.color;
		children_json = JsonArray(map(node.children, \ch -> JsonString(id2s(ch.assertion))));
		stmt_feats = ruStmtFeatures(node.stmt, lang);
		child_jsons = ruCollectColoredExamples(node.children, theorem, id2s(node.assertion), depth + 1, lang);
		example = JsonObject(concat([
			Pair("theorem",   JsonString(theorem)),
			Pair("assertion", JsonString(id2s(node.assertion))),
			Pair("parent",    JsonString(parent)),
			Pair("depth",     JsonDouble(i2d(depth))),
			Pair("children",  children_json),
			Pair("color",     JsonString(color_s))
		], stmt_feats));
		arrayPush(child_jsons, example)
	}))
}

ruColorCoverage(cov : RuProofCoverage) -> [RuColoredCoverage] {
	switch (cov) {
		RuProofCoverageHyp(__): [];
		RuProofCoverageStep(ass, stmt, coveredBy, children): {
			child_colored = concatA(map(children, \ch -> ruColorCoverage(ch)));
			[RuColoredCoverage(ass, stmt, coveredBy, child_colored)]
		}
	}
}

// Per-atom node counts of a colored coverage forest.  Key "" counts red nodes.
ruCountColors(colored : [RuColoredCoverage]) -> Tree<string, int> {
	fold(colored, makeTree(), \acc, node -> {
		with_self  = setTree(acc, node.color, lookupTreeDef(acc, node.color, 0) + 1);
		with_kids  = ruCountColors(node.children);
		mergeTreeCustom(with_self, with_kids, \__, a, b -> a + b)
	})
}

ruMergeCountTrees(a : Tree<string, int>, b : Tree<string, int>) -> Tree<string, int> {
	mergeTreeCustom(a, b, \__, x, y -> x + y)
}

RuReproveCoverageResult(
	colored : [RuColoredCoverage],
	total   : int,
	covered : int,
	proved  : bool
);

// Reprove one theorem with the DSL tactic (or the default frontier loop),
// then align the original proof tree and colour every step by the atom that
// expanded the matching prop.
ruReproveCoverageTheorem(
	th         : RuTheorem,
	task       : RuTask,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv,
	step_index : RuIndex<Pair<int,int>>
) -> RuReproveCoverageResult {
	max_iters = ruTaskIntArg(task, "max-iterations", 3);
	dsl_src   = ruTaskStringArg(task, "tactic", "");
	// Default: proof-guided loop — each iteration re-aims spr+BFS at the
	// current real-proof frontier.  bounded-bfs uses a huge depth cap because
	// under focus the tree is already deep; max-size is the real budget.
	effective_dsl = if (dsl_src != "") dsl_src else
		"loop(focus(frontier, seq(spr(" + i2s(attempts) + ", " + i2s(max_size) +
		"), bounded-bfs(1000000, " + i2s(max_size) + "))), " + i2s(max_iters) + ")";
	ctx = RuTacticContext(math, env, Some(step_index), None());
	builder : RuTacticBuilder = switch (ruParseAndBuildTactic(effective_dsl, ctx)) {
		Some(b): b;
		None():  ruStaticTacticBuilder(ruDoneTactic);
	};
	penv     = ruBuildAndProve(th, task, index, builder, time_limit, None(), math, env);
	orig_tree = ruTheoremProofTree(th, math);
	coverage  = ruAlignProofWithTree(orig_tree, vector2array(penv.tree.root.children));
	RuReproveCoverageResult(
		ruColorCoverage(coverage),
		ruCoverageStepCount(coverage),
		ruCoveredStepCount(coverage),
		length(^(penv.tree.proofs)) > 0
	)
}

ruRunReproveCoverage(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	target = ruDetermineTarget(task, math, env);
	if (target == RuTargetNone()) {
		env.out.println("no target for reprove-coverage");
		Some(state);
	} else {
		max_size  = ruTaskIntArg(task, "max-size",  4096);
		attempts  = ruTaskIntArg(task, "attempts",  3);
		index       = ruMakeIndexForTarget(target, math, env);
		min_rule_nodes = ruTaskIntArg(task, "min-index-rule-nodes", 1);
		step_index  = ruBuildStepIndex(math, min_rule_nodes);
		output_key  = ruTaskStringArg(task, "output", "");
		lang        = math.decls.lang;

		// Job budget: ruMapFnComm's outer timer must cover n*th_time/p.
		th_time_ms = ruParseTime(ruTaskStringArg(task, "time-limit", "60s"));
		n_theorems = i2d(length(filter(
			getTreeValues(ruDeclsTheorems(math.decls)),
			\th -> ruTargetPredicate(target)(th) && ruTheoremIsProved(th)
		)));
		p_count    = max(1.0, i2d(availableProcessors()));
		map_time_ms = max(th_time_ms, n_theorems * th_time_ms / p_count);
		job_time_str = ruTaskStringArg(task, "job-time-limit", "");
		map_time_capped = if (job_time_str != "")
			min(map_time_ms, ruParseTime(job_time_str))
		else map_time_ms;
		map_task = RuTask(task with args = setTree(task.args, "time-limit",
			flow(i2s(round(map_time_capped / 1000.0)) + "s")
		));

		theorem_count = ref 0;
		proved_count  = ref 0;
		all_counts    : ref [Tree<string, int>] = ref [];
		all_examples  : ref [Json] = ref [];
		inc_th        = ruAtomicIntInc(theorem_count);
		inc_prov      = ruAtomicIntInc(proved_count);
		push_counts   = ruAtomicRefArrayPush(all_counts);
		push_example  = ruAtomicRefArrayPush(all_examples);

		cover_fn = \decl, time_limit, env1 -> {
			th = cast(decl : RuDecl -> RuTheorem);
			if (ruTheoremIsProved(th)) {
				res = ruReproveCoverageTheorem(
					th, task, index, time_limit,
					max_size, attempts, math, env1, step_index
				);
				counts = ruCountColors(res.colored);
				inc_th(1);
				push_counts(counts);
				if (res.proved) inc_prov(1);
				if (output_key != "") {
					examples = ruCollectColoredExamples(res.colored, id2s(th.info.id), "", 0, lang);
					iter(examples, \ex -> push_example(ex));
				}
				if (ruVerbose(env1.conf) > 0) {
					env1.out.println(
						id2s(th.info.id) + ": " + i2s(res.covered) + "/" + i2s(res.total) +
						" covered  [" + ruCounts2s(counts) + "]" +
						(if (res.proved) " PROVED" else "")
					);
				}
			}
			RuMappedDecl(true, false, decl)
		};

		new_state = ruMapFnComm(
			RuUnit(map_task, state, env.out),
			RuMapFn(
				RuMapFnInfo(
					"reprove-coverage",
					\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
					\__ -> 1.0,
					\ -> i2s(^proved_count) + "/" + i2s(^theorem_count) + " proved"
				),
				cover_fn
			)
		);

		totals = fold(^all_counts, makeTree(), ruMergeCountTrees);
		grand  = foldTree(totals, 0, \__, c, acc -> acc + c);
		env.out.println(
			"=== reprove-coverage results ===\n" +
			"theorems: " + i2s(^theorem_count) + "\n" +
			"proved:   " + i2s(^proved_count) + " / " + i2s(^theorem_count) + "\n" +
			"steps by covering atom:\n" +
			concatStrings(map(ruSortCountPairs(totals), \p ->
				"  " + (if (p.first == "") "red (uncovered)" else p.first) + ": " + i2s(p.second) +
				(if (grand > 0) " (" + d2s(i2d(p.second) / i2d(grand) * 100.0) + "%)" else "") + "\n"
			))
		);

		n_ex = if (output_key != "") {
			examples = ^all_examples;
			n = length(examples);
			ru_root = ruOptsString(conf.opts, "ru-root", ".");
			out_path = pathCombine(ru_root, "db/" + output_key + ".json");
			if (!setFileContent(out_path, json2stringFormatted(JsonArray(examples)))) {
				env.out.println("reprove-coverage: failed to write " + out_path);
			} else {
				env.out.println("saved " + i2s(n) + " examples to " + out_path);
			};
			n
		} else 0;

		red = lookupTreeDef(totals, "", 0);
		Some(RuState(new_state with
			vars = setTree(new_state.vars, "reprove-coverage", pairs2tree([
				Pair("theorem-count", flow(^theorem_count)),
				Pair("proved-count",  flow(^proved_count)),
				Pair("step-count",    flow(grand)),
				Pair("red-count",     flow(red)),
				Pair("example-count", flow(n_ex))
			]))
		))
	}
}

// Sort per-atom counts by descending count for stable, readable output.
ruSortCountPairs(t : Tree<string, int>) -> [Pair<string, int>] {
	pairs = map(tree2pairs(t), \p -> Pair(p.first, p.second));
	sortCustom(pairs, \p -> p.second, false)
}

ruCounts2s(t : Tree<string, int>) -> string {
	strGlue(map(ruSortCountPairs(t), \p ->
		(if (p.first == "") "red" else p.first) + "=" + i2s(p.second)
	), " ")
}
