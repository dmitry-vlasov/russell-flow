import ru/prover/core/runner;
import ru/prover/core/util;
import ru/prover/commands/coverage;
import ru/prover/tactics/breadth_first;
import ru/prover/tactics/dsl;
import ru/prover/tactics/subproof_replay;
import ru/prover/core/stats;
import ru/prover/core/fragment;
import ru/prover/ml/premise_selector;
import ru/map_decls;
import comm;

export {
	ruCommReprove : RuComm;
}

ruCommReprove = RuComm(
	RuCommInfo(
		"reprove", "prover",
		"reprove theorems with a tactic supplied via the DSL (default: bounded-bfs)",
		"target", true, false,
		[
			RuCommArg("target",         true, "the target: a theorem, file or all",                                            "all"),
			RuCommArg("max-depth",      true, "max proof tree depth (used by the default tactic)",                             "5"),
			RuCommArg("max-size",       true, "max proof tree size (used by the default tactic)",                              "4096"),
			RuCommArg("time-limit",     true, "per-theorem wall-clock limit (e.g. 60s, 5m)",                                   "60s"),
			RuCommArg("job-time-limit", true, "total wall-clock cap for the whole job (empty = n*time-limit/p)",               ""),
			RuCommArg("fragment-depth", true, "fragment-index depth (>0 builds the fragment index and enables fragment-replay)", "0"),
			RuCommArg("forward-closure-depth", true, "shallow forward proof search: depth of premise closure (0 disables; 1-3 typical)", "0"),
			RuCommArg("forward-closure-size",  true, "max number of facts in the forward closure index", "1024"),
			RuCommArg("load-ml",        true, "set to 1 to load the ML selector (required by the `ml` atom)",                  "0"),
			RuCommArg("tactic",         true, "tactic DSL expression; if empty, bounded-bfs(max-depth, max-size) is used",     ""),
			RuCommArg("strict-fail",    true, "set to 1 to crash if any theorem could not be reproved (CI / regression mode)", "0"),
			RuCommArg("coverage",       true, "set to 1 to measure proof-step coverage from the search tree inline",           "0"),
			RuCommArg("parallel",             true, "set to 1 to run theorems in parallel (faster for oracle/replay tactics that do not use the internal concurrent prover)", "0"),
			RuCommArg("min-index-rule-nodes", true, "min rule-node count for step index entries (1 = index all steps; only used when tactic contains spr or linear-guided)", "1"),
			ruInfoDeclArg,
			ruInfoProgressArg,
		], []
	),
	ruRunReprove
);

ruRunReprove(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	target = ruDetermineTarget(task, math, env);
	if (target == RuTargetNone()) {
		env.out.error("reprove: no target", []);
		Some(state);
	} else {
		index          = ruMakeIndexForTarget(target, math, env);
		max_frag_depth = ruTaskIntArg(task, "fragment-depth", 0);
		frag_pair      = if (max_frag_depth > 0)
			Some(ruBuildFragments(math, max_frag_depth, env))
		else None();
		// step_index is expensive on large corpora (~7s and several GB for
		// set-50000+).  Only build it when the tactic actually references
		// the `spr` atom that needs it.
		tactic_src_early = ruTaskStringArg(task, "tactic", "");
		min_rule_nodes = ruTaskIntArg(task, "min-index-rule-nodes", 1);
		step_index = if (strContains(tactic_src_early, "spr") || strContains(tactic_src_early, "linear-guided"))
			Some(ruBuildStepIndex(math, min_rule_nodes))
		else None();
		load_ml    = ruTaskIntArg(task, "load-ml", 0) > 0;
		selector   = if (load_ml) {
			s = ruLoadMlSelector(conf);
			if (sizeTree(s.features) == 0) {
				env.out.error("reprove: no ML models found, run learn-assertions first", []);
				None()
			} else Some(s)
		} else None();

		if (load_ml && selector == None()) Some(state)
		else {
			ctx = RuTacticContext(math, env, step_index, selector);
			tactic_str = ruTaskStringArg(task, "tactic", "");
			default_builder = ruStaticTacticBuilder(ruDefaultReproveTactic(task));
			builder : RuTacticBuilder = if (tactic_str != "") {
				switch (ruParseAndBuildTactic(tactic_str, ctx)) {
					Some(b): b;
					None():  default_builder;
				}
			} else default_builder;

			do_coverage    = ruTaskIntArg(task, "coverage", 0) > 0;
			per_th_ms       = ruParseTime(ruTaskStringArg(task, "time-limit", "60s"));
			processed_count = ref 0;
			finished_count  = ref 0;
			reproved_count  = ref 0;
			started_ids     : ref [int] = ref [];
			reproved_ids    : ref [int] = ref [];
			total_steps     : ref int = ref 0;
			covered_steps   : ref int = ref 0;
			full_cov_count  : ref int = ref 0;   // theorems whose original proof is 100% covered
			gap_count       : ref int = ref 0;   // 100% covered but NOT reproved — engine-gap signal
			// Outer traversal is sequential (-seq target), so a plain ref Set is safe.
			// Count each theorem's coverage only on its first attempt; retries are skipped
			// to avoid inflating the denominator when fast-failing theorems get many retries.
			covered_th_ids  : ref Set<int> = ref makeSet();
			inc_reproved    = ruAtomicIntInc(reproved_count);
			inc_processed   = ruAtomicIntInc(processed_count);
			inc_finished    = ruAtomicIntInc(finished_count);
			push_started    = ruAtomicRefArrayPush(started_ids);
			push_reproved   = ruAtomicRefArrayPush(reproved_ids);
			add_total       = ruAtomicIntInc(total_steps);
			add_covered     = ruAtomicIntInc(covered_steps);
			inc_full_cov    = ruAtomicIntInc(full_cov_count);
			inc_gap         = ruAtomicIntInc(gap_count);

			reprove_fn = \decl, time_limit, env1 -> {
				th = cast(decl : RuDecl -> RuTheorem);
				if (ruTheoremIsProved(th)) {
					inc_processed(1);
					push_started(th.info.id);
					th_timer = ruMakeTimer();
					// Cap at per_th_ms so retries (which inherit the full remaining
					// job budget) cannot exceed the user-intended per-theorem limit.
					capped_limit = min(time_limit, per_th_ms);
					penv = ruBuildAndProve(th, task, index, builder, capped_limit, frag_pair, math, env1);
					inc_finished(1);
					// A proof reached the goal AND respects the original theorem's
					// disjoint-variable budget (no strengthening). Both are required
					// for a genuine reproval of THIS theorem.
					reproved = length(^(penv.tree.proofs)) > 0 && ruReprovedWithinDisjs(th, penv, math, env1);
					if (reproved) {
						inc_reproved(1);
						push_reproved(th.info.id);
											} else {
											}
					// Coverage extracted while the tree is still live, before GC.
					// Only count on first attempt per theorem to avoid retry inflation.
					if (do_coverage && !containsSet(^covered_th_ids, th.info.id)) {
						covered_th_ids := insertSet(^covered_th_ids, th.info.id);
						orig_tree = ruTheoremProofTree(th, math);
						cov = ruAlignProofWithTree(orig_tree, vector2array(penv.tree.root.children));
						tot = ruCoverageStepCount(cov);
						covd = ruCoveredStepCount(cov);
						add_total(tot);
						add_covered(covd);
						// full-covered = every original step explored; gap = fully
						// covered yet not reproved (the engine found the skeleton but
						// could not assemble a proof — an engine-gap signal, formerly
						// measure-coverage's distinguishing output).
						full_covered = tot > 0 && covd == tot;
						if (full_covered) inc_full_cov(1);
						if (full_covered && !reproved) inc_gap(1);
					}
				}
				RuMappedDecl(true, false, decl);
			};

			// parallel=1: lightweight tactics (oracle, replay) that do not use the
			// internal concurrent prover can safely run theorems in parallel — just
			// pass the task through unchanged.
			//
			// parallel=0 (default): ruProve uses ruConcurrent internally; running
			// multiple theorems concurrently causes nested thread-pool contention.
			// Force sequential outer traversal via -seq and scale the total budget
			// so each theorem gets per_th_ms * min(n, nProc) / n ≈ per_th_ms at
			// full parallelism — the same throughput without OOM.
			run_parallel  = ruTaskIntArg(task, "parallel", 0) > 0;
			dispatch_task = if (run_parallel) task else {
				n_theorems     = length(filter(ruTargetDecls(target, math, env), ruDeclIsTheorem));
				n_par          = availableProcessors();
				computed_total = per_th_ms * i2d(min(max(1, n_theorems), n_par));
				job_limit_str  = ruTaskStringArg(task, "job-time-limit", "");
				total_ms       = if (job_limit_str != "" && job_limit_str != "no") min(computed_total, ruParseTime(job_limit_str)) else computed_total;
				RuTask(task with args =
					setTree(
						setTree(task.args, "target", ruTaskStringArg(task, "target", "all") + "-seq"),
						"time-limit", ruTime2s(total_ms)
					)
				)
			};
			new_state = ruMapFnComm(
				RuUnit(dispatch_task, state, env.out),
				RuMapFn(
					RuMapFnInfo(
						"reprove",
						\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
						\__ -> 1.0,
						\ -> "reproved: " + i2s(^reproved_count) + " theorems"
					),
					reprove_fn
				)
			);

			// Compute not-reproved as started − reproved to avoid duplicates from
			// retry passes calling reprove_fn more than once for the same theorem.
			reproved_set   = buildSet(^reproved_ids);
			not_reproved   = set2array(fold(^started_ids, makeSet(), \acc, id ->
				if (containsSet(reproved_set, id)) acc else insertSet(acc, id)
			));
												if (ruTaskIntArg(task, "strict-fail", 0) > 0 && not_reproved != []) {
				ruCrash("reprove: strict-fail: " + i2s(length(not_reproved)) + " theorem(s) failed to reprove");
			}

			cov_vars = if (do_coverage) {
				n_tot = ^total_steps;
				n_cov = ^covered_steps;
				[
					Pair("covered-steps",  flow(n_cov)),
					Pair("total-steps",    flow(n_tot)),
					Pair("coverage-pct",   flow(if (n_tot > 0) i2d(n_cov) / i2d(n_tot) * 100.0 else 0.0)),
					Pair("full-cov-count", flow(^full_cov_count)),
					Pair("gap-count",      flow(^gap_count))
				]
			} else [];

			Some(RuState(new_state with
				vars = setTree(new_state.vars, "reprove", pairs2tree(concat([
					Pair("reproved-count",  flow(^reproved_count)),
					Pair("failed-count",    flow(length(not_reproved))),
					Pair("failed-theorems", flow(map(not_reproved, id2s)))
				], cov_vars)))
			))
		}
	}
}

ruDefaultReproveTactic(task : RuTask) -> RuProverTactic {
	max_depth = ruTaskIntArg(task, "max-depth", 5);
	max_size  = ruTaskIntArg(task, "max-size",  4096);
	ruBoundedBFSTactic(max_depth, max_size)
}

// Reproving means proving the ORIGINAL theorem, so a found proof may use the
// SAME or FEWER disjoint-variable ($d) restrictions than the theorem declares,
// but never MORE. A proof needing extra $d proves a strictly stronger-hypothesis
// theorem that merely shares the conclusion — not a reproval. Each found proof
// carries the $d its steps require; normalising RuTheorem(th with proof=p)
// surfaces them at theorem level, and ruSubsetDisjs(found, declared) accepts
// exactly the loosen-or-equal case.
ruReprovedWithinDisjs(th : RuTheorem, penv : RuProverEnv, math : RuMath, env : RuEnv) -> bool {
	exists(^(penv.tree.proofs), \p -> {
		normalized = ruNormalizeTheoremVarsDisjs(RuTheorem(th with proof = p));
		ruSubsetDisjs(normalized.infer.vars.disjs, th.infer.vars.disjs)
	})
}
