import ru/proof_tree;
import ru/prover/core/tree;

export {
	// Alignment of an original proof tree against an explored prover variant tree.
	RuProofCoverage ::= RuProofCoverageStep, RuProofCoverageHyp;
		// A proof step.  coveredBy is the tag of the DSL atom that expanded the
		// matching prop in the variant tree ("" = covered by no tactic).
		RuProofCoverageStep(
			assertion : int,
			stmt      : RuStmt,
			coveredBy : string,
			children  : [RuProofCoverage]
		);
		// A hypothesis leaf: always implicitly reachable, not counted as a step.
		RuProofCoverageHyp(ind : int);

	ruIsCovered(cb : string) -> bool;

	// Align original proof tree against variant tree candidates at each level.
	// candidates = vector2array(root.children) at the top call.  Each covered
	// step is tagged with the atom that expanded its prop.
	ruAlignProofWithTree(node : RuProofTree, candidates : [RuProverProp]) -> RuProofCoverage;

	ruCoverageStepCount(cov : RuProofCoverage) -> int;
	ruCoveredStepCount(cov  : RuProofCoverage) -> int;
	ruCoverageRatio(cov     : RuProofCoverage) -> double;

	// Frontier seeds: uncovered steps immediately below a covered step (or the root).
	// The root itself is a frontier seed if its top step is uncovered.
	ruFrontierSeeds(cov : RuProofCoverage) -> [RuProofCoverageStep];

	ruCoverage2s(cov : RuProofCoverage, indent : string) -> string;
}

ruIsCovered(cb : string) -> bool { cb != "" }

ruAlignProofWithTree(node : RuProofTree, candidates : [RuProverProp]) -> RuProofCoverage {
	switch (node) {
		RuProofHyp(ind, __): RuProofCoverageHyp(ind);
		RuProofStep(ass_id, children, stmt): {
			// Find the first prop in the variant tree that tried this assertion AND was
			// actually expanded.  An unexpanded prop is merely a candidate instantiated
			// as a side effect of expanding its parent; its leaf E-nodes were never
			// created or premise-matched, so it must not count as covered.
			matched = find(candidates, \prop -> prop.assertion.info.id == ass_id && ^(prop.expanded) != "");
			switch (matched) {
				Some(prop): {
					// Covered: recursively align children against this prop's subgoal candidates.
					// coveredBy = the DSL atom that expanded this prop.
					prop_exps = vector2array(prop.children); // [RuProverExp]
					child_covs = mapi(children, \i, child -> {
						if (i < length(prop_exps)) {
							ruAlignProofWithTree(child, vector2array(prop_exps[i].children))
						} else {
							ruAlignProofWithTree(child, [])
						}
					});
					RuProofCoverageStep(ass_id, stmt, ^(prop.expanded), child_covs)
				}
				None(): {
					// Uncovered: pass empty candidates all the way down.
					RuProofCoverageStep(ass_id, stmt, "",
						map(children, \child -> ruAlignProofWithTree(child, []))
					)
				}
			}
		}
	}
}

ruCoverageStepCount(cov : RuProofCoverage) -> int {
	switch (cov) {
		RuProofCoverageHyp(__): 0;
		RuProofCoverageStep(__, __, __, children):
			1 + fold(children, 0, \acc, ch -> acc + ruCoverageStepCount(ch));
	}
}

ruCoveredStepCount(cov : RuProofCoverage) -> int {
	switch (cov) {
		RuProofCoverageHyp(__): 0;
		RuProofCoverageStep(__, __, coveredBy, children):
			(if (ruIsCovered(coveredBy)) 1 else 0) +
			fold(children, 0, \acc, ch -> acc + ruCoveredStepCount(ch));
	}
}

ruCoverageRatio(cov : RuProofCoverage) -> double {
	total = ruCoverageStepCount(cov);
	if (total == 0) 0.0 else i2d(ruCoveredStepCount(cov)) / i2d(total)
}

ruFrontierSeeds(cov : RuProofCoverage) -> [RuProofCoverageStep] {
	// Root is always considered to have a "covered parent".
	ruFrontierSeedsHelper(cov, true)
}

ruFrontierSeedsHelper(cov : RuProofCoverage, parent_covered : bool) -> [RuProofCoverageStep] {
	switch (cov) {
		RuProofCoverageHyp(__): [];
		RuProofCoverageStep(ass, stmt, coveredBy, children): {
			covered = ruIsCovered(coveredBy);
			if (!covered && parent_covered) {
				[RuProofCoverageStep(ass, stmt, coveredBy, children)]
			} else {
				concatA(map(children, \ch -> ruFrontierSeedsHelper(ch, covered)))
			}
		}
	}
}

ruCoverage2s(cov : RuProofCoverage, indent : string) -> string {
	switch (cov) {
		RuProofCoverageHyp(ind): indent + "hyp[" + i2s(ind) + "]\n";
		RuProofCoverageStep(ass, __, coveredBy, children):
			indent + (if (ruIsCovered(coveredBy)) "+ " + coveredBy + " " else "- ") + id2s(ass) + "\n" +
			concatStrings(map(children, \ch -> ruCoverage2s(ch, indent + "  ")));
	}
}
