import ru/prover/core/prove;
import ru/prover/core/util;
import ru/prover/tactics/breadth_first;
import ru/prover/tactics/dsl;
import ru/prover/core/stats;
import ru/prover/core/fragment;
import ru/prover/ml/premise_selector;
import ru/util/normalize;
import ru/util/src;
import ru/util/utils;
import ru/map_decls;
import comm;

export {
	ruCommProve : RuComm;
}

ruCommProve = RuComm(
	RuCommInfo(
		"prove", "prover",
		"prove theorems with a tactic and write found proofs back",
		"target", true, false,
		[
			RuCommArg("target",                true,  "the target: a theorem, file or all",                                             "all"),
			RuCommArg("max-depth",             true,  "max proof tree depth (used by the default tactic)",                              "5"),
			RuCommArg("max-size",              true,  "max proof tree size (used by the default tactic)",                               "4096"),
			RuCommArg("time-limit",            true,  "per-theorem wall-clock limit (e.g. 60s, 5m)",                                    "60s"),
			RuCommArg("job-time-limit",        true,  "total wall-clock cap for the whole job (empty = n*time-limit/p)",                ""),
			RuCommArg("fragment-depth",        true,  "fragment-index depth (>0 enables fragment-replay tactic atoms)",                 "0"),
			RuCommArg("forward-closure-depth", true,  "shallow forward proof search: depth of premise closure (0 disables; 1-3 typical)", "0"),
			RuCommArg("forward-closure-size",  true,  "max number of facts in the forward closure index",                               "1024"),
			RuCommArg("tactic",                true,  "tactic DSL expression; if empty, bounded-bfs(max-depth, max-size) is used",      ""),
		], []
	),
	ruRunProve
);

ruRunProve(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	target = ruDetermineTarget(task, math, env);
	if (target == RuTargetNone()) {
		env.out.println("prove: no target");
		Some(state);
	} else {
		index          = ruMakeIndexForTarget(target, math, env);
		max_frag_depth = ruTaskIntArg(task, "fragment-depth", 0);
		frag_pair      = if (max_frag_depth > 0)
			Some(ruBuildFragments(math, max_frag_depth, env))
		else None();
		tactic_src_early = ruTaskStringArg(task, "tactic", "");
		step_index = if (strContains(tactic_src_early, "spr"))
			Some(ruBuildStepIndex(math, 3))
		else None();
		ctx = RuTacticContext(math, env, step_index, frag_pair, None());
		tactic_str = ruTaskStringArg(task, "tactic", "");
		default_builder = ruStaticTacticBuilder(ruDefaultProveTactic(task));
		builder : RuTacticBuilder = if (tactic_str != "") {
			switch (ruParseAndBuildTactic(tactic_str, ctx)) {
				Some(b): b;
				None():  default_builder;
			}
		} else default_builder;

		per_th_ms      = ruParseTime(ruTaskStringArg(task, "time-limit", "60s"));
		proved_count   = ref 0;
		finished_count = ref 0;
		started_ids    : ref [int] = ref [];
		proved_ids     : ref [int] = ref [];
		inc_proved     = ruAtomicIntInc(proved_count);
		inc_finished   = ruAtomicIntInc(finished_count);
		push_started   = ruAtomicRefArrayPush(started_ids);
		push_proved    = ruAtomicRefArrayPush(proved_ids);

		prove_fn = \decl, time_limit, env1 -> {
			th = cast(decl : RuDecl -> RuTheorem);
			th_timer = ruMakeTimer();
			push_started(th.info.id);
			// Cap at per_th_ms so retries cannot exceed the user-intended per-theorem limit.
			capped_limit = min(time_limit, per_th_ms);
			goal = if (ruTheoremIsProved(th)) ruProofQedStep(th.proof)
			       else RuStep(-1, -1, [], th.infer.prop, ruNoProof, -1);
			prover_task = RuProverTask(th.info, ruDoneTactic, id2s(th.info.id), task.args, th.infer.hyps, goal);
			penv_pre = switch (frag_pair) {
				Some(fp): ruInitProverEnvWithFrags(prover_task, math, env1, index, capped_limit, fp);
				None():   ruInitProverEnv(prover_task, math, env1, index, capped_limit);
			};
			built = builder.build(penv_pre);
			penv0 = built.first;
			penv0.tactic := Some(built.second);
			penv1 = ruExpandHyp(penv0.tree.root, penv0);
			penv2 = ruProve(penv1);
			inc_finished(1);
			switch (ruProverEnvProof(penv2.tree)) {
				Some(proof): {
					inc_proved(1);
					push_proved(th.info.id);
					proved_th = ruNormalizeTheoremVarsDisjs(RuTheorem(th with proof = proof));
					if (ruVerbose(env1.conf) > 0) {
						env1.out.println(i2s(^finished_count) + " '" + id2s(th.info.id) +
							"' PROVED in " + ruTimePassed2s(th_timer) +
							", tree size: " + i2s(ruProverTreeSize(penv2.tree)));
					}
					RuMappedDecl(true, true, proved_th);
				}
				None(): {
					if (ruVerbose(env1.conf) > 0) {
						env1.out.println(i2s(^finished_count) + " '" + id2s(th.info.id) +
							"' NOT proved in " + ruTimePassed2s(th_timer));
					}
					RuMappedDecl(true, false, decl);
				}
			}
		};

		// Proving is internally concurrent (ruProve uses ruConcurrent); running
		// multiple theorems concurrently at the outer level causes nested
		// thread-pool contention. Force sequential outer traversal via -seq.
		// Scale the total budget by min(n, nProc) so that each theorem gets
		// per_th_ms * min(n, nProc) / n ≈ per_th_ms / density — the same budget
		// the old concurrent dispatch provided (time * nProc / n), without OOM.
		n_theorems     = length(filter(ruTargetDecls(target, math, env), ruDeclIsTheorem));
		n_par          = availableProcessors();
		computed_total = per_th_ms * i2d(min(max(1, n_theorems), n_par));
		job_limit_str  = ruTaskStringArg(task, "job-time-limit", "");
		total_ms       = if (job_limit_str != "" && job_limit_str != "no") min(computed_total, ruParseTime(job_limit_str)) else computed_total;
		seq_task = RuTask(task with args =
			setTree(
				setTree(task.args, "target", ruTaskStringArg(task, "target", "all") + "-seq"),
				"time-limit", ruTime2s(total_ms)
			)
		);
		new_state = ruMapFnComm(
			RuUnit(seq_task, state, env.out),
			RuMapFn(
				RuMapFnInfo(
					"prove",
					\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
					\__ -> 1.0,
					\ -> "proved: " + i2s(^proved_count) + " theorems"
				),
				prove_fn
			)
		);
		// Compute not-proved as started − proved (catches both search failures
		// and theorems that timed out before prove_fn could complete).
		proved_set = buildSet(^proved_ids);
		not_proved = set2array(fold(^started_ids, makeSet(), \acc, id ->
			if (containsSet(proved_set, id)) acc else insertSet(acc, id)
		));
		if (ruVerbose(env.conf) > 0) {
			env.out.println("prove: proved " + i2s(^proved_count) + " theorems");
		}
		if (not_proved != []) {
			env.out.println("prove: not proved: " + strGlue(map(not_proved, id2s), ", "));
		}
		Some(RuState(new_state with
			vars = setTree(new_state.vars, "prove", pairs2tree([
				Pair("proved-count",    flow(^proved_count)),
				Pair("failed-count",    flow(length(not_proved))),
				Pair("failed-theorems", flow(map(not_proved, id2s)))
			]))
		))
	}
}

ruDefaultProveTactic(task : RuTask) -> RuProverTactic {
	max_depth = ruTaskIntArg(task, "max-depth", 5);
	max_size  = ruTaskIntArg(task, "max-size",  4096);
	ruBoundedBFSTactic(max_depth, max_size)
}
