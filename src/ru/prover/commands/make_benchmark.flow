import formats/json/json;
import ru/util/decls;
import ru/map_decls;
import comm;

export {
	ruCommMakeBenchmark : RuComm;
}

RuBenchmarkBucket(
	name  : string,
	min   : int,
	max   : int,    // -1 = unbounded
	share : double
);

ruBenchmarkBuckets : [RuBenchmarkBucket] = [
	RuBenchmarkBucket("small",  2,  5,  0.25),
	RuBenchmarkBucket("medium", 6,  15, 0.35),
	RuBenchmarkBucket("large",  16, 30, 0.25),
	RuBenchmarkBucket("huge",   31, -1, 0.15),
];

ruCommMakeBenchmark = RuComm(
	RuCommInfo(
		"make-benchmark", "prover",
		"select a stratified benchmark set of theorems for proof compression evaluation",
		"file", false, false,
		[
			RuCommArg("file",    true, "output JSON file for the benchmark set", "benchmark.json"),
			RuCommArg("size",    true, "total number of theorems to select", "200"),
			RuCommArg("seed",    true, "random seed for reproducibility", "42"),
			RuCommArg("dataset", true, "named dataset within the file (empty string = 'default')", ""),
		], []
	),
	ruRunBenchmarkSelect
);

ruRunBenchmarkSelect(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	timer = ruMakeTimer();

	file    = ruTaskStringArg(task, "file", "benchmark.json");
	size    = ruTaskIntArg(task, "size", 200);
	seed    = ruTaskIntArg(task, "seed", 42);
	ds_arg  = ruTaskStringArg(task, "dataset", "");
	ds_name = if (ds_arg == "") "default" else ds_arg;

	all_theorems = getTreeValues(ruDeclsTheorems(math.decls));
	// exclude trivial 1-step proofs: they cannot be compressed
	non_trivial = filter(all_theorems, \th -> length(th.proof.steps) >= 2);

	selected = ruStratifiedSample(non_trivial, size, seed);

	
	ru_root = ruOptsString(conf.opts, "ru-root", ".");
	names   = map(selected, \th -> id2s(th.info.id));
	path    = if (isAbsolutePath(file)) file else pathCombine(ru_root, file);

	// Read existing datasets from file (if any) so we can merge rather than overwrite.
	existing_datasets : Tree<string, Json> = {
		if (fileExists(path)) {
			existing = parseJsonSafe(getFileContent(path));
			ds_root = getJsonFieldValue(existing, "datasets", JsonNull());
			if (ds_root != JsonNull()) {
				switch (ds_root) {
					JsonObject(fields): fold(fields, makeTree(), \acc, p -> setTree(acc, p.first, p.second));
					default: makeTree();
				}
			} else makeTree();
		} else makeTree();
	};

	new_dataset = JsonObject([
		Pair("seed",     JsonDouble(i2d(seed))),
		Pair("size",     JsonDouble(i2d(length(selected)))),
		Pair("theorems", JsonArray(map(names, \s -> JsonString(s))))
	]);
	merged_datasets = setTree(existing_datasets, ds_name, new_dataset);
	datasets_json   = JsonObject(map(tree2pairs(merged_datasets), \p -> Pair(p.first, p.second)));

	json_val = JsonObject([
		Pair("source",   JsonString(ru_root)),
		Pair("datasets", datasets_json)
	]);

	if (!setFileContent(path, json2stringFormatted(json_val))) {
		env.out.error("make-benchmark: failed to write to " + path, []);
	} 
	Some(RuState(state with
		vars = setTree(state.vars, "make-benchmark", pairs2tree([
			Pair("file",     flow(path)),
			Pair("dataset",  flow(ds_name)),
			Pair("size",     flow(length(selected))),
			Pair("theorems", flow(names))
		]))
	));
}

ruInBucket(th : RuTheorem, b : RuBenchmarkBucket) -> bool {
	n = length(th.proof.steps);
	n >= b.min && (b.max < 0 || n <= b.max)
}

ruStratifiedSample(theorems : [RuTheorem], size : int, seed : int) -> [RuTheorem] {
	rng = randomGenerator(seed);
	concatA(mapi(ruBenchmarkBuckets, \i, b -> {
		bucket  = filter(theorems, \th -> ruInBucket(th, b));
		desired = round(i2d(size) * b.share);
		n       = min(desired, length(bucket));
		take(ruSeededShuffle(bucket, rng), n)
	}))
}

ruSeededShuffle(arr : [?], rng : () -> double) -> [?] {
	keyed = map(arr, \x -> Pair(rng(), x));
	map(sortCustom(keyed, \p -> p.first, false), \p -> p.second)
}
