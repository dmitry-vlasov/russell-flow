import formats/json/json;
import ru/prover/ml/lgg;
import ru/util/src2s;

export {
	// Per-assertion learned models (one per method).

	RuAssertionModelMedoid(
		assertion  : int,
		pos_medoid : RuExp,
		neg_medoid : RuExp,
		pos_count  : int,
		neg_count  : int
	);

	RuAssertionModelIteratedLgg(
		assertion : int,
		pos_lgg   : RuExp,
		neg_lgg   : RuExp,
		pos_count : int,
		neg_count : int
	);

	// Feature centroid stored as sorted sparse vector [Pair<rule_id, weight>].
	RuAssertionModelFeatures(
		assertion    : int,
		pos_centroid : [Pair<int, double>],
		neg_centroid : [Pair<int, double>],
		pos_count    : int,
		neg_count    : int
	);

	// Compact RuExp <-> JSON: flat int array [kind,v1,v2, ...], position omitted.
	ruExpToCompactJson(e : RuExp) -> Json;
	ruCompactJson2Exp(json : Json) -> Maybe<RuExp>;

	// Feature vector <-> JSON.
	ruFeatureVec2json(v : [Pair<int, double>]) -> Json;
	ruJson2FeatureVec(json : Json) -> [Pair<int, double>];

	// Collection serialization: Tree<int, model> -> JsonArray.
	ruMedoidModels2json(models : Tree<int, RuAssertionModelMedoid>) -> Json;
	ruJson2MedoidModels(json : Json) -> Tree<int, RuAssertionModelMedoid>;

	ruIteratedLggModels2json(models : Tree<int, RuAssertionModelIteratedLgg>) -> Json;
	ruJson2IteratedLggModels(json : Json) -> Tree<int, RuAssertionModelIteratedLgg>;

	ruFeaturesModels2json(models : Tree<int, RuAssertionModelFeatures>) -> Json;
	ruJson2FeaturesModels(json : Json) -> Tree<int, RuAssertionModelFeatures>;

	// Per-assertion k-NN model: stores up to max_k training feature vectors for
	// nearest-neighbour distance scoring (pos_nn_dist - neg_nn_dist).
	RuAssertionModelKnn(
		assertion    : int,
		pos_examples : [[Pair<int, double>]],
		neg_examples : [[Pair<int, double>]],
		pos_count    : int,
		neg_count    : int
	);

	ruKnnModels2json(models : Tree<int, RuAssertionModelKnn>) -> Json;
	ruJson2KnnModels(json : Json) -> Tree<int, RuAssertionModelKnn>;

	// Human-readable summaries.
	ruMedoidModel2s(m : RuAssertionModelMedoid, math : RuMath) -> string;
	ruIteratedLggModel2s(m : RuAssertionModelIteratedLgg, math : RuMath) -> string;
	ruFeaturesModel2s(m : RuAssertionModelFeatures, top_k : int) -> string;
	ruKnnModel2s(m : RuAssertionModelKnn, top_k : int) -> string;
}

// --- Compact RuExp <-> JSON: flat int array [kind,v1,v2, ...], position omitted ---

ruExpToCompactJson(e : RuExp) -> Json {
	ints = fold(e.nodes, [], \acc, n ->
		switch (n) {
			RuRuleNode(idType, arityLen): concat(acc, [JsonDouble(0.0), JsonDouble(i2d(idType)), JsonDouble(i2d(arityLen))]);
			RuVar(id, tp):               concat(acc, [JsonDouble(1.0), JsonDouble(i2d(id)),      JsonDouble(i2d(tp))]);
		}
	);
	JsonArray(ints);
}

ruCompactJson2Exp(json : Json) -> Maybe<RuExp> {
	arr = getJsonArrayValue(json, []);
	n   = length(arr);
	if (n == 0 || n % 3 != 0) None()
	else {
		nodes = filtermap(enumFromTo(0, n / 3 - 1), \i -> {
			kind = getJsonIntValue(arr[i * 3],     -1);
			v1   = getJsonIntValue(arr[i * 3 + 1],  0);
			v2   = getJsonIntValue(arr[i * 3 + 2],  0);
			if (kind == 0) Some(RuRuleNode(v1, v2))
			else if (kind == 1) Some(RuVar(v1, v2))
			else None();
		});
		if (length(nodes) * 3 == n) Some(RuExp(nodes, -1)) else None();
	}
}

// --- Feature vector <-> JSON ---

ruFeatureVec2json(v : [Pair<int, double>]) -> Json {
	JsonArray(map(v, \p -> JsonArray([JsonDouble(i2d(p.first)), JsonDouble(p.second)])));
}

ruJson2FeatureVec(json : Json) -> [Pair<int, double>] {
	filtermap(getJsonArrayValue(json, []), \item -> {
		arr = getJsonArrayValue(item, []);
		if (length(arr) != 2) None()
		else {
			k = round(getJsonDoubleValue(arr[0], -1.0));
			v = getJsonDoubleValue(arr[1], 0.0);
			if (k < 0) None() else Some(Pair(k, v));
		}
	});
}

// --- Medoid model ---

ruMedoidModel2json(m : RuAssertionModelMedoid) -> Json {
	JsonObject([
		Pair("assertion",  JsonDouble(i2d(m.assertion))),
		Pair("pos_medoid", ruExpToCompactJson(m.pos_medoid)),
		Pair("neg_medoid", ruExpToCompactJson(m.neg_medoid)),
		Pair("pos_count",  JsonDouble(i2d(m.pos_count))),
		Pair("neg_count",  JsonDouble(i2d(m.neg_count)))
	]);
}

ruJson2MedoidModel(json : Json) -> Maybe<RuAssertionModelMedoid> {
	assertion = getJsonIntField(json, "assertion", -1);
	pm_opt    = ruCompactJson2Exp(getJsonFieldValue(json, "pos_medoid", JsonNull()));
	nm_opt    = ruCompactJson2Exp(getJsonFieldValue(json, "neg_medoid", JsonNull()));
	pc        = getJsonIntField(json, "pos_count", 0);
	nc        = getJsonIntField(json, "neg_count", 0);
	if (assertion < 0) None()
	else switch (pm_opt) {
		Some(pm): switch (nm_opt) {
			Some(nm): Some(RuAssertionModelMedoid(assertion, pm, nm, pc, nc));
			None(): None();
		}
		None(): None();
	}
}

ruMedoidModels2json(models : Tree<int, RuAssertionModelMedoid>) -> Json {
	JsonArray(map(getTreeValues(models), ruMedoidModel2json));
}

ruJson2MedoidModels(json : Json) -> Tree<int, RuAssertionModelMedoid> {
	fold(filtermap(getJsonArrayValue(json, []), ruJson2MedoidModel), makeTree(), \acc, m ->
		setTree(acc, m.assertion, m)
	);
}

// --- Iterated-LGG model ---

ruIteratedLggModel2json(m : RuAssertionModelIteratedLgg) -> Json {
	JsonObject([
		Pair("assertion", JsonDouble(i2d(m.assertion))),
		Pair("pos_lgg",   ruExpToCompactJson(m.pos_lgg)),
		Pair("neg_lgg",   ruExpToCompactJson(m.neg_lgg)),
		Pair("pos_count", JsonDouble(i2d(m.pos_count))),
		Pair("neg_count", JsonDouble(i2d(m.neg_count)))
	]);
}

ruJson2IteratedLggModel(json : Json) -> Maybe<RuAssertionModelIteratedLgg> {
	assertion = getJsonIntField(json, "assertion", -1);
	pl_opt    = ruCompactJson2Exp(getJsonFieldValue(json, "pos_lgg", JsonNull()));
	nl_opt    = ruCompactJson2Exp(getJsonFieldValue(json, "neg_lgg", JsonNull()));
	pc        = getJsonIntField(json, "pos_count", 0);
	nc        = getJsonIntField(json, "neg_count", 0);
	if (assertion < 0) None()
	else switch (pl_opt) {
		Some(pl): switch (nl_opt) {
			Some(nl): Some(RuAssertionModelIteratedLgg(assertion, pl, nl, pc, nc));
			None(): None();
		}
		None(): None();
	}
}

ruIteratedLggModels2json(models : Tree<int, RuAssertionModelIteratedLgg>) -> Json {
	JsonArray(map(getTreeValues(models), ruIteratedLggModel2json));
}

ruJson2IteratedLggModels(json : Json) -> Tree<int, RuAssertionModelIteratedLgg> {
	fold(filtermap(getJsonArrayValue(json, []), ruJson2IteratedLggModel), makeTree(), \acc, m ->
		setTree(acc, m.assertion, m)
	);
}

// --- Features model ---

ruFeaturesModel2json(m : RuAssertionModelFeatures) -> Json {
	JsonObject([
		Pair("assertion",    JsonDouble(i2d(m.assertion))),
		Pair("pos_centroid", ruFeatureVec2json(m.pos_centroid)),
		Pair("neg_centroid", ruFeatureVec2json(m.neg_centroid)),
		Pair("pos_count",    JsonDouble(i2d(m.pos_count))),
		Pair("neg_count",    JsonDouble(i2d(m.neg_count)))
	]);
}

ruJson2FeaturesModel(json : Json) -> Maybe<RuAssertionModelFeatures> {
	assertion = getJsonIntField(json, "assertion", -1);
	if (assertion < 0) None()
	else Some(RuAssertionModelFeatures(
		assertion,
		ruJson2FeatureVec(getJsonFieldValue(json, "pos_centroid", JsonNull())),
		ruJson2FeatureVec(getJsonFieldValue(json, "neg_centroid", JsonNull())),
		getJsonIntField(json, "pos_count", 0),
		getJsonIntField(json, "neg_count", 0)
	));
}

ruFeaturesModels2json(models : Tree<int, RuAssertionModelFeatures>) -> Json {
	JsonArray(map(getTreeValues(models), ruFeaturesModel2json));
}

ruJson2FeaturesModels(json : Json) -> Tree<int, RuAssertionModelFeatures> {
	fold(filtermap(getJsonArrayValue(json, []), ruJson2FeaturesModel), makeTree(), \acc, m ->
		setTree(acc, m.assertion, m)
	);
}

// --- k-NN model ---

ruFeatureVecList2json(vecs : [[Pair<int, double>]]) -> Json {
	JsonArray(map(vecs, ruFeatureVec2json));
}

ruJson2FeatureVecList(json : Json) -> [[Pair<int, double>]] {
	map(getJsonArrayValue(json, []), ruJson2FeatureVec);
}

ruKnnModel2json(m : RuAssertionModelKnn) -> Json {
	JsonObject([
		Pair("assertion",    JsonDouble(i2d(m.assertion))),
		Pair("pos_examples", ruFeatureVecList2json(m.pos_examples)),
		Pair("neg_examples", ruFeatureVecList2json(m.neg_examples)),
		Pair("pos_count",    JsonDouble(i2d(m.pos_count))),
		Pair("neg_count",    JsonDouble(i2d(m.neg_count)))
	]);
}

ruJson2KnnModel(json : Json) -> Maybe<RuAssertionModelKnn> {
	assertion = getJsonIntField(json, "assertion", -1);
	if (assertion < 0) None()
	else Some(RuAssertionModelKnn(
		assertion,
		ruJson2FeatureVecList(getJsonFieldValue(json, "pos_examples", JsonNull())),
		ruJson2FeatureVecList(getJsonFieldValue(json, "neg_examples", JsonNull())),
		getJsonIntField(json, "pos_count", 0),
		getJsonIntField(json, "neg_count", 0)
	));
}

ruKnnModels2json(models : Tree<int, RuAssertionModelKnn>) -> Json {
	JsonArray(map(getTreeValues(models), ruKnnModel2json));
}

ruJson2KnnModels(json : Json) -> Tree<int, RuAssertionModelKnn> {
	fold(filtermap(getJsonArrayValue(json, []), ruJson2KnnModel), makeTree(), \acc, m ->
		setTree(acc, m.assertion, m)
	);
}

// --- Human-readable output ---

ruMedoidModel2s(m : RuAssertionModelMedoid, math : RuMath) -> string {
	"[medoid] " + id2s(m.assertion) +
	" (P=" + i2s(m.pos_count) + ", N=" + i2s(m.neg_count) + ")\n" +
	"  pos: " + ru2s(m.pos_medoid, math) + "\n" +
	"  neg: " + ru2s(m.neg_medoid, math) + "\n";
}

ruIteratedLggModel2s(m : RuAssertionModelIteratedLgg, math : RuMath) -> string {
	p_vars = fold(m.pos_lgg.nodes, 0, \acc, n -> switch (n) { RuVar(__,__): acc + 1; default: acc; });
	n_vars = fold(m.neg_lgg.nodes, 0, \acc, n -> switch (n) { RuVar(__,__): acc + 1; default: acc; });
	"[iterated-lgg] " + id2s(m.assertion) +
	" (P=" + i2s(m.pos_count) + ", N=" + i2s(m.neg_count) + ")\n" +
	"  pos: " + ru2s(m.pos_lgg, math) +
	"  [" + i2s(ruExpRuleNodeCount(m.pos_lgg)) + " rules, " + i2s(p_vars) + " vars]\n" +
	"  neg: " + ru2s(m.neg_lgg, math) +
	"  [" + i2s(ruExpRuleNodeCount(m.neg_lgg)) + " rules, " + i2s(n_vars) + " vars]\n";
}

ruKnnModel2s(m : RuAssertionModelKnn, top_k : int) -> string {
	"[knn] " + id2s(m.assertion) +
	" (P=" + i2s(m.pos_count) + ", N=" + i2s(m.neg_count) +
	", stored_pos=" + i2s(length(m.pos_examples)) + ", stored_neg=" + i2s(length(m.neg_examples)) + ")\n";
}

ruFeaturesModel2s(m : RuAssertionModelFeatures, top_k : int) -> string {
	pos_t = fold(m.pos_centroid, makeTree(), \acc, p -> setTree(acc, p.first, p.second));
	neg_t = fold(m.neg_centroid, makeTree(), \acc, p -> setTree(acc, p.first, p.second));
	all_keys = mergeSets(buildSet(getTreeKeys(pos_t)), buildSet(getTreeKeys(neg_t)));
	scored = map(set2array(all_keys), \k ->
		Pair(k, abs(lookupTreeDef(pos_t, k, 0.0) - lookupTreeDef(neg_t, k, 0.0)))
	);
	top = take(sortCustom(scored, \p -> p.second, false), top_k);
	lines = strGlue(map(top, \p ->
		"    " + i2s(p.first) +
		": pos=" + d2s(lookupTreeDef(pos_t, p.first, 0.0)) +
		" neg=" + d2s(lookupTreeDef(neg_t, p.first, 0.0)) +
		" diff=" + d2s(p.second)
	), "\n");
	"[features] " + id2s(m.assertion) +
	" (P=" + i2s(m.pos_count) + ", N=" + i2s(m.neg_count) + ")\n" +
	"  top-" + i2s(top_k) + " discriminative features:\n" + lines + "\n";
}
