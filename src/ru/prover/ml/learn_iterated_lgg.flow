import ru/prover/ml/assertion_model;
import ru/prover/ml/collect_data;
import ru/prover/ml/learn_medoid;
import comm;

export {
	ruCommLearnAssertionIteratedLgg : RuComm;
}

ruCommLearnAssertionIteratedLgg = RuComm(
	RuCommInfo(
		"learn-assertion-iterated-lgg", "prover",
		"learn per-assertion iterated-LGG template models from collected learning data",
		"", false, false,
		[
			RuCommArg("min-rules", true, "minimum rule-node count to keep in LGG template (0 = unbounded)", "1"),
		], []
	),
	ruRunLearnAssertionIteratedLgg
);

ruRunLearnAssertionIteratedLgg(unit : RuUnit) -> Maybe<RuState> {
	env       = ruUnitEnv(unit);
	task      = unit.task;
	state     = unit.state;
	conf      = state.conf;
	timer     = ruMakeTimer();
	min_rules = ruTaskIntArg(task, "min-rules", 1);

	data = ruLoadCollectedData(conf);
	if (sizeTree(data) == 0) {
		env.out.println("learn-assertion-iterated-lgg: no collected data found, run collect-learning-data first");
		Some(state);
	} else {
		models = foldTree(data, makeTree(), \id, usage, acc ->
			switch (ruComputeIteratedLggModel(id, usage, min_rules)) {
				Some(m): setTree(acc, id, m);
				None():  acc;
			}
		);
		ru_root = ruOptsString(conf.opts, "ru-root", ".");
		out_path = pathCombine(ru_root, "db/assertion-models-iterated-lgg.json");
		if (!setFileContent(out_path, json2string(ruIteratedLggModels2json(models)))) {
			env.out.println("learn-assertion-iterated-lgg: failed to write to " + out_path);
		} else if (ruVerbose(conf) > 0) {
			env.out.println("learn-assertion-iterated-lgg: learned " + i2s(sizeTree(models)) + " models in " + ruTimePassed2s(timer));
			env.out.println("learn-assertion-iterated-lgg: saved to " + out_path);
		}
		Some(RuState(state with
			vars = setTree(state.vars, "learn-assertion-iterated-lgg", pairs2tree([
				Pair("count", flow(sizeTree(models))),
				Pair("file",  flow(out_path))
			]))
		));
	}
}

ruComputeIteratedLggModel(id : int, usage : RuAssertionUsage, min_rules : int) -> Maybe<RuAssertionModelIteratedLgg> {
	pos_exps  = ruExtractGoalExps(filter(usage.contexts, \ctx -> ctx.sign));
	neg_exps0 = ruExtractGoalExps(filter(usage.contexts, \ctx -> !ctx.sign));
	neg_exps  = if (length(neg_exps0) > length(pos_exps)) take(neg_exps0, length(pos_exps)) else neg_exps0;
	lgg = if (min_rules <= 0) ruLggExpSet else \exps -> ruLggExpSetBounded(exps, min_rules);
	if (length(pos_exps) == 0 || length(neg_exps) == 0) None()
	else Some(RuAssertionModelIteratedLgg(
		id,
		lgg(pos_exps),
		lgg(neg_exps),
		length(pos_exps),
		length(neg_exps)
	));
}
