import ru/prover/ml/assertion_model;
import ru/prover/ml/collect_data;
import ru/prover/ml/learn_medoid;
import comm;

export {
	ruCommLearnAssertionFeatures : RuComm;
}

ruCommLearnAssertionFeatures = RuComm(
	RuCommInfo(
		"learn-assertion-features", "prover",
		"learn per-assertion feature-centroid models from collected learning data",
		"", false, false,
		[], []
	),
	ruRunLearnAssertionFeatures
);

ruRunLearnAssertionFeatures(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	state = unit.state;
	conf  = state.conf;
	timer = ruMakeTimer();

	data = ruLoadCollectedData(conf);
	if (sizeTree(data) == 0) {
		env.out.println("learn-assertion-features: no collected data found, run collect-learning-data first");
		Some(state);
	} else {
		models = foldTree(data, makeTree(), \id, usage, acc ->
			switch (ruComputeFeaturesModel(id, usage)) {
				Some(m): setTree(acc, id, m);
				None():  acc;
			}
		);
		ru_root = ruOptsString(conf.opts, "ru-root", ".");
		out_path = pathCombine(ru_root, "db/assertion-models-features.json");
		if (!setFileContent(out_path, json2string(ruFeaturesModels2json(models)))) {
			env.out.println("learn-assertion-features: failed to write to " + out_path);
		} else if (ruVerbose(conf) > 0) {
			env.out.println("learn-assertion-features: learned " + i2s(sizeTree(models)) + " models in " + ruTimePassed2s(timer));
			env.out.println("learn-assertion-features: saved to " + out_path);
		}
		Some(RuState(state with
			vars = setTree(state.vars, "learn-assertion-features", pairs2tree([
				Pair("count", flow(sizeTree(models))),
				Pair("file",  flow(out_path))
			]))
		));
	}
}

ruComputeFeaturesModel(id : int, usage : RuAssertionUsage) -> Maybe<RuAssertionModelFeatures> {
	pos_exps = ruExtractGoalExps(filter(usage.contexts, \ctx -> ctx.sign));
	neg_exps = ruExtractGoalExps(filter(usage.contexts, \ctx -> !ctx.sign));
	if (length(pos_exps) == 0 || length(neg_exps) == 0) None()
	else Some(RuAssertionModelFeatures(
		id,
		ruFeatureVecMean(map(pos_exps, ruExpFeatureVec)),
		ruFeatureVecMean(map(neg_exps, ruExpFeatureVec)),
		length(pos_exps),
		length(neg_exps)
	));
}
