import ru/prover/ml/assertion_model;
import ru/prover/ml/learn_knn;
import ru/prover/ml/lgg;
import ru/prover/core/tree;
import ru/prover/core/controls;
import ru/unify/index;

export {
	RuMlSelector(
		features  : Tree<int, RuAssertionModelFeatures>,
		medoids   : Tree<int, RuAssertionModelMedoid>,
		lgg_tmpls : Tree<int, RuAssertionModelIteratedLgg>,
		knn       : Tree<int, RuAssertionModelKnn>,
		w_feat    : double,
		w_medoid  : double,
		w_lgg     : double,
		w_knn     : double,
		normalize : bool
	);

	ruLoadMlSelector(conf : RuConf) -> RuMlSelector;

	// Score a candidate prop: lower = more likely the right choice.
	// Returns 0.0 when no model exists for the assertion (neutral).
	ruMlScoreProp(prop : RuProverProp, sel : RuMlSelector) -> double;

	// Score a unified candidate directly (used by benchmark-rank, which works
	// at the RuUnified level before RuProverProp nodes are created).
	ruMlScoreUnified(u : RuUnified<RuAssertion>, hyp : RuProverHyp, sel : RuMlSelector) -> double;

	// Tactic that ranks all leaf candidates by ML score each step,
	// returning up to top_k best. Stops on proof found or tree limits.
	ruMlTactic(sel : RuMlSelector, top_k : int, max_depth : int, max_size : int) -> RuProverTactic;
}

ruLoadMlSelector(conf : RuConf) -> RuMlSelector {
	ru_root = ruOptsString(conf.opts, "ru-root", ".");
	load = \name -> parseJsonSafe(getFileContent(pathCombine(ru_root, "db/" + name)));
	RuMlSelector(
		ruJson2FeaturesModels(load("assertion-models-features.json")),
		ruJson2MedoidModels(load("assertion-models-medoid.json")),
		ruJson2IteratedLggModels(load("assertion-models-iterated-lgg.json")),
		ruJson2KnnModels(load("assertion-models-knn.json")),
		1.0, 0.0, 0.0, 0.0, true
	)
}

ruFirstGoalExp(prop : RuProverProp) -> RuExp {
	fold(prop.parent.stmt.exps, ruNoExp, \acc, te ->
		if (length(acc.nodes) > 0) acc
		else switch (te) { RuExp(__,__): te; default: ruNoExp; }
	)
}

ruFeatureScore(id : int, goal : RuExp, models : Tree<int, RuAssertionModelFeatures>) -> double {
	switch (lookupTree(models, id)) {
		None(): 0.0;
		Some(m): {
			v = ruExpFeatureVec(goal);
			ruFeatureVecDist(v, m.pos_centroid) - ruFeatureVecDist(v, m.neg_centroid);
		}
	}
}

ruMedoidScore(id : int, goal : RuExp, models : Tree<int, RuAssertionModelMedoid>) -> double {
	switch (lookupTree(models, id)) {
		None(): 0.0;
		Some(m): ruLggDistance(goal, m.pos_medoid) - ruLggDistance(goal, m.neg_medoid);
	}
}

ruKnnScore(id : int, goal : RuExp, models : Tree<int, RuAssertionModelKnn>) -> double {
	switch (lookupTree(models, id)) {
		None(): 0.0;
		Some(m): {
			if (length(m.pos_examples) == 0 || length(m.neg_examples) == 0) 0.0
			else {
				v = ruExpFeatureVec(goal);
				if (length(v) == 0) 0.0
				else {
					pos_nn = fold(tail(m.pos_examples), ruFeatureVecDist(v, m.pos_examples[0]),
						\acc, e -> min(acc, ruFeatureVecDist(v, e)));
					neg_nn = fold(tail(m.neg_examples), ruFeatureVecDist(v, m.neg_examples[0]),
						\acc, e -> min(acc, ruFeatureVecDist(v, e)));
					pos_nn - neg_nn
				}
			}
		}
	}
}

ruLggTemplateScore(id : int, goal : RuExp, models : Tree<int, RuAssertionModelIteratedLgg>) -> double {
	switch (lookupTree(models, id)) {
		None(): 0.0;
		Some(m): {
			// Only use template if at least one side has non-trivial structure.
			pos_rules = ruExpRuleNodeCount(m.pos_lgg);
			neg_rules = ruExpRuleNodeCount(m.neg_lgg);
			if (pos_rules == 0 && neg_rules == 0) 0.0
			else ruLggDistance(goal, m.pos_lgg) - ruLggDistance(goal, m.neg_lgg);
		}
	}
}

ruMlScoreProp(prop : RuProverProp, sel : RuMlSelector) -> double {
	id   = prop.assertion.info.id;
	goal = ruFirstGoalExp(prop);
	if (length(goal.nodes) == 0) 0.0
	else
		sel.w_feat   * ruFeatureScore(id, goal, sel.features) +
		sel.w_medoid * ruMedoidScore(id, goal, sel.medoids) +
		sel.w_lgg    * ruLggTemplateScore(id, goal, sel.lgg_tmpls) +
		sel.w_knn    * ruKnnScore(id, goal, sel.knn);
}

ruMlScoreUnified(u : RuUnified<RuAssertion>, hyp : RuProverHyp, sel : RuMlSelector) -> double {
	id   = u.data.info.id;
	goal = fold(hyp.stmt.exps, ruNoExp, \acc, te ->
		if (length(acc.nodes) > 0) acc
		else switch (te) { RuExp(__, __): te; default: ruNoExp; }
	);
	if (length(goal.nodes) == 0) 0.0
	else
		sel.w_feat   * ruFeatureScore(id, goal, sel.features) +
		sel.w_medoid * ruMedoidScore(id, goal, sel.medoids) +
		sel.w_lgg    * ruLggTemplateScore(id, goal, sel.lgg_tmpls) +
		sel.w_knn    * ruKnnScore(id, goal, sel.knn);
}

ruZscore(raw : [double], normalize : bool) -> [double] {
	n = max(length(raw), 1);
	mean = fold(raw, 0.0, \a, x -> a + x) / i2d(n);
	std  = sqrt(fold(raw, 0.0, \a, x -> a + x * x) / i2d(n) - mean * mean);
	if (!normalize || std < 0.000000001) raw
	else map(raw, \x -> (x - mean) / std);
}

ruMlTactic(sel : RuMlSelector, top_k : int, max_depth : int, max_size : int) -> RuProverTactic {
	RuProverTactic("ml-premise",
		\tree ->
			if (length(^(tree.proofs)) > 0
				|| ruProverTreeDepth(tree) > max_depth
				|| ruProverTreeSize(tree) > max_size) RuTacticDone()
			else {
			all_leafs  = getTreeValues(tree.leafs);
			feat_raw   = map(all_leafs, \prop -> {
				id = prop.assertion.info.id; goal = ruFirstGoalExp(prop);
				if (length(goal.nodes) == 0) 0.0 else ruFeatureScore(id, goal, sel.features)
			});
			medoid_raw = map(all_leafs, \prop -> {
				id = prop.assertion.info.id; goal = ruFirstGoalExp(prop);
				if (length(goal.nodes) == 0) 0.0 else ruMedoidScore(id, goal, sel.medoids)
			});
			lgg_raw    = map(all_leafs, \prop -> {
				id = prop.assertion.info.id; goal = ruFirstGoalExp(prop);
				if (length(goal.nodes) == 0) 0.0 else ruLggTemplateScore(id, goal, sel.lgg_tmpls)
			});
			knn_raw    = map(all_leafs, \prop -> {
				id = prop.assertion.info.id; goal = ruFirstGoalExp(prop);
				if (length(goal.nodes) == 0) 0.0 else ruKnnScore(id, goal, sel.knn)
			});
			feat_s   = ruZscore(feat_raw,   sel.normalize);
			medoid_s = ruZscore(medoid_raw, sel.normalize);
			lgg_s    = ruZscore(lgg_raw,    sel.normalize);
			knn_s    = ruZscore(knn_raw,    sel.normalize);
			scored = mapi(all_leafs, \i, prop ->
				Pair(sel.w_feat * feat_s[i] + sel.w_medoid * medoid_s[i] + sel.w_lgg * lgg_s[i] + sel.w_knn * knn_s[i], prop)
			);
			sorted = sortCustom(scored, \p -> p.first, true);
			candidates = if (top_k > 0 && top_k < length(sorted)) take(sorted, top_k) else sorted;
			RuTacticExpand(map(candidates, \p -> p.second));
			}
	);
}
