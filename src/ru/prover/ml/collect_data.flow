import formats/json/json;
import ru/prover/ml/learning_data;
import ru/prover/ml/assertion_model;
import ds/vector;
import base/util/progress;
import ru/prover/core/prove;
import ru/prover/core/stats;
import ru/map_decls;

export {
    ruRunCollectLearningData(unit : RuUnit) -> Maybe<RuState>;
    ruCommCollectLearningData : RuComm;

    // JSON serialization for the collected learning data.
    // Only sign + goal RuExp parts are stored (premises are not needed for centroid learning).
    ruAssertionUsages2json(data : Tree<int, RuAssertionUsage>) -> Json;
    ruJson2AssertionUsages(json : Json) -> Tree<int, RuAssertionUsage>;

    // Standard path for the persisted data file.
    ruCollectedDataPath(conf : RuConf) -> string;

    // Load previously collected data from disk; empty tree if file not found.
    ruLoadCollectedData(conf : RuConf) -> Tree<int, RuAssertionUsage>;
}

ruCommCollectLearningData = RuComm(
	RuCommInfo(
		"collect-learning-data", "prover", "collect data for machine learning", "target", true, false,
		[
			RuCommArg("target",  true, "the target: a theorem, file or all", "all"),
			RuCommArg("max-neg", true, "max negative contexts per assertion (0 = unlimited, default caps at |pos|)", "0"),
		], []
	),
	ruRunCollectLearningData
);

ruRunCollectLearningData(unit : RuUnit) -> Maybe<RuState> {
	env     = ruUnitEnv(unit);
	task    = unit.task;
	state   = unit.state;
	conf    = state.conf;
	max_neg = ruTaskIntArg(task, "max-neg", 0);
	math = ruMathFromSources(state.ru, env);
	timer = ruMakeTimer();
	target = ruDetermineTarget(unit.task, math, env);
	if (target != RuTargetNone()) {
		collected_count = ref 0;
		failed_theorems = ref [];
		inc_collected = ruAtomicIntInc(collected_count);
		th_fail = ruAtomicRefArrayPush(failed_theorems);
		all_imported = ruSourcesAllImported(math.sources, env);
		index = ruMakeIndexForTarget(target, math, env);
        collected_map = makeConcurHashMap(idfn);
		collect_learning_data_fn = \decl, time_limit, env1 -> {
			th = cast(decl : RuDecl -> RuTheorem);
			if (ruTheoremIsProved(th)) {
				if (ruVerbose(env1.conf) > 2) {
					env1.out.println(i2s(^collected_count) + ": going to collect_learning_data theorem '" + id2s(th.info.id) + "' ... ");
				}
				th_timer = ruMakeTimer();
                th_collected = ruCollectLearningDataFromTheorem(th, index, ruTaskArgs2Tree(task.args), time_limit, math, env, conf);
				inc_collected(1);
                setConcurHashMap(collected_map, th.info.id, th_collected);
            }
            RuMappedDecl(true, false, decl);
		}
		new_state = ruMapFnComm(
			RuUnit(unit.task, state, env.out),
			RuMapFn(
				RuMapFnInfo(
					"collect-learning-data",
					\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
					ruProofLengthMeasure,
					\ -> "collected: " + i2s(^collected_count) + " theorems"
				),
				collect_learning_data_fn
			)
		);
		// Merge per-theorem maps after parallel collection completes.
		merged = fold(keysConcurHashMap(collected_map), makeTree(), \acc, id -> {
			data = getConcurHashMap(collected_map, id, makeTree());
			ruMergeLearningData(acc, data);
		});
		// Cap negatives per assertion: at most min(max_neg, |pos|) to keep data balanced.
		collected = mapTree(merged, \usage -> {
			pos = filter(usage.contexts, \ctx -> ctx.sign);
			neg = filter(usage.contexts, \ctx -> !ctx.sign);
			cap = if (max_neg > 0) min(max_neg, length(pos)) else length(pos);
			RuAssertionUsage(usage with contexts = concat(pos, take(neg, cap)));
		});
		// Persist to disk for use by learn-* commands.
		out_path = ruCollectedDataPath(conf);
		out_dir = dirName(out_path);
		dir_err = ensureDirectoryExists(out_dir);
		if (dir_err != "") {
			env.out.println("collect-learning-data: failed to create directory " + out_dir + ": " + dir_err);
		} else if (!setFileContent(out_path, json2string(ruAssertionUsages2json(collected)))) {
			env.out.println("collect-learning-data: failed to write to " + out_path);
		} else if (ruVerbose(conf) > 0) {
			env.out.println("collect-learning-data: saved " + i2s(sizeTree(collected)) + " assertion usages to " + out_path);
		}
		if (ruVerbose(env.conf) > 0) {
			env.out.println("collected: " + i2s(^collected_count) + " theorems");
		}
		if (length(^failed_theorems) > 0) {
			if (length(^failed_theorems) < 10) {
				env.out.println("Failed to collect learning data from theorems: " + strGlue(map(^failed_theorems, id2s), ", "));
			} else {
				env.out.println("Failed to collect_learning_data theorems:\n" + strIndent(strGlue(map(^failed_theorems, id2s), "\n")));
			}
		}
		Some(RuState(new_state with
			vars = setTree(new_state.vars, "collect-learning-data", pairs2tree([
				Pair("failed-count", flow(length(^failed_theorems))),
				Pair("failed-theorems", flow(map(^failed_theorems, id2s))),
				Pair("collected-count", flow(^collected_count))
			]));
		));
	} else {
		env.out.println("no target for proof reproving with oracle");
		Some(state);
	}
}

ruCollectLearningDataFromTheorem(
    th : RuTheorem, index : RuIndex<RuAssertion>, args : Tree<string, string>,
    time_limit : double, math : RuMath, env : RuEnv, conf : RuConf
) -> Tree<int, RuAssertionUsage> {

    mapping = ref makeTree();
	root = lookupTreeDef(math.decls.assertions, ruProofQedStep(th.proof).assertion, ruNoAxiom);
	proof = ruTheoremProofTree(th, math);
	premises = th.infer.hyps;
    initialized = ref false;
	collected = ref makeTree();
	compute_leafs = \tree -> {
			if (!^initialized) {
				traverseInOrder(tree.leafs, \__,node ->
					if (node.assertion.info.id == proof.assertion) {
						collected := ruAddLearningContext(
							^collected, 
							node.assertion.info.id,
							RuUsageContext(true, premises, node.parent.stmt.exps)
						);
						mapping := setTree(^mapping, node, proof);
					} else {
						collected := ruAddLearningContext(
							^collected, 
							node.assertion.info.id, 
							RuUsageContext(false, premises, node.parent.stmt.exps)
						);
					}
				);
				initialized := true;
			}
			ret = foldTree(tree.leafs, [], \__, node, acc -> 
				switch (lookupTree(^mapping, node)) {
					Some(__): {
						// positive context
						/*collected := ruAddLearningContext(
							^collected, 
							node.assertion.info.id, 
							RuUsageContext(true, premises, node.parent.expr)
						);*/
						concat(acc, [node]);
					}
					None(): {
						// negative context
						switch (node.parent) {
							RuProverExp(ind,__,stmt,__,grand): {
								switch (lookupTree(^mapping, grand)) {
									Some(p): {
										child = p.children[ind];
										switch (child) {
											RuProofStep(__,__,__): {
												collected := ruAddLearningContext(
													^collected, 
													node.assertion.info.id, 
													RuUsageContext(true, premises, stmt.exps)
												);
												mapping := setTree(^mapping, node, child);
											}
											RuProofHyp(__,__): { 
												//print ln("<<!! NEG(A) !!>>: " + id2s(node.assertion.info.id));
												collected := ruAddLearningContext(
													^collected, 
													node.assertion.info.id, 
													RuUsageContext(false, premises, node.parent.stmt.exps)
												);
											}
										}
									}
									None(): {
										//print ln("<<!! NEG(B) !!>>: " + id2s(node.assertion.info.id));
										collected := ruAddLearningContext(
											^collected, 
											node.assertion.info.id, 
											RuUsageContext(false, premises, node.parent.stmt.exps)
										);
									}
								}
							}
							RuProverRoot(__,__,__): { }
						}
						acc;
					}
				}
			);
			//print ln("TO EXPAND: " + strGlue(map(ret, \n -> i2s(n.id) + "=" + id2s(n.assertion.info.id)), ", "));
			ret;
		};
	tactic = RuProverTactic("collect-learning-data", "collect-learning-data",
		\tree -> {
			leafs = compute_leafs(tree);
			if (leafs == []) RuTacticDone() else RuTacticExpand(leafs)
		},
		ruTreeNotProved
	);

    prover_task = RuProverTask(th.info, tactic, id2s(th.info.id), args, premises, ruProofQedStep(th.proof));
	penv0 = ruInitProverEnv(prover_task, math, env, index, time_limit);
	penv1 = ruExpandHyp(penv0.tree.root, penv0);
	ruProveSequential(penv1);

    ^collected;
}

ruLearningData2s(data : Tree<int, RuAssertionUsage>, math : RuMath) -> string {
	list = foldTree(data, makeList(), \id, usage, acc ->
		Cons(ruAssertionUsage2s(usage, math, true), acc)
	);
	concatStrings(list2array(list));
}

// --- JSON serialization of collected learning data ---
// Format: [{"assertion": int, "contexts": [{"sign": bool, "goal_exps": [[kind,v1,v2],...]},...]}]
// Premises are omitted — only sign + goal RuExp parts are needed for centroid learning.


ruUsageContext2json(ctx : RuUsageContext) -> Json {
	goal_exps = filtermap(ctx.goal, \te ->
		switch (te) {
			RuExp(__,__): Some(ruExpToCompactJson(te));
			default: None();
		}
	);
	JsonObject([
		Pair("sign",      JsonBool(ctx.sign)),
		Pair("goal_exps", JsonArray(goal_exps))
	]);
}

ruJson2UsageContext(json : Json) -> Maybe<RuUsageContext> {
	sign     = getJsonBoolField(json, "sign", false);
	exps_arr = getJsonArrayField(json, "goal_exps");
	exps     = filtermap(exps_arr, ruCompactJson2Exp);
	if (length(exps) == 0) None()
	else Some(RuUsageContext(sign, [], exps));
}

ruAssertionUsage2json(usage : RuAssertionUsage) -> Json {
	JsonObject([
		Pair("assertion", JsonDouble(i2d(usage.assertion))),
		Pair("contexts",  JsonArray(map(usage.contexts, ruUsageContext2json)))
	]);
}

ruJson2AssertionUsageItem(json : Json) -> Maybe<RuAssertionUsage> {
	assertion = getJsonIntField(json, "assertion", -1);
	if (assertion < 0) None()
	else {
		ctxs = filtermap(getJsonArrayField(json, "contexts"), ruJson2UsageContext);
		if (length(ctxs) == 0) None()
		else Some(RuAssertionUsage(assertion, ctxs));
	}
}

ruAssertionUsages2json(data : Tree<int, RuAssertionUsage>) -> Json {
	JsonArray(map(getTreeValues(data), ruAssertionUsage2json));
}

ruJson2AssertionUsages(json : Json) -> Tree<int, RuAssertionUsage> {
	fold(filtermap(getJsonArrayValue(json, []), ruJson2AssertionUsageItem), makeTree(), \acc, u ->
		setTree(acc, u.assertion, u)
	);
}

ruCollectedDataPath(conf : RuConf) -> string {
	ru_root = ruOptsString(conf.opts, "ru-root", ".");
	pathCombine(ru_root, "db/collected-learning-data.json");
}

ruLoadCollectedData(conf : RuConf) -> Tree<int, RuAssertionUsage> {
	path = ruCollectedDataPath(conf);
	if (!fileExists(path)) makeTree()
	else ruJson2AssertionUsages(parseJsonSafe(getFileContent(path)));
}
