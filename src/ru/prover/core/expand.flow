import ru/prover/core/proofs;
import ru/prover/core/forward_closure;

export {
	ruExpandHyp(hyp : RuProverHyp, prover_env : RuProverEnv) -> RuProverEnv;
	ruExpandProp(prop : RuProverProp, prover_env : RuProverEnv) -> RuProverEnv;
}

ruExpandHyp(hyp : RuProverHyp, prover_env : RuProverEnv) -> RuProverEnv {
	t1 = ruMakeTimer();
	unified = concat(
		prover_env.fns.unifyAssertion(hyp),
		prover_env.fns.unifyFragment(hyp)
	);
	if (ruOptsString(prover_env.env.conf.opts, "reprove-stats", "") == "1") {
		ruAddStats("unify_assertion", RuStatsRow("unifying " + ruSafeExp2s(ruExp(hyp.stmt.exps[0]), prover_env.math.decls.lang),
			pairs2tree([
				Pair("size", i2d(length(ruExp(hyp.stmt.exps[0]).nodes))), 
				Pair("time", ruTimePassed(t1)), 
				Pair("rets", i2d(length(unified)))
			])
		));
	}
	// Sort most-specific candidates first (more variables bound by unification = tighter fit).
	// Prop IDs reflect insertion order, so TopN beam tactics naturally prefer specific candidates.
	unified_sorted = sortCustom(unified, \u -> ruSubstSize(u.sub), false);
	expanded_leafs = fold(unified_sorted, prover_env.tree.leafs,
		\acc, unif -> {
			assertion = unif.data;
			precedes = ruDeclInfoPreceeds(assertion.info, prover_env.conf.task.info, prover_env.importDependencies);
			if (!precedes) acc else {
				t2 = ruMakeTimer();
				a_vars  = ruAssertion2Vars(unif.data);
				t2_ = ruTimePassed(t2);
				
				t3 = ruMakeTimer();
				fresher = ruMakeFresherSubst(
					foldSet(a_vars, [], \ac, v -> 
						if (ruSubstMapsVar(unif.sub, v.id)) ac else concat(ac, [v])
					), 
					prover_env.fns.fresher
				);
				t3_ = ruTimePassed(t3);
				
				
				t4 = ruMakeTimer();
				s_all = ruUnsafeCompose(unif.sub, fresher);
				t4_ = ruTimePassed(t4);
				
				t5 = ruMakeTimer();
				prop = RuProverProp(
					prover_env.fns.idxer(),
					assertion, makeVector(4), 
					ruFilterSub(s_all, \v,__ -> !containsSet(a_vars, v)),
					ruFilterSub(s_all, \v,__ -> containsSet(a_vars, v)),
					makeVector(ruArity(assertion)),
					hyp,
					ref ""
				);
				prover_env.fns.onProp(prop);
				ruAtomicVectorPush(hyp.children)(prop);
				t5_ = ruTimePassed(t5);
				
				t6 = ruMakeTimer();
				ret = setTree(acc, prop.id, prop);
				t6_ = ruTimePassed(t6);
				
				t = ruTimePassed(t2);
				if (ruOptsString(prover_env.env.conf.opts, "reprove-stats", "") == "1") {
					ruAddStats("add_unified", RuStatsRow("adding " + ruSafeExp2s(ruExp(hyp.stmt.exps[0]), prover_env.math.decls.lang) + " for " + id2s(unif.data.info.id), 
						pairs2tree([
							Pair("size", i2d(ruSubstSize(s_all))), 
							Pair("time",  t), 
							Pair("time2", t2_), 
							Pair("time3", t3_),
							Pair("time4", t4_),
							Pair("time5", t5_),
							Pair("time6", t6_),
							Pair("count", 1.0)
						])
					));
				}
				ret
			}
		}
	);
	RuProverEnv(prover_env with 
		tree = RuProverTree(prover_env.tree with 
			leafs = expanded_leafs, 
			nodes = mergeTree(prover_env.tree.nodes, expanded_leafs)
		)
	);
}

ruExpandProp(prop : RuProverProp, prover_env : RuProverEnv) -> RuProverEnv {
	// Stamp the prop with the DSL atom currently expanding it, so coverage
	// can attribute each node to the tactic responsible.  "?" when the active
	// tactic carries no tag (non-DSL use) — still distinct from "" (unexpanded).
	prop.expanded := switch (^(prover_env.tactic)) {
		Some(t): if (t.tag == "") "?" else t.tag;
		None():  "?";
	};
	if (ruArity(prop.assertion) == 0) {
		pushVector(prop.proofs, RuProverProofProp(prop, prop.sub, []));
		RuProverEnv(prover_env with 
			tree = RuProverTree(prover_env.tree with 
				leafs = removeFromTree(prover_env.tree.leafs, prop.id)
			)
		);
	} else {
		foldi(prop.assertion.infer.hyps, prover_env, \i, acc, h -> {
			exs = map(h.stmt.exps, \e -> ruApplySubst(ruApplySubst(ruExp(e), prop.sub), prop.outer));
			if (!prover_env.fns.admitExp(exs[0])) acc else {
				hyp = RuProverExp(i, makeVector(4), RuStmt(h.stmt with exps = exs), makeVector(0), prop);
				pushVector(prop.children, hyp);
				t1 = ruMakeTimer();
				unified = prover_env.fns.unifyPremise(hyp);
				if (ruOptsString(prover_env.env.conf.opts, "reprove-stats", "") == "1") {
					ruAddStats("unify_premise", RuStatsRow("unifying " + ruSafeExp2s(ruExp(hyp.stmt.exps[0]), prover_env.math.decls.lang), 
						pairs2tree([
							Pair("size", i2d(length(ruExp(hyp.stmt.exps[0]).nodes))), 
							Pair("time", ruTimePassed(t1)), 
							Pair("rets", i2d(length(unified)))
						])
					));
				}
				top_proofs = makeVector(length(unified));
				iter(unified, \unif -> {
					all_exps = mapi(exs, \j, ex_j -> if (j == 0) unif.expr else ruApplySubst(ex_j, unif.sub));
					hypProof = RuProverProofTop(hyp, RuStmt(h.stmt with exps = all_exps), unif.data, unif.sub);
					pushVector(top_proofs, hypProof);
					ruAddProof(prop, hypProof, acc);
				});
				appendVector(hyp.proofs, top_proofs);
				// Forward-closure splice: any leaf that unifies with a fact in the
				// shallow forward closure can be closed here, without further
				// backward expansion, by splicing the cached witness.
				//
				// Skip depth-0 matches: those are literal premise hits, already
				// covered by unifyPremise above. Adding both would double-count
				// in the proof cartesian product (ruAddProof) and burn time.
				//
				// Cap the number of splices per leaf so the per-prop cartesian
				// product in ruAddProof stays bounded. Each splice creates one
				// more proof for the leaf; with many splices and many siblings,
				// the cartprod size explodes quickly.
				fwd_unified_all = filter(prover_env.fns.unifyClosure(hyp), \u -> {
					switch (u.data.witness) {
						RuFwPremise(__):           false;
						RuFwApply(__,__,__,__):    true;
					}
				});
				// Prefer shallowest splices first: they produce the smallest proof
				// subtrees, keeping ruAddProof's cartesian product manageable. The
				// cap then trims the long tail without dropping the best candidates.
				fwd_sorted = sortCustom(fwd_unified_all, \u -> u.data.depth, true);
				fwd_cap = 4;
				fwd_unified = if (length(fwd_sorted) > fwd_cap) take(fwd_sorted, fwd_cap) else fwd_sorted;
				if (fwd_unified != []) {
					fwd_proofs = makeVector(length(fwd_unified));
					iter(fwd_unified, \unif -> {
						all_exps = mapi(exs, \j, ex_j -> if (j == 0) unif.expr else ruApplySubst(ex_j, unif.sub));
						closing_stmt = RuStmt(h.stmt with exps = all_exps);
						spliced = ruSpliceForwardWitness(unif.data.witness, closing_stmt, unif.sub, prover_env.math);
						fwdProof = RuProverProofForward(hyp, closing_stmt, unif.sub, spliced);
						pushVector(fwd_proofs, fwdProof);
						ruAddProof(prop, fwdProof, acc);
					});
					appendVector(hyp.proofs, fwd_proofs);
				}
				t2 = ruMakeTimer();
				ret = ruExpandHyp(hyp, acc);
				if (ruOptsString(prover_env.env.conf.opts, "reprove-stats", "") == "1") {
					ruAddStats("ruExpandHyp", RuStatsRow("expanding " + ruSafeExp2s(ruExp(hyp.stmt.exps[0]), prover_env.math.decls.lang), 
						pairs2tree([
							Pair("time", ruTimePassed(t2)), 
							Pair("count", 1.0)
						])
					));
				}
				ret
			}
		});
	}
}
