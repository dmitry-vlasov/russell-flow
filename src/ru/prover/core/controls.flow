import ru/prover/core/tree;

export {

	// Result of one tactic step. The tactic tells the engine:
	//   RuTacticExpand(leafs) — expand these leafs, then call step again
	//   RuTacticSwitch(next)  — I'm done; replace me with `next` and call its step
	//   RuTacticDone()        — I'm done; terminate the search
	RuProverTacticStep ::= RuTacticExpand, RuTacticSwitch, RuTacticDone;
	RuTacticExpand(leafs : [RuProverProp]);
	RuTacticSwitch(next : RuProverTactic);
	RuTacticDone();

	// A prover tactic is a step generator: given the current tree it decides
	// what to expand next, when to switch to a different tactic, or when to
	// stop. Tactics may carry internal state in their closure (refs); that
	// state survives across calls as long as the same RuProverTactic value is
	// reused.  Combinators (sequence, loop-while-progress) compose tactics by
	// returning RuTacticSwitch with a freshly built successor.
	//
	// `keep_expanding` is a stateless tree predicate the engine calls per-prop
	// during parallel batch expansion to short-circuit when budget is exceeded
	// (e.g. tree.size > max_size in bounded BFS) — without it a batch must
	// fully expand before the next `step` call can detect the limit and exit.
	// Default is "proof not yet found"; tactics with explicit size/depth caps
	// should override it.
	RuProverTactic(
		description : string,
		step : (RuProverTree) -> RuProverTacticStep,
		keep_expanding : (RuProverTree) -> bool
	);

	// A tactic that immediately terminates.  Useful as a sentinel.
	ruDoneTactic : RuProverTactic;

	// Stateless tree-state checks used as default keep_expanding predicates.
	ruTreeNotProved(tree : RuProverTree) -> bool;
}

ruTreeNotProved(tree : RuProverTree) -> bool {
	length(^(tree.proofs)) == 0
}

ruDoneTactic = RuProverTactic("done", \__ -> RuTacticDone(), \__ -> false);
