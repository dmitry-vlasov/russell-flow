import ru/prover/core/env;
import ru/prover/core/strategies/subproof_replay;
import ru/prover/core/strategies/fragment_replay;
import ru/prover/core/strategies/combined;
import ru/prover/core/tactics/breadth_first;
import ru/prover/core/tactics/combinators;
import ru/prover/core/tactics/follow_proof;
import ru/prover/core/tactics/linear_guided;
import ru/prover/ml/premise_selector;
import ru/unify/index;
import ru/verify/math;
import ru/proof_tree;

export {
	// Context passed to atomic-tactic builders that need access to the math
	// model, environment, or pre-built indices.  Atoms that don't need a
	// particular field can ignore it; atoms that need a missing field
	// produce an error at build time.
	RuTacticContext(
		math       : RuMath,
		env        : RuEnv,
		step_index : Maybe<RuIndex<Pair<int,int>>>,
		frag_pair  : Maybe<Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>>,
		selector   : Maybe<RuMlSelector>
	);

	// The DSL produces a "tactic builder": a closure invoked once the
	// prover env exists, returning the actual tactic.  Most atoms ignore
	// the env (use ruStaticTacticBuilder), but ones like linear-guided
	// need penv.fns / penv.fragmentTrees populated by ruInitProverEnv.
	//
	// Engine flow: build env with a placeholder tactic, then immediately
	// call builder.build(penv) and store the result in penv.tactic.
	RuTacticBuilder(build : (RuProverEnv) -> RuProverTactic);
	ruStaticTacticBuilder(t : RuProverTactic) -> RuTacticBuilder;

	// Parsed AST node.  A tactic expression is a function call: a name and
	// a list of arguments.  Arguments are either positional or named.
	// Values are either nested ASTs (sub-tactics) or string literals (which
	// the atom-specific builder interprets as int/duration/etc).
	RuTacticAst(name : string, args : [RuTacticArg]);
	RuTacticArg ::= RuTacticArgPos, RuTacticArgNamed;
	RuTacticArgPos(value : RuTacticVal);
	RuTacticArgNamed(name : string, value : RuTacticVal);
	RuTacticVal ::= RuTacticValAst, RuTacticValLit;
	RuTacticValAst(ast : RuTacticAst);
	RuTacticValLit(s : string);

	// Parse a DSL expression.  On success returns Some(ast); on syntax
	// error returns None and prints a diagnostic to env.out.
	ruParseTacticDsl(src : string, env : RuEnv) -> Maybe<RuTacticAst>;

	// Build a tactic builder from an AST.  On unknown atoms or bad args
	// returns None and prints a diagnostic.
	ruBuildTacticFromAst(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder>;

	// Parse + build in one call.
	ruParseAndBuildTactic(src : string, ctx : RuTacticContext) -> Maybe<RuTacticBuilder>;
}

ruStaticTacticBuilder(t : RuProverTactic) -> RuTacticBuilder { RuTacticBuilder(\__ -> t) }

// ---------------- parser state ----------------

RuDslState(
	src : string,
	pos : ref int,
	err : ref Maybe<Pair<int, string>>  // (position, message) of first error
);

ruDslFail(st : RuDslState, msg : string) -> void {
	if (^(st.err) == None()) {
		st.err := Some(Pair(^(st.pos), msg))
	}
}

ruDslPeek(st : RuDslState) -> int {
	if (^(st.pos) >= strlen(st.src)) -1
	else getCharCodeAt(st.src, ^(st.pos))
}

ruDslAdvance(st : RuDslState) -> void {
	st.pos := ^(st.pos) + 1
}

ruDslSkipWs(st : RuDslState) -> void {
	c = ruDslPeek(st);
	if (c == 32 || c == 9 || c == 10 || c == 13) {
		ruDslAdvance(st);
		ruDslSkipWs(st);
	}
}

ruDslIsLetter(c : int) -> bool {
	(c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
}
ruDslIsDigit(c : int) -> bool {
	c >= 48 && c <= 57
}
ruDslIsIdentCont(c : int) -> bool {
	ruDslIsLetter(c) || ruDslIsDigit(c) || c == 45  // '-' allowed inside ident
}

// Read an identifier starting with a letter.  Returns "" on no match.
ruDslReadIdent(st : RuDslState) -> string {
	c = ruDslPeek(st);
	if (!ruDslIsLetter(c)) ""
	else {
		start = ^(st.pos);
		ruDslReadIdentCont(st);
		substring(st.src, start, ^(st.pos) - start)
	}
}

ruDslReadIdentCont(st : RuDslState) -> void {
	c = ruDslPeek(st);
	if (c >= 0 && ruDslIsIdentCont(c)) {
		ruDslAdvance(st);
		ruDslReadIdentCont(st);
	}
}

// Read a numeric literal (digits, optionally followed by a duration suffix
// like 's', 'ms', 'm', 'h').  Returns "" on no match.
ruDslReadLiteral(st : RuDslState) -> string {
	c = ruDslPeek(st);
	if (!ruDslIsDigit(c)) ""
	else {
		start = ^(st.pos);
		ruDslReadDigits(st);
		c2 = ruDslPeek(st);
		if (c2 == 115 || c2 == 109 || c2 == 104) {
			if (c2 == 109) {
				ruDslAdvance(st);
				c3 = ruDslPeek(st);
				if (c3 == 115) ruDslAdvance(st);
			} else {
				ruDslAdvance(st);
			}
		}
		substring(st.src, start, ^(st.pos) - start)
	}
}

ruDslReadDigits(st : RuDslState) -> void {
	c = ruDslPeek(st);
	if (c >= 0 && ruDslIsDigit(c)) {
		ruDslAdvance(st);
		ruDslReadDigits(st);
	}
}

// ---------------- grammar ----------------

// expr := IDENT ( '(' arglist ')' )?
ruDslParseExpr(st : RuDslState) -> Maybe<RuTacticAst> {
	ruDslSkipWs(st);
	name = ruDslReadIdent(st);
	if (name == "") {
		ruDslFail(st, "expected tactic name");
		None()
	} else {
		ruDslSkipWs(st);
		if (ruDslPeek(st) == 40) {
			ruDslAdvance(st);
			args = ruDslParseArgList(st);
			ruDslSkipWs(st);
			if (ruDslPeek(st) == 41) {
				ruDslAdvance(st);
				Some(RuTacticAst(name, args))
			} else {
				ruDslFail(st, "expected ')'");
				None()
			}
		} else {
			Some(RuTacticAst(name, []))
		}
	}
}

ruDslParseArgList(st : RuDslState) -> [RuTacticArg] {
	ruDslSkipWs(st);
	if (ruDslPeek(st) == 41 || ruDslPeek(st) == -1) []
	else {
		arg = ruDslParseArg(st);
		ruDslSkipWs(st);
		if (ruDslPeek(st) == 44) {
			ruDslAdvance(st);
			rest = ruDslParseArgList(st);
			switch (arg) {
				Some(a): concat([a], rest);
				None(): rest;
			}
		} else {
			switch (arg) {
				Some(a): [a];
				None(): [];
			}
		}
	}
}

ruDslParseArg(st : RuDslState) -> Maybe<RuTacticArg> {
	ruDslSkipWs(st);
	saved = ^(st.pos);
	c = ruDslPeek(st);
	if (ruDslIsLetter(c)) {
		name = ruDslReadIdent(st);
		ruDslSkipWs(st);
		if (ruDslPeek(st) == 61) {
			ruDslAdvance(st);
			switch (ruDslParseValue(st)) {
				Some(v): Some(RuTacticArgNamed(name, v));
				None(): None();
			}
		} else {
			st.pos := saved;
			switch (ruDslParseValue(st)) {
				Some(v): Some(RuTacticArgPos(v));
				None(): None();
			}
		}
	} else {
		switch (ruDslParseValue(st)) {
			Some(v): Some(RuTacticArgPos(v));
			None(): None();
		}
	}
}

ruDslParseValue(st : RuDslState) -> Maybe<RuTacticVal> {
	ruDslSkipWs(st);
	c = ruDslPeek(st);
	if (ruDslIsDigit(c)) {
		lit = ruDslReadLiteral(st);
		if (lit == "") { ruDslFail(st, "bad literal"); None() }
		else Some(RuTacticValLit(lit))
	} else if (ruDslIsLetter(c)) {
		switch (ruDslParseExpr(st)) {
			Some(ast): Some(RuTacticValAst(ast));
			None(): None();
		}
	} else {
		ruDslFail(st, "expected value");
		None()
	}
}

ruParseTacticDsl(src : string, env : RuEnv) -> Maybe<RuTacticAst> {
	trimmed = if (strlen(src) >= 2 && getCharCodeAt(src, 0) == 34 && getCharCodeAt(src, strlen(src) - 1) == 34)
		substring(src, 1, strlen(src) - 2)
	else src;
	st = RuDslState(trimmed, ref 0, ref None());
	result = ruDslParseExpr(st);
	ruDslSkipWs(st);
	if (ruDslPeek(st) != -1 && ^(st.err) == None()) {
		ruDslFail(st, "unexpected trailing input");
	}
	switch (^(st.err)) {
		Some(perr): {
			env.out.println("tactic DSL parse error at position " + i2s(perr.first) + ": " + perr.second +
				"\n  source: " + src +
				"\n          " + strRepeat(" ", perr.first) + "^");
			None()
		}
		None(): result;
	}
}

// ---------------- builder ----------------

ruDslPositional(ast : RuTacticAst) -> [RuTacticVal] {
	filtermap(ast.args, \arg ->
		switch (arg) {
			RuTacticArgPos(v): Some(v);
			RuTacticArgNamed(__, __): None();
		}
	)
}

ruDslGetArg(ast : RuTacticAst, name : string, pos_idx : int) -> Maybe<RuTacticVal> {
	named = filtermap(ast.args, \arg ->
		switch (arg) {
			RuTacticArgNamed(n, v): if (n == name) Some(v) else None();
			RuTacticArgPos(__): None();
		}
	);
	if (named != []) Some(named[0])
	else {
		poss = ruDslPositional(ast);
		if (pos_idx < length(poss)) Some(poss[pos_idx]) else None();
	}
}

ruDslGetInt(ast : RuTacticAst, name : string, pos_idx : int, dflt : int) -> int {
	switch (ruDslGetArg(ast, name, pos_idx)) {
		Some(v): switch (v) {
			RuTacticValLit(s): s2i(s);
			RuTacticValAst(__): dflt;
		}
		None(): dflt;
	}
}

ruDslGetString(ast : RuTacticAst, name : string, pos_idx : int, dflt : string) -> string {
	switch (ruDslGetArg(ast, name, pos_idx)) {
		Some(v): switch (v) {
			RuTacticValAst(sub): sub.name;  // bare ident becomes a 0-arg ast — use its name as string
			RuTacticValLit(s): s;
		}
		None(): dflt;
	}
}

ruDslGetDuration(ast : RuTacticAst, name : string, pos_idx : int, dflt_ms : double) -> double {
	switch (ruDslGetArg(ast, name, pos_idx)) {
		Some(v): switch (v) {
			RuTacticValLit(s): ruParseTime(s);
			RuTacticValAst(__): dflt_ms;
		}
		None(): dflt_ms;
	}
}

ruDslGetTacticBuilder(ast : RuTacticAst, pos_idx : int, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	poss = ruDslPositional(ast);
	if (pos_idx >= length(poss)) None()
	else switch (poss[pos_idx]) {
		RuTacticValAst(sub): ruBuildTacticFromAst(sub, ctx);
		RuTacticValLit(s): {
			ctx.env.out.println("tactic DSL: expected tactic, got literal: " + s);
			None()
		}
	}
}

ruDslBuildBuilderList(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<[RuTacticBuilder]> {
	poss = ruDslPositional(ast);
	results = map(poss, \v ->
		switch (v) {
			RuTacticValAst(sub): ruBuildTacticFromAst(sub, ctx);
			RuTacticValLit(s): {
				ctx.env.out.println("tactic DSL: expected tactic, got literal: " + s);
				None()
			}
		}
	);
	if (exists(results, isNone)) None()
	else Some(map(results, \r -> switch (r) { Some(b): b; None(): ruStaticTacticBuilder(ruDoneTactic); }))
}

ruBuildTacticFromAst(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	n = ast.name;
	if (n == "bfs")              Some(ruStaticTacticBuilder(ruBreadthFirstTactic))
	else if (n == "done")        Some(ruStaticTacticBuilder(ruDoneTactic))
	else if (n == "giveup")      Some(ruStaticTacticBuilder(ruDoneTactic))
	else if (n == "bounded-bfs") {
		md = ruDslGetInt(ast, "max-depth", 0, 5);
		ms = ruDslGetInt(ast, "max-size",  1, 4096);
		Some(ruStaticTacticBuilder(ruBoundedBFSTactic(md, ms)));
	}
	else if (n == "top-n-bfs") {
		nn = ruDslGetInt(ast, "n",         0, 10);
		md = ruDslGetInt(ast, "max-depth", 1, 5);
		ms = ruDslGetInt(ast, "max-size",  2, 4096);
		Some(ruStaticTacticBuilder(ruTopNBFSTactic(nn, md, ms)));
	}
	else if (n == "unif-quality" || n == "uq") ruDslBuildUnifQuality(ast)
	else if (n == "spr")             ruDslBuildSpr(ast, ctx)
	else if (n == "fragment-replay") ruDslBuildFragReplay(ast, ctx)
	else if (n == "ml")              ruDslBuildMl(ast, ctx)
	else if (n == "linear-guided")   ruDslBuildLinearGuided(ast)
	else if (n == "follow-proof")    ruDslBuildFollowProof(ast, ctx)
	else if (n == "seq")             ruDslBuildSeq(ast, ctx)
	else if (n == "loop")            ruDslBuildLoop(ast, ctx)
	else if (n == "limited")         ruDslBuildLimited(ast, ctx)
	else {
		ctx.env.out.println("tactic DSL: unknown atom '" + ast.name + "'");
		None();
	}
}

ruDslBuildUnifQuality(ast : RuTacticAst) -> Maybe<RuTacticBuilder> {
	n  = ruDslGetInt(ast, "rank",      0, 10);
	md = ruDslGetInt(ast, "max-depth", 1, 2);
	ms = ruDslGetInt(ast, "max-size",  2, 32);
	Some(ruStaticTacticBuilder(ruUnifQualityTactic(n, md, ms)))
}

ruDslBuildSpr(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	switch (ctx.step_index) {
		None(): { ctx.env.out.println("tactic DSL: spr needs step_index in context"); None() }
		Some(idx): {
			attempts = ruDslGetInt(ast, "attempts", 0, 3);
			max_size = ruDslGetInt(ast, "max-size", 1, 4096);
			Some(ruStaticTacticBuilder(ruSubproofReplayTactic(idx, max_size, attempts, ctx.math, ctx.env)));
		}
	}
}

ruDslBuildFragReplay(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	switch (ctx.frag_pair) {
		None(): { ctx.env.out.println("tactic DSL: fragment-replay needs frag_pair in context (set fragment-depth > 0)"); None() }
		Some(fp): {
			max_depth = ruDslGetInt(ast, "max-depth", 0, 5);
			max_size  = ruDslGetInt(ast, "max-size",  1, 4096);
			attempts  = ruDslGetInt(ast, "attempts",  2, 3);
			Some(ruStaticTacticBuilder(ruFragmentReplayStrategy(fp, max_depth, max_size, attempts, ctx.math, ctx.env)));
		}
	}
}

ruDslBuildMl(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	switch (ctx.selector) {
		None(): { ctx.env.out.println("tactic DSL: ml needs an ML selector in context (load-ml=1 or run learn-assertions first)"); None() }
		Some(sel): {
			top_k     = ruDslGetInt(ast, "top-k",     0, 5);
			max_depth = ruDslGetInt(ast, "max-depth", 1, 7);
			max_size  = ruDslGetInt(ast, "max-size",  2, 10000);
			Some(ruStaticTacticBuilder(ruMlTactic(sel, top_k, max_depth, max_size)));
		}
	}
}

ruDslBuildLinearGuided(ast : RuTacticAst) -> Maybe<RuTacticBuilder> {
	md = ruDslGetInt(ast, "max-depth", 0, 5);
	ms = ruDslGetInt(ast, "max-size",  1, 4096);
	// Deferred: needs the fully-built env for matchesPremise and fragmentTrees.
	Some(RuTacticBuilder(\penv -> ruLinearGuidedTactic(md, ms, penv)))
}

ruDslBuildFollowProof(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	// follow-proof(theorem-name) — looks up the named theorem and follows its
	// QED step's sub-proof.  Useful for diagnostics ("can the engine replay
	// X's existing proof?") rather than for routine proving.
	switch (ruDslGetArg(ast, "theorem", 0)) {
		None(): { ctx.env.out.println("tactic DSL: follow-proof needs a theorem name"); None() }
		Some(v): {
			name = switch (v) {
				RuTacticValAst(sub): sub.name;
				RuTacticValLit(s): s;
			};
			th_id = s2id_(name);
			switch (lookupTree(ctx.math.decls.assertions, th_id)) {
				None(): { ctx.env.out.println("tactic DSL: follow-proof: theorem '" + name + "' not found"); None() }
				Some(ass): switch (ass) {
					RuTheorem(__,__,__,__): {
						proof_step = ruTheoremProofTree(ass, ctx.math);
						Some(ruStaticTacticBuilder(ruFollowProofTactic(proof_step)));
					}
					default: { ctx.env.out.println("tactic DSL: follow-proof: '" + name + "' is not a theorem"); None() }
				}
			}
		}
	}
}

ruDslBuildSeq(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	switch (ruDslBuildBuilderList(ast, ctx)) {
		None(): None();
		Some(builders): Some(RuTacticBuilder(\penv -> ruSequenceTactic(map(builders, \b -> b.build(penv)))));
	}
}

ruDslBuildLoop(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	max_iters = ruDslGetInt(ast, "max-iters", 1, 3);
	poss = ruDslPositional(ast);
	if (poss == []) {
		ctx.env.out.println("tactic DSL: loop requires a body tactic");
		None()
	} else switch (poss[0]) {
		RuTacticValAst(body_ast): {
			Some(RuTacticBuilder(\penv -> {
				// Fresh body each iteration so state-carrying tactics reset.
				body_builder = \ -> switch (ruBuildTacticFromAst(body_ast, ctx)) {
					Some(b): b.build(penv);
					None():  ruDoneTactic;
				};
				ruLoopWhileProgressTactic(body_builder, max_iters)
			}));
		}
		RuTacticValLit(s): {
			ctx.env.out.println("tactic DSL: loop body must be a tactic, got literal: " + s);
			None()
		}
	}
}

ruDslBuildLimited(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	switch (ruDslGetTacticBuilder(ast, 0, ctx)) {
		None(): None();
		Some(inner_builder): {
			time_ms  = ruDslGetDuration(ast, "time",     1, 0.0);
			applied  = ruDslGetInt(ast,      "applied",  2, 0);
			produced = ruDslGetInt(ast,      "produced", 3, 0);
			Some(RuTacticBuilder(\penv -> ruLimitedTactic(inner_builder.build(penv), time_ms, applied, produced)));
		}
	}
}

ruParseAndBuildTactic(src : string, ctx : RuTacticContext) -> Maybe<RuTacticBuilder> {
	switch (ruParseTacticDsl(src, ctx.env)) {
		Some(ast): ruBuildTacticFromAst(ast, ctx);
		None(): None();
	}
}
