import ru/prover/core/strategies/subproof_replay;
import ru/prover/core/strategies/fragment_replay;
import ru/prover/core/strategies/combined;
import ru/prover/core/tactics/breadth_first;
import ru/prover/core/tactics/combinators;
import ru/unify/index;
import ru/verify/math;

export {
	// Context passed to atomic-tactic builders that need access to the math
	// model, environment, or pre-built indices.  Atoms that don't need a
	// particular field can ignore it; atoms that need a missing field
	// produce an error at build time.
	RuTacticContext(
		math       : RuMath,
		env        : RuEnv,
		step_index : Maybe<RuIndex<Pair<int,int>>>,
		frag_pair  : Maybe<Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>>
	);

	// Parsed AST node.  A tactic expression is a function call: a name and
	// a list of arguments.  Arguments are either positional or named.
	// Values are either nested ASTs (sub-tactics) or string literals (which
	// the atom-specific builder interprets as int/duration/etc).
	RuTacticAst(name : string, args : [RuTacticArg]);
	RuTacticArg ::= RuTacticArgPos, RuTacticArgNamed;
	RuTacticArgPos(value : RuTacticVal);
	RuTacticArgNamed(name : string, value : RuTacticVal);
	RuTacticVal ::= RuTacticValAst, RuTacticValLit;
	RuTacticValAst(ast : RuTacticAst);
	RuTacticValLit(s : string);

	// Parse a DSL expression.  On success returns Some(ast); on syntax
	// error returns None and prints a diagnostic to env.out.
	ruParseTacticDsl(src : string, env : RuEnv) -> Maybe<RuTacticAst>;

	// Build a concrete tactic from an AST.  On unknown atoms or bad args
	// returns None and prints a diagnostic.
	ruBuildTacticFromAst(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuProverTactic>;

	// Parse + build in one call.
	ruParseAndBuildTactic(src : string, ctx : RuTacticContext) -> Maybe<RuProverTactic>;
}

// ---------------- parser state ----------------

RuDslState(
	src : string,
	pos : ref int,
	err : ref Maybe<Pair<int, string>>  // (position, message) of first error
);

ruDslFail(st : RuDslState, msg : string) -> void {
	if (^(st.err) == None()) {
		st.err := Some(Pair(^(st.pos), msg))
	}
}

ruDslPeek(st : RuDslState) -> int {
	if (^(st.pos) >= strlen(st.src)) -1
	else getCharCodeAt(st.src, ^(st.pos))
}

ruDslAdvance(st : RuDslState) -> void {
	st.pos := ^(st.pos) + 1
}

ruDslSkipWs(st : RuDslState) -> void {
	c = ruDslPeek(st);
	if (c == 32 || c == 9 || c == 10 || c == 13) {
		ruDslAdvance(st);
		ruDslSkipWs(st);
	}
}

ruDslIsLetter(c : int) -> bool {
	(c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
}
ruDslIsDigit(c : int) -> bool {
	c >= 48 && c <= 57
}
ruDslIsIdentCont(c : int) -> bool {
	ruDslIsLetter(c) || ruDslIsDigit(c) || c == 45  // '-' allowed inside ident
}

// Read an identifier starting with a letter.  Returns "" on no match.
ruDslReadIdent(st : RuDslState) -> string {
	c = ruDslPeek(st);
	if (!ruDslIsLetter(c)) ""
	else {
		start = ^(st.pos);
		ruDslReadIdentCont(st);
		substring(st.src, start, ^(st.pos) - start)
	}
}

ruDslReadIdentCont(st : RuDslState) -> void {
	c = ruDslPeek(st);
	if (c >= 0 && ruDslIsIdentCont(c)) {
		ruDslAdvance(st);
		ruDslReadIdentCont(st);
	}
}

// Read a numeric literal (digits, optionally followed by a duration suffix
// like 's', 'ms', 'm', 'h').  Returns "" on no match.
ruDslReadLiteral(st : RuDslState) -> string {
	c = ruDslPeek(st);
	if (!ruDslIsDigit(c)) ""
	else {
		start = ^(st.pos);
		ruDslReadDigits(st);
		// optional suffix
		c2 = ruDslPeek(st);
		if (c2 == 115 || c2 == 109 || c2 == 104) {
			// 's' (115), 'm' (109) — m may be 'ms'; 'h' (104)
			if (c2 == 109) {
				ruDslAdvance(st);
				c3 = ruDslPeek(st);
				if (c3 == 115) ruDslAdvance(st);
			} else {
				ruDslAdvance(st);
			}
		}
		substring(st.src, start, ^(st.pos) - start)
	}
}

ruDslReadDigits(st : RuDslState) -> void {
	c = ruDslPeek(st);
	if (c >= 0 && ruDslIsDigit(c)) {
		ruDslAdvance(st);
		ruDslReadDigits(st);
	}
}

// ---------------- grammar ----------------

// expr := IDENT ( '(' arglist ')' )?
ruDslParseExpr(st : RuDslState) -> Maybe<RuTacticAst> {
	ruDslSkipWs(st);
	name = ruDslReadIdent(st);
	if (name == "") {
		ruDslFail(st, "expected tactic name");
		None()
	} else {
		ruDslSkipWs(st);
		if (ruDslPeek(st) == 40) {  // '('
			ruDslAdvance(st);
			args = ruDslParseArgList(st);
			ruDslSkipWs(st);
			if (ruDslPeek(st) == 41) {  // ')'
				ruDslAdvance(st);
				Some(RuTacticAst(name, args))
			} else {
				ruDslFail(st, "expected ')'");
				None()
			}
		} else {
			Some(RuTacticAst(name, []))
		}
	}
}

ruDslParseArgList(st : RuDslState) -> [RuTacticArg] {
	ruDslSkipWs(st);
	if (ruDslPeek(st) == 41 || ruDslPeek(st) == -1) []  // ')' or EOF
	else {
		arg = ruDslParseArg(st);
		ruDslSkipWs(st);
		if (ruDslPeek(st) == 44) {  // ','
			ruDslAdvance(st);
			rest = ruDslParseArgList(st);
			switch (arg) {
				Some(a): concat([a], rest);
				None(): rest;
			}
		} else {
			switch (arg) {
				Some(a): [a];
				None(): [];
			}
		}
	}
}

// arg := IDENT '=' value | value
ruDslParseArg(st : RuDslState) -> Maybe<RuTacticArg> {
	ruDslSkipWs(st);
	saved = ^(st.pos);
	// Tentatively read an identifier; if followed by '=' it's a named arg,
	// otherwise rewind and parse as a value (which may be a nested call).
	c = ruDslPeek(st);
	if (ruDslIsLetter(c)) {
		name = ruDslReadIdent(st);
		after_ident = ^(st.pos);
		ruDslSkipWs(st);
		if (ruDslPeek(st) == 61) {  // '='
			ruDslAdvance(st);
			switch (ruDslParseValue(st)) {
				Some(v): Some(RuTacticArgNamed(name, v));
				None(): None();
			}
		} else {
			// Not a named arg — back up and parse as a value (handles bare
			// ident, ident with args, etc).
			st.pos := saved;
			switch (ruDslParseValue(st)) {
				Some(v): Some(RuTacticArgPos(v));
				None(): None();
			}
		}
	} else {
		switch (ruDslParseValue(st)) {
			Some(v): Some(RuTacticArgPos(v));
			None(): None();
		}
	}
}

// value := numeric-literal | expr
ruDslParseValue(st : RuDslState) -> Maybe<RuTacticVal> {
	ruDslSkipWs(st);
	c = ruDslPeek(st);
	if (ruDslIsDigit(c)) {
		lit = ruDslReadLiteral(st);
		if (lit == "") { ruDslFail(st, "bad literal"); None() }
		else Some(RuTacticValLit(lit))
	} else if (ruDslIsLetter(c)) {
		switch (ruDslParseExpr(st)) {
			Some(ast): Some(RuTacticValAst(ast));
			None(): None();
		}
	} else {
		ruDslFail(st, "expected value");
		None()
	}
}

ruParseTacticDsl(src : string, env : RuEnv) -> Maybe<RuTacticAst> {
	// Strip optional surrounding quotes carried in from the script DSL.
	trimmed = if (strlen(src) >= 2 && getCharCodeAt(src, 0) == 34 && getCharCodeAt(src, strlen(src) - 1) == 34)
		substring(src, 1, strlen(src) - 2)
	else src;
	st = RuDslState(trimmed, ref 0, ref None());
	result = ruDslParseExpr(st);
	ruDslSkipWs(st);
	if (ruDslPeek(st) != -1 && ^(st.err) == None()) {
		ruDslFail(st, "unexpected trailing input");
	}
	switch (^(st.err)) {
		Some(perr): {
			env.out.println("tactic DSL parse error at position " + i2s(perr.first) + ": " + perr.second +
				"\n  source: " + src +
				"\n          " + strRepeat(" ", perr.first) + "^");
			None()
		}
		None(): result;
	}
}

// ---------------- builder ----------------

// Extract positional args (preserving order).
ruDslPositional(ast : RuTacticAst) -> [RuTacticVal] {
	filtermap(ast.args, \arg ->
		switch (arg) {
			RuTacticArgPos(v): Some(v);
			RuTacticArgNamed(__, __): None();
		}
	)
}

// Look up a named arg, falling back to positional by index.
ruDslGetArg(ast : RuTacticAst, name : string, pos_idx : int) -> Maybe<RuTacticVal> {
	named = filtermap(ast.args, \arg ->
		switch (arg) {
			RuTacticArgNamed(n, v): if (n == name) Some(v) else None();
			RuTacticArgPos(__): None();
		}
	);
	if (named != []) Some(named[0])
	else {
		poss = ruDslPositional(ast);
		if (pos_idx < length(poss)) Some(poss[pos_idx]) else None();
	}
}

ruDslGetInt(ast : RuTacticAst, name : string, pos_idx : int, dflt : int) -> int {
	switch (ruDslGetArg(ast, name, pos_idx)) {
		Some(v): switch (v) {
			RuTacticValLit(s): s2i(s);
			RuTacticValAst(__): dflt;
		}
		None(): dflt;
	}
}

ruDslGetDuration(ast : RuTacticAst, name : string, pos_idx : int, dflt_ms : double) -> double {
	switch (ruDslGetArg(ast, name, pos_idx)) {
		Some(v): switch (v) {
			RuTacticValLit(s): ruParseTime(s);
			RuTacticValAst(__): dflt_ms;
		}
		None(): dflt_ms;
	}
}

ruDslGetTactic(ast : RuTacticAst, pos_idx : int, ctx : RuTacticContext) -> Maybe<RuProverTactic> {
	poss = ruDslPositional(ast);
	if (pos_idx >= length(poss)) None()
	else switch (poss[pos_idx]) {
		RuTacticValAst(sub): ruBuildTacticFromAst(sub, ctx);
		RuTacticValLit(s): {
			ctx.env.out.println("tactic DSL: expected tactic, got literal: " + s);
			None()
		}
	}
}

// Build a list of tactics from positional args.  Returns None if any
// child fails to build (already reported its own error).
ruDslBuildTacticList(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<[RuProverTactic]> {
	poss = ruDslPositional(ast);
	results = map(poss, \v ->
		switch (v) {
			RuTacticValAst(sub): ruBuildTacticFromAst(sub, ctx);
			RuTacticValLit(s): {
				ctx.env.out.println("tactic DSL: expected tactic, got literal: " + s);
				None()
			}
		}
	);
	if (exists(results, isNone)) None()
	else Some(map(results, \r -> switch (r) { Some(t): t; None(): ruDoneTactic; }))
}

ruBuildTacticFromAst(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuProverTactic> {
	n = ast.name;
	if (n == "bfs")              Some(ruBreadthFirstTactic)
	else if (n == "done")        Some(ruDoneTactic)
	else if (n == "giveup")      Some(ruDoneTactic)
	else if (n == "bounded-bfs") {
		md = ruDslGetInt(ast, "max-depth", 0, 5);
		ms = ruDslGetInt(ast, "max-size",  1, 4096);
		Some(ruBoundedBFSTactic(md, ms));
	}
	else if (n == "top-n-bfs") {
		nn = ruDslGetInt(ast, "n",         0, 10);
		md = ruDslGetInt(ast, "max-depth", 1, 5);
		ms = ruDslGetInt(ast, "max-size",  2, 4096);
		Some(ruTopNBFSTactic(nn, md, ms));
	}
	else if (n == "unif-quality" || n == "uq") ruDslBuildUnifQuality(ast)
	else if (n == "spr")     ruDslBuildSpr(ast, ctx)
	else if (n == "seq")     ruDslBuildSeq(ast, ctx)
	else if (n == "loop")    ruDslBuildLoop(ast, ctx)
	else if (n == "limited") ruDslBuildLimited(ast, ctx)
	else {
		ctx.env.out.println("tactic DSL: unknown atom '" + ast.name + "'");
		None();
	}
}

ruDslBuildUnifQuality(ast : RuTacticAst) -> Maybe<RuProverTactic> {
	n  = ruDslGetInt(ast, "rank",      0, 10);
	md = ruDslGetInt(ast, "max-depth", 1, 2);
	ms = ruDslGetInt(ast, "max-size",  2, 32);
	Some(ruUnifQualityTactic(n, md, ms))
}

ruDslBuildSpr(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuProverTactic> {
	switch (ctx.step_index) {
		None(): { ctx.env.out.println("tactic DSL: spr needs step_index in context"); None() }
		Some(idx): {
			attempts = ruDslGetInt(ast, "attempts", 0, 3);
			max_size = ruDslGetInt(ast, "max-size", 1, 4096);
			Some(ruSubproofReplayTactic(idx, max_size, attempts, ctx.math, ctx.env));
		}
	}
}

ruDslBuildSeq(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuProverTactic> {
	switch (ruDslBuildTacticList(ast, ctx)) {
		None(): None();
		Some(ts): Some(ruSequenceTactic(ts));
	}
}

ruDslBuildLoop(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuProverTactic> {
	// loop takes one positional tactic (the body) and an optional
	// max-iters argument.  The body is rebuilt fresh on each iteration so
	// state-carrying tactics (e.g. SPR) start over.
	max_iters = ruDslGetInt(ast, "max-iters", 1, 3);
	poss = ruDslPositional(ast);
	if (poss == []) {
		ctx.env.out.println("tactic DSL: loop requires a body tactic");
		None()
	} else switch (poss[0]) {
		RuTacticValAst(body_ast): {
			builder = \ -> switch (ruBuildTacticFromAst(body_ast, ctx)) {
				Some(t): t;
				None():  ruDoneTactic;
			};
			Some(ruLoopWhileProgressTactic(builder, max_iters));
		}
		RuTacticValLit(s): {
			ctx.env.out.println("tactic DSL: loop body must be a tactic, got literal: " + s);
			None()
		}
	}
}

ruDslBuildLimited(ast : RuTacticAst, ctx : RuTacticContext) -> Maybe<RuProverTactic> {
	switch (ruDslGetTactic(ast, 0, ctx)) {
		None(): None();
		Some(inner): {
			time_ms  = ruDslGetDuration(ast, "time",     1, 0.0);
			applied  = ruDslGetInt(ast,      "applied",  2, 0);
			produced = ruDslGetInt(ast,      "produced", 3, 0);
			Some(ruLimitedTactic(inner, time_ms, applied, produced));
		}
	}
}

ruParseAndBuildTactic(src : string, ctx : RuTacticContext) -> Maybe<RuProverTactic> {
	switch (ruParseTacticDsl(src, ctx.env)) {
		Some(ast): ruBuildTacticFromAst(ast, ctx);
		None(): None();
	}
}
