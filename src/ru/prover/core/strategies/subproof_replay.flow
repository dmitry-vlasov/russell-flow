import ru/prover/core/env;
import ru/prover/core/tactics/follow_proof;
import ru/prover/core/tactics/combinators;
import ru/unify/index;
import ru/proof_tree;

export {
	// Build an index of every proof step across all theorems, keyed by the
	// step's conclusion expression.  Steps whose conclusion has fewer than
	// min_rule_nodes rule nodes are omitted to avoid bare-variable explosion.
	ruBuildStepIndex(math : RuMath, min_rule_nodes : int) -> RuIndex<Pair<int,int>>;

	// Set of assertion IDs that appear in any indexed proof step.
	ruBuildIndexedAssertionSet(math : RuMath, min_rule_nodes : int) -> Set<int>;

	// Subproof-replay tactic: scans open leaves deepest-first, looking for one
	// whose goal expression has a matching proof step in the corpus.  When a
	// match is found, queues up the matched fragments and replays each via
	// bounded follow-proof.  Returns Done once `attempts` leaves have been
	// tried without yielding further fragments.
	ruSubproofReplayTactic(
		step_index : RuIndex<Pair<int,int>>,
		max_size   : int,
		attempts   : int,
		math       : RuMath,
		env        : RuEnv
	) -> RuProverTactic;

	// Depth of a prop in the proof tree (root = 1, increasing inward).
	ruSprPropDepth(prop : RuProverProp) -> int;
}

ruSprRuleNodeCount(e : RuExp) -> int {
	fold(e.nodes, 0, \acc, n -> switch (n) {
		RuRuleNode(__,__): acc + 1;
		RuVar(__,__):      acc;
	})
}

ruBuildIndexedAssertionSet(math : RuMath, min_rule_nodes : int) -> Set<int> {
	s : ref Set<int> = ref makeSet();
	traverseInOrder(math.decls.assertions, \__, ass ->
		switch (ass) {
			RuTheorem(__,__,__,__): {
				iter(ass.proof.steps, \step -> {
					e = ruExp(step.stmt.exps[0]);
					if (ruSprRuleNodeCount(e) >= min_rule_nodes)
						s := insertSet(^s, step.assertion)
				})
			}
			default: { }
		}
	);
	^s
}

ruBuildStepIndex(math : RuMath, min_rule_nodes : int) -> RuIndex<Pair<int,int>> {
	index : ref RuIndex<Pair<int,int>> = ref ruMakeIndex();
	traverseInOrder(math.decls.assertions, \__, ass ->
		switch (ass) {
			RuTheorem(__,__,__,__): {
				iteri(ass.proof.steps, \i, step -> {
					e = ruExp(step.stmt.exps[0]);
					if (ruSprRuleNodeCount(e) >= min_rule_nodes)
						index := ruSetIndex(e, Pair(ass.info.id, i), ^index)
				})
			}
			default: { }
		}
	);
	^index
}

ruSprPropDepth(prop : RuProverProp) -> int {
	switch (prop.parent) {
		RuProverRoot(__,__,__): 1;
		RuProverExp(__,__,__,__,grand): 1 + ruSprPropDepth(grand);
	}
}

ruStepsForLeaf(
	prop       : RuProverProp,
	step_index : RuIndex<Pair<int,int>>,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv
) -> [RuProofStep] {
	leaf_exp   = ruExp(prop.parent.stmt.exps[0]);
	leaf_len   = length(leaf_exp.nodes);
	// Skip leaves that are too generic (few rule nodes) or too complex (huge
	// match sets on large indices).
	leaf_rules = ruSprRuleNodeCount(leaf_exp);
	if (leaf_rules < 3 || leaf_rules > 12) [] else {
		matched = ruUnifyIndex(leaf_exp, step_index, ruEmptySubst, math, env);
		// "Shallow substitution" criterion: pattern explains at least as much
		// structure as the unifier introduces.
		candidates = filter(matched, \unif -> {
			subst_len = foldHashMap(unif.sub.map, 0, \__, se, acc -> acc + length(se.exp.nodes));
			leaf_len >= subst_len
		});
		filtermap(take(candidates, attempts), \unif ->
			switch (lookupTree(math.decls.assertions, unif.data.first)) {
				Some(ass): switch (ass) {
					RuTheorem(__,__,__,__): {
						i = unif.data.second;
						switch (ruSubproofTree(ass, i)) {
							RuProofStep(assertion, children, stmt): Some(RuProofStep(assertion, children, stmt));
							RuProofHyp(__,__): None()
						}
					}
					default: None()
				}
				None(): None()
			}
		)
	}
}

// SPR as a driver function fed to ruIterateTactic.  On each invocation,
// either pops a pending fragment to replay or scans for a new corpus match.
ruSubproofReplayTactic(
	step_index : RuIndex<Pair<int,int>>,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProverTactic {
	// SPR uses at most half the node budget so a following BFS phase always
	// has room to run.
	spr_max_size = max_size / 2;
	pending_steps      : ref [RuProofStep] = ref [];
	attempts_remaining : ref int           = ref attempts;

	driver = \tree -> {
		if (length(^(tree.proofs)) > 0) None()
		else if (length(^pending_steps) > 0) {
			s = (^pending_steps)[0];
			pending_steps := tail(^pending_steps);
			Some(ruBoundedFollowProofTactic(s, spr_max_size))
		} else if (^attempts_remaining <= 0) None()
		else {
			// Scan leaves deepest-first; skip any that yield no corpus match.
			leaves = sortCustom(getTreeValues(tree.leafs), \leaf -> ruSprPropDepth(leaf), false);
			found : Maybe<RuProofStep> = fold(leaves, None(), \acc, leaf ->
				switch (acc) {
					Some(__): acc;
					None(): if (^attempts_remaining <= 0) acc else {
						attempts_remaining := ^attempts_remaining - 1;
						steps = ruStepsForLeaf(leaf, step_index, attempts, math, env);
						if (steps != []) {
							pending_steps := tail(steps);
							Some(steps[0])
						} else None()
					}
				}
			);
			switch (found) {
				Some(first_step): Some(ruBoundedFollowProofTactic(first_step, spr_max_size));
				None(): { attempts_remaining := 0; None() }
			}
		}
	};

	ruIterateTactic(driver)
}
