import ru/prover/core/env;
import ru/prover/core/tactics/follow_proof;
import ru/prover/core/tactics/breadth_first;
import ru/unify/index;
import ru/proof_tree;

export {
	// Build an index of every proof step across all theorems, keyed by the
	// step's conclusion expression.  Steps whose conclusion has fewer than
	// min_rule_nodes rule nodes are omitted to avoid bare-variable explosion.
	ruBuildStepIndex(math : RuMath, min_rule_nodes : int) -> RuIndex<Pair<int,int>>;

	// Set of assertion IDs that appear in any indexed proof step.
	ruBuildIndexedAssertionSet(math : RuMath, min_rule_nodes : int) -> Set<int>;

	// Subproof-replay tactic: for each open leaf, look up matching proof steps
	// in the step index and replay each matching sub-proof.  Scans leaves
	// deepest-first, skipping leaves with no corpus match, until `attempts`
	// leaves have been tried.  Each replay is bounded by `max_size`.
	ruSubproofReplayTactic(
		step_index : RuIndex<Pair<int,int>>,
		max_size   : int,
		attempts   : int,
		math       : RuMath,
		env        : RuEnv
	) -> RuProverTactic;

	// Sequence combinator: runs tactics in order, advancing to the next when
	// the current one returns RuTacticDone.  When all are done, terminates.
	ruSequenceTactic(tactics : [RuProverTactic]) -> RuProverTactic;

	// Loop-while-progress combinator: runs `builder()` to completion; if the
	// tree grew, builds a fresh inner and runs it again, up to max_iters.
	// Stops on no progress, or when iters are exhausted, or when a proof is found.
	ruLoopWhileProgressTactic(builder : () -> RuProverTactic, max_iters : int) -> RuProverTactic;

	// Three-phase combined tactic with outer loop:
	//   Phase 0 (once): unif-quality BFS — fast beam search by specificity
	//                   (skipped when unif_rank=0)
	//   Loop body:      subproof-replay → bounded BFS
	//   Outer loop:     repeat the body up to max_iters times while progress is made.
	ruCombinedStrategy(
		step_index : RuIndex<Pair<int,int>>,
		unif_rank  : int,
		max_depth  : int,
		max_size   : int,
		attempts   : int,
		max_iters  : int,
		math       : RuMath,
		env        : RuEnv
	) -> RuProverTactic;
}

ruSprRuleNodeCount(e : RuExp) -> int {
	fold(e.nodes, 0, \acc, n -> switch (n) {
		RuRuleNode(__,__): acc + 1;
		RuVar(__,__):      acc;
	})
}

ruBuildIndexedAssertionSet(math : RuMath, min_rule_nodes : int) -> Set<int> {
	s : ref Set<int> = ref makeSet();
	traverseInOrder(math.decls.assertions, \__, ass ->
		switch (ass) {
			RuTheorem(__,__,__,__): {
				iter(ass.proof.steps, \step -> {
					e = ruExp(step.stmt.exps[0]);
					if (ruSprRuleNodeCount(e) >= min_rule_nodes)
						s := insertSet(^s, step.assertion)
				})
			}
			default: { }
		}
	);
	^s
}

ruBuildStepIndex(math : RuMath, min_rule_nodes : int) -> RuIndex<Pair<int,int>> {
	index : ref RuIndex<Pair<int,int>> = ref ruMakeIndex();
	traverseInOrder(math.decls.assertions, \__, ass ->
		switch (ass) {
			RuTheorem(__,__,__,__): {
				iteri(ass.proof.steps, \i, step -> {
					e = ruExp(step.stmt.exps[0]);
					if (ruSprRuleNodeCount(e) >= min_rule_nodes)
						index := ruSetIndex(e, Pair(ass.info.id, i), ^index)
				})
			}
			default: { }
		}
	);
	^index
}

ruSprPropDepth(prop : RuProverProp) -> int {
	switch (prop.parent) {
		RuProverRoot(__,__,__): 1;
		RuProverExp(__,__,__,__,grand): 1 + ruSprPropDepth(grand);
	}
}

ruStepsForLeaf(
	prop       : RuProverProp,
	step_index : RuIndex<Pair<int,int>>,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv
) -> [RuProofStep] {
	leaf_exp   = ruExp(prop.parent.stmt.exps[0]);
	leaf_len   = length(leaf_exp.nodes);
	// Skip leaves that are too generic (few rule nodes) or too complex (huge
	// match sets on large indices).
	leaf_rules = ruSprRuleNodeCount(leaf_exp);
	if (leaf_rules < 3 || leaf_rules > 12) [] else {
		matched = ruUnifyIndex(leaf_exp, step_index, ruEmptySubst, math, env);
		// "Shallow substitution" criterion: pattern explains at least as much
		// structure as the unifier introduces.
		candidates = filter(matched, \unif -> {
			subst_len = foldHashMap(unif.sub.map, 0, \__, se, acc -> acc + length(se.exp.nodes));
			leaf_len >= subst_len
		});
		filtermap(take(candidates, attempts), \unif ->
			switch (lookupTree(math.decls.assertions, unif.data.first)) {
				Some(ass): switch (ass) {
					RuTheorem(__,__,__,__): {
						i = unif.data.second;
						switch (ruSubproofTree(ass, i)) {
							RuProofStep(assertion, children, stmt): Some(RuProofStep(assertion, children, stmt));
							RuProofHyp(__,__): None()
						}
					}
					default: None()
				}
				None(): None()
			}
		)
	}
}

// ---------- Combinators ----------

ruSequenceTactic(tactics : [RuProverTactic]) -> RuProverTactic {
	if (tactics == []) ruDoneTactic
	else RuProverTactic("seq[" + tactics[0].description + "]",
		\tree -> switch (tactics[0].step(tree)) {
			RuTacticExpand(leafs): RuTacticExpand(leafs);
			RuTacticSwitch(next): RuTacticSwitch(ruSequenceTactic(concat([next], tail(tactics))));
			RuTacticDone(): {
				rest = tail(tactics);
				if (rest == []) RuTacticDone()
				else RuTacticSwitch(ruSequenceTactic(rest))
			}
		}
	)
}

ruLoopHelper(
	builder : () -> RuProverTactic,
	current : RuProverTactic,
	iters_left : int,
	prev_size : int
) -> RuProverTactic {
	RuProverTactic("loop[" + i2s(iters_left) + "/" + current.description + "]",
		\tree -> switch (current.step(tree)) {
			RuTacticExpand(leafs): RuTacticExpand(leafs);
			RuTacticSwitch(next): RuTacticSwitch(ruLoopHelper(builder, next, iters_left, prev_size));
			RuTacticDone(): {
				cur_size = sizeTree(tree.nodes);
				if (iters_left > 1 && cur_size > prev_size)
					RuTacticSwitch(ruLoopHelper(builder, builder(), iters_left - 1, cur_size))
				else RuTacticDone()
			}
		}
	)
}

ruLoopWhileProgressTactic(builder : () -> RuProverTactic, max_iters : int) -> RuProverTactic {
	if (max_iters <= 0) ruDoneTactic
	else ruLoopHelper(builder, builder(), max_iters, -1)
}

// ---------- SPR tactic ----------

ruSubproofReplayTactic(
	step_index : RuIndex<Pair<int,int>>,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProverTactic {
	// SPR is allowed at most half the node budget so a following BFS phase
	// always has room to run.  (The remaining budget is enforced by whoever
	// composes the BFS phase after SPR.)
	spr_max_size = max_size / 2;
	pending_steps      : ref [RuProofStep] = ref [];
	attempts_remaining : ref int           = ref attempts;

	RuProverTactic("subproof-replay",
		\tree ->
			if (length(^(tree.proofs)) > 0) RuTacticDone()
			else if (length(^pending_steps) > 0) {
				s = (^pending_steps)[0];
				pending_steps := tail(^pending_steps);
				RuTacticSwitch(ruBoundedFollowProofTactic(s, spr_max_size))
			} else if (^attempts_remaining <= 0) RuTacticDone()
			else {
				// Scan leaves deepest-first; skip any that yield no corpus match.
				leaves = sortCustom(getTreeValues(tree.leafs), \leaf -> ruSprPropDepth(leaf), false);
				found : Maybe<RuProofStep> = fold(leaves, None(), \acc, leaf ->
					switch (acc) {
						Some(__): acc;
						None(): if (^attempts_remaining <= 0) acc else {
							attempts_remaining := ^attempts_remaining - 1;
							steps = ruStepsForLeaf(leaf, step_index, attempts, math, env);
							if (steps != []) {
								pending_steps := tail(steps);
								Some(steps[0])
							} else None()
						}
					}
				);
				switch (found) {
					Some(first_step): RuTacticSwitch(ruBoundedFollowProofTactic(first_step, spr_max_size));
					None(): { attempts_remaining := 0; RuTacticDone() }
				}
			}
	)
}

// ---------- Combined ----------

ruCombinedStrategy(
	step_index : RuIndex<Pair<int,int>>,
	unif_rank  : int,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	max_iters  : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProverTactic {
	body_builder = \ -> ruSequenceTactic([
		ruSubproofReplayTactic(step_index, max_size, attempts, math, env),
		ruBoundedBFSTactic(max_depth, max_size)
	]);
	loop = ruLoopWhileProgressTactic(body_builder, max_iters);
	if (unif_rank > 0)
		// One-shot phase 0: tiny-budget unif-quality pass for theorems provable
		// in 1-2 steps; then the SPR+BFS loop on whatever's left.
		ruSequenceTactic([
			ruUnifQualityTactic(unif_rank, 2, 32),
			loop
		])
	else loop
}
