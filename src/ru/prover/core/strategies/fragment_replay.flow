import ru/prover/core/env;
import ru/prover/core/tactics/breadth_first;
import ru/prover/core/tactics/follow_proof;
import ru/prover/core/strategies/subproof_replay;
import ru/unify/index;

export {
	// Tactic that replays proof fragments from other theorems to guide proof
	// search.  On each step, picks the deepest open leaf, finds fragments
	// whose root expression unifies with that leaf's goal, and tries them via
	// ruFollowProofTactic.  After `attempts` are exhausted, hands off to a
	// bounded BFS via the standard sequence combinator.
	ruFragmentReplayStrategy(
		frag_pair  : Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>,
		max_depth  : int,
		max_size   : int,
		attempts   : int,
		math       : RuMath,
		env        : RuEnv
	) -> RuProverTactic;
}

ruFrsPropDepth(prop : RuProverProp) -> int {
	switch (prop.parent) {
		RuProverRoot(__,__,__): 1;
		RuProverExp(__,__,__,__,grand): 1 + ruFrsPropDepth(grand);
	}
}

ruFrsFragsForLeaf(
	prop      : RuProverProp,
	frag_pair : Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>,
	math      : RuMath,
	env       : RuEnv
) -> [RuProofStep] {
	leaf_exp = ruExp(prop.parent.stmt.exps[0]);
	matched  = ruUnifyIndex(leaf_exp, frag_pair.first, ruEmptySubst, math, env);
	filtermap(matched, \unif ->
		switch (lookupTree(frag_pair.second, unif.data.info.id)) {
			Some(frag): switch (frag.tree) {
				RuProofStep(ass, ch, stmt): Some(RuProofStep(ass, ch, stmt));
				RuProofHyp(__,__): None();
			}
			None(): None();
		}
	)
}

ruFragmentReplayBody(
	frag_pair  : Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProverTactic {
	pending_frags      : ref [RuProofStep] = ref [];
	attempts_remaining : ref int           = ref attempts;

	RuProverTactic("fragment-replay",
		\tree ->
			if (length(^(tree.proofs)) > 0) RuTacticDone()
			else if (length(^pending_frags) > 0) {
				f = (^pending_frags)[0];
				pending_frags := tail(^pending_frags);
				RuTacticSwitch(ruBoundedFollowProofTactic(f, max_size))
			} else if (^attempts_remaining <= 0) RuTacticDone()
			else {
				attempts_remaining := ^attempts_remaining - 1;
				leaves = getTreeValues(tree.leafs);
				deepest = if (leaves == []) None()
					else Some(fold(tail(leaves), leaves[0], \acc, leaf ->
						if (ruFrsPropDepth(leaf) >= ruFrsPropDepth(acc)) leaf else acc
					));
				switch (deepest) {
					None(): RuTacticDone();
					Some(leaf): {
						frags = ruFrsFragsForLeaf(leaf, frag_pair, math, env);
						if (frags == []) RuTacticDone()
						else {
							pending_frags := tail(frags);
							RuTacticSwitch(ruBoundedFollowProofTactic(frags[0], max_size))
						}
					}
				}
			}
	)
}

ruFragmentReplayStrategy(
	frag_pair  : Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProverTactic {
	ruSequenceTactic([
		ruFragmentReplayBody(frag_pair, max_size, attempts, math, env),
		ruBoundedBFSTactic(max_depth, max_size)
	])
}
