import ru/prover/core/env;
import ru/prover/core/tactics/breadth_first;
import ru/prover/core/tactics/follow_proof;
import ru/unify/index;

export {
	// Strategy that replays proof fragments from other theorems to guide proof search.
	// On each attempt, selects the deepest open leaf, finds all fragments whose root
	// expression unifies with that leaf's goal, and tries them one by one via
	// ruFollowProofTactic. After all attempts, falls back to bounded BFS.
	ruFragmentReplayStrategy(
		frag_pair  : Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>,
		max_depth  : int,
		max_size   : int,
		attempts   : int,
		math       : RuMath,
		env        : RuEnv
	) -> RuProverStrategy;
}

ruFrsPropDepth(prop : RuProverProp) -> int {
	switch (prop.parent) {
		RuProverRoot(__,__,__): 1;
		RuProverExp(__,__,__,__,grand): 1 + ruFrsPropDepth(grand);
	}
}

ruFrsDeepestLeaf(leafs : Tree<int, RuProverProp>) -> Maybe<RuProverProp> {
	leaves = getTreeValues(leafs);
	if (leaves == []) None()
	else Some(fold(tail(leaves), leaves[0], \acc, leaf ->
		if (ruFrsPropDepth(leaf) >= ruFrsPropDepth(acc)) leaf else acc
	))
}

ruFrsFragsForLeaf(
	prop      : RuProverProp,
	frag_pair : Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>,
	math      : RuMath,
	env       : RuEnv
) -> [RuProofStep] {
	leaf_exp = ruExp(prop.parent.stmt.exps[0]);
	matched  = ruUnifyIndex(leaf_exp, frag_pair.first, ruEmptySubst, math, env);
	filtermap(matched, \unif ->
		switch (lookupTree(frag_pair.second, unif.data.info.id)) {
			Some(frag): switch (frag.tree) {
				RuProofStep(ass, ch, stmt): Some(RuProofStep(ass, ch, stmt));
				RuProofHyp(__,__): None();
			}
			None(): None();
		}
	)
}

ruFragmentReplayStrategy(
	frag_pair  : Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProverStrategy {
	pending_frags      : ref [RuProofStep] = ref [];
	attempts_remaining : ref int           = ref attempts;
	bfs_done           : ref bool          = ref false;

	makeNextTactic = \tree -> {
		if (ruTreeIsProved(tree) || ^bfs_done) None()
		else if (length(^pending_frags) > 0) {
			f = (^pending_frags)[0];
			pending_frags := tail(^pending_frags);
			Some(ruFollowProofTactic(f))
		} else if (^attempts_remaining <= 0) {
			bfs_done := true;
			Some(ruBoundedBFSTactic(max_depth, max_size))
		} else {
			attempts_remaining := ^attempts_remaining - 1;
			switch (ruFrsDeepestLeaf(tree.leafs)) {
				None(): {
					bfs_done := true;
					Some(ruBoundedBFSTactic(max_depth, max_size))
				}
				Some(leaf): {
					frags = ruFrsFragsForLeaf(leaf, frag_pair, math, env);
					if (frags == []) {
						bfs_done := true;
						Some(ruBoundedBFSTactic(max_depth, max_size))
					} else {
						pending_frags := tail(frags);
						Some(ruFollowProofTactic(frags[0]))
					}
				}
			}
		}
	};

	RuProverStrategy("fragment-replay",
		\ -> RuProverTactic("frs-init", \__ -> [], \__ -> true),
		makeNextTactic
	)
}
