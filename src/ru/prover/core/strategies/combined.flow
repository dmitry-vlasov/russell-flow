import ru/prover/core/env;
import ru/prover/core/tactics/breadth_first;
import ru/prover/core/tactics/combinators;
import ru/prover/core/strategies/subproof_replay;
import ru/unify/index;

export {
	// Three-component composite tactic for general proof search:
	//   Phase 0 (once, optional): unif-quality BFS — fast beam search over the
	//                             most-specific candidates; skipped when unif_rank = 0.
	//   Body (repeated):          subproof-replay → bounded BFS.
	//   Outer loop:               repeat the body up to max_iters times while
	//                             the tree keeps growing.
	ruCombinedStrategy(
		step_index : RuIndex<Pair<int,int>>,
		unif_rank  : int,
		max_depth  : int,
		max_size   : int,
		attempts   : int,
		max_iters  : int,
		math       : RuMath,
		env        : RuEnv
	) -> RuProverTactic;
}

ruCombinedStrategy(
	step_index : RuIndex<Pair<int,int>>,
	unif_rank  : int,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	max_iters  : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProverTactic {
	body = \ -> ruSequenceTactic([
		ruSubproofReplayTactic(step_index, max_size, attempts, math, env),
		ruBoundedBFSTactic(max_depth, max_size)
	]);
	loop = ruLoopWhileProgressTactic(body, max_iters);
	if (unif_rank > 0)
		// Tiny phase-0 pass; then the SPR+BFS loop on whatever remains.
		ruSequenceTactic([
			ruUnifQualityTactic(unif_rank, 2, 32),
			loop
		])
	else loop
}
