import ru/prover/core/env;
import ru/util/lemma;
import ru/unify/index;
import ru/prover/core/tactics/follow_proof;

export {
	ruSimilarProofsStrategy(index : RuIndex<RuAssertion>, penv : RuProverEnv) -> RuProverTactic;
}

ruSimilarProofsStrategy(index : RuIndex<RuAssertion>, penv : RuProverEnv) -> RuProverTactic {
	step_index = fold(ruIndexValues(index), ruMakeIndex(), \acc, ass -> {
		switch (ass) {
			RuTheorem(__,__,__,proof): {
				linear_proof = ruMergeAllLemmasIntoProof(proof, penv.math, penv.env);
				fold(linear_proof.steps, acc, \ac, step ->
					ruSetIndex(ruExp(step.stmt.exps[0]), RuTheoremStep(ass, step), ac)
				);
			}
			default: acc;
		}
	});

	RuProverTactic("similar proofs",
		\tree -> {
			foldTree(tree.leafs, [], \__, node, acc -> {
				similar = ruFindSimilarIndex(ruExp(node.parent.stmt.exps[0]), step_index, penv.math, penv.env);
				acc;
			});
			RuTacticDone();
		}
	);
}
