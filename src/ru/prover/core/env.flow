import base/util/math;
import ru/prover/core/util;
import ru/prover/core/conf;
import ru/prover/core/fragment;
import ru/unify/indexes;
import ru/verify/math;

export {

	RuTacticStack(
		tactic : RuProverTactic,
		parent : Maybe<RuTacticStack>
	);

	RuProverEnv(
		conf : RuProverConf,
		tree : RuProverTree,

		toExpand : ref [int],
		//tactics : Maybe<RuTacticStack>,
		tactic : ref Maybe<RuProverTactic>,

		math : RuMath,
		env : RuEnv,
		fns : RuProverFuncs,
		importDependencies : Tree<int, Set<int>>,
		fragmentTrees : Tree<int, RuProofFragment>,

		// Assertion IDs permanently excluded from unification during this proof session.
		// Modified by prove-forbid; checked inside fns.unifyAssertion.
		forbidden : ref Set<int>,

		// When non-empty, only assertions with these IDs are allowed (overrides forbidden).
		// Temporarily set by prove-expand with assertion= arg; always restored after.
		whitelist : ref [int]
	);

	RuProverFuncs(
		admitExp : (RuExp) -> bool,
		unifyAssertion : (RuProverHyp) -> [RuUnified<RuAssertion>],
		unifyPremise   : (RuProverHyp) -> [RuUnified<RuPremise>],
		unifyFragment  : (RuProverHyp) -> [RuUnified<RuAssertion>],
		fresher : (RuVar) -> RuVar,
		unconst : (RuExp) -> RuExp,
		onProof : (RuProofTree) -> void,
		onProp : (RuProverProp) -> void,
		idxer : () -> int
	);

	ruInitProverEnv(
		task : RuProverTask,
		math : RuMath, 
		env : RuEnv, 
		assertions : RuIndex<RuAssertion>, 
		time_limit : double
	) -> RuProverEnv;
}

ruEstimateMaxExp(index : RuIndex<RuAssertion>) -> int {
	theorems = filtermap(ruIndexValues(index), ruDecl2Theorem);
	proofs = map(theorems, \th -> th.proof);
	steps = ruConcatA(map(proofs, ruAllProofSteps));
	step_exp_lens = map(steps, \step ->
		i2d(fold(step.stmt.exps, 0, \acc, ex -> acc + length(ex.nodes)))
	);

	sum_num_max = ruSumDoublesFromArray(step_exp_lens);
	len_num_max = ruMaxDoubleFromArray(step_exp_lens);
	if (len_num_max < 4096.0) 256 else {
		avg_len = sum_num_max / i2d(length(step_exp_lens));
		sigma_sum = fold(step_exp_lens, 0.0, \acc, len ->
			acc + (len - avg_len) * (len - avg_len)
		);
		sigma = sqrt(sigma_sum / len_num_max);
		round(avg_len + 3.0 * sigma);
	}
	round(len_num_max + 64.0);
}

ruEstimateMaxExp1(index : RuIndex<RuAssertion>) -> int {
	len_num_max = ruFoldIndex(index, Triple(0.0, 0, 0), \acc, ass ->
		eitherMap(ruDecl2Theorem(ass), \th ->
			fold(th.proof.steps, acc, \ac, step -> {
				len = fold(step.stmt.exps, 0, \a, ex -> a + length(ruExp(ex).nodes));
				Triple(ac.first + i2d(len), ac.second + 1, max(acc.third, len))
			}),
			acc
		)
	);
	if (len_num_max.second < 4096) 256 else {
		avg_len = len_num_max.first / i2d(len_num_max.second);
		sigma_sum = ruFoldIndex(index, 0.0, \acc, ass ->
			eitherMap(ruDecl2Theorem(ass), \th ->
				fold(th.proof.steps, acc, \ac, step -> {
					delta = i2d(fold(step.stmt.exps, 0, \a, ex -> a + length(ruExp(ex).nodes))) - avg_len;
					ac + delta * delta;
				}),
				acc
			)
		);
		sigma = sqrt(sigma_sum / i2d(len_num_max.second));
		round(avg_len + 3.0 * sigma);
	}
	len_num_max.third + 64;
}

ruInitProverEnv(
	task : RuProverTask,
	math0 : RuMath, 
	env : RuEnv, 
	assertions : RuIndex<RuAssertion>, 
	time_limit : double
) -> RuProverEnv {
	c_task = ruConstProverTask(task, math0);
	math = c_task.env.math;
	premises = ruInitTaskPremisesIndex(c_task.const);
	max_frag_depth = s2i(lookupTreeDef(task.args, "fragment-depth", "0"));
	frag_pair = ruBuildFragments(math0, max_frag_depth, env);
	frag_index = frag_pair.first;
	frag_trees = frag_pair.second;
	proofs : ref [RuProof] = ref [];
	root = RuProverRoot(makeVector(5), c_task.const.goal.stmt, makeVector(1024));
	id = ref 0;
	inc_id = ruAtomicIntAdd(id);
	fresh_id = ref 0;
	inc_fresh_id = ruAtomicIntAdd(fresh_id);
	forbidden = ref makeSet();
	whitelist = ref [];
	add_proof = synchronizedUnaryFn(proofs, \proof_root -> {
		steps = map(ruMakeLinearProof(proof_root), \st ->
			RuStep(st with
				stmt = RuStmt(st.stmt with
					exps = map(st.stmt.exps, \ex -> c_task.env.unconst(ruExp(ex)))
				)
			)
		);
		switch (ruMakeProofFromSteps(task, steps, math, env)) {
			Some(proof): {
				refArrayPush(proofs, proof);
			}
			None(): {
				if (env.conf.verbose > 2) {
					env.out.println("PROOF IS ILLEGAL for " + id2s(task.info.id) + ":\n" + strIndent(
						concatStrings(map(steps, \step -> ru2s(step, math)))
					));
				}
			}
		}
	})
	//max_expr_len = ruEstimateMaxExp(assertions);

	funcs = RuProverFuncs(
		\expr -> true,//length(expr.nodes) < max_expr_len,
		\hyp -> filter(ruUnifyIndex(ruExp(hyp.stmt.exps[0]), assertions, ruEmptySubst, math, env), \u ->
			if (length(^whitelist) > 0) contains(^whitelist, u.data.info.id)
			else !containsSet(^forbidden, u.data.info.id)
		),
		\hyp -> ruUnifyIndex(ruExp(hyp.stmt.exps[0]), premises, ruEmptySubst, math, env),
		\hyp -> ruUnifyIndex(ruExp(hyp.stmt.exps[0]), frag_index, ruEmptySubst, math, env),
		\v -> RuVar(s2id(id2s(v.id) + "_" + i2s(inc_fresh_id(1))), v.type),
		c_task.env.unconst,
		add_proof,
		nop1,
		\-> inc_id(1)
	);
	RuProverEnv(
		RuProverConf(
			task,
			ruMakeLimitedTimer(time_limit),
		),
		RuProverTree(makeTree(), makeTree(), root, proofs),
		ref [], ref Some(task.strategy.initTactic()),
		math, env, funcs,
		ruSourcesAllImported(math.sources, env),
		frag_trees,
		forbidden,
		whitelist,
	);
}
