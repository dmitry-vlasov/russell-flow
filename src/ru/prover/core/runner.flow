import ru/prover/core/env;
import ru/prover/core/prove;
import ru/prover/tactics/dsl;
import ru/util/utils;

export {
	// Run the prover for one theorem: init env → build tactic → expand root → prove.
	// Returns the finished RuProverEnv; caller reads results from penv.tree.
	// Pass None() for frag_pair to let ruInitProverEnv build fragments itself from
	// the task's fragment-depth arg; pass Some(fp) to reuse a pre-built index.
	ruBuildAndProve(
		th         : RuTheorem,
		task       : RuTask,
		index      : RuIndex<RuAssertion>,
		builder    : RuTacticBuilder,
		time_limit : double,
		frag_pair  : Maybe<Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>>,
		math       : RuMath,
		env        : RuEnv
	) -> RuProverEnv;
}

ruBuildAndProve(
	th         : RuTheorem,
	task       : RuTask,
	index      : RuIndex<RuAssertion>,
	builder    : RuTacticBuilder,
	time_limit : double,
	frag_pair  : Maybe<Pair<RuIndex<RuAssertion>, Tree<int, RuProofFragment>>>,
	math       : RuMath,
	env        : RuEnv
) -> RuProverEnv {
	prover_task = RuProverTask(
		th.info, ruDoneTactic, id2s(th.info.id),
		task.args, th.infer.hyps, ruProofQedStep(th.proof)
	);
	penv_pre = switch (frag_pair) {
		Some(fp): ruInitProverEnvWithFrags(prover_task, math, env, index, time_limit, fp);
		None():   ruInitProverEnv(prover_task, math, env, index, time_limit);
	};
	built = builder.build(penv_pre);
	penv0 = built.first;
	penv0.tactic := Some(built.second);
	penv1 = ruExpandHyp(penv0.tree.root, penv0);
	ruProve(penv1)
}
