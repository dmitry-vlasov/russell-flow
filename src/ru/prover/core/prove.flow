import ru/prover/core/expand;

export {
	ruInitProver(
		task : RuProverTask,
		math : RuMath,
		env : RuEnv,
		asses : RuIndex<RuAssertion>,
		ms_time_limit : double
	) -> RuProverEnv;

	ruProve(prover_env : RuProverEnv) -> RuProverEnv;
	// Sequential variant: avoids nested-concurrency issues when called inside
	// an already-parallel context (e.g. ruMapFnComm per-theorem workers).
	ruProveSequential(prover_env : RuProverEnv) -> RuProverEnv;
	ruProveProp(prop : RuProverProp, prover_env : RuProverEnv) -> RuProverEnv;
}

ruInitProver(
	task : RuProverTask,
	math : RuMath,
	env : RuEnv,
	asses : RuIndex<RuAssertion>,
	ms_time_limit : double
) -> RuProverEnv {
	prover_env = ruInitProverEnv(task, math, env, asses, ms_time_limit);
	prover_env.tactic := Some(prover_env.conf.task.tactic);
	ruExpandHyp(prover_env.tree.root, prover_env);
}

ruProveProp(prop : RuProverProp, prover_env : RuProverEnv) -> RuProverEnv {
	t1 = ruMakeTimer();
	env1 = ruExpandProp(prop, prover_env);
	if (ruOptsString(prover_env.env.conf.opts, "reprove-stats", "") == "1") {
		ruAddStats("ruExpandProp", RuStatsRow("expanding " + id2s(prop.assertion.info.id),
			pairs2tree([
				Pair("time", ruTimePassed(t1)),
				Pair("count", 1.0)
			])
		));
	}
	t2 = ruMakeTimer();
	ruBuildPropProofs(prop, prop.proofs, env1);
	if (ruOptsString(prover_env.env.conf.opts, "reprove-stats", "") == "1") {
		ruAddStats("ruBuildPropProofs", RuStatsRow("building proofs for " + id2s(prop.assertion.info.id),
			pairs2tree([
				Pair("time", ruTimePassed(t2)),
				Pair("count", 1.0)
			])
		));
	}
	env1;
}

// Pulls the next batch of leafs to expand from the current tactic, applying
// the tactic's step protocol: Done terminates, Switch swaps the tactic and
// retries, Expand returns the leafs.  Returns Pair(updated env, leafs).
// If leafs is [] the caller should treat the env's tactic as None and stop.
ruRunTacticStep(prover_env : RuProverEnv) -> Pair<RuProverEnv, [RuProverProp]> {
	switch (^(prover_env.tactic)) {
		Some(tactic): {
			switch (tactic.step(prover_env.tree)) {
				RuTacticDone(): {
					prover_env.tactic := None();
					Pair(prover_env, []);
				}
				RuTacticSwitch(next): {
					prover_env.tactic := Some(next);
					ruRunTacticStep(prover_env);
				}
				RuTacticExpand(leafs): Pair(prover_env, leafs);
			}
		}
		None(): Pair(prover_env, []);
	}
}

ruProve(prover_env : RuProverEnv) -> RuProverEnv {
	to_expand0 = filtermap(^(prover_env.toExpand), \ind ->
		lookupTree(prover_env.tree.leafs, ind)
	);
	prover_env.toExpand := [];
	to_expand_and_env =
		if (length(to_expand0) > 0) Pair(prover_env, to_expand0)
		else ruRunTacticStep(prover_env);
	env_after_step = to_expand_and_env.first;
	to_expand = to_expand_and_env.second;
	if (to_expand == []) env_after_step
	else {
		to_expand_removed = fold(to_expand, env_after_step.tree.leafs, \acc, prop ->
			removeFromTree(acc, prop.id)
		);
		env1 = RuProverEnv(env_after_step with
			tree = RuProverTree(env_after_step.tree with leafs = to_expand_removed)
		);
		env1_expanded = ruConcurrent(
			map(to_expand, \prop -> \env2 ->
				switch (^(env1.tactic)) {
					Some(tac): if (tac.keep_expanding(env1.tree)) ruProveProp(prop, RuProverEnv(env1 with env = env2)) else env1;
					None(): env1;
				}
			),
			env1.env
		);
		new_env = fold(env1_expanded, env1, \acc, e ->
			RuProverEnv(acc with
				tree = RuProverTree(acc.tree with
					leafs = mergeTree(acc.tree.leafs, e.tree.leafs),
					nodes = mergeTree(acc.tree.nodes, e.tree.leafs)
				)
			)
		);
		ruProve(new_env);
	}
}

ruProveSequential(prover_env : RuProverEnv) -> RuProverEnv {
	to_expand0 = filtermap(^(prover_env.toExpand), \ind ->
		lookupTree(prover_env.tree.leafs, ind)
	);
	prover_env.toExpand := [];
	to_expand_and_env =
		if (length(to_expand0) > 0) Pair(prover_env, to_expand0)
		else ruRunTacticStep(prover_env);
	env_after_step = to_expand_and_env.first;
	to_expand = to_expand_and_env.second;
	if (to_expand == []) env_after_step
	else {
		to_expand_removed = fold(to_expand, env_after_step.tree.leafs, \acc, prop ->
			removeFromTree(acc, prop.id)
		);
		env1 = RuProverEnv(env_after_step with
			tree = RuProverTree(env_after_step.tree with leafs = to_expand_removed)
		);
		env1_expanded = ruSequential(
			map(to_expand, \prop -> \env2 ->
				switch (^(env1.tactic)) {
					Some(tac): if (tac.keep_expanding(env1.tree)) ruProveProp(prop, RuProverEnv(env1 with env = env2)) else env1;
					None(): env1;
				}
			),
			env1.env
		);
		new_env = fold(env1_expanded, env1, \acc, e ->
			RuProverEnv(acc with
				tree = RuProverTree(acc.tree with
					leafs = mergeTree(acc.tree.leafs, e.tree.leafs),
					nodes = mergeTree(acc.tree.nodes, e.tree.leafs)
				)
			)
		);
		ruProveSequential(new_env);
	}
}
