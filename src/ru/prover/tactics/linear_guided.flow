import ru/prover/core/controls;
import ru/prover/core/tree;
import ru/prover/core/env;
import ru/subst;

export {
	// A tactic that prioritizes expanding fragment-matched propositions whose
	// every hypothesis expression directly unifies with a current theorem premise
	// ("complete" fragment applications). These correspond to the user's concept
	// of a "linear chain from goal to premises": the fragment is a path in an
	// existing proof, and all its leaves are already available as premises of the
	// theorem being proved, so the chain closes the subgoal in one shot.
	//
	// When no complete fragment is found, falls back to expanding all leaves (BFS).
	//
	// penv must already be fully initialised (ruInitProverEnvWithFrags called).
	ruLinearGuidedTactic(max_depth : int, max_size : int, penv : RuProverEnv) -> RuProverTactic;
}

ruLinearGuidedTactic(max_depth : int, max_size : int, penv : RuProverEnv) -> RuProverTactic {
	fns       = penv.fns;
	frag_trees = penv.fragmentTrees;

	// Returns true when prop is a fragment-backed proposition AND every one of
	// its instantiated hypothesis expressions matches a current theorem premise.
	is_complete_frag = \prop : RuProverProp -> {
		switch (lookupTree(frag_trees, prop.assertion.info.id)) {
			None(): false;
			Some(__):
				forall(prop.assertion.infer.hyps, \h -> {
					// Instantiate the hypothesis expression the same way ruExpandProp does.
					exp = ruApplySubst(ruApplySubst(ruExp(h.stmt.exps[0]), prop.sub), prop.outer);
					fns.matchesPremise(exp)
				})
		}
	};

	keep = ruDeltaKeepExpanding(max_depth, max_size);
	RuProverTactic("linear-guided",
		\tree ->
			if (!keep(tree)) RuTacticDone()
			else {
				leaves = getTreeValues(tree.leafs);
				complete = filter(leaves, is_complete_frag);
				RuTacticExpand(if (complete != []) complete else leaves)
			},
		keep
	)
}
