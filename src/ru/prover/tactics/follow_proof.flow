import ru/prover/core/controls;
import ru/prover/core/tree;

export {
	ruFollowProofTactic(proof : RuProofStep) -> RuProverTactic;
	// Like ruFollowProofTactic but terminates when tree size exceeds max_size.
	ruBoundedFollowProofTactic(proof : RuProofStep, max_size : int) -> RuProverTactic;
}

// Internal: compute the leafs whose assertion matches the proof step's path,
// updating the mapping ref so future calls see the discovered correspondences.
ruDoFollowProofExpand(
	proof : RuProofStep,
	mapping : ref Tree<RuProverProp, RuProofStep>,
	initialized : ref bool,
	tree : RuProverTree
) -> [RuProverProp] {
	if (!^initialized) {
		traverseInOrder(tree.leafs, \__,node ->
			if (node.assertion.info.id == proof.assertion) {
				mapping := setTree(^mapping, node, proof);
			}
		);
		initialized := true;
	}
	foldTree(tree.leafs, [], \__, node, acc ->
		switch (lookupTree(^mapping, node)) {
			Some(__): concat(acc, [node]);
			None(): {
				switch (node.parent) {
					RuProverExp(ind,__,__,__,grand): {
						switch (lookupTree(^mapping, grand)) {
							Some(p): {
								child = p.children[ind];
								switch (child) {
									RuProofStep(__,__,__): {
										mapping := setTree(^mapping, node, child);
									}
									RuProofHyp(__,__): { }
								}
							}
							None(): { }
						}
					}
					RuProverRoot(__,__,__): { }
				}
				acc;
			}
		}
	)
}

ruFollowProofTactic(proof : RuProofStep) -> RuProverTactic {
	mapping     : ref Tree<RuProverProp, RuProofStep> = ref makeTree();
	initialized : ref bool = ref false;
	RuProverTactic("follow proof",
		\tree ->
			if (length(^(tree.proofs)) > 0) RuTacticDone()
			else {
				leafs = ruDoFollowProofExpand(proof, mapping, initialized, tree);
				if (leafs == []) RuTacticDone() else RuTacticExpand(leafs);
			},
		ruTreeNotProved
	);
}

ruBoundedFollowProofTactic(proof : RuProofStep, max_size : int) -> RuProverTactic {
	mapping     : ref Tree<RuProverProp, RuProofStep> = ref makeTree();
	initialized : ref bool = ref false;
	// max_depth is bounded by the corpus proof tree's structure, not by an
	// engine-side cap — pass a huge sentinel so the depth check is a no-op.
	keep = ruDeltaKeepExpanding(1000000, max_size);
	RuProverTactic("follow proof bounded",
		\tree ->
			if (!keep(tree)) RuTacticDone()
			else {
				leafs = ruDoFollowProofExpand(proof, mapping, initialized, tree);
				if (leafs == []) RuTacticDone() else RuTacticExpand(leafs);
			},
		keep
	);
}
