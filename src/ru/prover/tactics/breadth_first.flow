import ru/prover/core/controls;
import ru/prover/core/tree;

export {
	ruBreadthFirstTactic : RuProverTactic;
	ruGiveupTactic : RuProverTactic;
	ruDefaultTactic : RuProverTactic = ruBreadthFirstTactic;
	ruBoundedBFSTactic(max_depth : int, max_size : int) -> RuProverTactic;
	// BFS limited to at most n leaf expansions per step (beam search over BFS order).
	ruTopNBFSTactic(n : int, max_depth : int, max_size : int) -> RuProverTactic;
	// BFS focused on the subtree rooted at a single leaf (identified by prop id).
	// Expands only descendants of that leaf up to max_depth prop levels below it,
	// with an independent size budget tracking nodes added since this tactic started.
	ruPerLeafBFSTactic(target_id : int, max_depth : int, max_size : int) -> RuProverTactic;
	// BFS beam: expands only the top-n candidates per round, ordered by insertion
	// order (which reflects unification specificity when expand.flow sorts by it).
	ruUnifQualityTactic(n : int, max_depth : int, max_size : int) -> RuProverTactic;
	// Like ruPerLeafBFSTactic but only expands props whose assertion appears in
	// indexed_asserts.  This restricts the search to assertions that were actually
	// used as proof steps in the indexed corpus, keeping the fanout small.
	ruIndexGuidedBFSTactic(indexed_asserts : Set<int>, target_id : int, max_depth : int, max_size : int) -> RuProverTactic;
}

ruBreadthFirstTactic = RuProverTactic("breadth-first-search",
	\tree ->
		if (length(^(tree.proofs)) > 0) RuTacticDone()
		else RuTacticExpand(getTreeValues(tree.leafs)),
	ruTreeNotProved
);

ruGiveupTactic = ruDoneTactic;

ruBoundedKeepExpanding(max_depth : int, max_size : int) -> (RuProverTree) -> bool {
	\tree -> (length(^(tree.proofs)) == 0 && ruProverTreeDepth(tree) <= max_depth && ruProverTreeSize(tree) <= max_size)
}

ruBoundedBFSTactic(max_depth : int, max_size : int) -> RuProverTactic {
	keep = ruBoundedKeepExpanding(max_depth, max_size);
	RuProverTactic("bounded-bfs",
		\tree -> if (!keep(tree)) RuTacticDone() else RuTacticExpand(getTreeValues(tree.leafs)),
		keep
	);
}

ruTopNBFSTactic(n : int, max_depth : int, max_size : int) -> RuProverTactic {
	keep = ruBoundedKeepExpanding(max_depth, max_size);
	RuProverTactic("bfs-top-" + i2s(n),
		\tree -> if (!keep(tree)) RuTacticDone() else RuTacticExpand(take(getTreeValues(tree.leafs), n)),
		keep
	);
}

ruPlbDepthFromAncestor(prop : RuProverProp, ancestor_id : int) -> int {
	if (prop.id == ancestor_id) 0
	else switch (prop.parent) {
		RuProverRoot(__, __, __): -1;
		RuProverExp(__, __, __, __, grand): {
			d = ruPlbDepthFromAncestor(grand, ancestor_id);
			if (d < 0) -1 else d + 1
		}
	}
}

ruPerLeafBFSTactic(target_id : int, max_depth : int, max_size : int) -> RuProverTactic {
	nodes_added : ref int = ref 0;
	last_size   : ref int = ref (-1);
	keep = \tree -> length(^(tree.proofs)) == 0 && ^nodes_added <= max_size;
	RuProverTactic("per-leaf-bfs-" + i2s(target_id),
		\tree -> {
			sz = sizeTree(tree.nodes);
			if (^last_size >= 0) nodes_added := ^nodes_added + (sz - ^last_size);
			last_size := sz;
			if (!keep(tree)) RuTacticDone()
			else RuTacticExpand(filter(getTreeValues(tree.leafs), \lf -> {
				d = ruPlbDepthFromAncestor(lf, target_id);
				d >= 0 && d < max_depth
			}))
		},
		keep
	)
}

ruIndexGuidedBFSTactic(indexed_asserts : Set<int>, target_id : int, max_depth : int, max_size : int) -> RuProverTactic {
	nodes_added : ref int = ref 0;
	last_size   : ref int = ref (-1);
	keep = \tree -> length(^(tree.proofs)) == 0 && ^nodes_added <= max_size;
	RuProverTactic("index-guided-bfs-" + i2s(target_id),
		\tree -> {
			sz = sizeTree(tree.nodes);
			if (^last_size >= 0) nodes_added := ^nodes_added + (sz - ^last_size);
			last_size := sz;
			if (!keep(tree)) RuTacticDone()
			else RuTacticExpand(filter(getTreeValues(tree.leafs), \lf -> {
				d = ruPlbDepthFromAncestor(lf, target_id);
				d >= 0 && d < max_depth && containsSet(indexed_asserts, lf.assertion.info.id)
			}))
		},
		keep
	)
}

ruUnifQualityTactic(n : int, max_depth : int, max_size : int) -> RuProverTactic {
	keep = ruBoundedKeepExpanding(max_depth, max_size);
	RuProverTactic("unif-quality-bfs-" + i2s(n),
		\tree -> if (!keep(tree)) RuTacticDone() else RuTacticExpand(take(getTreeValues(tree.leafs), n)),
		keep
	)
}
