import comm;
import base/util/lsp;
import lsp/util;
import ru/info;
import ru/util/cursor;

// LSP response commands. These are the typed JSON-building counterparts of the
// human-readable info-* commands: an info-* command stores raw structured data (for
// scripts/info/*.rus to format as text), while an lsp-* command takes the SAME shared
// data and emits the LSP-protocol JSON via the type-checked lspX2Json helpers. The
// LSP request handlers (src/lsp/methods/*) invoke these instead of the info-* commands,
// so the info-* commands stay free of any LSP/JSON concern.

export {
	ruInfoLspCommands : [RuComm];
}

ruInfoLspCommands = [
	RuComm(
		RuCommInfo(
			"lsp-document-symbol", "lsp", "LSP textDocument/documentSymbol response (JSON)", "file", false, false,
			[RuCommArg("file", false, "input file", "")], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			data = ruOutlineData(ruTaskStringArg(unit.task, "file", ""), env);
			resolver = makeLineResolver(data.code);
			unit.out.respond(JsonArray(map(data.items, \it -> {
				loc = ruRangeResolver2LspLocation(it.range, data.path, resolver);
				lspSymbol2Json(LspSymbol(it.name, "", ruString2LspSymbolKind(it.kind), false, loc.range, loc.range, []));
			})));
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"lsp-hover", "lsp", "LSP textDocument/hover response (JSON)", "", false, false,
			[
				RuCommArg("file", false, "input file", ""),
				RuCommArg("line", false, "line of expr", ""),
				RuCommArg("col",  false, "column of expr", ""),
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			hover = ruHoverAt(unit.task, env);
			unit.out.respond(
				if (hover.message == "") JsonNull()
				else lspHover2Json(LspHover(ruHover2LspMarkupContent(hover), None()))
			);
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"lsp-definition", "lsp", "LSP textDocument/definition + /declaration response (JSON)", "", false, false,
			[
				RuCommArg("file", false, "input file", ""),
				RuCommArg("line", false, "line of expr", ""),
				RuCommArg("col",  false, "column of expr", ""),
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			unit.out.respond(eitherMap(ruDeclLocationAt(unit.task, env),
				\loc -> JsonArray([lspLocation2Json(ruRangeCode2LspLocation(loc.range, loc.path, loc.code))]),
				JsonArray([])
			));
			Some(unit.state);
		}
	),
];
