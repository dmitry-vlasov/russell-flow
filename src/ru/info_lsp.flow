import comm;
import base/util/lsp;
import lsp/util;
import ru/info;
import ru/util/cursor;
import ru/util/utils;
import ru/cache/cache;

// LSP response commands. These are the typed JSON-building counterparts of the
// human-readable info-* commands: an info-* command stores raw structured data (for
// scripts/info/*.rus to format as text), while an lsp-* command takes the SAME shared
// data and emits the LSP-protocol JSON via the type-checked lspX2Json helpers. The
// LSP request handlers (src/lsp/methods/*) invoke these instead of the info-* commands,
// so the info-* commands stay free of any LSP/JSON concern.

export {
	ruInfoLspCommands : [RuComm];
}

ruInfoLspCommands = [
	RuComm(
		RuCommInfo(
			"lsp-document-symbol", "lsp", "LSP textDocument/documentSymbol response (JSON)", "file", false, false,
			[RuCommArg("file", false, "input file", "")], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			data = ruOutlineData(ruTaskStringArg(unit.task, "file", ""), env);
			resolver = makeLineResolver(data.code);
			unit.out.respond(JsonArray(map(data.items, \it -> {
				loc = ruRangeResolver2LspLocation(it.range, data.path, resolver);
				lspSymbol2Json(LspSymbol(it.name, "", ruString2LspSymbolKind(it.kind), false, loc.range, loc.range, []));
			})));
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"lsp-hover", "lsp", "LSP textDocument/hover response (JSON)", "", false, false,
			[
				RuCommArg("file", false, "input file", ""),
				RuCommArg("line", false, "line of expr", ""),
				RuCommArg("col",  false, "column of expr", ""),
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			hover = ruHoverAt(unit.task, env);
			unit.out.respond(
				if (hover.message == "") JsonNull()
				else lspHover2Json(LspHover(ruHover2LspMarkupContent(hover), None()))
			);
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"lsp-definition", "lsp", "LSP textDocument/definition + /declaration response (JSON)", "", false, false,
			[
				RuCommArg("file", false, "input file", ""),
				RuCommArg("line", false, "line of expr", ""),
				RuCommArg("col",  false, "column of expr", ""),
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			unit.out.respond(eitherMap(ruDeclLocationAt(unit.task, env),
				\loc -> JsonArray([lspLocation2Json(ruRangeCode2LspLocation(loc.range, loc.path, loc.code))]),
				JsonArray([])
			));
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"lsp-references", "lsp", "LSP textDocument/references response (JSON)", "", false, false,
			[
				RuCommArg("file", false, "input file", ""),
				RuCommArg("line", false, "line of expr", ""),
				RuCommArg("col",  false, "column of expr", ""),
			], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			unit.out.respond(JsonArray(map(ruUsesAt(unit.task, env), \p ->
				lspLocation2Json(ruLocation2LspLocation(p.first, "", Some(p.second)))
			)));
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"lsp-workspace-symbol", "lsp", "LSP workspace/symbol response (JSON)", "name", false, false,
			[RuCommArg("name", false, "entity name", "")], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			id = s2id_(ruTaskStringArg(unit.task, "name", ""));
			unit.out.respond(eitherMap(ruCachedDecl2LspSymbolInfo(id, env),
				\info -> JsonArray([lspSymbolInformation2Json(info)]),
				{
					code = ruCodeCacheGet(id, env);
					if (code.path == "") JsonArray([])
					else JsonArray([lspLocation2Json(ruRangeCode2LspLocation(RuRange(0, ruFirstNLinesPos(code.code, 32)), code.path, code.code))]);
				}
			));
			Some(unit.state);
		}
	),
	RuComm(
		RuCommInfo(
			"lsp-math", "lsp", "LSP math-entities response (JSON): located decls with tooltips", "kind", false, false,
			[RuCommArg("kind", true, "kind of math: const, type, axiom, rule, def, theorem, or all", "all")], []
		),
		\unit -> {
			env = ruUnitEnv(unit);
			unit.out.respond(JsonArray(filtermap(ruMathEntities(ruTaskStringArg(unit.task, "kind", ""), env),
				\p -> maybeMap(ruNameRangeByPos(p.first.info.pos, p.second.code), \range ->
					JsonObject([
						Pair("kind", JsonString(ruDeclKind(p.first))),
						Pair("location", lspLocation2Json(ruRangeResolver2LspLocation(range, p.second.path, p.second.resolver))),
						Pair("name", JsonString(id2s(p.first.info.id))),
						Pair("tooltip", JsonString(ruDeclCode(p.first, p.second.src, p.second.code, env))),
					])
				)
			)));
			Some(unit.state);
		}
	),
];
