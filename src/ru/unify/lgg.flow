import ru/src;
import base/util/math;

export {
	// Least General Generalization of two expressions.
	// Returns the most specific expression that generalizes both e1 and e2.
	// Variables are treated as atomic: two vars are "same" only if their ids match.
	// Fresh vars introduced at mismatch positions have id "_lgg_N" for counter N.
	ruLggExps(e1 : RuExp, e2 : RuExp) -> RuExp;

	// Iterated LGG of a non-empty list: fold ruLggExps left to right.
	ruLggExpSet(exps : [RuExp]) -> RuExp;

	// Bounded iterated LGG: sorts by similarity to the most specific expression,
	// then folds left-to-right but skips any step that would drop the rule-node
	// count below min_rules. Prevents full collapse on diverse sets.
	ruLggExpSetBounded(exps : [RuExp], min_rules : int) -> RuExp;

	// Distance in [0,1]: 0 = identical structure, 1 = nothing in common.
	// d(e1,e2) = 1 - |rule-nodes in lgg(e1,e2)| / max(|rule-nodes in e1|, |rule-nodes in e2|)
	ruLggDistance(e1 : RuExp, e2 : RuExp) -> double;

	// Count RuRuleNode nodes (ignores RuVar nodes).
	ruExpRuleNodeCount(e : RuExp) -> int;

	// Sparse feature vector: 1-gram rule-node ID frequencies in DFS order.
	// Stored as sorted [Pair<rule_id, normalized_freq>] (sorted by rule_id).
	// Values are normalized frequencies (sum = 1.0, or [] if expression has no rule nodes).
	ruExpFeatureVec(e : RuExp) -> [Pair<int, double>];

	// Arithmetic mean of feature vectors (used at learn time).
	ruFeatureVecMean(vecs : [[Pair<int, double>]]) -> [Pair<int, double>];

	// Cosine distance in [0,1]: 0 = identical, 1 = orthogonal.
	// O(n+m) merge on sorted arrays.
	ruFeatureVecDist(v1 : [Pair<int, double>], v2 : [Pair<int, double>]) -> double;
}

// Internal: (result nodes, advance in e1, advance in e2)
RuLggStep(nodes : [RuExpNode], adv1 : int, adv2 : int);

ruLggFreshVar(counter : ref int, type : int) -> RuVar {
	id = ^counter;
	counter := ^counter + 1;
	RuVar(s2id("_lgg_" + i2s(id)), type);
}

ruExpNodeType(n : RuExpNode) -> int {
	switch (n) {
		RuRuleNode(idType, __): ruIdType2Type(idType);
		RuVar(__, type):        type;
	}
}

ruExpNodeSpan(n : RuExpNode) -> int {
	switch (n) {
		RuRuleNode(__, arityLen): ruArityLen2Len(arityLen) + 1;
		RuVar(__, __):            1;
	}
}

ruDoLggAt(
	nodes1 : [RuExpNode], i1 : int,
	nodes2 : [RuExpNode], i2 : int,
	counter : ref int
) -> RuLggStep {
	n1 = nodes1[i1];
	n2 = nodes2[i2];
	switch (n1) {
		RuRuleNode(rt1, al1): {
			rule1  = ruIdType2Id(rt1);
			type1  = ruIdType2Type(rt1);
			arity1 = ruArityLen2Arity(al1);
			len1   = ruArityLen2Len(al1);
			switch (n2) {
				RuRuleNode(rt2, al2): {
					rule2  = ruIdType2Id(rt2);
					arity2 = ruArityLen2Arity(al2);
					len2   = ruArityLen2Len(al2);
					if (rule1 == rule2 && arity1 == arity2) {
						children = ruDoLggChildren(nodes1, i1 + 1, nodes2, i2 + 1, arity1, counter);
						root_node = ruMakeRuleNode(rule1, type1, arity1, length(children));
						RuLggStep(concat([root_node], children), len1 + 1, len2 + 1);
					} else {
						fresh = ruLggFreshVar(counter, type1);
						RuLggStep([fresh], len1 + 1, ruArityLen2Len(al2) + 1);
					}
				}
				RuVar(__, __): {
					fresh = ruLggFreshVar(counter, type1);
					RuLggStep([fresh], len1 + 1, 1);
				}
			}
		}
		RuVar(id1, type1): {
			switch (n2) {
				RuVar(id2, __): {
					if (id1 == id2) {
						RuLggStep([n1], 1, 1);
					} else {
						fresh = ruLggFreshVar(counter, type1);
						RuLggStep([fresh], 1, 1);
					}
				}
				RuRuleNode(__, al2): {
					fresh = ruLggFreshVar(counter, type1);
					RuLggStep([fresh], 1, ruArityLen2Len(al2) + 1);
				}
			}
		}
	}
}

ruDoLggChildren(
	nodes1 : [RuExpNode], i1 : int,
	nodes2 : [RuExpNode], i2 : int,
	arity  : int,
	counter : ref int
) -> [RuExpNode] {
	if (arity == 0) [] else {
		step = ruDoLggAt(nodes1, i1, nodes2, i2, counter);
		rest = ruDoLggChildren(nodes1, i1 + step.adv1, nodes2, i2 + step.adv2, arity - 1, counter);
		concat(step.nodes, rest);
	}
}

ruLggExps(e1 : RuExp, e2 : RuExp) -> RuExp {
	if (length(e1.nodes) == 0 || length(e2.nodes) == 0) ruNoExp else {
		counter = ref 0;
		step = ruDoLggAt(e1.nodes, 0, e2.nodes, 0, counter);
		RuExp(step.nodes, -1);
	}
}

ruLggExpSet(exps : [RuExp]) -> RuExp {
	n = length(exps);
	if (n == 0) ruNoExp else {
		fold(tail(exps), exps[0], \acc, e -> ruLggExps(acc, e));
	}
}

ruLggExpSetBounded(exps : [RuExp], min_rules : int) -> RuExp {
	n = length(exps);
	if (n == 0) ruNoExp
	else if (n == 1) exps[0]
	else {
		// Anchor: the most specific expression (most rule-nodes).
		anchor = fold(tail(exps), exps[0], \best, e ->
			if (ruExpRuleNodeCount(e) > ruExpRuleNodeCount(best)) e else best
		);
		// Sort ascending by distance to anchor so most similar come first.
		sorted = map(
			sortCustom(map(exps, \e -> Pair(ruLggDistance(e, anchor), e)), \p -> p.first, true),
			\p -> p.second
		);
		// Fold, skipping any step that would drop below min_rules.
		fold(tail(sorted), sorted[0], \acc, e -> {
			candidate = ruLggExps(acc, e);
			if (ruExpRuleNodeCount(candidate) >= min_rules) candidate else acc;
		});
	}
}

ruLggDistance(e1 : RuExp, e2 : RuExp) -> double {
	lgg   = ruLggExps(e1, e2);
	lgg_n = ruExpRuleNodeCount(lgg);
	e1_n  = ruExpRuleNodeCount(e1);
	e2_n  = ruExpRuleNodeCount(e2);
	denom = max(e1_n, e2_n);
	if (denom == 0) 0.0 else 1.0 - i2d(lgg_n) / i2d(denom);
}

ruExpRuleNodeCount(e : RuExp) -> int {
	fold(e.nodes, 0, \acc, n ->
		switch (n) {
			RuRuleNode(__, __): acc + 1;
			RuVar(__, __):      acc;
		}
	);
}

ruExpFeatureVec(e : RuExp) -> [Pair<int, double>] {
	raw = fold(e.nodes, makeTree(), \acc, node ->
		switch (node) {
			RuRuleNode(rt, __): {
				r = ruIdType2Id(rt);
				setTree(acc, r, lookupTreeDef(acc, r, 0.0) + 1.0);
			}
			RuVar(__, __): acc;
		}
	);
	total = foldTree(raw, 0.0, \__, v, acc -> acc + v);
	if (total == 0.0) []
	else foldTree(raw, [], \k, v, acc -> arrayPush(acc, Pair(k, v / total)));
}

ruFeatureVecMean(vecs : [[Pair<int, double>]]) -> [Pair<int, double>] {
	n = length(vecs);
	if (n == 0) [] else {
		summed = fold(vecs, makeTree(), \acc, vec ->
			fold(vec, acc, \a, p ->
				setTree(a, p.first, lookupTreeDef(a, p.first, 0.0) + p.second)
			)
		);
		foldTree(summed, [], \k, v, acc -> arrayPush(acc, Pair(k, v / i2d(n))));
	}
}

ruFeatureVecDist(v1 : [Pair<int, double>], v2 : [Pair<int, double>]) -> double {
	dot   = ruFeatureVecDot(v1, v2, 0, 0);
	norm1 = sqrt(fold(v1, 0.0, \acc, p -> acc + p.second * p.second));
	norm2 = sqrt(fold(v2, 0.0, \acc, p -> acc + p.second * p.second));
	denom = norm1 * norm2;
	if (denom == 0.0) 1.0 else 1.0 - dot / denom;
}

ruFeatureVecDot(v1 : [Pair<int, double>], v2 : [Pair<int, double>], i : int, j : int) -> double {
	n1 = length(v1); n2 = length(v2);
	if (i >= n1 || j >= n2) 0.0
	else {
		k1 = v1[i].first; k2 = v2[j].first;
		if      (k1 == k2) v1[i].second * v2[j].second + ruFeatureVecDot(v1, v2, i + 1, j + 1)
		else if (k1 <  k2) ruFeatureVecDot(v1, v2, i + 1, j)
		else               ruFeatureVecDot(v1, v2, i, j + 1);
	}
}
