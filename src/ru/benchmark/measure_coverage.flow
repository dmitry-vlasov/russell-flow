import ru/benchmark/coverage;
import ru/prover/core/prove;
import ru/prover/core/strategies/subproof_replay;
import ru/map_decls;
import ru/util/target;
import comm;

export {
	ruCommMeasureCoverage : RuComm;
}

ruCommMeasureCoverage = RuComm(
	RuCommInfo(
		"measure-coverage", "prover",
		"measure fraction of original proof steps rediscovered by fragment-replay proof search",
		"target", true, false,
		[
			RuCommArg("target",    true, "the target: a theorem, file or all", "all"),
			RuCommArg("max-depth", true, "max proof tree depth",               "5"),
			RuCommArg("max-size",  true, "max proof tree size",                "4096"),
			RuCommArg("attempts",  true, "number of replay attempts per leaf", "3"),
			RuCommArg("time-limit",true, "per-theorem wall-clock limit",       "60s"),
		], []
	),
	ruRunMeasureCoverage
);

ruMeasureCoverageTheorem(
	th         : RuTheorem,
	args       : Tree<string, flow>,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv,
	step_index : RuIndex<Pair<int,int>>
) -> RuProofCoverage {
	strategy    = ruSubproofReplayStrategy(step_index, max_depth, max_size, attempts, math, env);
	prover_task = RuProverTask(
		th.info,
		strategy,
		id2s(th.info.id),
		args,
		th.infer.hyps,
		ruProofQedStep(th.proof)
	);
	prover_env1 = ruInitProverEnv(prover_task, math, env, index, time_limit);
	prover_env2 = ruExpandHyp(prover_env1.tree.root, prover_env1);
	prover_env3 = ruProve(prover_env2);
	orig_tree = ruTheoremProofTree(th, math);
	ruAlignProofWithTree(orig_tree, vector2array(prover_env3.tree.root.children))
}

ruRunMeasureCoverage(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	target = ruDetermineTarget(task, math, env);
	if (target == RuTargetNone()) {
		env.out.println("no target for measure-coverage");
		Some(state);
	} else {
		max_depth  = ruTaskIntArg(task, "max-depth", 5);
		max_size   = ruTaskIntArg(task, "max-size",  4096);
		attempts   = ruTaskIntArg(task, "attempts",  3);
		index      = ruMakeIndexForTarget(target, math, env);
		step_index = ruBuildStepIndex(math, 3);

		total_steps   = ref 0;
		covered_steps = ref 0;
		theorem_count = ref 0;
		proved_count  = ref 0;
		inc_theorems  = ruAtomicIntInc(theorem_count);
		inc_proved    = ruAtomicIntInc(proved_count);
		add_total     = ruAtomicIntInc(total_steps);
		add_covered   = ruAtomicIntInc(covered_steps);

		measure_fn = \decl, time_limit, env1 -> {
			th = cast(decl : RuDecl -> RuTheorem);
			if (ruTheoremIsProved(th)) {
				cov = ruMeasureCoverageTheorem(
					th, task.args, index, time_limit,
					max_depth, max_size, attempts, math, env1, step_index
				);
				total   = ruCoverageStepCount(cov);
				covered = ruCoveredStepCount(cov);
				ratio   = ruCoverageRatio(cov);
				proved  = total > 0 && covered == total;

				inc_theorems(1);
				add_total(total);
				add_covered(covered);
				if (proved) inc_proved(1);

				if (ruVerbose(env1.conf) > 0) {
					frontier = ruFrontierSeeds(cov);
					env1.out.println(
						id2s(th.info.id) + ": " +
						i2s(covered) + "/" + i2s(total) + " steps covered (" +
						d2s(ratio * 100.0) + "%)" +
						(if (proved) " PROVED" else "") +
						(if (length(frontier) > 0)
							", frontier: " + strGlue(map(frontier, \s -> id2s(s.assertion)), ", ")
						else "")
					);
				}
				if (ruVerbose(env1.conf) > 1) {
					env1.out.println(ruCoverage2s(cov, "  "));
				}
			}
			RuMappedDecl(true, false, decl)
		};

		new_state = ruMapFnComm(
			RuUnit(unit.task, state, env.out),
			RuMapFn(
				RuMapFnInfo(
					"measure-coverage",
					\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
					\__ -> 1.0,
					\ -> "coverage: " +
						i2s(^covered_steps) + "/" + i2s(^total_steps) + " steps (" +
						(if (^total_steps > 0)
							d2s(i2d(^covered_steps) / i2d(^total_steps) * 100.0)
						else "0.0") + "%)" +
						", " + i2s(^proved_count) + "/" + i2s(^theorem_count) + " theorems proved"
				),
				measure_fn
			)
		);

		n_th    = ^theorem_count;
		n_cov   = ^covered_steps;
		n_tot   = ^total_steps;
		n_proved = ^proved_count;
		avg_pct = if (n_tot > 0) i2d(n_cov) / i2d(n_tot) * 100.0 else 0.0;

		env.out.println(
			"=== measure-coverage results ===\n" +
			"theorems:      " + i2s(n_th) + "\n" +
			"proved:        " + i2s(n_proved) + " / " + i2s(n_th) + "\n" +
			"steps covered: " + i2s(n_cov) + " / " + i2s(n_tot) +
				" (" + d2s(avg_pct) + "% avg)"
		);

		Some(RuState(new_state with
			vars = setTree(new_state.vars, "measure-coverage", pairs2tree([
				Pair("theorem-count",  flow(n_th)),
				Pair("proved-count",   flow(n_proved)),
				Pair("covered-steps",  flow(n_cov)),
				Pair("total-steps",    flow(n_tot)),
				Pair("coverage-pct",   flow(avg_pct))
			]))
		))
	}
}
