import ru/benchmark/coverage;
import ru/prover/core/prove;
import ru/prover/tactics/subproof_replay;
import ru/prover/tactics/combined;
import ru/prover/tactics/dsl;
import ru/map_decls;
import ru/util/target;
import comm;

export {
	ruCommMeasureCoverage : RuComm;
}

// Module-level cache so ruBuildStepIndex is called at most once per process.
// The pair stores (theorem-count, index) so a reload invalidates it correctly.
ruStepIndexCache : ref Pair<int, RuIndex<Pair<int,int>>> = ref Pair(-1, ruMakeIndex());

ruCommMeasureCoverage = RuComm(
	RuCommInfo(
		"measure-coverage", "prover",
		"measure fraction of original proof steps rediscovered by fragment-replay proof search",
		"target", true, false,
		[
			RuCommArg("target",    true, "the target: a theorem, file or all", "all"),
			RuCommArg("max-depth", true, "max proof tree depth",               "5"),
			RuCommArg("max-size",  true, "max proof tree size",                "4096"),
			RuCommArg("attempts",       true, "number of replay attempts per leaf",                                      "3"),
			RuCommArg("time-limit",     true, "per-theorem wall-clock limit",                                            "60s"),
			RuCommArg("job-time-limit", true, "total wall-clock cap for the whole job (empty = n*time-limit/p)",         ""),
			RuCommArg("unif-rank",      true, "beam width for phase-0 unif-quality BFS (0=skip)",                       "0"),
			RuCommArg("max-iterations", true, "outer loop iterations over phases 1+2",                                  "3"),
			RuCommArg("tactic",         true, "tactic DSL expression that overrides the default combined strategy",     ""),
		], []
	),
	ruRunMeasureCoverage
);

// Result of measuring one theorem: the structural coverage annotation, plus
// whether the engine actually extracted a complete, substitution-consistent
// proof (length(tree.proofs) > 0) — the genuine "reproved" criterion.
RuCoverageResult(coverage : RuProofCoverage, really_proved : bool);

ruMeasureCoverageTheorem(
	th         : RuTheorem,
	task       : RuTask,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv,
	step_index : RuIndex<Pair<int,int>>
) -> RuCoverageResult {
	unif_rank  = ruTaskIntArg(task, "unif-rank",      0);
	max_iters  = ruTaskIntArg(task, "max-iterations", 3);
	dsl_src    = ruTaskStringArg(task, "tactic", "");
	default_builder = ruStaticTacticBuilder(
		ruCombinedStrategy(step_index, unif_rank, max_depth, max_size, attempts, max_iters, th.info.id, math, env)
	);
	builder : RuTacticBuilder = if (dsl_src != "") {
		ctx = RuTacticContext(math, env, Some(step_index), None(), None());
		switch (ruParseAndBuildTactic(dsl_src, ctx)) {
			Some(b): b;
			None():  default_builder;
		}
	} else default_builder;
	prover_task = RuProverTask(
		th.info,
		ruDoneTactic,
		id2s(th.info.id),
		task.args,
		th.infer.hyps,
		ruProofQedStep(th.proof)
	);
	prover_env_pre = ruInitProverEnv(prover_task, math, env, index, time_limit);
	built = builder.build(prover_env_pre);
	prover_env1 = built.first;
	prover_env1.tactic := Some(built.second);
	prover_env2 = ruExpandHyp(prover_env1.tree.root, prover_env1);
	prover_env3 = ruProve(prover_env2);
	orig_tree = ruTheoremProofTree(th, math);
	coverage = ruAlignProofWithTree(orig_tree, vector2array(prover_env3.tree.root.children));
	RuCoverageResult(coverage, length(^(prover_env3.tree.proofs)) > 0)
}

ruRunMeasureCoverage(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	target = ruDetermineTarget(task, math, env);
	if (target == RuTargetNone()) {
		env.out.println("no target for measure-coverage");
		Some(state);
	} else {
		max_depth  = ruTaskIntArg(task, "max-depth",  5);
		max_size   = ruTaskIntArg(task, "max-size",   4096);
		attempts   = ruTaskIntArg(task, "attempts",   3);
		index      = ruMakeIndexForTarget(target, math, env);
		// Cache the step index in a module-level ref keyed by theorem count.
		// Avoids rebuilding a ~7s / ~6 GB index on every single-theorem call.
		n_all = sizeTree(math.decls.assertions);
		step_index : RuIndex<Pair<int,int>> =
			if ((^ruStepIndexCache).first == n_all) (^ruStepIndexCache).second
			else {
				idx = ruBuildStepIndex(math, 3);
				ruStepIndexCache := Pair(n_all, idx);
				idx
			};

		// Compute total job budget so ruMapFnComm's outer timer covers n*th_time/p.
		// ruParseTime returns milliseconds; convert back to whole seconds for the string.
		th_time_ms  = ruParseTime(ruTaskStringArg(task, "time-limit", "60s"));
		n_theorems  = i2d(length(filter(
			getTreeValues(ruDeclsTheorems(math.decls)),
			\th -> ruTargetPredicate(target)(th) && ruTheoremIsProved(th)
		)));
		p_count     = max(1.0, i2d(availableProcessors()));
		// When N <= P all theorems run fully in parallel, so wall time = th_time.
		// When N > P, total wall time = N*th/P.  Take the max to ensure each
		// theorem always gets its full budget even when N is small.
		map_time_ms = max(th_time_ms, n_theorems * th_time_ms / p_count);
		job_time_str = ruTaskStringArg(task, "job-time-limit", "");
		map_time_capped = if (job_time_str != "")
			min(map_time_ms, ruParseTime(job_time_str))
		else map_time_ms;
		map_task = RuTask(task with args = setTree(task.args, "time-limit",
			flow(i2s(round(map_time_capped / 1000.0)) + "s")
		));

		total_steps    = ref 0;
		covered_steps  = ref 0;
		theorem_count  = ref 0;
		full_cov_count = ref 0;   // theorems with 100% step coverage
		proved_count   = ref 0;   // theorems where the engine extracted a real proof
		gap_count      = ref 0;   // 100% covered but NOT really proved — engine-bug signal
		inc_theorems   = ruAtomicIntInc(theorem_count);
		inc_full_cov   = ruAtomicIntInc(full_cov_count);
		inc_proved     = ruAtomicIntInc(proved_count);
		inc_gap        = ruAtomicIntInc(gap_count);
		add_total      = ruAtomicIntInc(total_steps);
		add_covered    = ruAtomicIntInc(covered_steps);

		measure_fn = \decl, time_limit, env1 -> {
			th = cast(decl : RuDecl -> RuTheorem);
			if (ruTheoremIsProved(th)) {
				result  = ruMeasureCoverageTheorem(
					th, task, index, time_limit,
					max_depth, max_size, attempts, math, env1, step_index
				);
				cov     = result.coverage;
				total   = ruCoverageStepCount(cov);
				covered = ruCoveredStepCount(cov);
				ratio   = ruCoverageRatio(cov);
				full_covered  = total > 0 && covered == total;
				really_proved = result.really_proved;

				inc_theorems(1);
				add_total(total);
				add_covered(covered);
				if (full_covered)  inc_full_cov(1);
				if (really_proved) inc_proved(1);
				// 100% structural coverage MUST imply a real proof; if not, the
				// engine found the proof skeleton but failed to extract it.
				if (full_covered && !really_proved) inc_gap(1);

				if (ruVerbose(env1.conf) > 0) {
					frontier = ruFrontierSeeds(cov);
					env1.out.println(
						id2s(th.info.id) + ": " +
						i2s(covered) + "/" + i2s(total) + " steps covered (" +
						d2s(ratio * 100.0) + "%)" +
						(if (full_covered) " FULLY-COVERED" else "") +
						(if (really_proved) " PROVED" else " NOT-PROVED") +
						(if (full_covered && !really_proved) "  <<< COVERAGE/PROOF GAP" else "") +
						(if (length(frontier) > 0)
							", frontier: " + strGlue(map(frontier, \s -> id2s(s.assertion)), ", ")
						else "")
					);
				}
				if (ruVerbose(env1.conf) > 1) {
					env1.out.println(ruCoverage2s(cov, "  "));
				}
			}
			RuMappedDecl(true, false, decl)
		};

		new_state = ruMapFnComm(
			RuUnit(map_task, state, env.out),
			RuMapFn(
				RuMapFnInfo(
					"measure-coverage",
					\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
					\__ -> 1.0,
					\ -> "coverage: " +
						i2s(^covered_steps) + "/" + i2s(^total_steps) + " steps (" +
						(if (^total_steps > 0)
							d2s(i2d(^covered_steps) / i2d(^total_steps) * 100.0)
						else "0.0") + "%)" +
						", " + i2s(^proved_count) + "/" + i2s(^theorem_count) + " theorems proved"
				),
				measure_fn
			)
		);

		n_th       = ^theorem_count;
		n_cov      = ^covered_steps;
		n_tot      = ^total_steps;
		n_proved   = ^proved_count;
		n_full_cov = ^full_cov_count;
		n_gap      = ^gap_count;
		avg_pct = if (n_tot > 0) i2d(n_cov) / i2d(n_tot) * 100.0 else 0.0;

		env.out.println(
			"=== measure-coverage results ===\n" +
			"theorems:        " + i2s(n_th) + "\n" +
			"reproved (real): " + i2s(n_proved) + " / " + i2s(n_th) +
				"   (engine extracted a complete proof)\n" +
			"fully covered:   " + i2s(n_full_cov) + " / " + i2s(n_th) +
				"   (100% of original proof steps explored)\n" +
			"steps covered:   " + i2s(n_cov) + " / " + i2s(n_tot) +
				" (" + d2s(avg_pct) + "% avg)\n" +
			"coverage/proof gap: " + i2s(n_gap) +
				(if (n_gap > 0)
					"   <<< BUG: theorems fully covered but NOT reproved"
				else
					"   (none — full coverage always yielded a real proof)")
		);

		Some(RuState(new_state with
			vars = setTree(new_state.vars, "measure-coverage", pairs2tree([
				Pair("theorem-count",  flow(n_th)),
				Pair("proved-count",   flow(n_proved)),
				Pair("full-cov-count", flow(n_full_cov)),
				Pair("gap-count",      flow(n_gap)),
				Pair("covered-steps",  flow(n_cov)),
				Pair("total-steps",    flow(n_tot)),
				Pair("coverage-pct",   flow(avg_pct))
			]))
		))
	}
}
