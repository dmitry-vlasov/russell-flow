import ru/benchmark/coverage;
import ru/prover/core/prove;
import ru/prover/core/tactics/breadth_first;
import ru/prover/core/strategies/subproof_replay;
import ru/map_decls;
import ru/util/target;
import ru/util/exp2s;
import base/concurrent;
import formats/json/json;
import comm;

export {
	ruCommReproveCoverage : RuComm;

	ruStmtFeatures(stmt : RuStmt, lang : RuLang) -> [Pair<string, Json>];
	ruCollectColoredExamples(colored : [RuColoredCoverage], theorem : string, parent : string, depth : int, lang : RuLang) -> [Json];

	// Node color: GREEN = initial-alignment interior (all GREEN children), YELLOW = frontier, RED = uncovered.
	// Color is sticky: once yellow or red, never upgraded to green by later tactic passes.
	RuNodeColor ::= RuGreen, RuYellowReplay, RuYellowBfs, RuRed;
		RuGreen();        // covered initially AND all direct children are also GREEN (pure interior)
		RuYellowReplay(); // covered initially but at the frontier, OR covered by a later replay pass
		RuYellowBfs();    // covered by a BFS pass (always frontier by definition)
		RuRed();          // never covered by any tactic

	RuColoredCoverage(
		assertion : int,
		stmt      : RuStmt,
		color     : RuNodeColor,
		children  : [RuColoredCoverage]
	);

	RuCoverageIterResult(
		green         : int,
		yellow_replay : int,
		yellow_bfs    : int,
		red           : int,
		proved        : bool,
		iters         : int,       // number of completed outer iterations
		colored       : [RuColoredCoverage]
	);

	ruReproveCoverageTheorem(
		th          : RuTheorem,
		args        : Tree<string, flow>,
		index       : RuIndex<RuAssertion>,
		time_limit  : double,
		max_depth   : int,
		max_size    : int,
		attempts    : int,
		max_iters   : int,
		bfs_depth   : int,
		bfs_size    : int,
		math        : RuMath,
		env         : RuEnv,
		step_index  : RuIndex<Pair<int,int>>
	) -> RuCoverageIterResult;
}

ruCommReproveCoverage = RuComm(
	RuCommInfo(
		"reprove-coverage", "prover",
		"outer loop: replay-saturation then BFS pass, repeat; tracks green/yellow-replay/yellow-bfs/red coloring",
		"target", true, false,
		[
			RuCommArg("target",         true, "the target: a theorem, file or all",          "all"),
			RuCommArg("max-depth",      true, "max proof tree depth",                        "5"),
			RuCommArg("max-size",       true, "max proof tree size",                         "4096"),
			RuCommArg("attempts",       true, "number of replay attempts per leaf",          "3"),
			RuCommArg("time-limit",     true, "per-theorem wall-clock limit",                "60s"),
			RuCommArg("job-time-limit", true, "total wall-clock limit for the whole job (empty = unlimited)", ""),
			RuCommArg("max-iterations", true, "max replay iterations per inner phase",       "5"),
			RuCommArg("bfs-depth",      true, "BFS depth for post-saturation pass (0=skip)", "3"),
			RuCommArg("bfs-size",       true, "BFS size budget for post-saturation pass",    "4096"),
			RuCommArg("output",         true, "save training examples to db/<name>.json (empty = skip)", ""),
		], []
	),
	ruRunReproveCoverage
);

ruStmtFeatures(stmt : RuStmt, lang : RuLang) -> [Pair<string, Json>] {
	if (length(stmt.exps) == 0) [] else {
		switch (stmt.exps[0]) {
			RuTerm(__, __, __): [];
			RuExp(nodes, __): {
				exp = cast(stmt.exps[0] : RuTermExp -> RuExp);
				rule_count = fold(nodes, 0, \acc, n -> switch (n) {
					RuRuleNode(__, __): acc + 1;
					default: acc;
				});
				top_rule = if (length(nodes) > 0) {
					switch (nodes[0]) {
						RuRuleNode(ruleType, __): id2s(ruIdType2Id(ruleType));
						RuVar(__, __): "";
					}
				} else "";
				[
					Pair("stmt_size", JsonDouble(i2d(rule_count))),
					Pair("stmt_top",  JsonString(top_rule)),
					Pair("stmt_str",  JsonString(ruSafeExp2s(exp, lang)))
				]
			}
		}
	}
}

ruCollectColoredExamples(
	colored  : [RuColoredCoverage],
	theorem  : string,
	parent   : string,
	depth    : int,
	lang     : RuLang
) -> [Json] {
	concatA(map(colored, \node -> {
		color_s = switch (node.color) {
			RuGreen():        "green";
			RuYellowReplay(): "yellow-replay";
			RuYellowBfs():    "yellow-bfs";
			RuRed():          "red";
		};
		children_json = JsonArray(map(node.children, \ch -> JsonString(id2s(ch.assertion))));
		stmt_feats = ruStmtFeatures(node.stmt, lang);
		child_jsons = ruCollectColoredExamples(node.children, theorem, id2s(node.assertion), depth + 1, lang);
		example = JsonObject(concat([
			Pair("theorem",   JsonString(theorem)),
			Pair("assertion", JsonString(id2s(node.assertion))),
			Pair("parent",    JsonString(parent)),
			Pair("depth",     JsonDouble(i2d(depth))),
			Pair("children",  children_json),
			Pair("color",     JsonString(color_s))
		], stmt_feats));
		arrayPush(child_jsons, example)
	}))
}

// Run the fragment-replay prover for a single step goal.
ruProveStep(
	th         : RuTheorem,
	step_stmt  : RuStmt,
	step_ass   : int,
	args       : Tree<string, flow>,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	math       : RuMath,
	env        : RuEnv,
	step_index : RuIndex<Pair<int,int>>
) -> [RuProverProp] {
	goal_step = RuStep(-1, step_ass, [], step_stmt, ruNoProof, -1);
	strategy  = ruSubproofReplayStrategy(step_index, max_depth, max_size, attempts, math, env);
	prover_task = RuProverTask(
		th.info, strategy,
		id2s(th.info.id) + "/" + id2s(step_ass),
		args, th.infer.hyps, goal_step
	);
	prover_env1 = ruInitProverEnv(prover_task, math, env, index, time_limit);
	prover_env2 = ruExpandHyp(prover_env1.tree.root, prover_env1);
	prover_env3 = ruProve(prover_env2);
	vector2array(prover_env3.tree.root.children)
}

// BFS-based single-step prover for post-saturation frontier seeds.
ruBfsProveStep(
	th         : RuTheorem,
	step_stmt  : RuStmt,
	step_ass   : int,
	args       : Tree<string, flow>,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	bfs_depth  : int,
	bfs_size   : int,
	math       : RuMath,
	env        : RuEnv
) -> [RuProverProp] {
	goal_step = RuStep(-1, step_ass, [], step_stmt, ruNoProof, -1);
	strategy = RuProverStrategy("bfs",
		\ -> ruBoundedBFSTactic(bfs_depth, bfs_size),
		\__ -> None()
	);
	prover_task = RuProverTask(
		th.info, strategy,
		id2s(th.info.id) + "/" + id2s(step_ass) + "/bfs",
		args, th.infer.hyps, goal_step
	);
	prover_env1 = ruInitProverEnv(prover_task, math, env, index, time_limit);
	prover_env2 = ruExpandHyp(prover_env1.tree.root, prover_env1);
	// Keep only the seed assertion's props in the frontier so BFS starts from step_ass.
	// Without this filter, an arity-0 axiom fires first, a proof is found, and BFS
	// stops before expanding the seed (leaving it with expanded=false and no children).
	filtered_leafs = filterTree(prover_env2.tree.leafs, \__, prop -> prop.assertion.info.id == step_ass);
	prover_env2b = RuProverEnv(prover_env2 with
		tree = RuProverTree(prover_env2.tree with leafs = filtered_leafs)
	);
	prover_env3 = ruProveSequential(prover_env2b);
	vector2array(prover_env3.tree.root.children)
}

// Merge new candidates into the coverage tree at frontier-seed positions.
// Newly covered nodes are tagged with newCoveredBy.
ruMergeCoverageUpdate(
	cov          : RuProofCoverage,
	new_cands    : Tree<int, [RuProverProp]>,
	parent_cov   : bool,
	newCoveredBy : RuCoveredBy
) -> RuProofCoverage {
	switch (cov) {
		RuProofCoverageHyp(__): cov;
		RuProofCoverageStep(ass, stmt, coveredBy, children): {
			covered = ruIsCovered(coveredBy);
			if (!covered && parent_cov) {
				// Frontier seed: check if new candidates cover it.
				new_props = lookupTreeDef(new_cands, ass, []);
				now_covered = exists(new_props, \prop -> prop.assertion.info.id == ass);
				if (now_covered) {
					matched_prop = either(find(new_props, \p -> p.assertion.info.id == ass), ruNoProverProp);
					prop_exps = vector2array(matched_prop.children);
					// Seed node gets newCoveredBy (RuCoveredByReplay/Bfs → sticky YELLOW).
					// Its children covered in the same call get RuCoveredInitial() so they
					// can still be classified GREEN if their own subtrees are fully interior.
					new_children = mapi(children, \i, child ->
						if (i < length(prop_exps))
							ruAlignCoverageWithCands(child, vector2array(prop_exps[i].children), RuCoveredInitial(), RuCoveredInitial())
						else
							ruAlignCoverageWithCands(child, [], RuCoveredInitial(), RuCoveredInitial())
					);
					RuProofCoverageStep(ass, stmt, newCoveredBy, new_children)
				} else {
					cov
				}
			} else if (covered) {
				RuProofCoverageStep(ass, stmt, coveredBy,
					map(children, \ch -> ruMergeCoverageUpdate(ch, new_cands, true, newCoveredBy))
				)
			} else {
				cov
			}
		}
	}
}

// Single BFS pass on all current frontier seeds. Tags new nodes RuCoveredYellowBfs.
ruBfsFrontierPass(
	cov        : RuProofCoverage,
	th         : RuTheorem,
	args       : Tree<string, flow>,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	bfs_depth  : int,
	bfs_size   : int,
	math       : RuMath,
	env        : RuEnv
) -> RuProofCoverage {
	if (bfs_depth <= 0) cov else {
		seeds = ruFrontierSeeds(cov);
		if (seeds == []) cov else {
			new_cands = fold(seeds, makeTree(), \acc, seed -> {
				props = ruBfsProveStep(th, seed.stmt, seed.assertion, args, index, time_limit,
					bfs_depth, bfs_size, math, env);
				setTree(acc, seed.assertion, props)
			});
			ruMergeCoverageUpdate(cov, new_cands, true, RuCoveredByBfs())
		}
	}
}

// Replay phase: iterate sub-proof replay until saturation or max_iters reached.
// Tags newly covered nodes RuCoveredYellowReplay.
ruReplayPhase(
	cov        : RuProofCoverage,
	th         : RuTheorem,
	args       : Tree<string, flow>,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	max_iters  : int,
	math       : RuMath,
	env        : RuEnv,
	step_index : RuIndex<Pair<int,int>>,
	iter       : int
) -> RuProofCoverage {
	seeds   = ruFrontierSeeds(cov);
	covered = ruCoveredStepCount(cov);
	if (seeds == [] || iter >= max_iters) cov
	else {
		new_cands = fold(seeds, makeTree(), \acc, seed -> {
			props = ruProveStep(
				th, seed.stmt, seed.assertion, args, index, time_limit,
				max_depth, max_size, attempts, math, env, step_index
			);
			setTree(acc, seed.assertion, props)
		});
		cov1 = ruMergeCoverageUpdate(cov, new_cands, true, RuCoveredByReplay());
		if (ruCoveredStepCount(cov1) == covered) cov1
		else ruReplayPhase(cov1, th, args, index, time_limit, max_depth, max_size, attempts,
			max_iters, math, env, step_index, iter + 1)
	}
}

// Bottom-up: compute the color of a single coverage node.
// GREEN only for RuCoveredInitial nodes whose ALL direct children are also GREEN.
// Color is sticky: RuCoveredByReplay → always YellowReplay, RuCoveredByBfs → always YellowBfs.
ruNodeColor(cov : RuProofCoverage) -> RuNodeColor {
	switch (cov) {
		RuProofCoverageHyp(__): RuGreen(); // hyps are always available
		RuProofCoverageStep(__, __, coveredBy, children): {
			switch (coveredBy) {
				RuNotCovered():      RuRed();
				RuCoveredByReplay(): RuYellowReplay();
				RuCoveredByBfs():    RuYellowBfs();
				RuCoveredInitial():
					if (forall(children, \ch -> ruNodeColor(ch) == RuGreen())) RuGreen()
					else RuYellowReplay();
			}
		}
	}
}

// Convert coverage tree to flat colored list (for counting and training data).
ruColorCoverage(cov : RuProofCoverage) -> [RuColoredCoverage] {
	switch (cov) {
		RuProofCoverageHyp(__): [];
		RuProofCoverageStep(ass, stmt, __, children): {
			color = ruNodeColor(cov);
			child_colored = concatA(map(children, \ch -> ruColorCoverage(ch)));
			[RuColoredCoverage(ass, stmt, color, child_colored)]
		}
	}
}

RuCoverageIterResult(
	green         : int,
	yellow_replay : int,
	yellow_bfs    : int,
	red           : int,
	proved        : bool,
	iters         : int,
	colored       : [RuColoredCoverage]
);

// Quadruple: (green, yellow_replay, yellow_bfs, red)
ruCountColors(colored : [RuColoredCoverage]) -> Quadruple<int, int, int, int> {
	fold(colored, Quadruple(0, 0, 0, 0), \acc, node -> {
		own = switch (node.color) {
			RuGreen():        Quadruple(acc.first + 1, acc.second, acc.third, acc.fourth);
			RuYellowReplay(): Quadruple(acc.first, acc.second + 1, acc.third, acc.fourth);
			RuYellowBfs():    Quadruple(acc.first, acc.second, acc.third + 1, acc.fourth);
			RuRed():          Quadruple(acc.first, acc.second, acc.third, acc.fourth + 1);
		};
		child_counts = ruCountColors(node.children);
		Quadruple(
			own.first  + child_counts.first,
			own.second + child_counts.second,
			own.third  + child_counts.third,
			own.fourth + child_counts.fourth
		)
	})
}

ruFinalizeCoverage(cov : RuProofCoverage, total : int, iters : int) -> RuCoverageIterResult {
	colored = ruColorCoverage(cov);
	counts  = ruCountColors(colored);
	proved  = ruCoveredStepCount(cov) == total && total > 0;
	RuCoverageIterResult(counts.first, counts.second, counts.third, counts.fourth, proved, iters, colored)
}

// Outer loop: replay phase then BFS pass, repeat until no progress or no seeds.
ruOuterLoop(
	cov        : RuProofCoverage,
	th         : RuTheorem,
	args       : Tree<string, flow>,
	index      : RuIndex<RuAssertion>,
	time_limit : double,
	max_depth  : int,
	max_size   : int,
	attempts   : int,
	max_iters  : int,
	bfs_depth  : int,
	bfs_size   : int,
	math       : RuMath,
	env        : RuEnv,
	step_index : RuIndex<Pair<int,int>>,
	total      : int,
	outer_iter : int
) -> RuCoverageIterResult {
	// Phase 1: replay until saturation.
	cov1 = ruReplayPhase(cov, th, args, index, time_limit, max_depth, max_size, attempts,
		max_iters, math, env, step_index, 0);

	if (bfs_depth <= 0 || ruFrontierSeeds(cov1) == []) {
		ruFinalizeCoverage(cov1, total, outer_iter)
	} else {
		// Phase 2: single BFS pass.
		cov2     = ruBfsFrontierPass(cov1, th, args, index, time_limit, bfs_depth, bfs_size, math, env);
		progress = ruCoveredStepCount(cov2) > ruCoveredStepCount(cov1);
		if (!progress) {
			ruFinalizeCoverage(cov2, total, outer_iter)
		} else {
			// BFS uncovered new nodes; go back to replay with them as new seeds.
			ruOuterLoop(cov2, th, args, index, time_limit, max_depth, max_size, attempts,
				max_iters, bfs_depth, bfs_size, math, env, step_index, total, outer_iter + 1)
		}
	}
}

ruReproveCoverageTheorem(
	th          : RuTheorem,
	args        : Tree<string, flow>,
	index       : RuIndex<RuAssertion>,
	time_limit  : double,
	max_depth   : int,
	max_size    : int,
	attempts    : int,
	max_iters   : int,
	bfs_depth   : int,
	bfs_size    : int,
	math        : RuMath,
	env         : RuEnv,
	step_index  : RuIndex<Pair<int,int>>
) -> RuCoverageIterResult {
	// Initial replay run: produces Green nodes.
	strategy    = ruSubproofReplayStrategy(step_index, max_depth, max_size, attempts, math, env);
	prover_task = RuProverTask(
		th.info, strategy, id2s(th.info.id),
		args, th.infer.hyps, ruProofQedStep(th.proof)
	);
	prover_env1 = ruInitProverEnv(prover_task, math, env, index, time_limit);
	prover_env2 = ruExpandHyp(prover_env1.tree.root, prover_env1);
	prover_env3 = ruProve(prover_env2);
	orig_tree   = ruTheoremProofTree(th, math);
	cov0        = ruAlignProofWithTree(orig_tree, vector2array(prover_env3.tree.root.children));
	total       = ruCoverageStepCount(cov0);

	ruOuterLoop(cov0, th, args, index, time_limit, max_depth, max_size, attempts,
		max_iters, bfs_depth, bfs_size, math, env, step_index, total, 0)
}

ruRunReproveCoverage(unit : RuUnit) -> Maybe<RuState> {
	env   = ruUnitEnv(unit);
	task  = unit.task;
	state = unit.state;
	conf  = state.conf;
	math  = ruMathFromSources(state.ru, env);
	target = ruDetermineTarget(task, math, env);
	if (target == RuTargetNone()) {
		env.out.println("no target for reprove-coverage");
		Some(state);
	} else {
		max_depth   = ruTaskIntArg(task, "max-depth",      5);
		max_size    = ruTaskIntArg(task, "max-size",       4096);
		attempts    = ruTaskIntArg(task, "attempts",       3);
		max_iters   = ruTaskIntArg(task, "max-iterations", 5);
		bfs_depth   = ruTaskIntArg(task, "bfs-depth",      3);
		bfs_size    = ruTaskIntArg(task, "bfs-size",       4096);
		// Per-theorem wall-clock budget — read directly so ruMapFnComm cannot
		// divide it across theorems.
		th_time_limit = ruParseTime(ruTaskStringArg(task, "time-limit", "60s"));
		// Compute how many theorems match the target so we can set the map-level
		// time budget to th_time_limit * N / P, ensuring each theorem gets its
		// full per-theorem budget from ruMapFnComm's outer ruEvalTimed3.
		n_theorems = i2d(length(filter(
			getTreeValues(ruDeclsTheorems(math.decls)),
			\th -> ruTargetPredicate(target)(th) && ruTheoremIsProved(th)
		)));
		p_count = max(1.0, i2d(availableProcessors()));
		map_time_s = n_theorems * th_time_limit / p_count;
		// If job-time-limit is set, cap total time but keep per-theorem budget intact
		// by taking the max (so the outer timer never fires before th_time_limit).
		job_time_str = ruTaskStringArg(task, "job-time-limit", "");
		map_time_capped = if (job_time_str != "")
			max(map_time_s, ruParseTime(job_time_str))
		else
			map_time_s;
		// map_time_capped is in ms (ruParseTime units); convert to whole seconds for the string.
		job_task = RuTask(task with args = setTree(task.args, "time-limit", flow(i2s(round(map_time_capped / 1000.0)) + "s")));
		index       = ruMakeIndexForTarget(target, math, env);
		step_index  = ruBuildStepIndex(math, 3);

		output_key  = ruTaskStringArg(task, "output", "");
		lang        = math.decls.lang;

		total_green  = ref 0;
		total_yr     = ref 0;
		total_yb     = ref 0;
		total_red    = ref 0;
		theorem_count = ref 0;
		proved_count  = ref 0;
		all_examples  = ref [];
		inc_th        = ruAtomicIntInc(theorem_count);
		inc_prov      = ruAtomicIntInc(proved_count);
		add_green     = ruAtomicIntInc(total_green);
		add_yr        = ruAtomicIntInc(total_yr);
		add_yb        = ruAtomicIntInc(total_yb);
		add_red       = ruAtomicIntInc(total_red);
		push_example  = ruAtomicRefArrayPush(all_examples);

		cover_fn = \decl, __, env1 -> {
			th = cast(decl : RuDecl -> RuTheorem);
			if (ruTheoremIsProved(th)) {
				res = ruReproveCoverageTheorem(
					th, task.args, index, th_time_limit,
					max_depth, max_size, attempts, max_iters, bfs_depth, bfs_size, math, env1, step_index
				);
				inc_th(1);
				add_green(res.green);
				add_yr(res.yellow_replay);
				add_yb(res.yellow_bfs);
				add_red(res.red);
				if (res.proved) inc_prov(1);
				if (output_key != "") {
					th_name  = id2s(th.info.id);
					examples = ruCollectColoredExamples(res.colored, th_name, "", 0, lang);
					iter(examples, \ex -> push_example(ex));
					if (ruVerbose(env1.conf) > 0) {
						env1.out.println(
							th_name + ": " +
							"green=" + i2s(res.green) +
							" yellow-replay=" + i2s(res.yellow_replay) +
							" yellow-bfs=" + i2s(res.yellow_bfs) +
							" red=" + i2s(res.red) +
							" iters=" + i2s(res.iters) +
							" examples=" + i2s(length(examples)) +
							(if (res.proved) " PROVED" else "")
						);
					}
				} else {
					if (ruVerbose(env1.conf) > 0) {
						env1.out.println(
							id2s(th.info.id) + ": " +
							"green=" + i2s(res.green) +
							" yellow-replay=" + i2s(res.yellow_replay) +
							" yellow-bfs=" + i2s(res.yellow_bfs) +
							" red=" + i2s(res.red) +
							" iters=" + i2s(res.iters) +
							(if (res.proved) " PROVED" else "")
						);
					}
				}
			}
			RuMappedDecl(true, false, decl)
		};

		new_state = ruMapFnComm(
			RuUnit(job_task, state, env.out),
			RuMapFn(
				RuMapFnInfo(
					"reprove-coverage",
					\decl -> ruTargetPredicate(target)(decl) && ruDeclIsTheorem(decl),
					\__ -> 1.0,
					\ -> "green=" + i2s(^total_green) +
						" yellow-replay=" + i2s(^total_yr) +
						" yellow-bfs=" + i2s(^total_yb) +
						" red=" + i2s(^total_red)
				),
				cover_fn
			)
		);

		g = ^total_green; yr = ^total_yr; yb = ^total_yb; r = ^total_red;
		tot = g + yr + yb + r;
		env.out.println(
			"=== reprove-coverage results ===\n" +
			"theorems:      " + i2s(^theorem_count) + "\n" +
			"proved:        " + i2s(^proved_count) + " / " + i2s(^theorem_count) + "\n" +
			"green:         " + i2s(g)  + (if (tot > 0) " (" + d2s(i2d(g) /i2d(tot)*100.0) + "%)" else "") + "\n" +
			"yellow-replay: " + i2s(yr) + (if (tot > 0) " (" + d2s(i2d(yr)/i2d(tot)*100.0) + "%)" else "") + "\n" +
			"yellow-bfs:    " + i2s(yb) + (if (tot > 0) " (" + d2s(i2d(yb)/i2d(tot)*100.0) + "%)" else "") + "\n" +
			"red:           " + i2s(r)  + (if (tot > 0) " (" + d2s(i2d(r) /i2d(tot)*100.0) + "%)" else "")
		);

		n_ex = if (output_key != "") {
			examples = ^all_examples;
			n = length(examples);
			ru_root = ruOptsString(conf.opts, "ru-root", ".");
			out_path = pathCombine(ru_root, "db/" + output_key + ".json");
			if (!setFileContent(out_path, json2stringFormatted(JsonArray(examples)))) {
				env.out.println("reprove-coverage: failed to write " + out_path);
			} else {
				env.out.println("saved " + i2s(n) + " examples to " + out_path);
			};
			n
		} else 0;

		Some(RuState(new_state with
			vars = setTree(new_state.vars, "reprove-coverage", pairs2tree([
				Pair("theorem-count",  flow(^theorem_count)),
				Pair("proved-count",   flow(^proved_count)),
				Pair("green",          flow(g)),
				Pair("yellow-replay",  flow(yr)),
				Pair("yellow-bfs",     flow(yb)),
				Pair("red",            flow(r)),
				Pair("example-count",  flow(n_ex))
			]))
		))
	}
}
