import base/util/timer;
import ru/cache/cache;
import ru/parse/util;

export {
	RuLoaded ::= RuRawSource, RuSource;

	ruLoadAll(env : RuEnv, module : int, from_cache : (int) -> Maybe<RuSource>) -> Maybe<Tree<int, RuLoaded>>;
	// Like ruLoadAll, but reports progress: info_source per loaded module, info_total at completion.
	ruLoadAllInfo(env : RuEnv, module : int, from_cache : (int) -> Maybe<RuSource>, info_source : (string, string) -> void, info_total : (string, string) -> void) -> Maybe<Tree<int, RuLoaded>>;
	ruLoadOne(env : RuEnv, module : int, from_cache : (int) -> Maybe<RuSource>) -> Maybe<RuLoaded>;

	ruLoader = RuLoader(
		"/*", "*/", "//", "\n", "import", ";;", ".ru", 
		ruCacheCodeLoader
	);

	ruCacheCodeLoader(module : int, env : RuEnv) -> Maybe<RuCode>;

	ruRawSourceFromCode(code : RuCode, env : RuEnv) -> RuRawSource;
}

ruCacheCodeLoader(module : int, env : RuEnv) -> Maybe<RuCode> {
	cached = ruCodeCacheGet(module, env);
	if (ruCodeIsDefined(cached)) Some(cached) else {
		ruFileCodeLoader(module, env);
	}
}

ruLoadAll(env : RuEnv, module : int, from_cache : (int) -> Maybe<RuSource>) -> Maybe<Tree<int, RuLoaded>> {
	ruLoadAllInfo(env, module, from_cache, nop2, nop2);
}

ruLoadAllInfo(env : RuEnv, module : int, from_cache : (int) -> Maybe<RuSource>, info_source : (string, string) -> void, info_total : (string, string) -> void) -> Maybe<Tree<int, RuLoaded>> {
	err_count = ref 0;
	timer = ruMakeTimer();
	loaded = ruLoadImports([module], ruAddErrCounter2Env(env, err_count), from_cache, makeTree(), info_source);
	if (^err_count == 0) {
		// Always invoke the callback; it is a nop unless the script supplied a lambda.
		info_total(i2s(sizeTree(loaded)), ruTimePassed2s(timer));
		Some(loaded);
	} else {
		env.out.error(strRight(ruLoader.ext, 1) + " failed to load: '" + id2s(module) + "'", []);
		None();
	}
}

ruLoadOne(env : RuEnv, module : int, from_cache : (int) -> Maybe<RuSource>) -> Maybe<RuLoaded> {
	switch (from_cache(module)) {
		Some(src): {
			Some(src);
		}
		None(): {
			cast(ruLoadRawSource(module, env, ruLoader) : Maybe<RuRawSource> -> Maybe<RuLoaded>);
		}
	}
}

ruLoadImports(imports : [int], env : RuEnv, from_cache : (int) -> Maybe<RuSource>, acc : Tree<int, RuLoaded>, info_source : (string, string) -> void) -> Tree<int, RuLoaded> {
	if (imports == []) acc else {
		timer = ruMakeTimer();
		loaded : [RuLoaded]  = filtermap(ruConcurrent(map(imports, \imp -> \env1 -> ruLoadOne(env1, imp, from_cache)), env), idfn);
		// Per-source progress; nop unless the script supplied an info-source lambda.
		// id2s_ (NOT id2s): the arg is evaluated eagerly even for the nop2 default,
		// and a loaded module's id may not be registered (e.g. set's large id space)
		// — id2s would crash the whole load; id2s_ yields "" instead.
		iter(loaded, \l -> info_source(id2s_(ruSourceModule(l)), ruTimePassed2s(timer)));
		acc1 = fold(loaded, acc, \ac, l -> setTree(ac, ruSourceModule(l), l));
		new_imports = fold(loaded, makeSet(), \ac, l ->
			fold(ruSourceImports(l), ac, \a, p -> {
				imp = s2id(ruTrimPath(id2s(p), env.conf, ruLoader.ext));
				if (containsKeyTree(acc1, imp)) a else insertSet(a, imp);
			})
		);
		ruLoadImports(set2array(new_imports), env, from_cache, acc1, info_source)
	}
}

ruRawSourceFromCode(code : RuCode, env : RuEnv) -> RuRawSource {
	ruLoadRawSourceFromCode(code, env, ruLoader);
}
