import math/stringmath;
import ru/parse/exps/parser;
import ru/src;
import ru/util/math;

export {
	ruParseExps(types: [int], nodes : [RuTermNode], lang : RuLang, place : RuPlace, env : RuEnv) -> Maybe<[RuExp]>;
	ruParseExp(term: RuTerm, lang : RuLang, place : RuPlace, env : RuEnv) -> Maybe<RuExp>;
	// Invalidate the cached lang FIRST-consts table. Call once per parse pass
	// (ruCreateAssertions) — the lang it is computed from differs between passes
	// (e.g. each sync-file reparse builds a fresh merged lang).
	ruInvalidateLangFirstConsts() -> void;
}

ruParseExp(term: RuTerm, lang : RuLang, place : RuPlace, env : RuEnv) -> Maybe<RuExp> {
	maybeBind(ruParseExps([term.type], term.nodes, lang, place, env), \es ->
		if (length(es) != 1) None() else Some(es[0])
	)
}

ruCreateTypeParsers(nodes : [RuTermNode], lang : RuLang, env : RuEnv) -> Tree<int, RuTypeParser> {
	types = foldTree(lang.types,
		makeTree(),
		\id, type, acc -> setTree(acc, id, ruMakeTypeParser(type, env))
	);
	symbs = fold(nodes, makeSet(), \acc, node ->
		switch (node) {
			RuVar(__, type): acc;
			RuConstRef(c): insertSet(acc, c);
		}
	);
	fold(
		filter(
			getTreeValues(lang.rules),
			\rule -> forall(rule.term.nodes, \node ->
				switch (node) {
					RuConstRef(c): containsSet(symbs, c);
					default: true;
				}
			)
		),
		types,
		\acc, rule -> ruAddRule2TypeParserTree(rule, acc, env)
	);
}

// Global cache: FIRST sets computed once per parse pass from that pass's lang.
// Value: type_id -> set of constants that can appear as first token of any expression of that type.
// Keyed by an EPOCH bumped once per ruCreateAssertions pass (ruInvalidateLangFirstConsts),
// NOT by sizeTree(lang.rules): two different langs with the same rule count — a
// cross-project global server, or a same-count file edit — would otherwise reuse a
// stale table. One recompute per pass, reused across the pass's many expressions.
ru_lang_first_consts_epoch = ref 0;
ruLangFirstConstsCache : ref Pair<int, Tree<int, Set<int>>> = ref Pair(-1, makeTree());

ruInvalidateLangFirstConsts() -> void {
	ru_lang_first_consts_epoch := ^ru_lang_first_consts_epoch + 1;
}

ruGetLangFirstConsts(lang : RuLang) -> Tree<int, Set<int>> {
	cached = ^ruLangFirstConstsCache;
	ep = ^ru_lang_first_consts_epoch;
	if (cached.first == ep) cached.second
	else {
		fc = ruComputeLangFirstConsts(lang);
		ruLangFirstConstsCache := Pair(ep, fc);
		fc
	}
}

// Compute for each type the set of constants that can appear as the first token of any expression of that type.
// Uses the FULL lang (not filtered per-expression) so it can be cached.
// FIRST(t) = { c | rule for t starts with c } ∪ { c | rule for t starts with var of type t', c ∈ FIRST(t') }
ruComputeLangFirstConsts(lang : RuLang) -> Tree<int, Set<int>> {
	// Initialize all types with empty sets
	init = foldTree(lang.types, makeTree(), \id, __, acc -> setTree(acc, id, makeSet()));
	// Add direct first constants from rules starting with a constant
	with_direct = foldTree(lang.rules, init, \id, rule, acc ->
		if (length(rule.term.nodes) == 0) acc else
		switch (rule.term.nodes[0]) {
			RuConstRef(c): setTree(acc, rule.term.type, insertSet(lookupTreeDef(acc, rule.term.type, makeSet()), c));
			default: acc;
		}
	);
	// Propagate: rules starting with a variable of type t' contribute FIRST(t') to FIRST(rule.type)
	ruPropagateFirstConsts(with_direct, lang.rules)
}

ruPropagateFirstConsts(sets : Tree<int, Set<int>>, rules : Tree<int, RuRule>) -> Tree<int, Set<int>> {
	result = foldTree(rules, Pair(sets, false), \id, rule, acc ->
		if (length(rule.term.nodes) == 0) acc else
		switch (rule.term.nodes[0]) {
			RuVar(__, sub_type): {
				sub_first = lookupTreeDef(acc.first, sub_type, makeSet());
				curr = lookupTreeDef(acc.first, rule.term.type, makeSet());
				merged = mergeSets(curr, sub_first);
				if (sizeSet(merged) == sizeSet(curr)) acc
				else Pair(setTree(acc.first, rule.term.type, merged), true)
			}
			default: acc;
		}
	);
	if (!result.second) result.first
	else ruPropagateFirstConsts(result.first, rules)
}

RuParseAcc(
	exps : [RuExp],
	pos : int,
);

//counter = ref 0;
//debug = ref false;

ruParseExps(tps: [int], nodes : [RuTermNode], lang : RuLang, place : RuPlace, env : RuEnv) -> Maybe<[RuExp]> {
	if (length(nodes) == 0) {
		env.out.error("empty expression is met", []);
		None()
	} else {
		//counter := ^counter + 1;
		//debug := ^counter == 40;
		//println("COUNTER: " + i2s(^counter) + " EXP: " + ruTerm2s(RuTerm(tps[0], nodes, -1)));
		types = ruCreateTypeParsers(nodes, lang, env);
		first_consts = ruGetLangFirstConsts(lang);
		maybeBind(
			fold(tps,
				Some(RuParseAcc([], 0)),
				\macc, type -> maybeBind(macc,
					\acc -> switch (lookupTree(types, type)) {
						Some(tenv): {
							ret = maybeMap(
								ruParseExpr(
									RuParseEnv(nodes, types, first_consts, lang, env),
									acc.pos,
									RuParseStack(None(), acc.pos, acc.pos, type, tenv.trie, [])
								),
								\pair -> {
									/*exxx = RuExp(reverseA(pair.first), acc.pos);
									println("TYPE: " + id2s(type) + "=(" + i2s(type) + ") PARSED TYPE: " + id2s(ruExpType(exxx)) + "=(" + i2s(ruExpType(exxx)) + ")\n" +
										"RAW:\n" + strIndent(ruExpRPN2sFull(exxx)) + "\n" +
										"ruTypeParserTree2s:\n" + ruTypeParserTree2s(types) + "\n"
									);*/
									RuParseAcc(arrayPush(acc.exps, RuExp(reverseA(pair.first), acc.pos)), pair.second)
								}
							);
							if (ret == None()) {
								term_symbs = set2array(fold(nodes, makeSet(),
									\ac, node ->
										switch (node) {
											RuVar(__,__): ac;
											RuConstRef(c): insertSet(ac, c);
										}
								));
								err = "expr: '" + ruTypedTermNodes2s(nodes) + "' was not parsed" +
									(if (env.conf.verbose <= 1) "" else
									"pos: " + i2s(acc.pos) + "\n" +
									"parsed:\n" + strIndent(superglue(acc.exps, ruExpRPN2s, "\n")) + "\n" +
									"types:\n" + ruTypeParserTree2s(types) + "\n" +
									"term symbs: " + strGlue(map(term_symbs, id2s), ", ") + "\n" +
									"all rules:\n" + concatStrings(map(getTreeValues(lang.rules), \r -> "\t" + ruTerm2s(r.term) + "\n")));
								env.out.error(err, [place]);
								//ruCrash("parser failure:\n" + err + "\n\n");
							}
							ret
						}
						None(): {
							env.out.error("unknown type: '" + id2s(type) + "', term: " + ruTypedTermNodes2s(nodes), [place]);
							None();
						}
					}
				)
			), \acc: RuParseAcc -> if (acc.pos == length(nodes)) Some(acc.exps) else {
				env.out.error("some extra expression leftover is not parsed, term: " + ruTypedTermNodes2s(nodes), [place]);
				None();
			}
		)
	}
}

RuParseEnv(
	nodes : [RuTermNode],
	types : Tree<int, RuTypeParser>,
	first_consts : Tree<int, Set<int>>,
	lang : RuLang,
	env : RuEnv,
);

RuParseStack(
	parent : Maybe<RuParseStack>,
	start : int,
	curr : int,
	type_id : int,
	trie : RuTrie2<int, RuRuleNode>,
	expr : [[RuExpNode]],
);

ruDoConcatAReversed(i: int, expr : [[RuExpNode]], acc: [RuExpNode]) -> [RuExpNode] {
	if (i == -1) acc else {
		ruDoConcatAReversed(i - 1, expr, concat(acc, expr[i]))
	}
}

ruConcatAReversed(expr : [[RuExpNode]]) -> [RuExpNode] {
	ruDoConcatAReversed(length(expr) - 1, expr, [])
}

ruPopExprStack(env : RuParseEnv, pos : int, stack : RuParseStack) -> RuParseStack {
	switch (stack.trie.data) {
		Some(rf): {
			subexpr = ruConcatAReversed(stack.expr);
			full_expr = arrayPush(subexpr,
				RuRuleNode(
					rf.idType,
					ruMakeArityLen(ruArityLen2Arity(rf.arityLen), length(subexpr))
				),
			);
			switch (stack.parent) {
				Some(parent): {
					ruPopExprStack(env, pos,
						RuParseStack(parent with expr = arrayPush(parent.expr, full_expr))
					);
				}
				None():
					RuParseStack(stack with expr = [full_expr]);
			}
		}
		None(): stack;
	}
}


ruParseExprStep(pos : int, n: RuTrie2<int, RuRuleNode>, stack : RuParseStack, env : RuParseEnv) -> Maybe<Pair<[RuExpNode], int>> {
	poped = ruPopExprStack(env, pos, RuParseStack(stack with trie = n));
	if (ruTrie2IsEnd(poped.trie) && isNone(poped.parent)) {
		Some(Pair(poped.expr[0], pos + 1));
	} else {
		ruParseExpr(env, pos + 1, poped);
	}
}

ruParseExprTryVar(pos : int, type: int, n: RuTrie2<int, RuRuleNode>, stack : RuParseStack, env : RuParseEnv) -> Maybe<Pair<[RuExpNode], int>> {
	maybeBind(lookupTree(env.types, type),
		\tenv -> if (type == stack.type_id && stack.curr == stack.start) None() else {
			ruParseExpr(env, pos,
				RuParseStack(
					Some(RuParseStack(stack with trie = n)),
					pos, pos, type, tenv.trie, []
				)
			)
		}
	)
}

ruParseExprTrySupers(pos : int, var: int, type: int, stack : RuParseStack, env : RuParseEnv) -> Maybe<Pair<[RuExpNode], int>> {
	ruParseExprTrySupers1(pos, var, type, type, [], stack, env)
}

// chain: intermediate coercion rule nodes accumulated so far (innermost first, in sub-array postfix order)
ruParseExprTrySupers1(pos : int, var: int, orig_type: int, type: int, chain : [RuExpNode], stack : RuParseStack, env : RuParseEnv) -> Maybe<Pair<[RuExpNode], int>> {
	supers = lookupTreeDef(env.types, type, ruNoTypeParser).supers;
	foldTree(stack.trie.map1, None(), \tp, m, acc ->
		if (isSome(acc)) acc else {
			switch (lookupTree(supers, tp)) {
				Some(rule): {
					// Build full coercion chain: [RuVar, ...chain..., final_rule_node]
					// After reverseA in ruParseExps this becomes PREFIX: [final_rule, ...chain_rev..., RuVar]
					chain_len = length(chain);
					final_node = ruMakeRuleNode(rule.info.id, rule.term.type, 1, 1 + chain_len);
					sub_array = concat([RuVar(var, orig_type)], concat(chain, [final_node]));
					ruParseExprStep(pos, m, RuParseStack(stack with
						expr = arrayPush(stack.expr, sub_array)
					), env);
				}
				None(): {
					switch (ruParseExprTryVar(pos, tp, m, stack, env)) {
						Some(ret): Some(ret);
						None(): {
							foldTree(supers, None(), \t, int_rule, ac -> if (isSome(ac)) ac else {
								// Add intermediate coercion node to chain and recurse
								int_node = ruMakeRuleNode(int_rule.info.id, int_rule.term.type, 1, 1 + length(chain));
								ruParseExprTrySupers1(pos, var, orig_type, t, arrayPush(chain, int_node), stack, env)
							})
						}
					}
				}
			}
		}
	);
}

ruParseExpr(env : RuParseEnv, pos : int, stack0 : RuParseStack) -> Maybe<Pair<[RuExpNode], int>> {
	stack = RuParseStack(stack0 with curr = pos);
	switch (env.nodes[pos]) {
		RuVar(var, type): {
			switch (lookupTree(stack.trie.map1, type)) {
				Some(n): {
					new_stack = RuParseStack(stack with expr = arrayPush(stack.expr, [RuVar(var, type)]));
					switch (ruParseExprStep(pos, n, new_stack, env)) {
						Some(ret): Some(ret);
						None(): ruParseExprTrySupers(pos, var, type, stack, env);
					}
				}
				None(): ruParseExprTrySupers(pos, var, type, stack, env);
			}
		}
		RuConstRef(const): {
			// Only call ruParseExprTryVar(t, ...) if const can be the first token of any expression of type t.
			// Uses globally cached lang FIRST sets (O(1) per lookup).
			tryVarIfConstKnown = \t, v, ac ->
				if (isSome(ac)) ac else {
					switch (lookupTree(env.first_consts, t)) {
						None(): ac;
						Some(first): if (!containsSet(first, const)) ac
									 else ruParseExprTryVar(pos, t, v, stack, env)
					}
				};
			// Coercion fallback: coercion rules (single-variable) are excluded from the trie,
			// so when a constant can start an expression of a sub-type of t, try that sub-type
			// and wrap the result with the coercion rule.  For set.mm FIRST(setvar)={} so this
			// is always a no-op.  For kore-fol it handles Symbol/Variable constants as Pattern.
			// Note: S_tenv.supers maps S's super-types, so we invert: find S where S.supers[t] exists.
			tryVarViaCoercion = \t, v, ac ->
				if (isSome(ac)) ac else
				foldTree(env.types, ac, \s_id, s_tenv, ac2 ->
					if (isSome(ac2)) ac2 else
					if (s_id == t) ac2 else
					if (containsKeyTree(stack.trie.map1, s_id)) ac2 else
					switch (lookupTree(s_tenv.supers, t)) {
						Some(coerce_rule): switch (lookupTree(env.first_consts, s_id)) {
							None(): ac2;
							Some(sub_first):
								if (!containsSet(sub_first, const)) ac2
								else ruParseExprTryVar(pos, s_id,
									RuTrie2(
										Some(ruMakeRuleNode(coerce_rule.info.id, coerce_rule.term.type, 1, 0)),
										makeTree(), makeTree()
									),
									stack, env
								)
						};
						None(): ac2;
					}
				);
			tryAll = \t, v, ac -> tryVarViaCoercion(t, v, tryVarIfConstKnown(t, v, ac));
			switch (lookupTree(stack.trie.map2, const)) {
				Some(n): {
					switch (ruParseExprStep(pos, n, stack, env)) {
						Some(ret): Some(ret);
						None(): foldTree(stack.trie.map1, None(), tryAll);
					}
				}
				None(): foldTree(stack.trie.map1, None(), tryAll);
			}
		}
	}
}
