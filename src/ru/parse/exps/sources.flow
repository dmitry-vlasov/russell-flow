import base/stats;
import ru/parse/parse;
import ru/verify/math;
import ru/parse/exps/lang;
import ru/parse/exps/assertions;
import ru/parse/load;

export {
	ruCreateMath(sources : [RuAnySource], env : RuEnv) -> Maybe<RuMath>;
	ruCollectMathFast(sources : Tree<int, RuAnySource>, env : RuEnv) -> Maybe<RuMath>;
	ruParseFast(module : int, env : RuEnv) -> Maybe<RuSource>;
	ruParseSource2RuSource(parsed : RuParseSource, env : RuEnv) -> RuSource;
	// Ensure the project's global language cache is built before anything parses
	// against it. If the lang cache is empty (cold/deleted disk cache), read the
	// project roots once to populate it. SERIALIZED so that, under the server's
	// concurrent request handling, only ONE build runs and every other request
	// blocks on the lock until it finishes — instead of parsing against a
	// half-built language and flooding "unknown type: 'wff'". Idempotent + cheap
	// once loaded (the inner re-check returns immediately).
	ruEnsureProjectLoaded(env : RuEnv) -> void;
}

ru_project_load_lock = ref 0;

// The serialized worker (only one runs at a time; see ruEnsureProjectLoaded).
ruDoEnsureProjectLoaded = synchronizedUnaryFn(ru_project_load_lock, \env : RuEnv -> {
	if (sizeTree(ruLangCacheGet().rules) == 0) {
		iter(env.conf.projectRoots, \root -> {
			root_path = ruResolveRelativePath(root, env.conf.workingDir);
			if (fileExists(root_path)) {
				module = ruTrimPath(root_path, env.conf, ".ru");
				maybeApply(
					ruLoadAll(env, s2id(module), \id -> ruCacheGet(id, false, env)),
					\srcs -> { ruCollectMathFast(srcs, env); {} }
				);
			}
		});
		// Persist the id-table so the disk cache we just (re)built is reloadable:
		// the .cache files store absolute ids that are meaningless without __ids.txt,
		// so without this every restart re-runs this full rebuild.
		ruSaveIds(env);
	}
});

ruEnsureProjectLoaded(env : RuEnv) -> void {
	ruDoEnsureProjectLoaded(env);
}

ruCollectMathFast(sources : Tree<int, RuAnySource>, env : RuEnv) -> Maybe<RuMath> {
	ruCreateMath(getTreeValues(sources), env);
}

ruParseFast(module : int, env0 : RuEnv) -> Maybe<RuSource> {
	err_count = ref 0;
	env = ruAddErrCounter2Env(env0, err_count);
	maybeBind(ruLoadOne(env, module, \id -> ruCacheGet(id, true, env)), \loaded ->
		switch (loaded) {
			RuSource(__,__,__,__): Some(loaded);
			RuRawSource(__,__,__): {
				maybeBind(ruParseSource(loaded, env), \parsed -> {
					src = ruParseSource2RuSource(parsed, env);
					if (^err_count == 0) Some(src) else None();
				});
			}
		}
	);
}

ruParseSource2RuSource(parsed : RuParseSource, env : RuEnv) -> RuSource {
	// Block until the project language is built, so we never parse against a
	// half-built lang during the initial (cold-cache) load. Cheap outer check
	// keeps the already-loaded case lock-free.
	if (sizeTree(ruLangCacheGet().rules) == 0) ruEnsureProjectLoaded(env);
	decls : [RuDeclAux] = ruSources2AnyDecls([parsed]);
	// Parse against the global lang MERGED with THIS file's own lang decls. The
	// sync-file-* path (didOpen / file save) calls ruCacheRemove first, which strips
	// this file's rules/consts/types from the global lang cache before reparsing —
	// so an expression that uses a rule defined in the SAME file (e.g. df-an's body
	// uses `wa`, and both are in Logical_conjunction.ru) would otherwise fail with
	// "was not parsed". A SILENT merge (file's decls win): the sync path removed them
	// first so there is normally no overlap, but the cursor's ad-hoc reparse can run
	// while they are still in the global lang, and a duplicate-rule diagnostic there
	// would pollute the editor — the freshly parsed decls are authoritative.
	g = ruLangCacheGet();
	fl = ruCreateLang(decls, env);
	lang = RuLang(mergeTree(g.consts, fl.consts), mergeTree(g.types, fl.types), mergeTree(g.rules, fl.rules));
	assertions = ruCreateAssertions(decls, lang, env);
	ruCreateSource(parsed, RuDecls(lang, assertions), env);
}

ruCreateMath(sources : [RuAnySource], env0 : RuEnv) -> Maybe<RuMath> {
	err_count = ref 0;
	env = ruAddErrCounter2Env(env0, err_count);
	timer = ruMakeTimer();
	already_parsed = filtermap(sources, \src ->
		switch (src) {
			RuRawSource(__,__,__): None();
			RuParsed():            Some(src)
		}
	);
	raw = filtermap(sources, \src ->
		switch (src) {
			RuRawSource(__,__,__): Some(src);
			RuParsed():            None();
		}
	);
	parse_src_timer = ruMakeTimer();
	just_parsed : [RuParsed] = filtermap(
		concatA(ruConcurrent(map(
			ruParseSplitRawSources(raw),
			\srcs -> \env1 -> map(srcs, \src -> ruParseSource(src, env1))
		), env)), 
		idfn
	);
	parsed = ruParsedSourcesOrder(concat(just_parsed, already_parsed), env.out);
	all_decls = ruSources2AnyDecls(parsed);
	lang = ruCreateLang(all_decls, env);
	parse_exps_timer = ruMakeTimer();
	assertions = ruCreateAssertions(all_decls, lang, env);
	decls = RuDecls(lang, assertions);
	sources_tree = fold(parsed, makeTree(), \acc, src ->
		switch (src) {
			RuSource(__,__,__,info):      setTree(acc, info.id, src);
			RuParseSource(__,__,__,info): setTree(acc, info.id, ruCreateSource(src, decls, env));
		}
	);
	created = RuMath(sources_tree, decls);
	ruSaveIds(env);
	if (^err_count == 0) {
		Some(created);
	} else {
		None();
	}
}

ruParseSplitRawSources(raw : [RuRawSource]) -> [[RuRawSource]] {
	sum_length = fold(raw, 0.0, \acc, s -> acc + i2d(strlen(s.src)));
	length_per_processor = sum_length / i2d(availableProcessors());
	curr = makeVector(128);
	split = fold(raw, Pair([], 0.0), \acc, s -> {
		sum =  acc.second + i2d(strlen(s.src));
		if (sum < length_per_processor) {
			pushVector(curr, s);
			Pair(acc with second = sum);
		} else {
			slice = vector2array(curr);
			clearVector(curr);
			pushVector(curr, s);
			Pair(concat(acc.first, [slice]), 0.0);
		}
	});
	if (sizeVector(curr) == 0) split.first else {
		concat(split.first, [vector2array(curr)]);
	}
}

ruCreateSource(parse_src : RuParseSource, decls : RuDecls, env : RuEnv) -> RuSource {
	ru_src = RuSource(
		map(parse_src.imports, \imp -> RuImport(imp.module, imp.pos)),
		filtermap(parse_src.decls, \decl -> ruFindDecl(decl.id, decls, env)),
		ruCreateComments(parse_src.comments, parse_src.info, env),
		parse_src.info
	);
	if (ruOptsString(env.conf.opts, "caching", "") != "0") {
		if (length(parse_src.decls) == length(ru_src.decls)) {
			ruCacheAdd(ru_src, true, env);
			ruDiskCacheSave(ru_src, env);
		} else {
			ruCacheRemove(parse_src.info.id, env);
			ruDiskCacheDelete(parse_src.info.id, env);
		}
	}
	ru_src;
}
