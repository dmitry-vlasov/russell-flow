import ru/unify/index;
import ru/prover/core/util;
import ru/unify/prod;
import ru/verify/theorem;

export {
	RuAssertionMatch(
		less : RuAssertion, // The less general assertion
		more : RuAssertion, // The more general assertion
		sub : RuSubst, // Substitution, which makes a less general from more general
		hypsMap : [int]   // The hypothesis map: for each more hypothesis the index of corresponding less hyp.
	);
	ruMatchAssertions(a1 : RuAssertion, a2 : RuAssertion, math : RuMath, env : RuEnv) -> Maybe<RuAssertionMatch>;

	// Replace all occurrences of less with more general
	// Rewrite every theorem that uses `match.less` to call the more-general
	// `match.more` instead. Returns Some(math) only if EVERY rewritten user still
	// verifies; None if any rewrite would be unsound (e.g. `match.more` needs
	// disjoint-variable conditions the user lacks), so the caller can keep
	// `match.less` rather than produce a disproved corpus.
	ruReplaceMatch(match : RuAssertionMatch, math : RuMath, name2thms : Tree<int, Set<int>>, env : RuEnv) -> Maybe<RuMath>;
	ruAssertionsMatch2s(match : RuAssertionMatch, math : RuMath) -> string;
}

ruMatchAssertions(a1 : RuAssertion, a2 : RuAssertion, math : RuMath, env : RuEnv) -> Maybe<RuAssertionMatch> {
	a2c = ruConstAssertion(a2, math);
	a2_hyps = fold(a2c.const.infer.hyps, ruMakeIndex(), \acc, hyp -> ruSetIndex(ruExp(hyp.stmt.exps[0]), hyp, acc));
	a1_hyps = a1.infer.hyps;
	time_limit = 10000.0;
	timer = ruMakeLimitedTimer(time_limit);
	check_disj = \s -> {
		unc_s = ruTransformSubst(s, a2c.env.unconst);
		switch (ruComputeDisjs(unc_s, a1.infer.vars.disjs, RuDisjsInherent(makeSet()))) {
			RuDisjsInherent(disjs): ruIsSubset(disjs, a2.infer.vars.disjs);
			RuDisjViolation(__,__): false;
		}
	}
	ret = maybeMap(
		maybeBind(ruUnifyExps([ruExp(a1.infer.prop.exps[0]), ruExp(a2c.const.infer.prop.exps[0])], ruEmptySubst, math, env),
			\sub -> {
				if (length(a1_hyps) == 0) Some(RuAssertionMatch(a2, a1, sub, [])) else {
					hyps_prod = CartProd(map(a1_hyps, \h -> {
						hyp_unified = ruUnifyIndex(
							ruApplySubst(ruExp(h.stmt.exps[0]), sub), a2_hyps, sub, 
							math, env
						);
						map(hyp_unified, \un -> RuSubData(un.sub, un.data));
					}));
					sub_unified = ruUnifySubsProd(hyps_prod, \__-> true, math, env);
					findmap(sub_unified, \sd -> {
						if (!check_disj(sd.sub)) {
							None();
						} else {
							Some(RuAssertionMatch(a2, a1, sd.sub, 
								map(a1.infer.hyps, \h -> sd.data[h.ind].ind)
							))
						}
					});
				}
			}
		),
		\match -> {
			match_sub = ruTransformSubst(match.sub, a2c.env.unconst);
			RuAssertionMatch(match with sub = ruReduceSubst(match_sub));
		}
	);
	maybeMap(ret, \match -> ruCheckAssertionsMatch(match, math, env));
	ret
}

ruAssertionsMatch2s(match : RuAssertionMatch, math : RuMath) -> string {
	"sub:\n" + strIndent(ruSubst2s(match.sub, math)) + "\n" +
	"hyps map: [" + strGlue(map(match.hypsMap, i2s), ", ") + "]";
}

ruCheckAssertionsMatch(match : RuAssertionMatch, math : RuMath, env : RuEnv) -> void {
	a1 = match.more;
	a2 = match.less; 
	check_exps_are_eq = \e1, e2, i -> {
		e1_prime = ruApplySubst(e1, match.sub);
		if (e2.nodes != e1_prime.nodes) {
			ruCrash(
				"Error: matched propositions doesn't coincide:\n" +
				"more:\n" + ruDeclShort2s(match.more, math) + "\n" +
				"less:\n" + ruDeclShort2s(match.less, math) + "\n" +
				"match:\n" + strIndent(ruAssertionsMatch2s(match, math)) + "\n" +
				(if (i < 0) "" else "hyp ind: " + i2s(i) + "\n") +
				ru2s(e2, math) + "\n" +
				ru2s(e1_prime, math) + "\n" +
				ruExpRPN2s(e2) + "\n" +
				ruExpRPN2s(e1_prime) + "\n"
			);
		}
	}
	if (length(match.hypsMap) != ruArity(a1)) {
		ruCrash("Error: matched hyps lentgh doesn't match: " + i2s(length(match.hypsMap)) + " != " + i2s(ruArity(a1)));
	}
	check_exps_are_eq(ruExp(a1.infer.prop.exps[0]), ruExp(a2.infer.prop.exps[0]), -1);
	iter(a1.infer.hyps, \hyp ->
		check_exps_are_eq(ruExp(hyp.stmt.exps[0]), ruExp(a2.infer.hyps[match.hypsMap[hyp.ind]].stmt.exps[0]), hyp.ind)
	);
}

ruReplaceMatch(match : RuAssertionMatch, math : RuMath, name2uses : Tree<int, Set<int>>, env : RuEnv) -> Maybe<RuMath> {
	// The more-general target must still exist: in a chain of removals an earlier
	// step may already have removed it, and rewriting to a removed assertion would
	// dangle. Refuse in that case (caller keeps `match.less`).
	if (!containsKeyTree(math.decls.assertions, match.more.info.id)) None() else {
	uses = filtermap(
		set2array(lookupTreeDef(name2uses, match.less.info.id, makeSet())),
		\id -> maybeBind(lookupTree(math.decls.assertions, id), ruDecl2Theorem)
	);
	// Thread Maybe<RuMath>: as soon as one user cannot be soundly rewritten the
	// whole replacement fails (None), so the caller keeps `match.less` and no
	// partial rewrite leaks out.
	fold(uses, Some(math), \acc_m : Maybe<RuMath>, th ->
		maybeBind(acc_m, \acc -> {
						new_proof = ruRewriteProofMatch(th.proof, match, env);
			new_th = ruUpdateTheoremVars(RuTheorem(th with proof = new_proof));
			candidate = ruMathReplaceDecl(acc, new_th, env);
			// Soundness gate: the rewritten proof must not require more disjoint-
			// variable conditions than the theorem declares. ruVerifyTheorem
			// recomputes the required $d and checks ruSubsetDisjs.
			if (ruIsVerified(ruVerifyTheorem(new_th, candidate, env))) {
				Some(candidate);
			} else {
								None();
			}
		})
	);
	}
}

// Rewrite every step that calls `match.less` to call `match.more` (remapping the
// hypothesis refs via match.hypsMap), recursing into inline sub-proofs so uses
// hidden inside treefy-created lemmas are rewritten too. A normal step's `proof`
// is ruNoProof (no steps), so the recursion terminates.
ruRewriteProofMatch(proof : RuProof, match : RuAssertionMatch, env : RuEnv) -> RuProof {
	RuProof(proof with
		steps = map(proof.steps, \step -> {
			s = if (step.assertion != match.less.info.id) step else {
								RuStep(step with
					assertion = match.more.info.id,
					refs = map(match.hypsMap, \i -> step.refs[i])
				);
			};
			RuStep(s with proof = ruRewriteProofMatch(s.proof, match, env));
		})
	);
}
