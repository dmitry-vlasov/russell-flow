// Unilambda — minimal proof-term parser.
//
// Parses the bare application-tree surface used by the MVP `eval`:
//
//   term  := ident ( '(' args? ')' )?
//   args  := term ( ',' term )*
//   ident := [A-Za-z0-9_-*.]+
//
// A bare identifier parses to `UniVar`; `ident(...)` parses to `UniApp`.
// Whether a `UniVar` is a metavariable or a nullary application is decided at
// eval time by whether its name resolves to an assertion. Formula leaves and
// the full `.uni` clause language (with the Russell expression grammar) are a
// later increment — this parser handles only the proof-term tree.

import uni/ast;
import ru/src;   // s2id / id2s

export {
	UniParseRes ::= UniParsed, UniParseErr;
		UniParsed(term : UniTerm, pos : int);
		UniParseErr(msg : string, pos : int);

	// Parse a whole proof term, requiring all (non-whitespace) input consumed.
	uniParse(s : string) -> UniParseRes;
}

uniParse(s : string) -> UniParseRes {
	switch (uniParseTerm(s, 0)) {
		UniParseErr(m, p): UniParseErr(m, p);
		UniParsed(term, pos): {
			end = uniSkipWs(s, pos);
			if (end == strlen(s)) UniParsed(term, end)
			else UniParseErr("unexpected trailing input", end);
		}
	}
}

uniParseTerm(s : string, i0 : int) -> UniParseRes {
	i = uniSkipWs(s, i0);
	id_end = uniReadIdent(s, i);
	if (id_end == i) UniParseErr("expected an identifier", i) else {
		name = substring(s, i, id_end - i);
		j = uniSkipWs(s, id_end);
		if (j < strlen(s) && getCharAt(s, j) == "(") {
			uniParseApp(s, name, j + 1);
		} else {
			UniParsed(UniVar(s2id(name)), id_end);
		}
	}
}

// Parse `args? ')'` starting just after '(' and build the application node.
uniParseApp(s : string, name : string, i0 : int) -> UniParseRes {
	i = uniSkipWs(s, i0);
	if (i < strlen(s) && getCharAt(s, i) == ")") {
		UniParsed(UniApp(s2id(name), []), i + 1);
	} else {
		uniParseArgList(s, i, [], \args, p -> UniParsed(UniApp(s2id(name), args), p));
	}
}

// Collect comma-separated terms until ')'. `k` receives the args and end pos.
uniParseArgList(s : string, i0 : int, acc : [UniTerm], k : ([UniTerm], int) -> UniParseRes) -> UniParseRes {
	switch (uniParseTerm(s, i0)) {
		UniParseErr(m, p): UniParseErr(m, p);
		UniParsed(term, p): {
			acc1 = arrayPush(acc, term);
			j = uniSkipWs(s, p);
			if (j >= strlen(s)) UniParseErr("expected ',' or ')'", j)
			else if (getCharAt(s, j) == ",") uniParseArgList(s, j + 1, acc1, k)
			else if (getCharAt(s, j) == ")") k(acc1, j + 1)
			else UniParseErr("expected ',' or ')'", j);
		}
	}
}

uniSkipWs(s : string, i : int) -> int {
	if (i < strlen(s) && uniIsWs(getCharAt(s, i))) uniSkipWs(s, i + 1) else i;
}

uniReadIdent(s : string, i : int) -> int {
	if (i < strlen(s) && uniIsIdentChar(getCharAt(s, i))) uniReadIdent(s, i + 1) else i;
}

uniIsWs(c : string) -> bool {
	c == " " || c == "\t" || c == "\n" || c == "\r";
}

uniIsIdentChar(c : string) -> bool {
	strContains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-*.", c);
}
