// Unilambda — commands.
//
// `uni-eval term="ax-mp(x, ax-mp(y, z))"` parses the proof term, evaluates it
// against the loaded math, and prints the most-general statement it proves:
//
//   ax-mp(x, ax-mp(y, z))  ==>  \ |- ph, |- ( ph -> ( ps -> ch ) ), ... |- ch
//
// The clause/REPL surface and `uni-uneval` come in later increments.

import comm;
import unit;
import uni/ast;
import uni/parse;
import uni/eval;
import uni/run;
import uni/bound;
import ru/src;          // RuStmt, RuExp, RuVar
import ru/math;         // RuMath
import ru/subst;        // ruApplySubst
import ru/util/math;    // ruMathFromSources
import ru/util/src;     // ruExp2Vars
import ru/util/src2s;   // ruExp
import ru/util/exp2s;   // ruExp2s
import base/task;       // ruTaskStringArg
import base/conf;       // ruResolveRelativePath, RuConf
import base/util/fs;    // getFileContent, fileExists
import base/dir;        // getRussellDir
import base/env;        // RuEnv

export {
	uniCommands : [RuComm];

	// Parse a unilambda proof-term string, evaluate it against `math`, and
	// render the resulting `\ hyps |- prop` statement (or an error message).
	// Shared by the `uni-eval` command and the `server=unilambda` REPL.
	uniRenderEval(term_str : string, math : RuMath, env : RuEnv) -> string;
}

// Resolve a `.uni` file argument: relative to the working directory if it
// exists there, otherwise relative to the russell scripts dir (so bundled test
// fixtures can be referenced as e.g. `test/nat.uni` from any working directory).
uniResolveUniFile(file : string, conf : RuConf) -> string {
	cwd_path = ruResolveRelativePath(file, conf.workingDir);
	if (fileExists(cwd_path)) cwd_path else getRussellDir() + "/scripts/" + file;
}

uniRenderEval(term_str : string, math : RuMath, env : RuEnv) -> string {
	switch (uniParse(term_str)) {
		UniParseErr(m, p): "parse error: " + m + " (at offset " + i2s(p) + ")";
		UniParsed(term, __): switch (uniEval(term, math, env)) {
			UniErr(m): m;
			UniOk(prop, ev): {
				leaves = uniTermLeaves(term, \n -> uniIsAssertion(n, math));
				hyps = filtermap(leaves, \n ->
					maybeMap(lookupTree(ev.leaves, n), \st -> uniApplyStmt(ev.sub, st))
				);
				hyps_s = strGlue(map(hyps, \h -> uniStmtBare2s(h, math)), ", ");
				prop_s = uniStmtBare2s(uniApplyStmt(ev.sub, prop), math);
				"\\ " + (if (hyps_s == "") "" else hyps_s + " ") + "|- " + prop_s;
			}
		}
	}
}

uniCommands = [
	RuComm(
		RuCommInfo(
			"uni-eval", "uni",
			"evaluate a unilambda proof term to the statement it proves", "",
			false, false,
			[RuCommArg("term", false, "proof term, e.g. \"ax-mp(x, ax-mp(y, z))\"", "")],
			[]
		),
		ruRunUniEval
	),
	RuComm(
		RuCommInfo(
			"uni-run", "uni",
			"run a .uni clause program: reduce each `eval` query to normal form", "file",
			false, false,
			[RuCommArg("file", false, "path to a .uni clause file", "")],
			[]
		),
		ruRunUniRun
	),
	RuComm(
		RuCommInfo(
			"uni-brun", "uni",
			"run a bound .uni program (clauses over real Russell formulas) against the loaded math", "file",
			false, false,
			[RuCommArg("file", false, "path to a bound .uni file", "")],
			[]
		),
		ruRunUniBRun
	)
];

ruRunUniBRun(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	fuel = s2i(ruTaskStringArg(unit.task, "fuel", "15"));
	file = ruTaskStringArg(unit.task, "file", "");
	if (file == "") {
		env.out.error("uni-brun: missing required 'file' argument", []);
		Some(unit.state);
	} else {
		path = uniResolveUniFile(file, unit.state.conf);
		if (!fileExists(path)) {
			env.out.error("uni-brun: file not found: '" + file + "'", []);
			Some(unit.state);
		} else {
			math = ruMathFromSources(unit.state.ru, env);
			lang = math.decls.lang;
			switch (uniParseBound(getFileContent(path), lang, env)) {
				UniProgErr(m): { env.out.error("uni-brun: " + m, []); Some(unit.state); }
				UniProgOk(prog, queries): {
					iter(queries, \q -> switch (q) {
						UniQEval(term, expect): {
							nf = uniReduce(prog, term, math, env, 1000000);
							got = uniBoundExp2s(nf, lang, prog.defined);
							env.out.println("eval  " + uniBoundExp2s(term, lang, prog.defined) + "  ==>  " + got);
							maybeApply(expect, \e -> {
								exp = uniBoundExp2s(e, lang, prog.defined);
								if (got != exp) {
									ruCrash("uni-brun assertion failed: eval " + uniBoundExp2s(term, lang, prog.defined) +
										" => expected '" + exp + "', got '" + got + "'");
								}
							});
						}
						UniQSolve(goal, target, expect): {
							sols = uniSolve(prog, goal, target, math, env, fuel);
							gvars = set2array(ruExp2Vars(goal));
							rendered = map(sols, \sub ->
								"{ " + strGlue(map(gvars, \v ->
									"?" + id2s(v.id) + " = " + uniBoundExp2s(ruApplySubst(RuExp([v], -1), sub), lang, prog.defined)
								), ", ") + " }"
							);
							env.out.println("solve " + uniBoundExp2s(goal, lang, prog.defined) + " = " +
								uniBoundExp2s(target, lang, prog.defined) +
								"  ==>  " + (if (rendered == []) "(no solutions)" else strGlue(rendered, "; ")));
							maybeApply(expect, \n -> {
								if (length(sols) != n) {
									ruCrash("uni-brun assertion failed: solve " + uniBoundExp2s(goal, lang, prog.defined) + " = " +
										uniBoundExp2s(target, lang, prog.defined) + " => expected " + i2s(n) +
										" solution(s), got " + i2s(length(sols)));
								}
							});
						}
					});
					Some(unit.state);
				}
			}
		}
	}
}

ruRunUniRun(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	fuel = s2i(ruTaskStringArg(unit.task, "fuel", "15"));
	file = ruTaskStringArg(unit.task, "file", "");
	if (file == "") {
		env.out.error("uni-run: missing required 'file' argument", []);
		Some(unit.state);
	} else {
		path = uniResolveUniFile(file, unit.state.conf);
		if (!fileExists(path)) {
			env.out.error("uni-run: file not found: '" + file + "'", []);
			Some(unit.state);
		} else {
			switch (uniParseProgram(getFileContent(path))) {
				UniProgErr(m): {
					env.out.error("uni-run: " + m, []);
					Some(unit.state);
				}
				UniProgOk(prog, queries): {
					math = ruMathFromSources(unit.state.ru, env);
					iter(queries, \q -> switch (q) {
						UniQEval(term, expect): {
							nf = uniReduce(prog, term, math, env, 1000000);
							got = uniExp2s(nf);
							env.out.println("eval  " + uniExp2s(term) + "  ==>  " + got);
							maybeApply(expect, \e -> {
								exp = uniExp2s(e);
								if (got != exp) {
									ruCrash("uni-run assertion failed: eval " + uniExp2s(term) +
										" => expected '" + exp + "', got '" + got + "'");
								}
							});
						}
						UniQSolve(goal, target, expect): {
							sols = uniSolve(prog, goal, target, math, env, fuel);
							gvars = set2array(ruExp2Vars(goal));
							rendered = map(sols, \sub ->
								"{ " + strGlue(map(gvars, \v ->
									"?" + id2s(v.id) + " = " + uniExp2s(ruApplySubst(RuExp([v], -1), sub))
								), ", ") + " }"
							);
							env.out.println("solve " + uniExp2s(goal) + " = " + uniExp2s(target) +
								"  ==>  " + (if (rendered == []) "(no solutions)" else strGlue(rendered, "; ")));
							maybeApply(expect, \n -> {
								if (length(sols) != n) {
									ruCrash("uni-run assertion failed: solve " + uniExp2s(goal) + " = " + uniExp2s(target) +
										" => expected " + i2s(n) + " solution(s), got " + i2s(length(sols)));
								}
							});
						}
					});
					Some(unit.state);
				}
			}
		}
	}
}

ruRunUniEval(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	math = ruMathFromSources(unit.state.ru, env);
	term_str = ruTaskStringArg(unit.task, "term", "");
	if (term_str == "") {
		env.out.error("uni-eval: missing required 'term' argument", []);
	} else {
		env.out.println(term_str + "  ==>  " + uniRenderEval(term_str, math, env));
	}
	Some(unit.state);
}

// Render a statement's expression(s) without the leading `|-` provability
// constant, so the unilambda turnstile can serve as the single hyps/conclusion
// separator (matching the `\ a, b |- c` spec notation).
uniStmtBare2s(stmt : RuStmt, math : RuMath) -> string {
	s = strGlue(map(stmt.exps, \e -> ruExp2s(ruExp(e), math.decls.lang)), " ");
	if (startsWith(s, "|- ")) strRight(s, 3) else s;
}
