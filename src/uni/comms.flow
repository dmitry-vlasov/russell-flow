// Unilambda — commands.
//
// `uni-eval term="ax-mp(x, ax-mp(y, z))"` parses the proof term, evaluates it
// against the loaded math, and prints the most-general statement it proves:
//
//   ax-mp(x, ax-mp(y, z))  ==>  \ |- ph, |- ( ph -> ( ps -> ch ) ), ... |- ch
//
// The clause/REPL surface and `uni-uneval` come in later increments.

import comm;
import unit;
import uni/ast;
import uni/parse;
import uni/eval;
import uni/run;
import ru/src;          // RuStmt, RuExp, RuVar
import ru/math;         // RuMath
import ru/subst;        // ruApplySubst
import ru/util/math;    // ruMathFromSources
import ru/util/src;     // ruExp2Vars
import ru/util/src2s;   // ruExp
import ru/util/exp2s;   // ruExp2s
import base/task;       // ruTaskStringArg
import base/conf;       // ruResolveRelativePath
import base/util/fs;    // getFileContent, fileExists
import base/env;        // RuEnv

export {
	uniCommands : [RuComm];

	// Parse a unilambda proof-term string, evaluate it against `math`, and
	// render the resulting `\ hyps |- prop` statement (or an error message).
	// Shared by the `uni-eval` command and the `server=unilambda` REPL.
	uniRenderEval(term_str : string, math : RuMath, env : RuEnv) -> string;
}

uniRenderEval(term_str : string, math : RuMath, env : RuEnv) -> string {
	switch (uniParse(term_str)) {
		UniParseErr(m, p): "parse error: " + m + " (at offset " + i2s(p) + ")";
		UniParsed(term, __): switch (uniEval(term, math, env)) {
			UniErr(m): m;
			UniOk(prop, ev): {
				leaves = uniTermLeaves(term, \n -> uniIsAssertion(n, math));
				hyps = filtermap(leaves, \n ->
					maybeMap(lookupTree(ev.leaves, n), \st -> uniApplyStmt(ev.sub, st))
				);
				hyps_s = strGlue(map(hyps, \h -> uniStmtBare2s(h, math)), ", ");
				prop_s = uniStmtBare2s(uniApplyStmt(ev.sub, prop), math);
				"\\ " + (if (hyps_s == "") "" else hyps_s + " ") + "|- " + prop_s;
			}
		}
	}
}

uniCommands = [
	RuComm(
		RuCommInfo(
			"uni-eval", "uni",
			"evaluate a unilambda proof term to the statement it proves", "",
			false, false,
			[RuCommArg("term", false, "proof term, e.g. \"ax-mp(x, ax-mp(y, z))\"", "")],
			[]
		),
		ruRunUniEval
	),
	RuComm(
		RuCommInfo(
			"uni-run", "uni",
			"run a .uni clause program: reduce each `eval` query to normal form", "file",
			false, false,
			[RuCommArg("file", false, "path to a .uni clause file", "")],
			[]
		),
		ruRunUniRun
	)
];

ruRunUniRun(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	file = ruTaskStringArg(unit.task, "file", "");
	if (file == "") {
		env.out.error("uni-run: missing required 'file' argument", []);
		Some(unit.state);
	} else {
		path = ruResolveRelativePath(file, unit.state.conf.workingDir);
		if (!fileExists(path)) {
			env.out.error("uni-run: file not found: '" + file + "'", []);
			Some(unit.state);
		} else {
			switch (uniParseProgram(getFileContent(path))) {
				UniProgErr(m): {
					env.out.error("uni-run: " + m, []);
					Some(unit.state);
				}
				UniProgOk(prog, queries): {
					math = ruMathFromSources(unit.state.ru, env);
					iter(queries, \q -> switch (q) {
						UniQEval(term): {
							nf = uniReduce(prog, term, math, env, 1000000);
							env.out.println("eval  " + uniExp2s(term) + "  ==>  " + uniExp2s(nf));
						}
						UniQSolve(goal, target): {
							sols = uniSolve(prog, goal, target, math, env, 12);
							gvars = set2array(ruExp2Vars(goal));
							rendered = map(sols, \sub ->
								"{ " + strGlue(map(gvars, \v ->
									id2s(v.id) + "* = " + uniExp2s(ruApplySubst(RuExp([v], -1), sub))
								), ", ") + " }"
							);
							env.out.println("solve " + uniExp2s(goal) + " = " + uniExp2s(target) +
								"  ==>  " + (if (rendered == []) "(no solutions)" else strGlue(rendered, "; ")));
						}
					});
					Some(unit.state);
				}
			}
		}
	}
}

ruRunUniEval(unit : RuUnit) -> Maybe<RuState> {
	env = ruUnitEnv(unit);
	math = ruMathFromSources(unit.state.ru, env);
	term_str = ruTaskStringArg(unit.task, "term", "");
	if (term_str == "") {
		env.out.error("uni-eval: missing required 'term' argument", []);
	} else {
		env.out.println(term_str + "  ==>  " + uniRenderEval(term_str, math, env));
	}
	Some(unit.state);
}

// Render a statement's expression(s) without the leading `|-` provability
// constant, so the unilambda turnstile can serve as the single hyps/conclusion
// separator (matching the `\ a, b |- c` spec notation).
uniStmtBare2s(stmt : RuStmt, math : RuMath) -> string {
	s = strGlue(map(stmt.exps, \e -> ruExp2s(ruExp(e), math.decls.lang)), " ");
	if (startsWith(s, "|- ")) strRight(s, 3) else s;
}
