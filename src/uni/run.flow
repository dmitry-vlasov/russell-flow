// Unilambda — clause interpreter, RuExp-native (one order-sorted universe).
//
// Terms ARE Russell expressions (`RuExp`): a function/constructor application
// `f(a, ...)` is a rule node, a `*`-suffixed identifier is a typed variable.
// Unification, matching and substitution are Russell's own order-sorted
// machinery (`ruUnifyExps`, `ruMatchExp`, `ruApplySubst`), so binding to real
// Russell math is just a matter of which sorts/symbols the terms use; the
// standalone case below uses a single universal sort, the bound case (later)
// uses wff/class/set with the loaded grammar.
//
// A `UniProgram` is a table of clauses `f(args) = body`, multiple per `f`.
// `f` with clauses is a defined function (reduced by narrowing); a symbol with
// no clauses is a constructor (data). `uniEval` reduces forward (call-by-value,
// first match, via `ruMatchExp`); `uniSolve` runs backward (narrowing, via
// `ruUnifyExps`), enumerating every substitution making `goal` reduce to `target`.

import ru/src;            // RuExp, RuVar, RuRuleNode, ruMakeRuleNode, arity/len/idType accessors
import ru/subst;          // RuSubst, ruApplySubst, ruMatchExp, ruMakeFresherSubst, ruEmptySubst
import ru/unify/exps;     // ruUnifyExps
import ru/util/src;       // ruExp2Vars
import ru/math;           // RuMath
import base/ids;          // s2id, id2s, tp2id
import base/env;          // RuEnv
import base/concurrent;   // ruAtomicIntAdd
import ds/tree;

export {
	UniClause(name : int, head : RuExp, body : RuExp);
	UniProgram(clauses : Tree<int, [UniClause]>, defined : Set<int>);
	ruEmptyUniProgram = UniProgram(makeTree(), makeSet());

	UniQuery ::= UniQEval, UniQSolve;
		UniQEval(term : RuExp);
		UniQSolve(goal : RuExp, target : RuExp);

	UniProgRes ::= UniProgOk, UniProgErr;
		UniProgOk(prog : UniProgram, queries : [UniQuery]);
		UniProgErr(msg : string);
	uniParseProgram(src : string) -> UniProgRes;

	// Forward: reduce a term to normal form (first-match, call-by-value).
	uniReduce(prog : UniProgram, e : RuExp, math : RuMath, env : RuEnv, fuel : int) -> RuExp;

	// Backward (narrowing): every substitution over `goal`'s variables for which
	// `goal` reduces to `target`. `fuel` bounds depth (narrowing is semi-decidable).
	uniSolve(prog : UniProgram, goal : RuExp, target : RuExp, math : RuMath, env : RuEnv, fuel : int) -> [RuSubst];

	// Build / inspect / render RuExp terms in unilambda's f(args) / x* notation.
	uniVarExp(name : int) -> RuExp;
	uniMkApp(rule : int, args : [RuExp]) -> RuExp;            // universal sort (standalone)
	uniMkAppS(rule : int, sort : int, args : [RuExp]) -> RuExp; // explicit result sort (bound mode)
	uniSortOf(e : RuExp) -> int;
	uniExpArgs(e : RuExp) -> [RuExp];
	uniExp2s(e : RuExp) -> string;

	// Truncate a `.uni` line at the first top-level '#' (comments outside backticks).
	uniStripLineComment(s : string) -> string;
}

uniStripLineComment(s : string) -> string { uniStripC(s, 0, false); }
uniStripC(s : string, i : int, inBt : bool) -> string {
	if (i >= strlen(s)) s else {
		c = getCharAt(s, i);
		if (c == "`") uniStripC(s, i + 1, !inBt)
		else if (c == "#" && !inBt) substring(s, 0, i)
		else uniStripC(s, i + 1, inBt);
	}
}

// The single universal sort for the standalone clause language. (When binding
// to real math, terms carry the actual wff/class/set sorts instead.)
uniSort() -> int { tp2id("uni-term"); }

uniVarExp(name : int) -> RuExp { RuExp([RuVar(name, uniSort())], -1); }

uniMkApp(rule : int, args : [RuExp]) -> RuExp { uniMkAppS(rule, uniSort(), args); }

uniMkAppS(rule : int, sort : int, args : [RuExp]) -> RuExp {
	kids = concatA(map(args, \a -> a.nodes));
	RuExp(concat([ruMakeRuleNode(rule, sort, length(args), length(kids))], kids), -1);
}

// The result sort carried by a term's head node (so reductions preserve sorts).
uniSortOf(e : RuExp) -> int {
	switch (e.nodes[0]) { RuVar(__, t): t; RuRuleNode(rt, __): ruIdType2Type(rt); }
}

// ---- RuExp tree navigation (flat prefix RPN; rule node `len` = #child nodes) ----

uniExpIsVar(e : RuExp) -> bool {
	switch (e.nodes[0]) { RuVar(__, __): true; RuRuleNode(__, __): false; }
}

uniExpRule(e : RuExp) -> int {
	switch (e.nodes[0]) { RuVar(__, __): -1; RuRuleNode(rt, __): ruIdType2Id(rt); }
}

uniExpArgs(e : RuExp) -> [RuExp] {
	switch (e.nodes[0]) {
		RuVar(__, __): [];
		RuRuleNode(__, al): uniExtractKids(e.nodes, 1, ruArityLen2Arity(al), []);
	}
}

uniExtractKids(nodes : [RuExpNode], off : int, k : int, acc : [RuExp]) -> [RuExp] {
	if (k == 0) acc else {
		span = switch (nodes[off]) { RuVar(__, __): 1; RuRuleNode(__, al): ruArityLen2Len(al) + 1; };
		uniExtractKids(nodes, off + span, k - 1, arrayPush(acc, RuExp(subrange(nodes, off, span), -1)));
	}
}

uniExp2s(e : RuExp) -> string {
	switch (e.nodes[0]) {
		RuVar(id, __): id2s(id) + "*";
		RuRuleNode(rt, __): {
			r = ruIdType2Id(rt);
			args = uniExpArgs(e);
			if (args == []) id2s(r) else id2s(r) + "(" + strGlue(map(args, uniExp2s), ", ") + ")";
		}
	}
}

// ---- clauses / freshening -------------------------------------------------

uniAddClause(prog : UniProgram, c : UniClause) -> UniProgram {
	UniProgram(
		setTree(prog.clauses, c.name, arrayPush(lookupTreeDef(prog.clauses, c.name, []), c)),
		insertSet(prog.defined, c.name)
	);
}

uniFreshenClause(c : UniClause, inc : (int) -> int) -> UniClause {
	vars = set2array(mergeSets(ruExp2Vars(c.head), ruExp2Vars(c.body)));
	fresh = ruMakeFresherSubst(vars, \v -> RuVar(s2id(id2s(v.id) + "_n" + i2s(inc(1))), v.type));
	UniClause(c.name, ruApplySubst(c.head, fresh), ruApplySubst(c.body, fresh));
}

// ---- forward evaluation (matching) ----------------------------------------

uniReduce(prog : UniProgram, e : RuExp, math : RuMath, env : RuEnv, fuel : int) -> RuExp {
	counter = ref 0;
	uniNormalize(prog, e, math, env, ruAtomicIntAdd(counter), fuel);
}

uniNormalize(prog : UniProgram, e : RuExp, math : RuMath, env : RuEnv, inc : (int) -> int, fuel : int) -> RuExp {
	if (fuel <= 0) e else {
		switch (e.nodes[0]) {
			RuVar(__, __): e;
			RuRuleNode(rt, __): {
				r = ruIdType2Id(rt);
				nargs = map(uniExpArgs(e), \a -> uniNormalize(prog, a, math, env, inc, fuel - 1));
				e2 = uniMkAppS(r, ruIdType2Type(rt), nargs);
				if (containsSet(prog.defined, r)) {
					uniFirstClause(prog, lookupTreeDef(prog.clauses, r, []), 0, e2, math, env, inc, fuel);
				} else e2;
			}
		}
	}
}

uniFirstClause(prog : UniProgram, clauses : [UniClause], i : int, e2 : RuExp, math : RuMath, env : RuEnv, inc : (int) -> int, fuel : int) -> RuExp {
	if (i >= length(clauses)) e2 else {
		c = uniFreshenClause(clauses[i], inc);
		switch (ruMatchExp(e2, c.head, math, env)) {
			None(): uniFirstClause(prog, clauses, i + 1, e2, math, env, inc, fuel);
			Some(sub): uniNormalize(prog, ruApplySubst(c.body, sub), math, env, inc, fuel - 1);
		}
	}
}

// ---- backward narrowing ---------------------------------------------------

uniSolve(prog : UniProgram, goal : RuExp, target : RuExp, math : RuMath, env : RuEnv, fuel : int) -> [RuSubst] {
	counter = ref 0;
	inc = ruAtomicIntAdd(counter);
	filtermap(uniNarrow(prog, goal, ruEmptySubst, math, env, inc, fuel), \p ->
		ruUnifyExps([p.first, ruApplySubst(target, p.second)], p.second, math, env)
	);
}

uniNarrow(prog : UniProgram, e : RuExp, sub : RuSubst, math : RuMath, env : RuEnv, inc : (int) -> int, fuel : int) -> [Pair<RuExp, RuSubst>] {
	if (fuel <= 0) [] else {
		e0 = ruApplySubst(e, sub);
		if (uniExpIsVar(e0)) [Pair(e0, sub)] else {
			r = uniExpRule(e0);
			sort = uniSortOf(e0);
			argSols = uniNarrowArgs(prog, uniExpArgs(e0), sub, math, env, inc, fuel);
			if (containsSet(prog.defined, r)) {
				concatA(map(argSols, \p ->
					concatA(map(lookupTreeDef(prog.clauses, r, []), \c0 -> {
						c = uniFreshenClause(c0, inc);
						ne = uniMkAppS(r, sort, p.first);
						switch (ruUnifyExps([ne, c.head], p.second, math, env)) {
							None(): [];
							Some(s2): uniNarrow(prog, c.body, s2, math, env, inc, fuel - 1);
						}
					}))
				));
			} else {
				map(argSols, \p -> Pair(uniMkAppS(r, sort, p.first), p.second));
			}
		}
	}
}

uniNarrowArgs(prog : UniProgram, args : [RuExp], sub : RuSubst, math : RuMath, env : RuEnv, inc : (int) -> int, fuel : int) -> [Pair<[RuExp], RuSubst>] {
	fold(args, [Pair([], sub)], \acc, arg ->
		concatA(map(acc, \pr ->
			map(uniNarrow(prog, arg, pr.second, math, env, inc, fuel), \q ->
				Pair(arrayPush(pr.first, q.first), q.second)
			)
		))
	);
}

// ---- parser ---------------------------------------------------------------

UniTPR ::= UniTPok, UniTPerr;
	UniTPok(term : RuExp, pos : int);
	UniTPerr(msg : string, pos : int);

uniParseProgram(src : string) -> UniProgRes {
	lines = strSplit(src, "\n");
	fold(lines, UniProgOk(ruEmptyUniProgram, []), \acc, line0 ->
		switch (acc) {
			UniProgErr(__): acc;
			UniProgOk(prog, queries): {
				line = trim2(uniStripLineComment(line0), " \t\r");
				if (line == "" || startsWith(line, "//")) acc
				else if (startsWith(line, "eval ")) {
					switch (uniParseCTerm(trim2(strRight(line, 5), " \t"), 0)) {
						UniTPerr(m, p): UniProgErr("query parse error in '" + line + "': " + m);
						UniTPok(term, __): UniProgOk(prog, arrayPush(queries, UniQEval(term)));
					}
				} else if (startsWith(line, "solve ")) {
					rest = trim2(strRight(line, 6), " \t");
					eq = strIndexOf(rest, "=");
					if (eq < 0) UniProgErr("solve query needs 'goal = target' in '" + line + "'") else {
						gp = uniParseCTerm(trim2(substring(rest, 0, eq), " \t"), 0);
						tp = uniParseCTerm(trim2(substring(rest, eq + 1, strlen(rest) - eq - 1), " \t"), 0);
						switch (gp) {
							UniTPerr(m, __): UniProgErr("solve goal parse error in '" + line + "': " + m);
							UniTPok(g, __): switch (tp) {
								UniTPerr(m, __): UniProgErr("solve target parse error in '" + line + "': " + m);
								UniTPok(tg, __): UniProgOk(prog, arrayPush(queries, UniQSolve(g, tg)));
							};
						}
					}
				} else {
					switch (uniParseClauseLine(line)) {
						UniClauseErr(m): UniProgErr("clause parse error in '" + line + "': " + m);
						UniClauseOk(c): UniProgOk(uniAddClause(prog, c), queries);
					}
				}
			}
		}
	);
}

UniClauseRes ::= UniClauseOk, UniClauseErr;
	UniClauseOk(clause : UniClause);
	UniClauseErr(msg : string);

// Parse one clause line `name = \ a1, a2 |- result`.
uniParseClauseLine(line : string) -> UniClauseRes {
	eq = strIndexOf(line, "=");
	if (eq < 0) UniClauseErr("expected '='") else {
		name = trim2(substring(line, 0, eq), " \t");
		rest = trim2(substring(line, eq + 1, strlen(line) - eq - 1), " \t");
		if (name == "") UniClauseErr("empty clause name")
		else if (!startsWith(rest, "\\")) UniClauseErr("expected '\\' after '='")
		else uniParseHead(s2id(name), name, trim2(strRight(rest, 1), " \t"), 0, []);
	}
}

uniParseHead(name : int, nameStr : string, s : string, i0 : int, acc : [RuExp]) -> UniClauseRes {
	i = uniCWs(s, i0);
	if (i < strlen(s) && getCharAt(s, i) == "|") uniParseResult(name, nameStr, s, i, acc) else {
		switch (uniParseCTerm(s, i)) {
			UniTPerr(m, __): UniClauseErr(m);
			UniTPok(term, p): {
				acc1 = arrayPush(acc, term);
				j = uniCWs(s, p);
				if (j >= strlen(s)) UniClauseErr("expected ',' or '|-'")
				else if (getCharAt(s, j) == ",") uniParseHead(name, nameStr, s, j + 1, acc1)
				else if (getCharAt(s, j) == "|") uniParseResult(name, nameStr, s, j, acc1)
				else UniClauseErr("expected ',' or '|-'");
			}
		}
	}
}

uniParseResult(name : int, nameStr : string, s : string, i : int, args : [RuExp]) -> UniClauseRes {
	if (i + 1 >= strlen(s) || getCharAt(s, i) != "|" || getCharAt(s, i + 1) != "-") {
		UniClauseErr("expected '|-'");
	} else {
		switch (uniParseCTerm(s, i + 2)) {
			UniTPerr(m, __): UniClauseErr(m);
			UniTPok(body, p): {
				if (uniCWs(s, p) == strlen(s)) UniClauseOk(UniClause(name, uniMkApp(name, args), body))
				else UniClauseErr("unexpected input after result");
			}
		}
	}
}

uniParseCTerm(s : string, i0 : int) -> UniTPR {
	i = uniCWs(s, i0);
	idEnd = uniCIdent(s, i);
	if (idEnd == i) UniTPerr("expected a term", i) else {
		ident = substring(s, i, idEnd - i);
		if (endsWith(ident, "*")) {
			UniTPok(uniVarExp(s2id(substring(ident, 0, strlen(ident) - 1))), idEnd);
		} else {
			j = uniCWs(s, idEnd);
			if (j < strlen(s) && getCharAt(s, j) == "(") uniParseCApp(s, ident, j + 1)
			else UniTPok(uniMkApp(s2id(ident), []), idEnd);
		}
	}
}

uniParseCApp(s : string, name : string, i0 : int) -> UniTPR {
	i = uniCWs(s, i0);
	if (i < strlen(s) && getCharAt(s, i) == ")") UniTPok(uniMkApp(s2id(name), []), i + 1)
	else uniParseCArgs(s, i, [], \args, p -> UniTPok(uniMkApp(s2id(name), args), p));
}

uniParseCArgs(s : string, i0 : int, acc : [RuExp], k : ([RuExp], int) -> UniTPR) -> UniTPR {
	switch (uniParseCTerm(s, i0)) {
		UniTPerr(m, p): UniTPerr(m, p);
		UniTPok(term, p): {
			acc1 = arrayPush(acc, term);
			j = uniCWs(s, p);
			if (j >= strlen(s)) UniTPerr("expected ',' or ')'", j)
			else if (getCharAt(s, j) == ",") uniParseCArgs(s, j + 1, acc1, k)
			else if (getCharAt(s, j) == ")") k(acc1, j + 1)
			else UniTPerr("expected ',' or ')'", j);
		}
	}
}

uniCWs(s : string, i : int) -> int {
	if (i < strlen(s) && uniCWsChar(getCharAt(s, i))) uniCWs(s, i + 1) else i;
}
uniCWsChar(c : string) -> bool { c == " " || c == "\t" || c == "\n" || c == "\r"; }

uniCIdent(s : string, i : int) -> int {
	if (i < strlen(s) && uniCIdentChar(getCharAt(s, i))) uniCIdent(s, i + 1) else i;
}
uniCIdentChar(c : string) -> bool {
	strContains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-.*", c);
}
