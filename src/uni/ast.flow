// Unilambda — abstract syntax of proof terms.
//
// A unilambda proof term is an application tree over rule/assertion names.
// A leaf (`UniVar`) is either a hypothesis/metavariable placeholder (if its
// name does not resolve to a known assertion) or a nullary application (if it
// does — e.g. an axiom `ax-1` written without parentheses). `UniApp` is an
// explicit application `name(arg, ...)`.
//
// `eval` (src/uni/eval.flow) computes the most-general statement such a term
// proves, by unifying each argument against the corresponding hypothesis of
// the applied assertion — the forward / verification direction.
//
// Recursive multi-clause definitions (UniClause/UniProgram) and the surface
// `.uni` language come in a later increment; this module is intentionally the
// bare proof-term tree the MVP eval operates on.

import ru/src;

export {
	UniTerm ::= UniVar, UniApp;
		// A leaf: either a free metavariable (hypothesis) or, when `name`
		// resolves to an assertion, a nullary application of that assertion.
		UniVar(name : int);
		// Application of a rule/assertion to argument terms.
		UniApp(name : int, args : [UniTerm]);

	uniTerm2s(t : UniTerm) -> string;
	// Distinct leaf names (genuine metavariables) in left-to-right
	// first-occurrence order, given the set of known assertion names.
	uniTermLeaves(t : UniTerm, isAssertion : (int) -> bool) -> [int];
}

uniTerm2s(t : UniTerm) -> string {
	switch (t) {
		UniVar(name): id2s(name);
		UniApp(name, args): id2s(name) + "(" + strGlue(map(args, uniTerm2s), ", ") + ")";
	}
}

uniTermLeaves(t : UniTerm, isAssertion : (int) -> bool) -> [int] {
	uniCollectLeaves(t, isAssertion, []);
}

uniCollectLeaves(t : UniTerm, isAssertion : (int) -> bool, acc : [int]) -> [int] {
	switch (t) {
		UniVar(name): {
			// An identifier that is an assertion is a nullary application,
			// not a leaf; a non-assertion identifier is a genuine metavariable.
			if (isAssertion(name) || contains(acc, name)) acc else arrayPush(acc, name);
		}
		UniApp(__, args): {
			// `name` of an application is always a rule reference, never a leaf.
			fold(args, acc, \ac, arg -> uniCollectLeaves(arg, isAssertion, ac));
		}
	}
}
