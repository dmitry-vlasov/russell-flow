// Interactive unilambda REPL (`server=unilambda`).
//
// A stateful read-eval-print loop over a loaded Russell math. Unlike the
// console server, RuState is threaded across lines, so you load the math once
// and then issue many queries against it:
//
//   uni> conf-load dir=./set
//   uni> read-ru file=set/.../Logical_implication.ru
//   uni> eval ax-mp(x, ax-1)
//   ax-mp(x, ax-1)  ==>  \ ph |- ( ps -> ph )
//
// Lines starting with `eval ` are unilambda proof terms, evaluated against the
// currently-loaded math (the Russell-formula surface). Every other line is run
// as an ordinary Russell script command (read-ru, conf-load, uni-run, …) with
// the resulting state carried into the next prompt.

import process;
import uni/comms;
import ru/util/math;   // ruMathFromSources

export {
	ruUnilambdaServer(env : RuEnv) -> void;
}

ruUnilambdaServer(env : RuEnv) -> void {
	env.out.println(
		"Unilambda REPL.\n"
		"  Load math:  conf-load dir=./<dataset>   then   read-ru file=<path.ru>\n"
		"  Query:      eval <proof-term>           e.g.   eval ax-mp(x, ax-1)\n"
		"  Other input runs as a Russell command (state persists). 'exit' to quit."
	);
	ruRunUnilambda(RuState(ruEmptyState with conf = env.conf), env);
	quit(0);
}

ruRunUnilambda(state : RuState, env : RuEnv) -> void {
	print("uni> ");
	line = trim2(readUntil("\n"), " \r\n\t");
	if (line == "exit" || line == "quit" || line == "bye" || line == ":q") {
		env.out.println("Bye.");
	} else if (line == "") {
		ruRunUnilambda(state, env);
	} else if (startsWith(line, "eval ")) {
		term_str = trim2(strRight(line, 5), " \t");
		math = ruMathFromSources(state.ru, env);
		env.out.println(term_str + "  ==>  " + uniRenderEval(term_str, math, env));
		ruRunUnilambda(state, env);
	} else {
		switch (ruParseScComm(line)) {
			Some(src): ruRunUnilambda(ruExecScript(src.comm, ruCommandsTree(), state, env.out), env);
			None(): {
				env.out.println("Syntax error: '" + line + "'");
				ruRunUnilambda(state, env);
			}
		}
	}
}
