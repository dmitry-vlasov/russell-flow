import ds/concur_hashmap;
import ds/vector;
import math/hash;
import text/binary;
import base/log;
import base/env;
import base/cache;

export {
	s2id_(s : string) -> int;
	s2id(string) -> int;
	id2s(id : int) -> string;
	// Non-crashing id2s: returns "" when id is not registered.
	id2s_(id : int) -> string;
	// Returns true when id was registered in this JVM session.
	ruIdRegistered(id : int) -> bool;
	ruSaveIds(env : RuEnv) -> void;
	ruReadIds(env : RuEnv) -> void;
	// Reload the persisted id table when the in-memory one is empty (e.g. after
	// `clear-ids`). The id table is otherwise loaded only once at process start,
	// so without this a `read` following a `clear-ids` in the SAME process (e.g.
	// `translate/mm2ru2mm X; <read-based command>` in one script) would hit
	// cached numeric ids with no string mapping ("Id N is not registred").
	ruEnsureIdsLoaded(env : RuEnv) -> void;
	ruIds() -> [string];
	ruIdsVersion() -> double;
	ruClearIds() -> void;

	// --- Type-id compaction (see ru/util/exp ruMakeIdType) ---
	// The packed idType reserves only ~12 bits for the type field, so a type id
	// stored there must be < 4096. General symbol ids (s2id) can exceed that
	// (parse order, or re-interning), so each general TYPE id is mapped to a dense
	// compact index in [0, 4096) used ONLY inside the packing. Grammar types are
	// few (≈3 in set.mm), so 4096 is ample; the rule field keeps the full 20 bits.
	// The mapping is append-only and persisted next to __ids.txt, so cached
	// (compact-encoded) expressions stay valid across sessions.
	ruTypeCompact(type_id : int) -> int;   // general type id -> compact (lazy, registers)
	ruTypeGeneral(compact : int) -> int;   // compact -> general type id (-1 if unknown)
	ruClearTypeIndex() -> void;
}

RU_MAX_TYPES = 4096;

RuIds(
	s2id : ConcurHashMap<string, int>,
	id2s : ConcurHashMap<int, string>,
	id_counter : ref int,
	was_modified : ref bool,
	version : ref double, // ids version
);

ru_ids = RuIds(
	makeConcurHashMap(fastHashString),
	makeConcurHashMap(idfn),
	ref 0,
	ref false,
	ref 0.0
);

// Set by `clear-ids`, reset once the canonical table is reloaded. Lets a `read`
// after a `clear-ids` in the SAME process (e.g. `translate/mm2ru2mm X` followed
// by a read-based command in one script) restore the persisted id numbering
// before resolving the cached numeric ids it depends on.
ru_ids_cleared = ref false;

ruIdsVersion() -> double {
	^(ru_ids.version);
}

ruClearIds() -> void {
	clearConcurHashMap(ru_ids.s2id);
	clearConcurHashMap(ru_ids.id2s);
	ru_ids.was_modified := false;
	ru_ids.id_counter := 0;
	ru_ids_cleared := true;
	ruClearTypeIndex();
}

// general type id -> compact, and the inverse dense list (compact -> general).
RuTypeIndex(g2c : ConcurHashMap<int, int>, c2g : Vector<int>, count : ref int);
ru_type_index = RuTypeIndex(makeConcurHashMap(idfn), makeVector(64), ref 0);

ruClearTypeIndex() -> void {
	clearConcurHashMap(ru_type_index.g2c);
	clearVector(ru_type_index.c2g);
	ru_type_index.count := 0;
}

do_type_compact = synchronizedUnaryFn(ru_type_index,
	\g ->
	if (containsKeyConcurHashMap(ru_type_index.g2c, g)) {
		getConcurHashMap(ru_type_index.g2c, g, -1);
	} else {
		c = ^(ru_type_index.count);
		if (c >= RU_MAX_TYPES) {
			ruCrash("too many grammar types (>= " + i2s(RU_MAX_TYPES) + "): packed idType type-field overflow");
		}
		setConcurHashMap(ru_type_index.g2c, g, c);
		pushVector(ru_type_index.c2g, g);
		ru_type_index.count := c + 1;
		c;
	}
);

ruTypeCompact(type_id : int) -> int {
	if (containsKeyConcurHashMap(ru_type_index.g2c, type_id)) {
		getConcurHashMap(ru_type_index.g2c, type_id, -1);
	} else {
		do_type_compact(type_id);
	}
}

ruTypeGeneral(compact : int) -> int {
	getVectorDef(ru_type_index.c2g, compact, -1);
}

// Persistence: the compact->general list (general type ids in compact order),
// restored so cached compact-encoded expressions decode to the same types.
ruTypeIndexList() -> [int] {
	vector2array(ru_type_index.c2g);
}
ruSetTypeIndexList(gids : [int]) -> void {
	ruClearTypeIndex();
	iter(gids, \g -> {
		setConcurHashMap(ru_type_index.g2c, g, ^(ru_type_index.count));
		pushVector(ru_type_index.c2g, g);
		ru_type_index.count := ^(ru_type_index.count) + 1;
	});
}

do_s2id = synchronizedUnaryFn(ru_ids, 
	\s ->
	if (containsKeyConcurHashMap(ru_ids.s2id, s)) {
		getConcurHashMap(ru_ids.s2id, s, -1);
	} else {
		id = atomicRefIntAddition(ru_ids.id_counter, 1);
		sets2id(s, id);
		id;
	}
);

s2id(s : string) -> int {
	if (containsKeyConcurHashMap(ru_ids.s2id, s)) {
		getConcurHashMap(ru_ids.s2id, s, -1);
	} else {
		ru_ids.was_modified := true;
		do_s2id(s);
	}
} 

s2id_(s : string) -> int {
	getConcurHashMap(ru_ids.s2id, s, -1);
}

id2s(id : int) -> string {
	if (id == -1) "" else
	if (!containsKeyConcurHashMap(ru_ids.id2s, id)) {
		ruCrash("Id '" + i2s(id) + "' is not registred in the id-to-string map");
		"";
	} else {
		str = getConcurHashMap(ru_ids.id2s, id, "");
		if (str == "") {
			ruCrash("getting empty string for id: " + i2s(id));
		}
		str;
	}
}

id2s_(id : int) -> string {
	getConcurHashMap(ru_ids.id2s, id, "");
}

ruIdRegistered(id : int) -> bool {
	id >= 0 && containsKeyConcurHashMap(ru_ids.id2s, id);
}

sets2id(s : string, id : int) -> void {
	if (s == "" || id < 0) {
		if (s == "") {
			ruCrash("setting empty string for id: " + i2s(id));
		} else {
			ruCrash("id is less then 0: " + i2s(id));
		}
	} else if (containsKeyConcurHashMap(ru_ids.s2id, s)) {
		ruCrash(
			"String '" + s + "' is already in the string-to-id map, corresponding id: " + i2s(s2id(s)) + ", new id: " + i2s(id)
		);
	} else if (containsKeyConcurHashMap(ru_ids.id2s, id)) {
		ruCrash(
			"Id '" + i2s(id) + "' is already in the id-to-string map, corresponding string: '" + id2s(id) + "', new string: '" + s + "'"
		);
	} else {
		setConcurHashMap(ru_ids.s2id, s, id);
		setConcurHashMap(ru_ids.id2s, id, s);
	}
}

ruIds() -> [string] {
	valuesConcurHashMap(ru_ids.id2s);
}

ruSaveIds(env : RuEnv) -> void {
	if (^(ru_ids.was_modified) && ^(ru_ids.id_counter) > 0) {
		arr = map(enumFromTo(0, ^(ru_ids.id_counter) - 1), \id -> 
			getConcurHashMap(ru_ids.id2s, id, "")
		);
		cache_dir = ruCacheDir(env.conf, "");
		file = cache_dir + "/__ids.txt";
		lines = concatStrings(concat([d2s(ruIdsVersion()) + "\n"],
			mapi(arr, \i, s -> s + if (i + 1 < length(arr)) "\n" else "")
		));
		setFileContent(file, lines);
		// Persist the type-compact list (general type ids in compact order) so the
		// compact ids baked into cached expressions decode to the same types.
		setFileContent(cache_dir + "/__type_ids.txt", strGlue(map(ruTypeIndexList(), i2s), "\n"));
		ru_ids.was_modified := false;
	}
}

ruReadIds(env : RuEnv) -> void {
	cache_dir = ruCacheDir(env.conf, "");
	file = cache_dir + "/__ids.txt";
	if (fileExists(file)) {
		source = getFileContent(file);
		lines = strSplit(source, "\n");
		version = s2d(lines[0]);
		strings = tailFrom(lines, 1);
		iteri(strings, \i, s -> sets2id(s, i));
		ru_ids.id_counter := length(strings);
		ru_ids.was_modified := false;
		ru_ids.version := version;
		type_file = cache_dir + "/__type_ids.txt";
		if (fileExists(type_file)) {
			tcontent = trim2(getFileContent(type_file), " \n\r\t");
			if (tcontent != "") ruSetTypeIndexList(map(strSplit(tcontent, "\n"), s2i));
		}
	} else {
		ru_ids.version := timestamp();
	}
	ru_ids_cleared := false;
}

ruEnsureIdsLoaded(env : RuEnv) -> void {
	// After a `clear-ids` the in-memory table is empty and any ids reassigned
	// since (e.g. by `conf-load`) start from 0 and so COLLIDE with the persisted
	// canonical numbering that the on-disk caches reference. Drop those and
	// reload the canonical table so cached numeric ids resolve correctly.
	if (^ru_ids_cleared) {
		ruClearIds();
		ruReadIds(env);
	}
}
