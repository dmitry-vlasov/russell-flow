import formats/json/json;
import base/dir;

export {
	ruGetDbItem(db : string, path : [string], workingDir : string) -> Json;
	ruSetDbItem(db : string, path : [string], item : Json, workingDir : string) -> void;
}

ruGetDbItem(db : string, path : [string], workingDir : string) -> Json {
	json = ruDoGetDbItem(db, path, workingDir);
	if (json != JsonNull()) json else {
		// Fall back to the tool-level common.json for defaults (e.g. symb_ambiguities)
		ruDoGetDbItem("common", path, "");
	}
}

ruDoGetDbItem(db : string, path : [string], workingDir : string) -> Json {
	// "common" is a global default shipped with the tool; everything else lives
	// next to the math sources in workingDir (falls back to CWD when unset).
	db_root = if (db == "common") getRussellDir()
	          else if (workingDir != "") workingDir
	          else resolveRelativePath(".");
	db_path = pathCombineMany([db_root, "db", changeFileExt(db, ".json")]);
	db_json = parseJsonSafe(getFileContent(db_path));
	getJsonNestedField(db_json, path);
}

ruSetDbItem(db : string, path : [string], item : Json, workingDir : string) -> void {
	db_root = if (workingDir != "") workingDir else resolveRelativePath(".");
	db_path = pathCombineMany([db_root, "db", changeFileExt(db, ".json")]);
	db_json = parseJsonSafe(getFileContent(db_path));
	db_modified = setJsonNestedField(db_json, path, item);
	setFileContent(db_path, json2stringFormatted(db_modified));
	{}
}
