import base/dir;
import base/conf;
import base/out;

export {
	ruCacheDir(conf : RuConf, mode : string) -> string;
	ruCachedPath(file : string, mode : string, conf : RuConf) -> string;
	ruCachedFile(path : string, mode : string, conf : RuConf) -> string;
	ruEnsureFileDirectoryExists(file : string, out : RuOut) -> void;
	ruEnsureDirectoryExists(dir : string, out : RuOut) -> void;
}

ruCacheDir(conf : RuConf, mode : string) -> string {
	// Caches are PER-PROJECT, living in a `.cache` subdir of the project directory,
	// so distinct projects (and re-translations) never contaminate each other's ids.
	// An explicit `cache-dir` opt still overrides; only when no project anchor is
	// known do we fall back to the shared global cache under getRussellDir().
	project_dir = ruProjectDir(conf);
	default_base = if (project_dir != "") rtrim2(project_dir, "/") + "/.cache"
		else rtrim2(getRussellDir(), "/") + "/cache";
	base_cache = ruOptsString(conf.opts, "cache-dir", default_base);
	dir = if (mode == "") base_cache else {
		rtrim2(base_cache, "/") + "/" + mode;
	}
	rtrim2(dir, "/");
}

// The project's root directory, used to anchor its per-project cache. Derived from
// the most project-specific anchor available; "" when nothing identifies a project.
ruProjectDir(conf : RuConf) -> string {
	ru_root = ruOptsString(conf.opts, "ru-root", "");
	if (ru_root != "") ru_root
	else if (conf.projectRoots != []) ruDirName(conf.projectRoots[0])
	else if (conf.workingDir != "") conf.workingDir
	else if (conf.importRoots != []) conf.importRoots[0]
	else "";
}

ru_cache_dir_delimiter = "_DIIIR_";
ru_cache_colon_delimiter = "_CCOOLLOONN_";

ruCachedPath(file : string, mode : string, conf : RuConf) -> string {
	ruCacheDir(conf, mode) + "/" + 
	strReplace(strReplace(file, ":", ru_cache_colon_delimiter), "/", ru_cache_dir_delimiter) + 
	".cache";
}

ruCachedFile(path : string, mode : string, conf : RuConf) -> string {
	cache_dir = ruCacheDir(conf, mode);
	if (!startsWith(path, cache_dir)) "" else {
		changeFileExt(
			strReplace(
				strReplace(
					strRight(path, strlen(cache_dir) + 1),
					ru_cache_colon_delimiter, ":"
				),
				ru_cache_dir_delimiter, "/"
			),
			""
		);
	}
}

ruEnsureFileDirectoryExists(file : string, out : RuOut) -> void {
	dir = ruDirName(file);
	err = ensureDirectoryExists(dir);
	if (err != "") {
		out.error("cannot create directory '" + dir + "' for the file: '" + file + "':\n\t" + err, []);
	}
}

ruEnsureDirectoryExists(dir : string, out : RuOut) -> void {
	err = ensureDirectoryExists(dir);
	if (err != "") {
		out.error("cannot create directory: '" + dir + "':\n\t" + err, []);
	}
}
