import base/util/timer;
import script/ast;
import script/value;
import unit;

export {
	RuCommArg(
		name : string,
		optional : bool,
		help : string,
		defval : string
	);
	// Commands may affect script variables and set some of them to specific return values.
	RuCommRet(
		name : string,
		type : string,
		help : string
	);
	RuCommInfo(
		name : string,
		category : string,
		help : string,
		defarg : string,
		autofile : bool,
		autoindent : bool,
		args : [RuCommArg],
		rets : [RuCommRet],
	);
	RuComm(
		info : RuCommInfo,
		run : (RuUnit) -> Maybe<RuState>
	);

	ruCommArg2s(arg : RuCommArg) -> string;
	ruCommInfo2s(info : RuCommInfo, with_args : bool) -> string;
	ruComm2s(comm : RuComm, with_args : bool) -> string;
	ruComms2s(comms : [RuComm], with_args : bool) -> string;
	ruApplyToProjectRoots(comm : RuComm) -> RuComm;

	// Read a `(string, string) -> void` progress callback named `name` from the
	// task args. Commands call the returned function unconditionally on each
	// progress event (per source, per item, at completion, …); it defaults to
	// `nop2` (silent), so a command emits intermediate output only when the
	// calling script supplies a lambda — the script picks the granularity by
	// which callbacks it provides. This is the generalisation of the read-mm
	// `info-total`/`info-source` pattern. See docs/scripting-language.md.
	ruTaskInfoFn2(env : RuEnv, args : Tree<string, flow>, name : string) -> (string, string) -> void;

	// Standard RuCommArg declarations for the progress-callback args, so commands
	// that read them via ruTaskInfoFn2 list them in their interface / `help`.
	// Default is nop2 (silent) — the command emits nothing unless a script lambda
	// is supplied. Splice the relevant ones into a command's args list.
	ruInfoSourceArg   : RuCommArg;
	ruInfoTotalArg    : RuCommArg;
	ruInfoDeclArg     : RuCommArg;
	ruInfoProgressArg : RuCommArg;
}

// NB: defval must stay "" — a non-empty defval is injected into task.args as a
// STRING, which ruTaskInfoFn2 would then reject ("must be a function"). The
// silent (nop2) default is implicit when the arg is absent; documented in help.
ruInfoSourceArg   = RuCommArg("info-source",   true, "progress callback (source, info) -> void, called per source/file; omit for silent (nop2)", "");
ruInfoTotalArg    = RuCommArg("info-total",    true, "progress callback (count, time) -> void, called once at completion; omit for silent (nop2)", "");
ruInfoDeclArg     = RuCommArg("info-decl",     true, "progress callback (decl-id, info) -> void, called per declaration/theorem; omit for silent (nop2)", "");
ruInfoProgressArg = RuCommArg("info-progress", true, "periodic progress callback (position, counts) -> void; omit for silent (nop2)", "");

ruTaskInfoFn2(env : RuEnv, args : Tree<string, flow>, name : string) -> (string, string) -> void {
	switch (lookupTree(args, name)) {
		Some(fn): {
			tp = runtimeValueType(fn);
			if (tp == "function") {
				cast(fn : flow -> (string, string) -> void);
			} else if (tp == "string" && cast(fn : flow -> string) == "") {
				// The arg is declared (RuCommArg) but not supplied: the command framework
				// injects its empty defval as "". Treat that as absent → silent.
				nop2;
			} else {
				// A non-empty, non-function value is a genuine mistake: report, stay silent.
				env.out.error("'" + name + "' parameter must be a function, got '" + tp + "':\n" + ruScValue2s(fn), []);
				nop2;
			}
		}
		// Silent by default: no progress unless the script passes a lambda.
		None(): nop2;
	}
}

ruCommArg2s(arg : RuCommArg) -> string {
	arg.name + " " + 
	(if (arg.optional) "(optional) " else "") + arg.help + 
	(if (arg.defval == "") "" else " defval: " + arg.defval);
}

ruCommArgs2s(args : [RuCommArg]) -> string {
	has_defval = exists(args, \arg -> arg.defval != "");
	arg_matr = filtermap([
		Some(map(args, \arg -> arg.name)),
		Some(map(args, \arg -> b2s(arg.optional))),
		Some(map(args, \arg -> arg.help)),
		if (has_defval) Some(map(args, \arg -> arg.defval)) else None(),
	], idfn);
	headers = filtermap([
		Some("Name"), 
		Some("Optional"),
		Some("Help"),
		if (has_defval) Some("Default") else None()
	], idfn);
	stringTable2s(arg_matr, Some(headers));
}

ruCommRets2s(rets : [RuCommRet]) -> string {
	arg_matr = [
		map(rets, \ret -> ret.name),
		map(rets, \ret -> ret.type),
		map(rets, \ret -> ret.help)
	];
	headers = ["Name", "Type", "Help"];
	stringTable2s(arg_matr, Some(headers));
}

ruCommInfo2s(info : RuCommInfo, with_args : bool) -> string {
	"Command:\n\t" + info.name + "\n" + 
	(if (info.category == "") "" else "Category:\n\t" + info.category + "\n") + 
	(if (info.defarg == "") "" else "Default argument:\n\t" + info.defarg + "\n") + 
	"Description:\n" + strIndent(info.help) + "\n" +
	(if (!with_args || info.args == []) "" else {
		"Arguments:\n" + strIndent(ruCommArgs2s(info.args)) + "\n";
	}) +
	(if (!with_args || info.rets == []) "" else {
		"Return values:\n" + strIndent(ruCommRets2s(info.rets)) + "\n";
	})
}

ruComm2s(comm : RuComm, with_args : bool) -> string {
	ruCommInfo2s(comm.info, with_args);
}

ruComms2s(comms : [RuComm], with_args : bool) -> string {
	comm_matr = filtermap([
		Some(map(comms, \comm -> comm.info.name)),
		Some(map(comms, \comm -> comm.info.category)),
		Some(map(comms, \comm -> comm.info.help)),
		if (with_args) Some(map(comms, \comm -> strGlue(map(comm.info.args, ruCommArg2s), ", "))) else None()
	], idfn);
	headers = filtermap([
		Some("Command name"), 
		Some("Category"),
		Some("Help"),
		if (with_args) Some("Arguments") else None()
	], idfn);
	stringTable2s(comm_matr, Some(headers)) + "\n";
}

ruApplyToProjectRoots(comm : RuComm) -> RuComm {
	RuComm(comm with
		info = RuCommInfo(comm.info with
			args = map(comm.info.args, \arg -> if (arg.name != "file") arg else RuCommArg(arg with optional = true))
		),
		run = \unit -> {
			task = unit.task;
			state = unit.state;
			if (containsKeyTree(task.args, "file")) {
				comm.run(unit);
			} else {
				fold(state.conf.projectRoots, Some(state), \acc, file ->
					maybeBind(acc, \s -> 
						comm.run(RuUnit(RuTask(task with args = setTree(task.args, "file", file)), s, unit.out))
					)
				);
			}
		}
	);
}
