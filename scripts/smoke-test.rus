/**
	@help {
		Fast smoke test: runs every major prover/refactor command on a small
		dataset and asserts invariants. A failed `assert` aborts with a non-zero
		exit code, so CI fails on any regression — including ones that merely
		produce wrong numbers rather than crashing.

		Designed to run in ~1-2 minutes on a small set (e.g. set-3000), so it can
		run on EVERY PR, complementing the slow full-set roundtrip/oracle steps.

		Invariants are deliberately loose (>=, ==100% for oracle, success flags)
		so the test is stable across set.mm updates while still catching real
		regressions in each command's machinery.
	}
	@defarg afile
	@category test

	@arg afile      { input Russell dataset directory name. @defval set-3000 }
*/

print "==== Russell smoke test ====";
print "dataset: $afile";

conf-load dir=./$afile;
conf-set gc-after-task=1;

read-ru;
	print ("read-ru: " + read-ru.size + " files");
	// GOLDEN: the pinned set-3000 fixture splits into exactly 7 source files.
	assert (read-ru.size == 7);

// --- verify: the whole dataset must verify ---
verify;
	print ("verify: success=" + verify.success + ", " + verify.size + " files");
	assert (verify.success);
	// GOLDEN: 256 verified theorems in the fixture (a drop signals a
	// translation/verification regression, not just a crash).
	assert (verify.size == 256);

// --- reprove with the ORACLE tactic: must reprove 100% with zero coverage gap ---
// (oracle follows the original proof, so this is a strong, stable invariant and
//  exercises the proof-assembly path end to end.)
reprove
	target=stride-30
	tactic="oracle(-1, -1)"
	time-limit=30s
	coverage=1;
	print ("reprove[oracle]: reproved=" + reprove.reproved-count + " failed=" + reprove.failed-count +
		" coverage=" + reprove.coverage-pct + "% gap=" + reprove.gap-count);
	// GOLDEN (set-3000 fixture is version-pinned, so exact values are stable and
	// machine-independent here: the oracle follows the original proof, so it does
	// not depend on search speed). stride-30 selects exactly 9 theorems.
	assert (reprove.reproved-count == 9);
	assert (reprove.failed-count == 0);
	assert (reprove.coverage-pct == 100.0);
	assert (reprove.gap-count == 0);

// --- reprove with BFS: exercises the free-search + proof-assembly path that
//     the oracle path does NOT (this is where the ruAddProof explosion lived).
//     We only require it doesn't crash and reproves at least one theorem. ---
reprove
	target=stride-30
	tactic="bounded-bfs(5, 4096)"
	time-limit=30s;
	print ("reprove[bfs]: reproved=" + reprove.reproved-count);
	// Lower-bound, not golden: free-search counts can dip on a slower CI box
	// where some theorems time out. Locally this is 3; require >= 2 so a real
	// regression (e.g. the proof-assembly explosion -> 0) still trips it.
	assert (reprove.reproved-count >= 2);

// --- reprove with SPR: exercises the subproof-replay / step-index path. ---
reprove
	target=stride-30
	tactic="spr(3, 4096)"
	time-limit=30s;
	print ("reprove[spr]: reproved=" + reprove.reproved-count);
	// Lower-bound: SPR reproves 1 locally; require >= 1 (it must complete and
	// extract at least one proof — a crash or empty result fails here).
	assert (reprove.reproved-count >= 1);

// --- compress: mutates proofs (squashes auto-provable fragments). ---
compress target=stride-30 step-time-limit=0.5;
	print ("compress: compressed=" + compress.compressed-count + " failed=" + compress.failed-count);
	assert (compress.failed-count == 0);
	// Lower-bound: 7 theorems compress locally; require >= 4 (compression must
	// still work; small dip allowed for slower CI step budgets).
	assert (compress.compressed-count >= 4);

// --- measure-autoprovability: per-step independent auto-provability rate. ---
measure-autoprovability target=stride-30 step-time-limit=0.5;
	print ("measure-autoprovability: rate=" + measure-autoprovability.rate +
		" (" + measure-autoprovability.auto-steps + "/" + measure-autoprovability.total-steps + ")");
	assert (measure-autoprovability.total-steps > 0);
	// Lower-bound on the rate: 1.0 locally; require >= 0.5 so a regression that
	// breaks per-step auto-proving (rate -> 0) fails, while CI-speed dips pass.
	assert (measure-autoprovability.rate >= 0.5);

// --- annotate-proof: per-step tactic-atom coloring (ML-training output). ---
annotate-proof target=stride-30 tactic="oracle(-1, -1)" time-limit=30s;
	print ("annotate-proof: theorems=" + annotate-proof.theorem-count + " proved=" + annotate-proof.proved-count);
	// GOLDEN theorem-count (deterministic selection); proved is search-dependent.
	assert (annotate-proof.theorem-count == 9);
	assert (annotate-proof.proved-count >= 1);

// --- make-benchmark: stratified benchmark-set construction. ---
make-benchmark size=10 output=smoke-bench;
	print ("make-benchmark: size=" + make-benchmark.size);
	// GOLDEN: deterministic stratified selection over the pinned fixture.
	assert (make-benchmark.size == 4);

// --- optimize-imports-ru: import minimization (no duplicate imports, all kept). ---
optimize-imports-ru;
	print ("optimize-imports-ru: " + optimize-imports-ru.size + " files");
	// GOLDEN: same 7 source files, imports minimized (count of files unchanged).
	assert (optimize-imports-ru.size == 7);

// --- round-trip invariant: ru -> mm must emit output for every source, i.e. the
//     back-translation does not silently drop theorems. Combined with the
//     `mm2ru2mm` step that precedes this script (mm -> ru -> mm + re-verify) and
//     the golden verify.size above, this guards the full translation round-trip.
ru-to-mm;
	print ("ru-to-mm: " + ru-to-mm.size + " files");
	assert (ru-to-mm.size > 0);

print "==== smoke test PASSED ====";
