/**
	@help {
		Complete test battery — the same scheme as the CI workflow
		(.github/workflows/test-russell-pr.yml), but run end-to-end in a SINGLE
		Russell process instead of one container step per check.

		Steps (in CI order — small/fast first for early failure):
		  1. script-lang      : the embedded .rus language itself (no dataset)
		  2. smoke            : mm2ru2mm + every major command on set-3000
		  3. refactors        : apply each corpus transform + re-verify on set-30000
		  4. tactic-semantics : SPR / linear-guided vs BFS differential on set-100000
		  5. full set         : mm -> ru -> mm round-trip on the whole set.mm
		  6. reprove oracle   : stratified sample of set.mm (every 50th theorem)
		  7. reprove single   : ioodvbdlimc1lem1 (large-theorem stress test)
		  8. kore-fol         : mm-theory/kore-fol round-trip
		  9. kore-fol reprove : reprove all kore-fol theorems with the oracle

		PREREQUISITES (this is a Russell script, so it cannot cut .mm prefixes —
		generate them first with bin/mm-prefix.sh, exactly as CI does):
		  bin/mm-prefix.sh set.mm   3000 set-3000.mm
		  bin/mm-prefix.sh set.mm  30000 set-30000.mm
		  bin/mm-prefix.sh set.mm 100000 set-100000.mm
		and set.mm + mm-theory/kore-fol must be present.

		Run from the math dir (~/dev/math), and give the JVM enough heap for the
		set-100000 / full-set steps:
		  russellj mem=16g test/all

		The whole battery shares ONE id table across datasets: each mm2ru2mm ends
		with `clear-ids`, and the next `read-ru` reloads the persisted canonical
		ids (see ruEnsureIdsLoaded), so the in-process chain matches CI's
		one-process-per-step behaviour.
	}
	@category test
*/

print "######## Russell full test battery (CI scheme, single process) ########";

// 1. Scripting-language test: the embedded .rus language (no math data needed).
print "";
print "==== [1/9] scripting-language ====";
test/script-lang;

// 2. Smoke test: mm2ru2mm + every major command on a small set.mm prefix.
print "";
print "==== [2/9] smoke (set-3000) ====";
translate/mm2ru2mm set-3000;
test/smoke afile=set-3000;

// 3. Refactor-commands test: apply every transform + re-verify on set-30000.
print "";
print "==== [3/9] refactors (set-30000) ====";
translate/mm2ru2mm set-30000;
test/refactors afile=set-30000;

// 4. Differential tactic-semantics test (SPR / linear-guided vs BFS) on set-100000.
print "";
print "==== [4/9] tactic-semantics (set-100000) ====";
translate/mm2ru2mm set-100000;
test/tactic-semantics afile=set-100000;

// 5. Full set.mm mm -> ru -> mm round-trip.
print "";
print "==== [5/9] full set.mm round-trip ====";
translate/mm2ru2mm set;

// 6. Reprove a stratified sample of set.mm theorems with the oracle.
print "";
print "==== [6/9] reprove oracle (set, stride 50) ====";
reprove/oracle set astride=50 time_limit=5m;

// 7. Reprove a single large theorem (stress test).
print "";
print "==== [7/9] reprove single (ioodvbdlimc1lem1) ====";
reprove/oracle-single set atheorem=ioodvbdlimc1lem1 time_limit=3m;

// 8. kore-fol round-trip.
print "";
print "==== [8/9] kore-fol round-trip ====";
translate/mm2ru2mm mm-theory/kore-fol;

// 9. Reprove all kore-fol theorems with the oracle.
print "";
print "==== [9/9] reprove oracle (kore-fol) ====";
reprove/oracle mm-theory/kore-fol time_limit=5m;

print "";
print "######## ALL TESTS PASSED ########";
