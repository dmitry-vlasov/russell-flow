/**
	@help {
		Complete test battery — the same scheme as the CI workflow
		(.github/workflows/test-russell-pr.yml), but run end-to-end in a SINGLE
		Russell process instead of one container step per check.

		Steps (in CI order — small/fast first for early failure):
		  1. smoke            : mm2ru2mm + every major command on set-3000
		  2. refactors        : apply each corpus transform + re-verify on set-30000
		  3. tactic-semantics : SPR / linear-guided vs BFS differential on set-100000
		  4. full set         : mm -> ru -> mm round-trip on the whole set.mm
		  5. reprove oracle   : stratified sample of set.mm (every 50th theorem)
		  6. reprove single   : ioodvbdlimc1lem1 (large-theorem stress test)
		  7. kore-fol         : mm-theory/kore-fol round-trip
		  8. kore-fol reprove : reprove all kore-fol theorems with the oracle

		PREREQUISITES (this is a Russell script, so it cannot cut .mm prefixes —
		generate them first with tools/mm-prefix.sh, exactly as CI does):
		  tools/mm-prefix.sh set.mm   3000 set-3000.mm
		  tools/mm-prefix.sh set.mm  30000 set-30000.mm
		  tools/mm-prefix.sh set.mm 100000 set-100000.mm
		and set.mm + mm-theory/kore-fol must be present.

		Run from the math dir (~/dev/math), and give the JVM enough heap for the
		set-100000 / full-set steps:
		  russellj mem=16g test/all

		The whole battery shares ONE id table across datasets: each mm2ru2mm ends
		with `clear-ids`, and the next `read-ru` reloads the persisted canonical
		ids (see ruEnsureIdsLoaded), so the in-process chain matches CI's
		one-process-per-step behaviour.
	}
	@category test
*/

print "######## Russell full test battery (CI scheme, single process) ########";

// 1. Smoke test: mm2ru2mm + every major command on a small set.mm prefix.
print "";
print "==== [1/8] smoke (set-3000) ====";
translate/mm2ru2mm set-3000;
test/smoke afile=set-3000;

// 2. Refactor-commands test: apply every transform + re-verify on set-30000.
print "";
print "==== [2/8] refactors (set-30000) ====";
translate/mm2ru2mm set-30000;
test/refactors afile=set-30000;

// 3. Differential tactic-semantics test (SPR / linear-guided vs BFS) on set-100000.
print "";
print "==== [3/8] tactic-semantics (set-100000) ====";
translate/mm2ru2mm set-100000;
test/tactic-semantics afile=set-100000;

// 4. Full set.mm mm -> ru -> mm round-trip.
print "";
print "==== [4/8] full set.mm round-trip ====";
translate/mm2ru2mm set;

// 5. Reprove a stratified sample of set.mm theorems with the oracle.
print "";
print "==== [5/8] reprove oracle (set, stride 50) ====";
reprove/oracle set astride=50 time_limit=5m;

// 6. Reprove a single large theorem (stress test).
print "";
print "==== [6/8] reprove single (ioodvbdlimc1lem1) ====";
reprove/oracle-single set atheorem=ioodvbdlimc1lem1 time_limit=3m;

// 7. kore-fol round-trip.
print "";
print "==== [7/8] kore-fol round-trip ====";
translate/mm2ru2mm mm-theory/kore-fol;

// 8. Reprove all kore-fol theorems with the oracle.
print "";
print "==== [8/8] reprove oracle (kore-fol) ====";
reprove/oracle mm-theory/kore-fol time_limit=5m;

print "";
print "######## ALL TESTS PASSED ########";
