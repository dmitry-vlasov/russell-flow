# Horn logic embeds into unilambda with NO new machinery: a Horn clause is a
# unilambda clause, and SLD resolution is `uneval` (backward narrowing). This is
# Prolog's classic append/3 — defined once, run both forward and backward.
#
# Lists: nil, cons(h, t) are constructors (no clauses, so they stay as data).

append = \ nil, ?ys |- ?ys
append = \ cons(?x, ?xs), ?ys |- cons(?x, append(?xs, ?ys))

# --- eval (forward), asserting the expected normal form ---
eval append(cons(a, cons(b, nil)), cons(c, nil)) => cons(a, cons(b, cons(c, nil)))   # [a,b] ++ [c]

# --- uneval (backward narrowing), asserting the expected solution count ---
solve append(?xs, ?ys) = cons(a, cons(b, cons(c, nil)))           => 4   # every split of [a,b,c]
solve append(cons(a, nil), ?ys) = cons(a, cons(b, nil))           => 1   # [a] ++ ys = [a,b]
solve append(?xs, cons(c, nil)) = cons(a, cons(b, cons(c, nil)))  => 1   # xs ++ [c] = [a,b,c]
