# Peano arithmetic as Horn-clause RELATIONS (Prolog style), NOT functions.
#
# A predicate p(...) reduces to the token `true` exactly when it holds; a rule
# body is the conjunction of its subgoals (via `and`); existential body
# variables (e.g. T*) are fresh and bound by the search. `solve <goal> = true`
# runs the backtracking SLD resolution via uneval and enumerates every solution.
#
#   plus(X, 0, X).                              plus = \ X*, 0, X* |- true
#   plus(X, s(Y), s(Z)) :- plus(X, Y, Z).       plus = \ X*, s(Y*), s(Z*) |- plus(X*, Y*, Z*)
#   mult(X, 0, 0).
#   mult(X, s(Y), Z) :- mult(X, Y, T), plus(T, X, Z).

and = \ true, true |- true

plus = \ X*, 0, X* |- true
plus = \ X*, s(Y*), s(Z*) |- plus(X*, Y*, Z*)

mult = \ X*, 0, 0 |- true
mult = \ X*, s(Y*), Z* |- and(mult(X*, Y*, T*), plus(T*, X*, Z*))

# :- plus(X, Y, s(s(s(0))))        all (X, Y) with X + Y = 3
solve plus(X*, Y*, s(s(s(0)))) = true

# :- mult(X, Y, s(s(s(s(0)))))     all (X, Y) with X * Y = 4
solve mult(X*, Y*, s(s(s(s(0))))) = true
