# Curry-Howard via unilambda: the simply-typed lambda calculus (implicational
# fragment) — equivalently, intuitionistic implicational propositional logic.
#
# Terms (de Bruijn, so no variable-name bookkeeping):
#   var(N)        de Bruijn index N (a Peano numeral 0, s(0), ...)
#   lam(E)        lambda abstraction (binds index 0)
#   app(F, X)     application
# Types / propositions:  arr(A, B) = A -> B ;  base atoms o, p, q.
#
# The judgment  hastype(G, term, type)  reduces to `true` when, in context G
# (a list of types, innermost first), the term has that type. Rule bodies are
# conjunctions (and); existential body vars (?A, ?B) are fresh. Then:
#   forward  (solve hastype(nil, <term>, ?T) = true) = TYPE INFERENCE
#   backward (solve hastype(nil, ?E, <type>) = true) = INHABITATION = PROVING

and = \ true, true |- true

# context lookup: the Nth type in G is A
nth = \ cons(?A, ?G), 0, ?A |- true
nth = \ cons(?B, ?G), s(?N), ?A |- nth(?G, ?N, ?A)

# typing rules
hastype = \ ?G, var(?N), ?A |- nth(?G, ?N, ?A)
hastype = \ ?G, lam(?E), arr(?A, ?B) |- hastype(cons(?A, ?G), ?E, ?B)
hastype = \ ?G, app(?F, ?X), ?B |- and(hastype(?G, ?F, arr(?A, ?B)), hastype(?G, ?X, ?A))

# ---- forward: infer the principal type of a term ----
# (de Bruijn indices are Peano numerals: index 1 is s(0), not the atom 1)
# Each query has a unique principal type / canonical proof, so we assert => 1.
solve hastype(nil, lam(var(0)), ?T) = true          => 1   # id  :  A -> A
solve hastype(nil, lam(lam(var(s(0)))), ?T) = true  => 1   # K   :  A -> (B -> A)
solve hastype(nil, lam(lam(var(0))), ?T) = true     => 1   # \x y. y : A -> (B -> B)

# ---- backward: inhabit a type = prove the proposition ----
# `solve1` = find the FIRST witness (a proof). Inhabitation has infinitely many
# proofs (eta-variants), so we want one; solve1 short-circuits at the first and
# never touches the budget — clauses are tried intro-before-elim (lam before app).
solve1 hastype(nil, ?E, arr(o, o)) = true            => 1   # prove  o -> o
solve1 hastype(nil, ?E, arr(o, arr(p, o))) = true    => 1   # prove  o -> (p -> o)   [ax-1]
