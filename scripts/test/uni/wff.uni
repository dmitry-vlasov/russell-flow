# Bound unilambda: clauses whose terms are REAL Russell wff formulas, run over
# the loaded prop-calculus grammar. Backtick formulas are parsed by the Russell
# grammar (note the real `→` token); the named functions are reduced by the
# engine; ?x/?y are unilambda metavariables. Both destructuring (ante/cons) and
# construction (swap/imp) of real wff, forward and backward.

var ph : wff
var ps : wff
var p  : wff
var q  : wff
var a  : wff
var b  : wff
var c  : wff

ante = \ `( ph → ps )` |- `ph`            # antecedent of an implication
cons = \ `( ph → ps )` |- `ps`            # consequent
swap = \ `( ph → ps )` |- `( ps → ph )`   # flip an implication
imp  = \ ?p, ?q |- `( p → q )`            # build an implication from two wffs

# --- eval (forward) over real wff, asserting the resulting formula ---
eval ante(`( ( a → b ) → c )`) => `( a → b )`
eval cons(`( ( a → b ) → c )`) => `c`
eval swap(`( a → b )`)         => `( b → a )`
eval imp(`a`, `b`)             => `( a → b )`
eval swap(swap(`( a → b )`))   => `( a → b )`

# --- uneval (backward narrowing) over real wff, asserting solution count ---
solve ante(?x) = `( a → b )`            => 1   # implications with antecedent ( a → b )
solve swap(?x) = `( a → b )`            => 1   # ?x = ( b → a )
solve imp(?x, ?y) = `( ( a → b ) → c )` => 1   # ?x = ( a → b ), ?y = c
