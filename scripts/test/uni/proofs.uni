# Proof-term eval over the REAL Russell propositional-calculus assertions
# (ax-mp / ax-1 / ax-2 / a1i / a2i / mpd / syl / mp2), loaded from the dataset.
#
# Each line is `<proof term> => <principal statement>`. `eval` composes the named
# assertions by UNIFYING their hypotheses with the sub-terms' conclusions and
# reads off the most-general statement the whole term proves. The expectation is
# checked UP TO VARIABLE RENAMING: write the schematic wff variables as v1, v2, …
# in order of first occurrence (`uni-peval` canonicalizes fresh-var names the
# same way before comparing). Leaves (x, y, z) are the term's open hypotheses.

# ax-mp twice: from x and (x -> (y -> z)) chained through a hypothesis
ax-mp(x, ax-mp(y, z)) => \ v1, v2, ( v2 -> ( v1 -> v3 ) ) |- v3

# discharge ax-1's first hypothesis with x
ax-mp(x, ax-1)        => \ v1 |- ( v2 -> v1 )

# ax-mp over a2i: the imp-distribution shape
ax-mp(x, a2i(y))      => \ ( v1 -> v2 ), ( v1 -> ( v2 -> v3 ) ) |- ( v1 -> v3 )

# mpd / syl coincide on this composition: hypothetical syllogism
mpd(x, a1i(y))        => \ ( v1 -> v2 ), ( v2 -> v3 ) |- ( v1 -> v3 )
syl(x, y)             => \ ( v1 -> v2 ), ( v2 -> v3 ) |- ( v1 -> v3 )

# mp2: double modus ponens
mp2(x, y, z)          => \ v1, v2, ( v1 -> ( v2 -> v3 ) ) |- v3

# nested a1i: add two antecedents
a1i(a1i(x))           => \ v1 |- ( v2 -> ( v3 -> v1 ) )
