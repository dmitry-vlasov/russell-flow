# Peano naturals: addition and multiplication as recursive unilambda clauses.
# Variables carry a trailing `*`; bare identifiers (0, s, plus, mult) are
# constructors / defined functions. `s` and `0` have no clauses, so they are
# data constructors; `plus` and `mult` have clauses, so they reduce.

plus = \ x*, 0 |- x*
plus = \ x*, s(y*) |- s(plus(x*, y*))

mult = \ x*, 0 |- 0
mult = \ x*, s(y*) |- plus(x*, mult(x*, y*))

# --- eval (forward), asserting the expected normal form via `=>` ---
eval plus(s(0), s(s(0)))     => s(s(s(0)))      # 1 + 2 = 3
eval plus(s(s(s(0))), 0)     => s(s(s(0)))      # 3 + 0 = 3
eval mult(s(s(0)), s(s(0)))  => s(s(s(s(0))))   # 2 * 2 = 4
eval mult(s(0), s(s(s(0))))  => s(s(s(0)))      # 1 * 3 = 3
eval mult(s(s(s(0))), 0)     => 0               # 3 * 0 = 0

# --- uneval (backward narrowing), asserting the expected solution count ---
solve plus(x*, y*) = s(s(s(0)))      => 4   # all (x,y) with x + y = 3
solve plus(s(0), y*) = s(s(s(0)))    => 1   # 1 + y = 3  ->  y = 2
solve plus(x*, s(0)) = s(s(s(s(0)))) => 1   # x + 1 = 4  ->  x = 3
solve mult(x*, y*) = s(s(0))         => 2   # factor 2:  (2,1) and (1,2)
