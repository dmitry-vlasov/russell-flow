/**
	@help {
		Self-contained test of the embedded scripting language itself (NOT the
		theorem engine): every basic type, every operator, every type operator,
		and every syntactic construction. Pure in-memory — needs no math library,
		no dataset, no config; safe and fast to run anywhere:

		  russellj test/script-lang     # exit 0 = pass, 255 = a failed assert

		Each check is an `assert`; a violated invariant aborts with exit 255 (see
		ruCrash), so this fails loudly on any scripting-language regression.
	}
	@category test
*/

print "==== Russell scripting-language test ====";

// ------------------------------------------------------------------ integers
print "-- int literals + arithmetic --";
assert ((2 + 3) == 5);
assert ((10 - 4) == 6);
assert ((3 * 4) == 12);
assert ((12 / 4) == 3);             // integer division
assert ((17 % 5) == 2);
assert ((1 + 2 + 3 + 4) == 10);     // variadic +
assert ((2 * 3 * 4) == 24);         // variadic *
assert ((-(5)) == (0 - 5));         // unary minus (prefix op)
assert ((((1 + 1) + 1) + 1) == 4);  // nesting

print "-- int comparisons --";
assert ((3 < 4));
assert ((4 <= 4));
assert ((5 > 1));
assert ((5 >= 5));
assert ((7 == 7));
assert ((7 != 8));

// ------------------------------------------------------------------- doubles
print "-- double literals + arithmetic --";
assert ((1.5 + 2.5) == 4.0);
assert ((5.0 - 1.5) == 3.5);
assert ((2.0 * 3.0) == 6.0);
assert ((7.5 / 2.5) == 3.0);        // double division
assert ((-(2.5)) == (0.0 - 2.5));

print "-- double comparisons --";
assert ((1.5 < 2.5));
assert ((3.0 >= 3.0));
assert ((2.0 != 2.5));
assert ((4.0 == 4.0));

// ------------------------------------------------------------------ booleans
print "-- booleans --";
assert ((true && true));
assert (!(false));
assert ((true || false));
assert (((false || false)) == false);
assert (((!true)) == false);
assert ((true != false));
assert ((true == true));

// ------------------------------------------------------------------- strings
print "-- strings --";
assert (("ab" + "cd") == "abcd");
assert (("x" + 1) == "x1");          // mixed + coerces to string
assert (("n=" + 3 + "!") == "n=3!"); // variadic string +
assert (("abc" < "abd"));
assert (("a" == "a"));
assert (("a" != "b"));
assert (("line1\nline2" != "line1")); // escape sequences

// -------------------------------------------------------------- conversions
print "-- type conversions (a2i / a2d / a2s / a2b) --";
assert (a2i("42") == 42);
assert (a2i(3.7) == 4);          // double -> int rounds
assert (a2i(true) == 1);
assert (a2d("1.5") == 1.5);
assert (a2d(2) == 2.0);          // int -> double
assert (a2s(42) == "42");
assert (a2s(true) == "true");
assert (a2s(1.5) == "1.5");
assert (a2b(0) == false);
assert (a2b(1) == true);
assert (a2b("false") == false);
assert (a2b("yes") == true);

// ------------------------------------------------------------------- arrays
print "-- arrays (literal, index, concat, equality) --";
arr := [10, 20, 30];
assert (arr[0] == 10);
assert (arr[2] == 30);
assert (([1, 2] + [3, 4]) == [1, 2, 3, 4]);   // array concat with +
assert ([1, 2, 3] == [1, 2, 3]);
assert ([1, 2] != [1, 3]);
assert ([] == []);
nested := [[1, 2], [3, 4]];
assert (nested[1][0] == 3);                    // chained index access

// --------------------------------------------------------------------- maps
print "-- maps (id keys, expr keys, index, field, merge) --";
m := { a = 1, b = 2 };
assert (m["a"] == 1);
assert (m.b == 2);                             // field access on a map
m2 := { 1 = "one", 2 = "two" };
assert (m2[1] == "one");
assert ({ a = 1 } == { a = 1 });
assert ({ a = 1 } != { a = 2 });
assert (({ a = 1 } + { b = 2 }) == { a = 1, b = 2 }); // map merge with +
assert ({} == {});

// ------------------------------------------------------------------ structs
print "-- structs (construct + field access) --";
p := Pair(10, 20);
assert (p.first == 10);
assert (p.second == 20);
some := Some(7);
assert (some.value == 7);

// -------------------------------------------------------------- conditional
print "-- conditional expression ( c ? p : n ) --";
assert ((true ? 1 : 2) == 1);
assert ((false ? 1 : 2) == 2);
assert (((3 > 2) ? "y" : "n") == "y");

// --------------------------------------------------------------------- let
print "-- let binding --";
assert ((let x = 5; (x + 1)) == 6);
assert ((let a = 3; (let b = 4; (a + b))) == 7);  // nested let

// ----------------------------------------------------------- sequence block
print "-- expression sequence { e; e; } --";
assert (({ 1; 2; 3; }) == 3);                  // value is the last expr

// ------------------------------------------------------------------ lambdas
print "-- lambdas + calls --";
f0 := \ -> 42;
assert (f0() == 42);
inc := \x -> (x + 1);
assert (inc(9) == 10);
add := \a, b -> (a + b);
assert (add(3, 4) == 7);
k := 100;
addk := \x -> (x + k);                         // closure captures k
assert (addk(1) == 101);

// ---------------------------------------------------------- complex lambdas
print "-- complex lambdas (currying, nesting, closures) --";

// Currying / partial application: a lambda that returns a lambda.
curry_add := \a -> \b -> (a + b);
assert (curry_add(3)(4) == 7);
add5 := curry_add(5);                          // partial application held in a var
assert (add5(10) == 15);

// Three-level nested closure: inner lambda sees all enclosing params.
adder3 := \x -> (\y -> (\z -> ((x + y) + z)));
assert (adder3(1)(2)(3) == 6);

// Higher-order: a lambda taking a lambda as an argument.
apply := \f, v -> f(v);
assert (apply(\n -> (n * n), 6) == 36);

// Apply a function twice (function used as a value, called twice).
twice := \g, v -> g(g(v));
assert (twice(\n -> (n + 1), 10) == 12);

// Distinct closures from one factory keep independent captured state.
make_adder := \base -> (\d -> (base + d));
f10 := make_adder(10);
f20 := make_adder(20);
assert (f10(1) == 11);
assert (f20(1) == 21);

// Closure capture of a free var used *inside a call's arguments*:
// `mul(kk, vv)` parses as a var with a call-access, so `kk` must still be
// captured by the inner lambda (regression guard for ruScExpVars/closures).
mul := \a, b -> (a * b);
scaler := \kk -> (\vv -> mul(kk, vv));
assert (scaler(3)(14) == 42);

// Closure capture of a free var used *inside an index access*.
data := [100, 200, 300];
idx := \arr, i -> arr[i];
select := \i -> idx(data, i);                  // captures `data` via call-access
assert (select(2) == 300);

// Function composition built from two captured closures.
compose := \f, g -> (\x -> f(g(x)));
inc := \x -> (x + 1);
dbl := \x -> (x * 2);
inc_then_dbl := compose(dbl, inc);
assert (inc_then_dbl(5) == 12);                // (5 + 1) * 2

// A lambda calling another (global) lambda, nested twice.
quad := \x -> dbl(dbl(x));
assert (quad(5) == 20);

// Closure over a non-numeric (string) captured value.
prefixer := \tag -> (\rest -> (tag + rest));
greet := prefixer("hi ");
assert (greet("there") == "hi there");

// Zero-arg lambda that returns a lambda.
gen := \ -> (\x -> (x + 100));
assert (gen()(1) == 101);

// Lambda capturing a `let`-bound variable.
let_closure := (let base = 50; (\d -> (base + d)));
assert (let_closure(5) == 55);

// Immediately-invoked lambda.
assert ((\a, b -> (a + b))(2, 3) == 5);

// Lambdas stored in / retrieved from data structures, then called.
fns := [\x -> (x + 1), \x -> (x * 2)];
assert (fns[1](21) == 42);
ops := { inc = \x -> (x + 1), dbl = \x -> (x * 2) };
assert (ops["dbl"](21) == 42);

// Capturing lambda passed to a host higher-order function (map).
factor := 3;
assert (map([1, 2, 3], \x -> (x * factor)) == [3, 6, 9]);

// --------------------------------------------- Flow9 host library functions
// Scripts can call Flow9 runtime library functions directly, passing
// script-level lambdas as the higher-order arguments.
print "-- Flow9 host functions (map / fold / filter / iter / ...) --";

// map / mapi
assert (map([1, 2, 3], \x -> (x * x)) == [1, 4, 9]);
assert (mapi([10, 20, 30], \i, x -> (i + x)) == [10, 21, 32]);

// fold / foldi  (fold also works with a string accumulator)
assert (fold([1, 2, 3, 4], 0, \acc, x -> (acc + x)) == 10);
assert (fold([1, 2, 3], "", \acc, x -> (acc + x)) == "123");
assert (foldi([5, 5, 5], 0, \i, acc, x -> ((acc + i) + x)) == 18);

// filter / filtermap  (filtermap returns Maybe built in the script)
assert (filter([1, 2, 3, 4, 5, 6], \x -> ((x % 2) == 0)) == [2, 4, 6]);
assert (filtermap([1, 2, 3, 4], \x -> (((x % 2) == 0) ? Some((x * 10)) : None())) == [20, 40]);

// exists / forall  (both truth values)
assert (exists([1, 2, 3], \x -> (x == 2)) == true);
assert (exists([1, 2, 3], \x -> (x == 9)) == false);
assert (forall([2, 4, 6], \x -> ((x % 2) == 0)) == true);
assert (forall([2, 3, 4], \x -> ((x % 2) == 0)) == false);

// find returns a Maybe — extract the hit via its `.value` field.
found := find([1, 2, 3, 4], \x -> (x > 2));
assert (found.value == 3);

// iter / iteri return void; assert they run to completion over a lambda.
assert (isdef(iter([1, 2, 3], \x -> (x + 1))) == true);
assert (isdef(iteri([1, 2, 3], \i, x -> (i + x))) == true);

// Plain (non-higher-order) host functions are callable too.
assert (length([1, 2, 3, 4]) == 4);
assert (concat([1, 2], [3, 4]) == [1, 2, 3, 4]);
assert (enumFromTo(1, 4) == [1, 2, 3, 4]);
assert (arrayPush([1, 2], 3) == [1, 2, 3]);
assert (strlen("hello") == 5);

// Nested host calls: fold over a filtered, mapped array.
assert (fold(filter(map([1, 2, 3], \x -> (x * 10)), \x -> (x > 10)), 0, \acc, x -> (acc + x)) == 50);

// A host call inside a script lambda's body.
sum := \arr -> fold(arr, 0, \acc, x -> (acc + x));
assert (sum([4, 5, 6]) == 15);

// A captured script variable used inside a lambda handed to a host fold.
bonus := 100;
assert (fold([1, 2, 3], 0, \acc, x -> ((acc + x) + bonus)) == 306);

// -------------------------------------------------------------- quote / eval
print "-- quote / eval --";
assert (eval(quote((6 + 1))) == 7);
assert (eval(quote(42)) == 42);

// ------------------------------------------------------------------- isdef
print "-- isdef / undef --";
assert (isdef(5) == true);
assert (isdef("x") == true);
assert (isdef(undef) == false);

// ----------------------------------------------------------------- if / else
print "-- if / else --";
r := 0;
if ((5 > 3)) { r := 1; } else { r := 2; }
assert (r == 1);
if ((1 > 2)) { r := 10; } else { r := 20; }
assert (r == 20);
if ((1 == 1)) { r := 99; }                     // if without else
assert (r == 99);

// --------------------------------------------------------------------- while
print "-- while --";
i := 0;
s := 0;
while ((i < 5)) {
	s := (s + i);
	i := (i + 1);
}
assert (s == 10);
assert (i == 5);

// ---------------------------------------------------- string interpolation
print "-- string interpolation (output-only) --";
who := "world";
print "interpolation: hello $who";             // should render 'hello world'

print "==== scripting-language test PASSED ====";
