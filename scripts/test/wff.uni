# Bound unilambda: clauses whose terms are REAL Russell wff formulas, run over
# the loaded prop-calculus grammar. `ante`/`cons` destructure an implication.
# Backtick formulas are parsed by the Russell grammar (note the real `→` token);
# ante/cons are defined functions reduced by the engine; x* is a metavariable.

var ph : wff
var ps : wff
var a : wff
var b : wff
var c : wff

ante = \ `( ph → ps )` |- `ph`
cons = \ `( ph → ps )` |- `ps`

# forward: pull apart a real implication
eval ante(`( ( a → b ) → c )`)
eval cons(`( ( a → b ) → c )`)

# backward (narrowing): which implications have antecedent ( a → b )?
solve ante(x*) = `( a → b )`
