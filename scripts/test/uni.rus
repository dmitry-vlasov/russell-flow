/**
	@help {
		Comprehensive unilambda smoke test over the `set` propositional calculus.
		Exercises both directions — eval (forward) and uneval/solve (backward):
		  1. proof terms over real Russell assertions       (uni-eval)
		  2. recursive clauses, Horn relations              (uni-run: nat/horn/peano.uni)
		  3. clauses over real Russell wff formulas          (uni-brun: wff.uni)
		  4. Curry-Howard: STLC typing rules — type inference + inhabitation (uni-run: ch.uni)

		  cd ~/dev/math && russellj test/uni no-server=1            (run from the math dir)
		  cd ~/dev/math && russellj test/uni afile=set-3000 no-server=1

		Needs the dataset's propositional-calculus sources (ax-mp/ax-1/ax-2 and
		a1i/a2i/mpd/syl/mp2) — present in any set prefix, so set-3000 suffices.
	}
	@defarg afile
	@category test

	@arg afile { dataset directory name (a translated set prefix). @defval set }
*/

conf-load dir=./$afile;
read-ru file=$afile/CLASSICAL_FIRST-ORDER_LOGIC_WITH_EQUALITY/Propositional_calculus/Logical_implication.ru;

print "== 1. proof-term eval: compose assertions, read off the statement (asserted up to renaming) ==";
uni-peval file=test/uni/proofs.uni;

print "== 2a. functional clauses (plus/mult as functions): eval forward, solve backward ==";
uni-run file=test/uni/nat.uni;

print "== 2b. functional-logic lists (append): eval forward, solve backward ==";
uni-run file=test/uni/horn.uni;

print "== 2c. Horn RELATIONS (Peano plus/3, mult/3 as predicates): SLD search via uneval ==";
uni-run file=test/uni/peano.uni;

print "== 3. bound to Russell: clauses over real wff, eval forward, solve backward ==";
uni-brun file=test/uni/wff.uni;

print "== 4. Curry-Howard: STLC typing rules — type inference (fwd) + inhabitation/proving (bwd) ==";
uni-run file=test/uni/ch.uni;
