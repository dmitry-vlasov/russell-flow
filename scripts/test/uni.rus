/**
	@help {
		Smoke-test unilambda `eval` on the four worked proof-term examples
		(mp2, a1i, mpd, syl) from the unilambda spec, over the `set` library's
		propositional calculus. Reads only Logical_implication.ru plus its
		imports (the propositional axioms), so it loads fast.

		  russellj test/uni no-server=1            (run from ~/dev/math)
	}
	@category test
*/

conf-load dir=./set;
read-ru file=set/CLASSICAL_FIRST-ORDER_LOGIC_WITH_EQUALITY/Propositional_calculus/Logical_implication.ru;

// mp2_proof = ax-mp(x*, ax-mp(y*, z*))   expect: \ |- ph, |- ps, |- ( ph -> ( ps -> ch ) ) |- ch
uni-eval term=ax-mp(x,ax-mp(y,z));

// a1i_proof = ax-mp(x*, ax-1)            expect: \ |- ph |- ( ps -> ph )
uni-eval term=ax-mp(x,ax-1);

// mpd-style = ax-mp(x*, a2i(y*))         expect: \ |- ( ph -> ps ), |- ( ph -> ( ps -> ch ) ) |- ( ps -> ch )
uni-eval term=ax-mp(x,a2i(y));

// syl_proof = mpd(x*, a1i(y*))           expect: \ |- ( ph -> ps ), |- ( ps -> ch ) |- ( ph -> ch )
uni-eval term=mpd(x,a1i(y));
