/**
	@help {
		Comprehensive unilambda smoke test over the `set` propositional calculus.
		Exercises both directions — eval (forward) and uneval/solve (backward) —
		across all three engines:
		  1. proof terms over real Russell assertions       (uni-eval)
		  2. recursive clauses + Horn logic                 (uni-run: nat.uni, horn.uni)
		  3. clauses over real Russell wff formulas          (uni-brun: wff.uni)

		  cd ~/dev/math && russellj test/uni no-server=1     (run from the math dir)
	}
	@category test
*/

conf-load dir=./set;
read-ru file=set/CLASSICAL_FIRST-ORDER_LOGIC_WITH_EQUALITY/Propositional_calculus/Logical_implication.ru;

print "== 1. proof-term eval: compose assertions, read off the statement ==";
uni-eval term=ax-mp(x,ax-mp(y,z));
uni-eval term=ax-mp(x,ax-1);
uni-eval term=ax-mp(x,a2i(y));
uni-eval term=mpd(x,a1i(y));
uni-eval term=syl(x,y);
uni-eval term=mp2(x,y,z);
uni-eval term=a1i(a1i(x));

print "== 2a. recursive clauses (plus/mult): eval forward, solve backward ==";
uni-run file=test/nat.uni;

print "== 2b. Horn logic (append/3): eval forward, solve backward ==";
uni-run file=test/horn.uni;

print "== 3. bound to Russell: clauses over real wff, eval forward, solve backward ==";
uni-brun file=test/wff.uni;
