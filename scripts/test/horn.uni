# Horn logic embeds into unilambda with NO new machinery: a Horn clause is a
# unilambda clause, and SLD resolution is `uneval` (backward narrowing). This is
# Prolog's classic append/3 — defined once, run both forward and backward.
#
# Lists: nil, cons(h, t) are constructors (no clauses, so they stay as data).

append = \ nil, ys* |- ys*
append = \ cons(x*, xs*), ys* |- cons(x*, append(xs*, ys*))

# forward: [a,b] ++ [c] = [a,b,c]
eval append(cons(a, cons(b, nil)), cons(c, nil))

# backward (the logic-programming direction): every way to split [a,b,c]
solve append(xs*, ys*) = cons(a, cons(b, cons(c, nil)))

# backward, partially constrained: what suffix ys* makes [a] ++ ys* = [a,b]?
solve append(cons(a, nil), ys*) = cons(a, cons(b, nil))
