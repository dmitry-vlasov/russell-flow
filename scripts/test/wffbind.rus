/**
	@help {
		Demonstrate unilambda bound to Russell: load the propositional-calculus
		grammar, then run scripts/test/wff.uni whose clause terms are real wff
		formulas, forward (eval) and backward (solve).

		  cd ~/dev/math && russellj test/wffbind no-server=1     (run from the math dir)
	}
	@category test
*/

conf-load dir=./set;
read-ru file=set/CLASSICAL_FIRST-ORDER_LOGIC_WITH_EQUALITY/Propositional_calculus/Logical_implication.ru;

uni-brun file=test/uni/wff.uni;
