# Peano naturals: addition and multiplication as recursive unilambda clauses.
# Variables carry a trailing `*`; bare identifiers (0, s, plus, mult) are
# constructors / defined functions. `s` and `0` have no clauses, so they are
# data constructors; `plus` and `mult` have clauses, so they reduce.

plus = \ x*, 0 |- x*
plus = \ x*, s(y*) |- s(plus(x*, y*))

mult = \ x*, 0 |- 0
mult = \ x*, s(y*) |- plus(x*, mult(x*, y*))

eval plus(s(0), s(s(0)))
eval mult(s(s(0)), s(s(0)))
eval plus(s(s(s(0))), 0)
eval mult(s(s(s(0))), 0)

# backward direction (narrowing): find all (x*, y*) with x + y = 3
solve plus(x*, y*) = s(s(s(0)))
# find x with x + 1 = 4
solve plus(x*, s(0)) = s(s(s(s(0))))
