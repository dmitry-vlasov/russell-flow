/**
	@help {
		Load a dataset and pretty-print an entity by name.

		Output-facing wrapper around the `info-show` command, which is silent on
		success (it stores its report in `info-show.text` and only raises errors).

		  russellj info/show afile=set-3000 name=<entity>
	}
	@defarg afile
	@category info

	@arg afile { dataset directory name. @defval set-3000 }
	@arg name  { entity name to print. @defval  }
*/

conf-load dir=./$afile;
read-ru;

info-show name=$name;
print info-show.text;
