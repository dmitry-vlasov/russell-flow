/**
	@help {
		Load a dataset and print all variable declarations.

		Output-facing wrapper around the `info-vars` command, which is silent on
		success (it stores its report in `info-vars.text`).

		  russellj info/vars afile=set-3000
	}
	@defarg afile
	@category info

	@arg afile { dataset directory name. @defval set-3000 }
*/

conf-load dir=./$afile;
read-ru;

info-vars;
print info-vars.text;
