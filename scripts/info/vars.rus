/**
	@help {
		Load a dataset and print all variable declarations.

		The `info-vars` command stores raw data (info-vars.vars, each with
		name/type); this script formats.

		  russellj info/vars afile=set-3000
	}
	@defarg afile
	@category info

	@arg afile { dataset directory name. @defval set-3000 }
*/

conf-load dir=./$afile;
read-ru;

info-vars;
print fold(info-vars.vars, "", \acc, v -> (acc + "  " + v.name + " : " + v.type + "\n"));
