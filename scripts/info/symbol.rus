/**
	@help {
		Load a dataset and print info about an entity by name (text form).

		Output-facing wrapper around the `info-symbol` command, which is silent on
		success (it stores its report in `info-symbol.text`).

		  russellj info/symbol afile=set-3000 name=<entity>
	}
	@defarg afile
	@category info

	@arg afile { dataset directory name. @defval set-3000 }
	@arg name  { entity name to look up. @defval  }
*/

conf-load dir=./$afile;
read-ru;

info-symbol name=$name;
print info-symbol.text;
