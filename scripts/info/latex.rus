/**
	@help {
		Load a dataset and find the symbol matching a LaTeX definition.

		Output-facing wrapper around the `info-latex` command, which is silent on
		success (it stores its report in `info-latex.text`).

		  russellj info/latex afile=set-3000 def=<latex>
	}
	@defarg afile
	@category info

	@arg afile { dataset directory name. @defval set-3000 }
	@arg def   { LaTeX definition of a symbol. @defval  }
*/

conf-load dir=./$afile;
read-ru;

info-latex def=$def;
print info-latex.text;
