/**
	@help {
		Show cache info. Output-facing wrapper around the `cache-info` command,
		which now stores its report in the state (`cache-info.text`) instead of
		printing it directly.

		  russellj info/cache
		  russellj info/cache what=disk full=1
	}
	@defarg what
	@category info

	@arg what { which cache: all, lang or disk. @defval all }
	@arg full { extended info (1) or concise (0). @defval 0 }
*/

cache-info what=$what full=$full;
print cache-info.text;
