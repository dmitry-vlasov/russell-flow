/**
	@help {
		Load a dataset and print the topological order of its sources.

		Output-facing wrapper around the `order-sources` command, which is silent on
		success (it stores its report in `order-sources.text`).

		  russellj info/order-sources afile=set-3000
	}
	@defarg afile
	@category info

	@arg afile { dataset directory name. @defval set-3000 }
*/

conf-load dir=./$afile;
read-ru;

order-sources;
print order-sources.text;
