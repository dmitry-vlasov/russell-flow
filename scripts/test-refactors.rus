/**
	@help {
		Refactor-command regression test.

		Each refactor transforms the theorem corpus in place; the universal
		correctness invariant is that the corpus STILL VERIFIES afterwards. A
		broken transform (e.g. one damaged by a refactoring) produces an
		unverifiable corpus, which `verify; assert (verify.success)` catches —
		this is exactly how the remove-redundant-axioms regression was found.

		Assertions (all unconditional — they hold on set-3000 and any LARGER
		set.mm prefix, since set-3000's theorems are a prefix-subset of every
		bigger set-N, so these invariants are monotonic):
		  - verify.success after every command.
		  - commands that transform something report a POSITIVE count (catches a
		    command silently going inert). NOT exact counts — shorten-proofs and
		    generalize are searches whose exact counts vary run to run.
		Note: this assumes a set.mm-derived corpus at least as rich as set-3000;
		on an unrelated tiny corpus a command could legitimately transform 0.

		Commands are applied in a FIXED ORDER on ONE loaded corpus (later commands
		see earlier transforms), which also mirrors how refactors are chained in
		practice.

		Three sections:
		  1. PINNED: targeted accuracy checks — specific theorems known to be
		     generalized / shortened / removed-as-trivial must actually be, so a
		     command silently no-op'ing on its intended input is caught (similar to
		     the tactic-semantics test). These pin theorem names; if upstream set.mm
		     drift changes those theorems' proofs the pins may need updating — rare,
		     and a one-line fix when it happens.
		  2. CHAIN (cumulative): every corpus transform applied in sequence — step/
		     hyp reducers, treefy/shorten/generalize, then the removal/restructure
		     commands (remove-trivial-theorems, remove-redundant-axioms,
		     refactor-less-general, remove-empty-sources, ru-remove-trivial-sources,
		     optimize-imports). verify after each. Chaining the removals guards
		     against the cross-command cascade where a removed assertion's users were
		     left dangling (fixed by the $d-aware, sub-proof-recursing ruReplaceMatch).
		  3. LAYOUT: extract-* / split-source-ru (in-memory), verify after each.

		Runs on set-30000 (~6s, 3150 theorems) in CI for meaningful coverage; works
		on any set.mm prefix down to set-3000.

		NOT covered here: merge-math (needs a 2nd dataset), fix/unfix-left-recursion
		(grammar; needs a grammar fixture).

		MAINTENANCE: when you add a corpus-transforming refactor, add an apply +
		verify block to the CHAIN, and a pinned targeted check to PINNED.

		Run locally:
		  russellj mm2ru2mm set-30000
		  russellj test-refactors afile=set-30000    # exit 0 = pass, 255 = failed assert
	}
	@defarg afile
	@category test

	@arg afile { input Russell dataset directory name. @defval set-30000 }
*/

print "==== refactor-commands test ====";
print "dataset: $afile";

conf-load dir=./$afile;
conf-set gc-after-task=1;
read-ru;
	assert (read-ru.size > 0);

verify;
	print ("[baseline] verify=" + verify.success + " size=" + verify.size);
	assert (verify.success);

// ---- PINNED accuracy checks: specific theorems must actually be transformed ----
// Run FIRST, on the pristine corpus. Each command targets ONE theorem known to
// be affected, so a command that silently stops transforming its intended input
// is caught (the CHAIN's count>0 could still pass on other theorems). These
// theorems live in set-3000, so they exist in every larger prefix. shorten-proofs
// is a time-limited SEARCH and is only reliable before the heavy chain runs, hence
// this section goes first. If set.mm drift changes these theorems' proofs, update
// the pinned name/expectation here (rare, one-line fix).

// generalize must produce a VALID generalization of peirceroll (a regression like
// the treefy/inline-lemma one yields generalized=0, not 1).
generalize target=peirceroll info=1;
	print ("[pin generalize peirceroll] generalized=" + generalize.generalized);
	assert (generalize.generalized == 1);

// shorten-proofs must shorten dfbi1ALT (it removes redundant steps from it).
shorten-proofs target=dfbi1ALT;
	print ("[pin shorten dfbi1ALT] shortened-steps=" + shorten-proofs.shortened-steps);
	assert (shorten-proofs.shortened-steps > 0);

// remove-trivial-theorems must drop con4 (an instance of a more-general assertion).
remove-trivial-theorems target=con4;
	print ("[pin trivial con4] removed=" + remove-trivial-theorems.removed);
	assert (remove-trivial-theorems.removed == 1);

// Reload the pristine corpus before the proof-preserving CHAIN below (the pinned
// checks above mutated it). These commands do not remove assertions, so applying
// them cumulatively is safe.
conf-load dir=./$afile;
read-ru;

// ---- proof-preserving step/hyp reducers (no-ops on set-3000, but must not break) ----
remove-duplicate-steps target=all;
verify;
	print ("[remove-duplicate-steps] verify=" + verify.success + " steps=" + remove-duplicate-steps.optimized-steps);
	assert (verify.success);
	assert (remove-duplicate-steps.optimized-steps >= 0);

remove-unused-steps target=all;
verify;
	print ("[remove-unused-steps] verify=" + verify.success + " steps=" + remove-unused-steps.optimized-steps);
	assert (verify.success);
	assert (remove-unused-steps.optimized-steps >= 0);

remove-unused-hyps target=all;
verify;
	print ("[remove-unused-hyps] verify=" + verify.success + " hyps=" + remove-unused-hyps.optimized-hyps);
	assert (verify.success);
	assert (remove-unused-hyps.optimized-hyps >= 0);

// ---- proof-shape transforms (active on set-3000) ----
treefy-proofs target=all;
verify;
	print ("[treefy-proofs] verify=" + verify.success + " treefied=" + treefy-proofs.treefied-theorems);
	assert (verify.success);
	// Monotonic invariant: set-3000's theorems are a prefix-subset of every
	// larger set-N, so a command active on set-3000 is active on any bigger
	// set.mm prefix too. Hence these >0 checks are unconditional.
	assert (treefy-proofs.treefied-theorems > 0);

shorten-proofs target=all;
verify;
	print ("[shorten-proofs] verify=" + verify.success + " shortened-steps=" + shorten-proofs.shortened-steps);
	assert (verify.success);
	assert (shorten-proofs.shortened-steps > 0);

// ---- corpus-level transforms (active on set-3000) ----
generalize target=all;
verify;
	print ("[generalize] verify=" + verify.success + " generalized=" + generalize.generalized);
	assert (verify.success);
	assert (generalize.generalized > 0);

// ---- corpus-reducing / restructuring transforms, CHAINED (cumulative) ----
// Chained on purpose: a removal refactor must not break theorems that a later
// command (or the verify) still needs. This used to cascade into a disproved
// corpus (a removed assertion's users were left dangling); ruReplaceMatch is now
// $d-aware and recurses into inline sub-proofs, so the cumulative chain stays
// valid and this section guards that fix against regression.
remove-trivial-theorems target=all;
verify;
	print ("[remove-trivial-theorems] verify=" + verify.success + " removed=" + remove-trivial-theorems.removed);
	assert (verify.success);
	assert (remove-trivial-theorems.removed > 0);

remove-redundant-axioms target=all;
verify;
	print ("[remove-redundant-axioms] verify=" + verify.success);
	assert (verify.success);

refactor-less-general target=all;
verify;
	print ("[refactor-less-general] verify=" + verify.success);
	assert (verify.success);

remove-empty-sources;
verify;
	print ("[remove-empty-sources] verify=" + verify.success);
	assert (verify.success);

ru-remove-trivial-sources;
verify;
	print ("[ru-remove-trivial-sources] verify=" + verify.success);
	assert (verify.success);

optimize-imports-ru;
verify;
	print ("[optimize-imports-ru] verify=" + verify.success + " size=" + optimize-imports-ru.size);
	assert (verify.success);
	assert (optimize-imports-ru.size > 0);

// ---- file-layout transforms: extract-* and split-source-ru ----
// These restructure the source tree (move decls into separate files / split one
// file into a directory) entirely in memory — no disk writes — so the same
// verify-after invariant applies. Fresh reload so they act on the pristine
// corpus, not the heavily-mutated one above.
conf-load dir=./$afile;
read-ru;
verify;
	print ("[layout baseline] verify=" + verify.success + " size=" + verify.size);
	assert (verify.success);

extract-constants;
verify;
	print ("[extract-constants] verify=" + verify.success);
	assert (verify.success);

extract-types;
verify;
	print ("[extract-types] verify=" + verify.success);
	assert (verify.success);

extract-rules;
verify;
	print ("[extract-rules] verify=" + verify.success);
	assert (verify.success);

extract-axioms;
verify;
	print ("[extract-axioms] verify=" + verify.success);
	assert (verify.success);

extract-defs;
verify;
	print ("[extract-defs] verify=" + verify.success);
	assert (verify.success);

// split-source-ru needs a concrete file to split: the project root, which is
// always <afile>_root (the var substitution replaces $afile literally).
split-source-ru file=$afile_root;
verify;
	print ("[split-source-ru] verify=" + verify.success + " size=" + split-source-ru.size);
	assert (verify.success);
	assert (split-source-ru.size > 0);

print "==== refactor-commands test PASSED ====";
